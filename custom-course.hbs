{{!< default}}

{{#post}}
<article class="course-master-page">

    {{!-- 1. SEO JSON-LD --}}
    {{#contentFor "scripts"}}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Course",
      "name": "{{title}}",
      "description": "{{excerpt}}",
      "provider": { "@type": "Organization", "name": "{{@site.title}}", "sameAs": "{{@site.url}}" },
      "author": { "@type": "Person", "name": "{{primary_author.name}}" },
      "image": "{{img_url feature_image absolute="true"}}"
    }
    </script>
    {{/contentFor}}

    {{!-- 2. HERO COMPONENT --}}
    {{> "course/hero"}}

    {{!-- Top Leaderboard Ad --}}
    <div class="container-wide" style="margin: var(--spacing-8) auto 0;">
        {{> "adsense" type="leaderboard"}}
    </div>

    {{!-- 3. MAIN GRID LAYOUT --}}
    <div class="container-wide" style="display: grid; grid-template-columns: minmax(0, 1.6fr) 350px; gap: var(--spacing-11); margin-top: var(--spacing-9);">
        
        {{!-- LEFT: MAIN CONTENT --}}
        <main>
            {{!-- In-Article Ad --}}
            {{> "adsense" type="in-article"}}

            <div class="post-content" style="margin-bottom: var(--spacing-10);">
                {{{html}}}
            </div>

            {{!-- Curriculum --}}
            {{> "course/curriculum"}}

            {{!-- Bottom Rectangle Ad --}}
            <div style="margin-top: var(--spacing-10);">
                {{> "adsense" type="rectangle"}}
            </div>
        </main>

        {{!-- RIGHT: STICKY SIDEBAR --}}
        <aside>
            <div style="position: sticky; top: calc(var(--navbar--height, 70px) + var(--spacing-6)); display: flex; flex-direction: column; gap: var(--spacing-6);">
                
                {{> "course/sidebar-box"}}
                
                {{!-- Sidebar Ad --}}
                {{> "adsense" type="vertical"}}
                
                {{> "course/instructor"}}

            </div>
        </aside>

    </div>
</article>

<style>
    @media (max-width: 991px) {
        .container-wide { grid-template-columns: 1fr !important; gap: var(--spacing-8); }
        aside { order: -1; margin-bottom: var(--spacing-8); }
        aside > div { position: static !important; } /* Disable sticky on mobile */
    }
</style>

{{> "sections/subscription"}}
{{/post}}