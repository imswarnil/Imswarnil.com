{{!< default}}

{{!-- Guestbook — Ghost native comments dressed up as a 90s guestbook wall.
     Create a page with slug "guestbook" and enable comments on the site. --}}
{{#post}}
<article class="{{post_class}}">
	<div class="container-site py-10">
		<div class="grid gap-10 lg:grid-cols-12">

			{{!-- Left: the hero — fixed beside the scrolling wall --}}
			<header class="lg:col-span-5">
				<div class="lg:sticky lg:top-20 lg:max-h-[calc(100dvh-6rem)] lg:self-start">
					<p class="chip animate-fade-in">{{> "icons/heart"}} est. the golden age of the internet</p>
					<h1 class="mt-5 text-4xl font-semibold tracking-tight sm:text-5xl text-balance">{{title}}</h1>
					<p class="mt-4 max-w-md text-lg leading-relaxed text-silver">
						{{#if custom_excerpt}}{{custom_excerpt}}{{else}}A wall of love, internet-style. Leave a note, a hot take, or proof you were here before it was cool.{{/if}}
					</p>

					{{!-- wall-of-love: floating signed notes --}}
					<div class="relative mt-8 hidden h-40 max-w-md lg:block" aria-hidden="true">
						<div class="float-frame absolute left-0 top-2 w-44 rotate-[-4deg] rounded-2xl border border-line bg-paper p-3.5 shadow-card" style="--tilt:-4deg">
							<p class="flex items-center gap-1.5 font-mono text-[9px] uppercase tracking-[0.18em] text-silver">{{> "icons/heart" class="h-3 w-3 text-red-400"}} entry #001</p>
							<p class="mt-1.5 text-[12px] font-medium leading-snug">"Great site. Would scroll again."</p>
						</div>
						<div class="float-frame-alt absolute left-36 top-12 w-48 rotate-[3deg] rounded-2xl border border-line bg-mist p-3.5 shadow-lift" style="--tilt:3deg">
							<p class="flex items-center gap-1.5 font-mono text-[9px] uppercase tracking-[0.18em] text-silver">{{> "icons/pen" class="h-3 w-3"}} entry #002</p>
							<p class="mt-1.5 text-[12px] font-medium leading-snug" style="font-family:Georgia,serif;font-style:italic">"came for the theme switcher, stayed for the confetti"</p>
						</div>
						<span class="absolute -top-1 left-48 text-red-400 animate-bounce">{{> "icons/heart" class="h-4 w-4"}}</span>
					</div>

					{{!-- what / how / why --}}
					<div class="mt-8 space-y-4 border-t border-line pt-6">
						<div class="flex gap-3">
							<span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full border border-line bg-mist font-mono text-[11px] font-bold">?</span>
							<p class="text-sm leading-relaxed text-silver"><strong class="font-semibold text-ink">What is this?</strong> A guestbook — the thing websites had before feeds. One wall, every visitor who cared enough to sign it.</p>
						</div>
						<div class="flex gap-3">
							<span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full border border-line bg-mist font-mono text-[11px] font-bold">✍</span>
							<p class="text-sm leading-relaxed text-silver"><strong class="font-semibold text-ink">How to sign:</strong> sign in with just your email (magic link, no password), write your note in the box on the right, hit post. Done — you're on the wall.</p>
						</div>
						<div class="flex gap-3">
							<span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full border border-line bg-mist font-mono text-[11px] font-bold">♥</span>
							<p class="text-sm leading-relaxed text-silver"><strong class="font-semibold text-ink">Why it matters:</strong> analytics tell me numbers; the wall tells me humans were here. I read every entry, reply to most, and on rough days this page does more than coffee.</p>
						</div>
					</div>

					{{#if content}}
					<div class="gh-content mt-6 max-w-md text-sm">{{content}}</div>
					{{/if}}
					<p class="mt-6 font-mono text-[10px] uppercase tracking-[0.2em] text-silver">free forever · moderated only for spam and cowardice</p>
				</div>
			</header>

			{{!-- Right: the wall — scrolls with the page --}}
			<section class="min-w-0 lg:col-span-7 lg:border-l lg:border-line lg:pl-10">
				{{#if @site.comments_enabled}}
					<p class="kicker mb-6">{{> "icons/heart"}} The wall — newest signatures first</p>
					<div class="guestbook-wall">
						{{comments title="" count=true}}
					</div>
				{{else}}
					<div class="rounded-2xl border border-dashed border-line p-12 text-center">
						<p class="text-lg font-semibold">The wall is closed for renovation.</p>
						<p class="mt-2 text-sm text-silver">Enable comments in Ghost Admin → Settings → Membership → Commenting, and the guestbook opens itself.</p>
					</div>
				{{/if}}
			</section>
		</div>
	</div>
</article>
{{/post}}
