{{!< default}}

{{!-- Guestbook — Ghost native comments dressed up as a 90s guestbook wall.
     Create a page with slug "guestbook" and enable comments on the site. --}}
{{#post}}
<article class="{{post_class}}">
	<div class="container-site py-10">
		<div class="grid gap-10 lg:grid-cols-12">

			{{!-- Left: the hero — sticky, stays put while the wall scrolls --}}
			<header class="lg:col-span-5">
				<div class="lg:sticky lg:top-24">
					<p class="chip animate-fade-in">{{> "icons/heart"}} est. the golden age of the internet</p>
					<h1 class="mt-6 text-4xl font-semibold tracking-tight sm:text-5xl text-balance">{{title}}</h1>
					<p class="mt-4 max-w-md text-lg leading-relaxed text-silver">
						{{#if custom_excerpt}}{{custom_excerpt}}{{else}}You made it all the way here. The least you can do is sign. Compliments, complaints and confessions all accepted — moderated only for spam and cowardice.{{/if}}
					</p>
					{{#if content}}
					<div class="gh-content mt-6 max-w-md text-sm">{{content}}</div>
					{{/if}}
					<div class="mt-8 flex flex-wrap gap-6 font-mono text-[10px] uppercase tracking-[0.25em] text-silver">
						<span class="flex items-center gap-2">{{> "icons/check" class="h-3.5 w-3.5"}} free forever</span>
						<span class="flex items-center gap-2">{{> "icons/sparkle" class="h-3.5 w-3.5"}} zero guest towels</span>
					</div>
					<p class="mt-6 font-mono text-[10px] uppercase tracking-[0.2em] text-silver">your note may be read aloud, dramatically, to no one</p>
					{{> "components/adsense" slot="3487917390" format="auto" class="!my-8 hidden lg:block"}}
				</div>
			</header>

			{{!-- Right: the wall — scrolls with the page --}}
			<section class="min-w-0 lg:col-span-7 lg:border-l lg:border-line lg:pl-10">
				{{#if @site.comments_enabled}}
					<p class="kicker mb-6">{{> "icons/heart"}} The wall — newest signatures first</p>
					<div class="guestbook-wall">
						{{comments title="" count=true}}
					</div>
				{{else}}
					<div class="rounded-2xl border border-dashed border-line p-12 text-center">
						<p class="text-lg font-semibold">The wall is closed for renovation.</p>
						<p class="mt-2 text-sm text-silver">Enable comments in Ghost Admin → Settings → Membership → Commenting, and the guestbook opens itself.</p>
					</div>
				{{/if}}
			</section>
		</div>
	</div>
</article>
{{/post}}
