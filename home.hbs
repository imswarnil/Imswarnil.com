{{!< default}}

{{!-- Hero --}}
<section class="border-b border-zinc-200 dark:border-zinc-800">
	<div class="mx-auto max-w-5xl px-4 py-16 sm:py-24">
		<h1 class="max-w-3xl text-4xl font-semibold leading-tight tracking-tight sm:text-5xl">{{@site.title}}</h1>
		<p class="mt-4 max-w-2xl text-lg leading-relaxed text-zinc-600 dark:text-zinc-400">{{@site.description}}</p>

		<div class="mt-8 flex flex-wrap gap-3">
			<a href="{{@site.url}}/blog/" class="rounded-md bg-zinc-900 px-4 py-2 text-sm font-medium text-white hover:bg-zinc-700 dark:bg-zinc-100 dark:text-zinc-900 dark:hover:bg-zinc-300">Read the blog</a>
			<a href="{{@site.url}}/archive/" class="rounded-md border border-zinc-300 px-4 py-2 text-sm font-medium hover:bg-zinc-100 dark:border-zinc-700 dark:hover:bg-zinc-800">Browse everything</a>
		</div>
	</div>
</section>

{{!-- Latest posts --}}
<section class="mx-auto max-w-5xl px-4 py-10">
	<h2 class="mb-6 text-xl font-semibold tracking-tight">Latest</h2>
	{{#get "posts" limit="6" include="tags" as |latest|}}
		{{#if latest}}
			<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
				{{#foreach latest}}
					{{> card}}
				{{/foreach}}
			</div>
		{{else}}
			<p class="text-sm text-zinc-500">Nothing published yet.</p>
		{{/if}}
	{{/get}}
</section>
