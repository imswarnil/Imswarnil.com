{{!< default}}

{{!-- /travel — trips index. Full-width background video, a quote, then trip
     cards. Countries + categories come from each trip's internal tags
     (#country-*, #travel-category-*) and power the client-side filter bar. --}}

<header class="tv-scanlines relative -mt-16 flex min-h-[72vh] items-end overflow-hidden sm:-mt-[4.25rem]">
	<div class="absolute inset-0" aria-hidden="true">
		<video src="https://cdn.coverr.co/videos/coverr-aerial-view-of-a-beach-4241/1080p.mp4"
			poster="" autoplay muted loop playsinline preload="metadata"
			class="h-full w-full object-cover"
			onerror="this.style.display='none'"></video>
		<div class="bg-grid absolute inset-0 bg-mist/60" style="z-index:-1"></div>
		<div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/25 to-black/30"></div>
	</div>
	<div class="container-site relative pb-14 pt-44">
		<p class="flex items-center gap-2 font-mono text-[10px] uppercase tracking-[0.3em] text-white/80 animate-fade-in">{{> "icons/map-pin" class="h-3.5 w-3.5"}} boarding pass, no return date</p>
		<h1 class="mt-4 max-w-3xl text-4xl font-black tracking-tight text-white sm:text-6xl text-balance animate-fade-up">Travel</h1>
		<blockquote class="mt-6 max-w-xl border-l-2 border-white/50 pl-4 text-lg italic leading-relaxed text-white/90 animate-fade-in" style="animation-delay:.25s">
			"We travel not to escape life, but for life not to escape us." <span class="not-italic font-mono text-xs text-white/60">— someone wise, quoted on every hostel wall</span>
		</blockquote>
		<div class="mt-8 flex flex-wrap gap-3 animate-fade-in" style="animation-delay:.4s">
			<a href="#trips" class="btn !bg-white !text-black hover:opacity-90">{{> "icons/play" class="h-4 w-4"}} Explore trips</a>
			<span class="flex items-center gap-2 font-mono text-[10px] uppercase tracking-[0.2em] text-white/70">
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17.8 19.2L16 11l3.5-3.5a2.1 2.1 0 0 0-3-3L13 8 4.8 6.2a1 1 0 0 0-1 .3L3 7.3l6.3 3.6-2.6 2.6H4l-1 1 3 1 1 3 1-1v-2.7l2.6-2.6 3.6 6.3.8-.8a1 1 0 0 0 .3-1z"/></svg>
				window seat always
			</span>
		</div>
	</div>
</header>

<section class="container-site py-12" id="trips">
	{{!-- Filter bar: built client-side from the trip cards' internal tags --}}
	<div class="flex flex-wrap items-center gap-2" id="travel-filters" hidden>
		<span class="kicker mr-2">{{> "icons/map-pin" class="h-3.5 w-3.5"}} Filter</span>
		{{!-- chips injected by JS --}}
	</div>

	{{#foreach posts}}
		{{#if @first}}<div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3" data-reveal-stagger="100">{{/if}}
		<article class="trip-card group relative" data-trip-tags="{{#foreach tags visibility="internal"}}{{slug}} {{/foreach}}">
			<a href="{{url}}" class="block" aria-label="Trip: {{title}}">
				<div class="relative aspect-[4/5] overflow-hidden rounded-2xl border border-line bg-mist shadow-card transition-all duration-300 group-hover:-translate-y-1.5 group-hover:shadow-lift">
					{{#if feature_image}}
						<img src="{{img_url feature_image size="600"}}" width="600" height="750" alt="{{title}}" loading="lazy" class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" />
					{{else}}
						<div class="bg-dots flex h-full w-full items-center justify-center text-silver">
							<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 4L3 6v14l6-2 6 2 6-2V4l-6 2z"/><path d="M9 4v14M15 6v14"/></svg>
						</div>
					{{/if}}
					<div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/10 to-transparent"></div>
					<span class="absolute left-3 top-3 rounded-full bg-white/90 px-2.5 py-1 font-mono text-[9px] font-bold uppercase tracking-[0.15em] text-black">{{date published_at format="MMM YYYY"}}</span>
					<div class="absolute inset-x-0 bottom-0 p-4">
						<div class="flex min-h-[1.25rem] flex-wrap gap-1" data-trip-chips></div>
						<h2 class="mt-1.5 text-xl font-bold leading-tight text-white [text-shadow:0_2px_8px_rgb(0_0_0/.5)]">{{title}}</h2>
						{{#if custom_excerpt}}<p class="mt-1 line-clamp-2 text-[13px] leading-relaxed text-white/80">{{custom_excerpt}}</p>{{/if}}
						{{#get "posts" filter="tag:hash-travel+tags:{{primary_tag.slug}}" limit="1" as |stories|}}
							<p class="mt-2 font-mono text-[10px] uppercase tracking-[0.2em] text-white/60">{{plural pagination.total empty="stories brewing" singular="% story" plural="% stories"}} · open itinerary →</p>
						{{/get}}
					</div>
				</div>
			</a>
		</article>
		{{#if @last}}</div>{{/if}}
	{{else}}
		<p class="mt-8 rounded-2xl border border-dashed border-line p-12 text-center text-sm text-silver">No trips yet. Tag a container post <code class="rounded bg-mist px-1.5 py-0.5 font-mono text-xs">#trip</code> — passport optional, tags mandatory.</p>
	{{/foreach}}

	{{> "components/pagination"}}
	{{> "components/adsense" slot="8939839370" format="auto"}}
</section>

<script>
	(function () {
		/* Country/category chips per card + a global filter bar, all from internal tags */
		function pretty(slug, prefix) {
			return slug.replace(prefix, '').split('-').map(function (w) { return w.charAt(0).toUpperCase() + w.slice(1); }).join(' ');
		}
		var PIN = '<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-1px;margin-right:3px" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/></svg>';
		var cards = [].slice.call(document.querySelectorAll('.trip-card'));
		var seen = {};
		cards.forEach(function (card) {
			var tags = (card.getAttribute('data-trip-tags') || '').split(/\s+/).filter(Boolean);
			var chips = card.querySelector('[data-trip-chips]');
			tags.forEach(function (t) {
				var label = null, pin = false;
				if (t.indexOf('hash-country-') === 0) { label = pretty(t, 'hash-country-'); pin = true; }
				else if (t.indexOf('hash-travel-category-') === 0) { label = pretty(t, 'hash-travel-category-'); }
				if (!label) return;
				if (chips) {
					var c = document.createElement('span');
					c.className = 'rounded-full bg-black/50 px-2 py-0.5 font-mono text-[9px] uppercase tracking-[0.12em] text-white backdrop-blur';
					c.innerHTML = (pin ? PIN : '') + label;
					chips.appendChild(c);
				}
				seen[t] = { label: label, pin: pin };
			});
		});
		var bar = document.getElementById('travel-filters');
		var keys = Object.keys(seen);
		if (bar && keys.length) {
			bar.hidden = false;
			var all = document.createElement('button');
			all.type = 'button'; all.className = 'chip is-active !bg-ink !text-paper'; all.textContent = 'Everywhere';
			bar.appendChild(all);
			function activate(btn, tag) {
				[].forEach.call(bar.querySelectorAll('button'), function (b) { b.classList.remove('is-active', '!bg-ink', '!text-paper'); });
				btn.classList.add('is-active', '!bg-ink', '!text-paper');
				cards.forEach(function (card) {
					card.style.display = !tag || (card.getAttribute('data-trip-tags') || '').indexOf(tag) > -1 ? '' : 'none';
				});
			}
			all.addEventListener('click', function () { activate(all, null); });
			keys.sort().forEach(function (t) {
				var b = document.createElement('button');
				b.type = 'button'; b.className = 'chip transition hover:bg-mist';
				b.innerHTML = (seen[t].pin ? PIN : '') + seen[t].label;
				b.addEventListener('click', function () { activate(b, t); });
				bar.appendChild(b);
			});
		}
	})();
</script>
