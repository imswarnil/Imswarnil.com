{{!< default}}

{{> page-header title="Tags" description="Every public tag on the site."}}

<section class="mx-auto max-w-5xl px-4 py-10">
	{{#get "tags" limit="100" include="count.posts" as |all_tags|}}
		<div class="flex flex-wrap gap-2">
			{{#foreach all_tags}}
				<a href="{{url}}" class="rounded-md border border-zinc-200 px-3 py-1.5 text-sm hover:bg-zinc-100 dark:border-zinc-800 dark:hover:bg-zinc-800">{{name}} <span class="text-zinc-500">{{count.posts}}</span></a>
			{{/foreach}}
		</div>
	{{/get}}
</section>
