{{!< default}}

{{!-- /signin — magic-link sign in page --}}
<section class="relative flex min-h-[80vh] items-center justify-center overflow-hidden py-16">
	<div class="bg-grid pointer-events-none absolute inset-0 fade-mask-b" aria-hidden="true"></div>

	<div class="container-site relative">
		<div class="card-surface mx-auto w-full max-w-md p-8 shadow-lift sm:p-10">
			<div class="mb-8 flex justify-center">
				{{> "components/logo"}}
			</div>

			{{#if @member}}
				<div class="text-center">
					<p class="kicker justify-center">{{> "icons/check"}} Signed in</p>
					<h1 class="mt-3 text-2xl font-semibold tracking-tight">You're already signed in</h1>
					<p class="mt-3 text-sm leading-relaxed text-silver">Welcome back{{#if @member.name}}, {{@member.name}}{{/if}}. Head to your account to manage your subscription.</p>
					<div class="mt-6 flex flex-col gap-3">
						<a href="#/portal/account" class="btn btn-primary w-full justify-center" data-portal="account">{{> "icons/user"}} My account</a>
						<a href="{{@site.url}}" class="btn-ghost justify-center">Back to home {{> "icons/arrow-right"}}</a>
					</div>
				</div>
			{{else}}
				{{#if @site.members_enabled}}
					<div class="text-center">
						<p class="kicker justify-center">Welcome back</p>
						<h1 class="mt-3 text-2xl font-semibold tracking-tight">Sign in to {{@site.title}}</h1>
						<p class="mt-3 text-sm leading-relaxed text-silver">No passwords here — we'll email you a login link.</p>
					</div>

					<form data-members-form="signin" class="mt-8">
						<label for="signin-email" class="mb-2 block text-left font-mono text-[11px] uppercase tracking-[0.2em] text-silver">Email address</label>
						<div class="flex flex-col gap-3">
							<input id="signin-email" data-members-email type="email" required placeholder="you@example.com" autocomplete="email"
								class="w-full rounded-xl border border-line bg-paper px-4 py-3 text-sm text-ink placeholder:text-silver/60 focus:border-ink focus:outline-none" />
							<button type="submit" class="btn btn-primary w-full justify-center">{{> "icons/mail"}} Send login link</button>
						</div>
						<p data-members-success hidden class="mt-4 rounded-xl border border-line bg-mist px-4 py-3 text-sm text-ink">Check your inbox! A login link is on its way.</p>
						<p data-members-error hidden class="mt-4 rounded-xl border border-line bg-mist px-4 py-3 text-sm text-ink"></p>
					</form>

					<p class="mt-8 border-t border-line pt-6 text-center text-sm text-silver">
						New around here? <a href="{{@site.url}}/signup/" class="font-medium text-ink underline decoration-line underline-offset-4 transition hover:decoration-ink">Create a free account</a>
					</p>
				{{else}}
					<div class="text-center">
						<h1 class="text-2xl font-semibold tracking-tight">Sign in unavailable</h1>
						<p class="mt-3 text-sm leading-relaxed text-silver">Memberships aren't enabled on this site right now.</p>
						<a href="{{@site.url}}" class="btn-ghost mt-6 justify-center">Back to home {{> "icons/arrow-right"}}</a>
					</div>
				{{/if}}
			{{/if}}
		</div>

		<p class="mt-6 text-center font-mono text-[11px] uppercase tracking-[0.25em] text-silver">Magic link · no passwords</p>
	</div>
</section>
