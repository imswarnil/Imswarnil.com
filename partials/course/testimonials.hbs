<section style="margin: var(--spacing-10) 0; border-top: 1px solid var(--color-border); padding-top: var(--spacing-10);">
    <h3 style="font-family: var(--font-family-headings); font-size: 1.8rem; margin-bottom: var(--spacing-7);">Student Success Stories</h3>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--spacing-6);">
        
        <div style="padding: var(--spacing-6); border: 1px dashed var(--color-border); border-radius: var(--radius-4);">
            <p style="font-style: italic; color: var(--color-contrast); margin-bottom: var(--spacing-4);">"The most structured course I've ever taken. I went from zero to building production apps in just 3 weeks."</p>
            <div style="display: flex; align-items: center; gap: 12px;">
                <div style="width: 32px; height: 32px; border-radius: 50%; background: var(--ghost-accent-color);"></div>
                <span style="font-weight: 700; font-size: 0.9rem;">Alex Rivers</span>
            </div>
        </div>

        <div style="padding: var(--spacing-6); border: 1px dashed var(--color-border); border-radius: var(--radius-4);">
            <p style="font-style: italic; color: var(--color-contrast); margin-bottom: var(--spacing-4);">"Finally understood concepts that seemed impossible before. Swarnil explains things with incredible clarity."</p>
            <div style="display: flex; align-items: center; gap: 12px;">
                <div style="width: 32px; height: 32px; border-radius: 50%; background: #3b82f6;"></div>
                <span style="font-weight: 700; font-size: 0.9rem;">Sarah Chen</span>
            </div>
        </div>

    </div>
</section>