<style>
    .cur-wrapper { margin: var(--spacing-10) 0; }
    .cur-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: var(--spacing-6); border-bottom: 1px solid var(--color-border); padding-bottom: var(--spacing-4); }
    .cur-list { border: 1px solid var(--color-border); border-radius: var(--radius-4); background: var(--color-background-100); overflow: hidden; }
    .cur-item { display: grid; grid-template-columns: 40px 1fr auto; gap: var(--spacing-4); align-items: center; padding: var(--spacing-5); border-bottom: 1px solid var(--color-border); text-decoration: none; transition: background 0.2s; }
    .cur-item:last-child { border-bottom: none; }
    .cur-item:hover { background: var(--color-background); }
    .cur-node { width: 32px; height: 32px; border-radius: 50%; background: var(--color-background); border: 1px solid var(--color-border); display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 0.75rem; color: var(--color-secondary); }
    .cur-title { font-weight: 700; color: var(--color-contrast); font-size: 1.05rem; }
    .cur-status { opacity: 0.5; font-size: 0.8rem; }
</style>

<section id="curriculum" class="cur-wrapper">
    {{#if primary_tag}}
        {{#get "posts" filter="tag:hash-lesson+tag:{{primary_tag.slug}}" order="published_at asc" as |lessons|}}
            <div class="cur-head">
                <h2 style="margin:0; font-family: var(--font-family-headings);">Course Syllabus</h2>
                <span style="font-weight: 700; color: var(--color-secondary);">{{pagination.total}} Lessons</span>
            </div>
            <div class="cur-list">
                {{#foreach lessons}}
                    <a href="{{url}}" class="cur-item">
                        <div class="cur-node">{{@number}}</div>
                        <div class="cur-title">{{title}}</div>
                        <div class="cur-status">{{#if access}}▶ Play{{else}}🔒 Locked{{/if}}</div>
                    </a>
                {{/foreach}}
            </div>
        {{/get}}
    {{/if}}
</section>