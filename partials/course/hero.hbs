<style>
    /* Hero Container & Grid */
    .ch-hero { position: relative; padding: var(--spacing-11) 0; border-bottom: 1px solid var(--color-border); background: var(--color-background); overflow: hidden; }
    .ch-bg-grid { position: absolute; inset: 0; z-index: 0; pointer-events: none; background-image: linear-gradient(to right, color-mix(in srgb, var(--color-border), transparent 60%) 1px, transparent 1px), linear-gradient(to bottom, color-mix(in srgb, var(--color-border), transparent 60%) 1px, transparent 1px); background-size: 32px 32px; mask-image: radial-gradient(ellipse at 50% 40%, black 15%, transparent 75%); -webkit-mask-image: radial-gradient(ellipse at 50% 40%, black 15%, transparent 75%); }
    .ch-grid { position: relative; z-index: 1; display: grid; grid-template-columns: 1.2fr 1fr; gap: var(--spacing-10); align-items: center; max-width: var(--container-wide--width); margin: 0 auto; padding: 0 var(--layout--padding); }

    /* Typography & CTAs */
    .ch-title { font-family: var(--font-family-headings); font-size: clamp(2.5rem, 5vw, 3.8rem); font-weight: 800; line-height: 1.1; margin-bottom: var(--spacing-5); color: var(--color-contrast); letter-spacing: -0.02em; }
    .ch-excerpt { font-size: 1.15rem; line-height: 1.6; color: var(--color-secondary); margin-bottom: var(--spacing-8); max-width: 95%; }
    .ch-cta-group { display: flex; flex-wrap: wrap; gap: var(--spacing-4); margin-bottom: var(--spacing-8); }
    #btn-watch-overview { display: none; } /* Hidden until JS finds a video */

    /* Stats Bar */
    .ch-stats-bar { display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: var(--spacing-6); padding-top: var(--spacing-6); border-top: 1px solid color-mix(in srgb, var(--color-border), transparent 30%); }
    .ch-stat { display: flex; flex-direction: column; gap: 4px; }
    .ch-stat-label { font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; color: var(--color-mute); }
    .ch-stat-val { font-size: 1rem; font-weight: 700; color: var(--color-contrast); display: flex; align-items: center; gap: 6px; }

    /* Media Column (16/9) */
    .ch-media-wrap { width: 100%; margin-left: auto; }
    .ch-img { width: 100%; aspect-ratio: 16/9; object-fit: cover; border-radius: var(--radius-4); border: 1px solid var(--color-border); box-shadow: 0 20px 40px rgba(0,0,0,0.1); }

    /* Video Modal */
    .ch-video-modal { border: none; padding: 0; background: transparent; width: 90vw; max-width: 1000px; border-radius: var(--radius-3); overflow: visible; }
    .ch-video-modal::backdrop { background: rgba(0, 0, 0, 0.85); backdrop-filter: blur(8px); }
    .ch-modal-close { position: absolute; top: -40px; right: 0; background: none; border: none; color: #fff; font-size: 2rem; cursor: pointer; line-height: 1; }
    .ch-video-container { position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; border-radius: var(--radius-3); background: #000; box-shadow: 0 20px 50px rgba(0,0,0,0.5); }
    .ch-video-container iframe, .ch-video-container video { position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none; }

    @media (max-width: 991px) {
        .ch-grid { grid-template-columns: 1fr; flex-direction: column-reverse; text-align: left; }
        .ch-media-wrap { margin-bottom: var(--spacing-7); }
    }
</style>

<header class="ch-hero">
    <div class="ch-bg-grid"></div>
    <div class="ch-grid">
        
        <div class="ch-hero-content">
            <h1 class="ch-title">{{title}}</h1>
            <p class="ch-excerpt">{{excerpt}}</p>

            <div class="ch-cta-group">
                <a href="#/portal/signup" class="button button-primary button-rounded" style="padding: 16px 36px;">Enroll Now</a>
                <button id="btn-watch-overview" class="button button-background-100 button-rounded" style="padding: 16px 36px; align-items: center; gap: 8px; cursor: pointer;">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg> Watch Overview
                </button>
            </div>

            <div class="ch-stats-bar">
                
                <div class="ch-stat">
                    <span class="ch-stat-label">Level</span>
                    <span class="ch-stat-val">
                        {{#has tag="#level-Beginner"}}Beginner{{else has tag="#level-Intermediate"}}Intermediate{{else has tag="#level-Advanced"}}Advanced{{else}}All Levels{{/has}}
                    </span>
                </div>

                <span id="raw-duration-slug" style="display:none;">
                    {{#foreach tags visibility="all"}}{{#match slug "~^" "duration-"}}{{slug}}{{/match}}{{/foreach}}
                </span>
                <div class="ch-stat" id="stat-duration-box" style="display: none;">
                    <span class="ch-stat-label">Duration</span>
                    <span class="ch-stat-val" id="formatted-duration">-</span>
                </div>

                {{#if primary_tag}}
                    {{#get "posts" filter="tag:hash-lesson+tag:{{primary_tag.slug}}" limit="all"}}
                        <div class="ch-stat">
                            <span class="ch-stat-label">Curriculum</span>
                            <span class="ch-stat-val">{{pagination.total}} Lessons</span>
                        </div>
                    {{/get}}
                {{/if}}

                <div class="ch-stat">
                    <span class="ch-stat-label">Certificate</span>
                    <span class="ch-stat-val">Included</span>
                </div>

                <div class="ch-stat">
                    <span class="ch-stat-label">Updated</span>
                    <span class="ch-stat-val">{{date updated_at format="MMM YYYY"}}</span>
                </div>

            </div>
        </div>

        <div class="ch-media-wrap">
            {{#if feature_image}}
                <img src="{{img_url feature_image size="l"}}" class="ch-img" alt="{{title}}" loading="eager">
            {{/if}}
        </div>
    </div>
</header>

<dialog id="video-overview-modal" class="ch-video-modal">
    <div style="position: relative;">
        <button class="ch-modal-close" id="close-video-modal">&times;</button>
        <div class="ch-video-container" id="video-modal-body"></div>
    </div>
</dialog>

<script>
document.addEventListener('DOMContentLoaded', () => {
    // 1. DYNAMIC DURATION PARSER (Now properly reads the slug)
    const rawSlug = document.getElementById('raw-duration-slug').innerText.trim();
    if (rawSlug && rawSlug.startsWith('duration-')) {
        const timeStr = rawSlug.replace('duration-', ''); // e.g. "1h-15m"
        const parts = timeStr.split('-');
        
        const formattedString = parts.map(part => {
            if (part.includes('h')) {
                const num = parseInt(part);
                return num + (num > 1 ? ' Hours' : ' Hour');
            }
            if (part.includes('m')) {
                const num = parseInt(part);
                return num + (num > 1 ? ' Minutes' : ' Minute');
            }
            return part;
        }).join(' ');

        document.getElementById('formatted-duration').innerText = formattedString;
        document.getElementById('stat-duration-box').style.display = 'flex';
    }

    // 2. VIDEO EXTRACTOR
    const postContent = document.querySelector('.post-content');
    const btnWatch = document.getElementById('btn-watch-overview');
    const modal = document.getElementById('video-overview-modal');
    const modalBody = document.getElementById('video-modal-body');
    const btnClose = document.getElementById('close-video-modal');

    if (postContent) {
        // Look for the first Ghost embed iframe or a direct HTML video
        const firstEmbedWrapper = postContent.querySelector('.kg-embed-card, .kg-video-card');
        if (firstEmbedWrapper) {
            const videoElement = firstEmbedWrapper.querySelector('iframe, video');
            if (videoElement) {
                btnWatch.style.display = 'inline-flex';
                modalBody.appendChild(videoElement);
                firstEmbedWrapper.remove(); // Remove from post body
            }
        }
    }

    // Modal Events
    btnWatch.addEventListener('click', () => modal.showModal());
    btnClose.addEventListener('click', () => {
        modal.close();
        const iframe = modalBody.querySelector('iframe');
        if (iframe) iframe.src = iframe.src; // Force pause
    });
    modal.addEventListener('click', (e) => {
        if (e.target === modal) btnClose.click();
    });
});
</script>