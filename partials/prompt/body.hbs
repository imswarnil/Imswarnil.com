{{!-- Prompt detail — rendered as an LLM chat. Convention: the post body opens
     with the prompt in a code block (```), followed by the result/notes. JS lifts
     that first <pre> into a "You" bubble (with a Copy button) and puts the rest in
     an "Assistant" bubble. custom_excerpt = the idea/context. --}}
<article class="{{post_class}}">
	<header class="relative overflow-hidden border-b border-line py-12">
		<div class="bg-dots pointer-events-none absolute inset-0 fade-mask-b" aria-hidden="true"></div>
		<div class="container-site relative">
			<nav class="flex flex-wrap items-center gap-2 font-mono text-[11px] uppercase tracking-[0.15em] text-silver" aria-label="Breadcrumb">
				<a href="{{@site.url}}/prompts/" class="transition hover:text-ink">Prompts</a>
				<span aria-hidden="true">/</span><span class="text-ink">this prompt</span>
			</nav>
			<h1 class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl text-balance">{{title}}</h1>
			{{#if custom_excerpt}}<p class="mt-3 max-w-2xl text-lg leading-relaxed text-silver">{{custom_excerpt}}</p>{{/if}}
			<div class="mt-4 flex flex-wrap items-center gap-2">
				{{#foreach tags visibility="public"}}<a href="{{url}}" class="chip transition hover:border-ink hover:text-ink">{{name}}</a>{{/foreach}}
				<span class="chip">{{> "icons/calendar"}} {{date published_at format="MMM YYYY"}}</span>
			</div>
		</div>
	</header>

	<div class="container-site py-10">
		<div class="mx-auto max-w-3xl">
			{{!-- chat window --}}
			<div class="overflow-hidden rounded-2xl border border-line bg-paper shadow-card">
				<div class="flex items-center gap-2 border-b border-line bg-mist/50 px-4 py-2.5">
					<span class="chat-avatar !h-6 !w-6 !rounded-md !text-[9px]">AI</span>
					<span class="font-mono text-[11px] uppercase tracking-[0.18em] text-silver">Prompt playground</span>
					<button type="button" class="btn-ghost btn-xs ml-auto" data-copy="#prompt-raw" data-copied="Copied ✓"><span data-copy-label>{{> "icons/code" class="h-3 w-3"}} Copy prompt</span></button>
				</div>
				<div class="p-5 sm:p-7">
					<div class="chat-thread" id="prompt-thread"></div>
				</div>
			</div>

			{{!-- raw body (hidden; JS reads from here) --}}
			<div id="prompt-content" hidden class="gh-content">{{content}}</div>

			<div class="mt-8 flex flex-wrap items-center justify-between gap-3 border-t border-line pt-6">
				<a href="{{@site.url}}/prompts/" class="btn-ghost btn-sm">{{> "icons/arrow-right" class="h-3.5 w-3.5 rotate-180"}} All prompts</a>
				{{> "post/share"}}
			</div>

			{{#get "posts" filter="tag:hash-prompt+id:-{{id}}" limit="3" include="tags" as |more|}}
				{{#if more}}
				<section class="mt-14 border-t border-line pt-10">
					<p class="kicker mb-5">{{> "icons/sparkle" class="h-3.5 w-3.5"}} More prompts</p>
					<div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">{{#foreach more}}{{> "cards/prompt"}}{{/foreach}}</div>
				</section>
				{{/if}}
			{{/get}}

			{{#if @site.comments_enabled}}<section class="mt-12 border-t border-line pt-10">{{> "components/comments" title="Improvements & variations"}}</section>{{/if}}
		</div>
	</div>

	<script>
	(function () {
		var src = document.getElementById('prompt-content');
		var thread = document.getElementById('prompt-thread');
		if (!src || !thread) return;

		function bubble(who, role, cls, node) {
			var row = document.createElement('div');
			row.className = 'chat-row ' + (who === 'you' ? 'is-you' : '');
			var av = document.createElement('span');
			av.className = 'chat-avatar';
			av.textContent = who === 'you' ? 'You' : 'AI';
			var col = document.createElement('div');
			col.className = 'chat-col';
			var r = document.createElement('span'); r.className = 'chat-role'; r.textContent = role;
			var b = document.createElement('div'); b.className = 'chat-bubble ' + cls;
			b.appendChild(node);
			col.appendChild(r); col.appendChild(b);
			row.appendChild(av); row.appendChild(col);
			thread.appendChild(row);
		}

		/* prompt = first <pre> (fallback: the whole body) */
		var pre = src.querySelector('pre');
		var promptText = pre ? (pre.innerText || pre.textContent) : (src.innerText || '').trim();
		var youPre = document.createElement('pre');
		youPre.id = 'prompt-raw';
		youPre.textContent = promptText;
		bubble('you', 'You', 'chat-bubble-you', youPre);

		/* result = everything after the prompt */
		if (pre) {
			var card = pre.closest('.kg-card, figure') || pre;
			card.remove();
		}
		var rest = src.innerHTML.trim();
		if (rest) {
			var ai = document.createElement('div');
			ai.className = 'gh-content';
			ai.innerHTML = rest;
			bubble('ai', 'Assistant', 'chat-bubble-ai', ai);
		}
	})();
	</script>
</article>
