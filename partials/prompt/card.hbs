{{!-- Prompt card — a mini chat bubble preview. --}}
<article class="card-surface group flex flex-col p-5 {{class}}">
	<div class="flex items-center gap-2">
		<span class="chat-avatar !h-7 !w-7 !rounded-lg !text-[10px]">AI</span>
		<span class="kicker !mb-0">{{> "icons/sparkle" class="h-3 w-3"}} Prompt</span>
		<span class="ml-auto font-mono text-[10px] text-silver">{{date published_at format="MMM YYYY"}}</span>
	</div>
	<h3 class="mt-3 text-base font-semibold leading-snug tracking-tight"><a href="{{url}}" class="transition hover:text-accent hover:underline hover:underline-offset-4">{{title}}</a></h3>
	<p class="mt-1.5 line-clamp-3 text-sm leading-relaxed text-silver">{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{excerpt words="24"}}{{/if}}</p>
	<div class="mt-4 flex items-center gap-2 border-t border-line pt-4">
		<a href="{{url}}" class="btn-ghost btn-sm">{{> "icons/arrow-right" class="h-3.5 w-3.5"}} Open</a>
		{{#primary_tag}}<span class="chip ml-auto !text-[10px]">{{name}}</span>{{/primary_tag}}
	</div>
</article>
