{{!--
	"Remove ads" chip — sits in the ad header (right side)
	================================================================
	Shown to visitors who can go ad-free by subscribing (see the gate in
	ad-unit.hbs). Opens Ghost Portal:
	  - logged-in free member → upgrade (account plans)
	  - anonymous             → signup
	Ghost Portal automatically intercepts #/portal/* links.
--}}
<a class="ad-remove"
	href="{{#if @member}}#/portal/account/plans{{else}}#/portal/signup{{/if}}"
	title="{{t "Go ad-free by becoming a member"}}">
	<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l1.9 5.1L19 9l-5.1 1.9L12 16l-1.9-5.1L5 9l5.1-1.9z"/></svg>
	<span>{{t "Remove ads"}}</span>
</a>
