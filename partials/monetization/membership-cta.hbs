{{!--
	"Remove ads" CTA — compact link inside the ad's top pill
	================================================================
	Shown next to the "Advertisement" label to visitors who can go ad-free by
	subscribing (see the gate in ad-unit.hbs). Opens Ghost Portal:
	  - logged-in free member → upgrade (account plans)
	  - anonymous             → signup
	Ghost Portal automatically intercepts #/portal/* links.
--}}
<a class="ad-membership-cta"
	href="{{#if @member}}#/portal/account/plans{{else}}#/portal/signup{{/if}}"
	title="{{t "Go ad-free by becoming a member"}}">{{t "Remove ads"}}</a>
