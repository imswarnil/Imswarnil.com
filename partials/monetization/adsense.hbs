{{!--
	Google AdSense — gate + dispatcher
	================================================================
	Publisher: ca-pub-1291242080282540

	Decides WHETHER to show an ad to this visitor. The actual markup lives in
	partials/monetization/ad-unit.hbs (rendered with this partial's context, so
	all params below flow straight through).

	An ad is shown only when ALL of these hold:
	  1. @custom.enable_adsense is ON (master switch, Ghost admin).
	  2. The post/page is NOT tagged #hide_adsense_ads. NOTE: `has` reads the
	     current data context, so this is only honoured when the partial is
	     called inside {{#post}}/{{#page}} (the per-post/page placements). On
	     listing/feed pages there is no single post, so only the switch applies.
	  3. The visitor is NOT ad-free via membership (@custom.ad_free_for):
	       "All members"  → any logged-in @member is ad-free
	       "Paid members" → only @member.paid is ad-free
	       "Disabled"     → membership never removes ads

	Params (forwarded to ad-unit):
	  slot       (required) AdSense ad-slot id.
	  format     data-ad-format. Default "auto". "fluid" for in-article/in-feed,
	             "autorelaxed" for multiplex.
	  layout     data-ad-layout (e.g. "in-article"). Optional.
	  layout_key data-ad-layout-key (in-feed ads). Optional.
	  label      Eyebrow text. Defaults to "Advertisement".
	  class      Extra wrapper class(es). Optional.
	  style      Extra inline style on the <ins>. Optional.
	  cta        If true, show the "Remove ads — become a member" CTA beneath
	             the ad (only to visitors who could actually go ad-free).
--}}
{{#if @custom.enable_adsense}}
{{^has tag="#hide_adsense_ads"}}

	{{#match @custom.ad_free_for "All members"}}
		{{!-- Ad-free for every member; show ad only to non-members. --}}
		{{#unless @member}}{{> "monetization/ad-unit"}}{{/unless}}

	{{else match @custom.ad_free_for "Paid members"}}
		{{!-- Ad-free for paid members; show ad to everyone else. --}}
		{{#unless @member.paid}}{{> "monetization/ad-unit"}}{{/unless}}

	{{else}}
		{{!-- Membership ad-free disabled: everyone sees ads. --}}
		{{> "monetization/ad-unit"}}
	{{/match}}

{{/has}}
{{/if}}
