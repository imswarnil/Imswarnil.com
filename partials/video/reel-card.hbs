{{!-- Reel / Short — 9:16 vertical card for #video posts also tagged #reel/#shorts.
     Thumbnail comes from the feature image, else the post's own YouTube id
     (extracted by main.js from the template). No hover-video (shorts pillarbox
     badly in a 16:9 embed) — data-no-preview keeps it thumbnail-only. --}}
<article class="reel-card video-card group {{class}}">
	<a href="{{url}}" class="block" aria-label="Watch short: {{title}}">
		<div class="relative aspect-[9/16] overflow-hidden rounded-2xl border border-line bg-mist shadow-card transition-all duration-300 group-hover:shadow-lift">
			{{#if feature_image}}
				<img data-skeleton src="{{img_url feature_image size="600"}}" width="360" height="640"
					alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" loading="lazy" decoding="async"
					class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
				<div class="skeleton absolute inset-0"></div>
			{{else}}
				<div class="video-fallback" data-video-card-media data-no-preview>
					<template data-video-src>{{content}}</template>
					<div class="bg-dots absolute inset-0 flex items-center justify-center" data-ph>{{> "icons/film" class="text-silver"}}</div>
				</div>
			{{/if}}
			<div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/5 to-black/20" aria-hidden="true"></div>
			<span class="absolute left-2.5 top-2.5 inline-flex items-center gap-1 rounded-full border border-white/20 bg-black/55 px-2 py-0.5 font-mono text-[9px] font-bold uppercase tracking-[0.14em] text-white backdrop-blur">{{> "icons/play" class="h-2.5 w-2.5"}} Short</span>
			<span class="absolute inset-0 flex items-center justify-center" aria-hidden="true">
				<span class="flex h-12 w-12 scale-90 items-center justify-center rounded-full bg-white/90 text-black shadow-lg transition-transform duration-300 group-hover:scale-100">{{> "icons/play" class="ml-0.5 h-5 w-5"}}</span>
			</span>
			<div class="absolute inset-x-0 bottom-0 p-3">
				<h3 class="line-clamp-2 text-[13px] font-semibold leading-snug text-white [text-shadow:0_1px_5px_rgb(0_0_0/.6)]">{{title}}</h3>
				<p class="mt-1 flex items-center gap-1.5 font-mono text-[9px] text-white/70">{{> "icons/calendar" class="h-2.5 w-2.5"}} {{date published_at format="DD MMM YYYY"}}</p>
			</div>
		</div>
	</a>
</article>
