{{!-- Netflix-style poster card — 2:3 artwork, gradient overlay, title + meta on
     the image, hover lift/zoom. Used on /videos and anywhere a wall of posters fits. --}}
<article class="group {{class}}">
	<a href="{{url}}" class="block" aria-label="Watch: {{title}}">
		<div class="relative aspect-[2/3] overflow-hidden rounded-xl border border-line bg-mist shadow-card transition-all duration-300 group-hover:-translate-y-1.5 group-hover:shadow-lift">
			{{#if feature_image}}
				<img src="{{img_url feature_image size="600"}}"
					srcset="{{img_url feature_image size="300"}} 300w, {{img_url feature_image size="600"}} 600w"
					sizes="(max-width: 640px) 45vw, 260px"
					width="600" height="900"
					alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" loading="lazy"
					class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
			{{else}}
				<div class="bg-dots flex h-full w-full items-center justify-center">{{> "icons/film" class="text-silver"}}</div>
			{{/if}}
			<div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/15 to-transparent" aria-hidden="true"></div>
			{{#if featured}}<span class="absolute left-2.5 top-2.5 rounded bg-white/90 px-1.5 py-0.5 font-mono text-[9px] font-bold uppercase tracking-[0.12em] text-black">Featured</span>{{/if}}
			<span class="absolute right-2.5 top-2.5 flex h-8 w-8 items-center justify-center rounded-full bg-white/90 text-black opacity-0 shadow transition duration-300 group-hover:opacity-100">{{> "icons/play" class="ml-0.5 h-3.5 w-3.5"}}</span>
			<span class="absolute bottom-16 right-2.5 rounded bg-black/75 px-1.5 py-0.5 font-mono text-[10px] font-semibold tabular-nums text-white" data-duration-tags="{{#foreach tags visibility="internal"}}{{slug}} {{/foreach}}" hidden></span>
			<div class="absolute inset-x-0 bottom-0 p-3.5">
				<h3 class="line-clamp-2 text-[15px] font-bold leading-snug text-white [text-shadow:0_1px_6px_rgb(0_0_0/.5)]">{{title}}</h3>
				<p class="mt-1.5 flex items-center gap-2 font-mono text-[10px] text-white/70">
					{{date published_at format="MMM YYYY"}}
					{{#primary_tag}}<span class="opacity-50">·</span> {{name}}{{/primary_tag}}
				</p>
			</div>
		</div>
	</a>
</article>
