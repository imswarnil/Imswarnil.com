{{!-- Single documentation page (#docs). Left: sticky grouped sidebar. Middle:
     the doc content + prev/next. Right: auto "On this page" TOC (built by main.js
     from h2/h3, same as lessons). The doc's primary tag is its section. --}}
<article class="{{post_class}} pt-8">
	<div class="container-site">
		{{!-- breadcrumb --}}
		<nav class="flex flex-wrap items-center gap-2 font-mono text-[10px] uppercase tracking-[0.15em] text-silver" aria-label="Breadcrumb">
			<a href="{{@site.url}}/docs/" class="transition hover:text-ink">Docs</a>
			{{#primary_tag}}<span aria-hidden="true">/</span><a href="{{url}}" class="transition hover:text-ink">{{name}}</a>{{/primary_tag}}
			<span aria-hidden="true">/</span><span class="text-ink">{{title}}</span>
		</nav>

		<div class="mt-6 lg:grid lg:grid-cols-12 lg:gap-10">
			{{!-- Sidebar (desktop) --}}
			<aside class="hidden lg:col-span-3 lg:block">
				<div class="lg:sticky lg:top-20 lg:max-h-[calc(100dvh-6rem)] lg:overflow-y-auto lg:pr-2 no-scrollbar">
					{{> "docs/sidebar" active=slug}}
				</div>
			</aside>

			{{!-- Mobile section switcher --}}
			<details class="mb-6 rounded-2xl border border-line bg-mist/40 p-4 lg:hidden">
				<summary class="flex cursor-pointer list-none items-center gap-2 font-semibold [&::-webkit-details-marker]:hidden">
					{{> "icons/book" class="h-4 w-4"}} All documentation {{> "icons/chevron-down" class="ml-auto text-silver"}}
				</summary>
				<div class="mt-4">{{> "docs/sidebar" active=slug}}</div>
			</details>

			{{!-- Content + TOC --}}
			<div class="min-w-0 lg:col-span-9 lg:flex lg:items-start lg:gap-10">
				{{> "utility/toc" class="mb-8 lg:order-2 lg:mb-0 lg:sticky lg:top-24 lg:w-64 lg:shrink-0"}}

				<div class="min-w-0 lg:order-1 lg:flex-1">
					<header>
						<h1 class="text-3xl font-semibold tracking-tight sm:text-4xl text-balance">{{title}}</h1>
						{{#if custom_excerpt}}<p class="mt-3 text-lg leading-relaxed text-silver">{{custom_excerpt}}</p>{{/if}}
					</header>

					<section class="gh-content mt-8">
						{{content}}
					</section>

					{{!-- Prev / next across all docs (filled from the sidebar) --}}
					<nav class="mt-12 grid border-y border-line sm:grid-cols-2 sm:divide-x sm:divide-line" aria-label="Docs pagination">
						<a href="#" data-doc-prev hidden class="group flex items-center gap-3 py-5 pr-4 transition hover:bg-mist/60">
							{{> "icons/arrow-right" class="shrink-0 rotate-180 text-silver transition group-hover:text-ink"}}
							<span class="min-w-0"><span class="block font-mono text-[10px] uppercase tracking-[0.2em] text-silver">Previous</span><span class="block truncate text-sm font-semibold" data-doc-prev-title></span></span>
						</a>
						<a href="#" data-doc-next hidden class="group flex items-center justify-end gap-3 py-5 text-right transition hover:bg-mist/60 sm:col-start-2 sm:pl-4">
							<span class="min-w-0"><span class="block font-mono text-[10px] uppercase tracking-[0.2em] text-silver">Next</span><span class="block truncate text-sm font-semibold" data-doc-next-title></span></span>
							{{> "icons/arrow-right" class="shrink-0 text-silver transition group-hover:text-ink"}}
						</a>
					</nav>

					<footer class="mt-6 flex items-center justify-between border-t border-line pt-6">
						<a href="{{@site.url}}/docs/" class="btn-ghost">{{> "icons/arrow-right" class="rotate-180"}} All docs</a>
						{{> "utility/share"}}
					</footer>
				</div>
			</div>
		</div>
	</div>
</article>

<script>
	(function () {
		var CURRENT = '{{slug}}';
		var links = [].slice.call(document.querySelectorAll('.docs-nav .docs-nav-link'));
		/* de-dupe by href (sidebar may render twice: desktop + mobile) */
		var seen = {}, order = [];
		links.forEach(function (a) {
			var href = a.getAttribute('href');
			if (!href || seen[href]) return;
			seen[href] = true; order.push(a);
		});
		var idx = order.findIndex(function (a) { return a.classList.contains('is-active'); });
		function fill(sel, item, titleSel) {
			document.querySelectorAll(sel).forEach(function (a) {
				if (!item) { a.remove(); return; }
				a.href = item.getAttribute('href');
				a.hidden = false;
				var t = titleSel && a.querySelector(titleSel);
				if (t) t.textContent = item.textContent.trim();
			});
		}
		fill('[data-doc-prev]', idx > 0 ? order[idx - 1] : null, '[data-doc-prev-title]');
		fill('[data-doc-next]', idx > -1 && idx < order.length - 1 ? order[idx + 1] : null, '[data-doc-next-title]');
	})();
</script>
