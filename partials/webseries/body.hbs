{{!-- Netflix-style webseries overview.
     Episodes are #episode posts sharing this series' public tag; each lookup
     is a SMALL scoped {{#get}} — the post's own {{content}}/helpers must stay
     OUTSIDE any get block (inside one, post context breaks and {{content}}
     renders "undefined"). --}}

{{!-- Netflix chrome — replaces the global navbar (hidden via body.tag-hash-webseries) --}}
<div class="series-bar" id="series-bar">
	<a href="{{@site.url}}/webseries/" class="series-bar-btn tooltip tooltip-bottom" data-tip="All series" aria-label="Back to all series">{{> "icons/arrow-right" class="rotate-180"}}</a>
	<p class="min-w-0 flex-1 truncate text-sm font-bold tracking-tight text-white [text-shadow:0_1px_6px_rgb(0_0_0/.5)]">{{title}}</p>
	<div class="flex shrink-0 items-center gap-1">
		<a href="#episodes" class="series-bar-btn tooltip tooltip-bottom" data-tip="Episodes" aria-label="Jump to episodes">{{> "icons/tv"}}</a>
		<button type="button" class="series-bar-btn tooltip tooltip-bottom" data-tip="Subscribe" data-modal-open="#subscribe-backdrop" aria-label="Subscribe">{{> "icons/bell"}}</button>
		<button type="button" data-mode-cycle class="series-bar-btn" aria-label="Switch theme mode"></button>
		<a href="{{@site.url}}/webseries/" class="series-bar-btn tooltip tooltip-left" data-tip="Close" aria-label="Close series">{{> "icons/close"}}</a>
	</div>
</div>

<article class="{{post_class}} -mt-16 sm:-mt-[4.25rem]" id="series-app"
	data-title="{{title}}"
	data-url="{{url absolute="true"}}"
	data-desc="{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{excerpt words="45"}}{{/if}}"
	data-image="{{#if feature_image}}{{img_url feature_image size="1600" absolute="true"}}{{/if}}">

	{{!-- Backdrop hero: series poster → first episode poster → the series' own
	     opening video (hoisted by JS, home-hero style) --}}
	<header class="tv-scanlines relative flex min-h-[86vh] items-end overflow-hidden">
		{{!-- Cinematic dark backdrop: series poster → first episode poster → the
		     reel thumbnail. Stays dark in every theme mode so the image always
		     reads (a paper-tinted scrim used to wash it to white in light mode). --}}
		<div class="video-hero-media" aria-hidden="true" id="series-backdrop">
			{{#if feature_image}}
				<img class="video-hero-poster" src="{{img_url feature_image size="2000"}}" alt="" width="2000" height="1125" fetchpriority="high" decoding="async" />
			{{else}}
				{{#foreach tags visibility="public" limit="1"}}
				{{#get "posts" filter="tag:hash-episode+tag:{{slug}}" order="published_at asc" limit="1" as |firstep|}}
					{{#foreach firstep}}{{#if feature_image}}<img class="video-hero-poster" src="{{img_url feature_image size="2000"}}" alt="" width="2000" height="1125" fetchpriority="high" decoding="async" />{{else}}<img class="video-hero-poster" src="https://i.ytimg.com/vi/ecOkmTD7KhU/maxresdefault.jpg" alt="" width="1280" height="720" decoding="async" onerror="this.onerror=null;this.src='https://i.ytimg.com/vi/ecOkmTD7KhU/hqdefault.jpg'" />{{/if}}{{/foreach}}
				{{else}}
					<img class="video-hero-poster" src="https://i.ytimg.com/vi/ecOkmTD7KhU/maxresdefault.jpg" alt="" width="1280" height="720" decoding="async" onerror="this.onerror=null;this.src='https://i.ytimg.com/vi/ecOkmTD7KhU/hqdefault.jpg'" />
				{{/get}}
				{{/foreach}}
			{{/if}}
			<span class="absolute inset-0 overflow-hidden" id="series-hero-video"></span>
			<div class="video-hero-scrim video-hero-scrim-b"></div>
			<div class="video-hero-scrim video-hero-scrim-x"></div>
		</div>

		<div class="container-site relative pb-12 pt-40 text-white">
			<div class="max-w-3xl">
				<p class="kicker !text-white/70">{{> "icons/film"}} Webseries</p>
				<h1 class="mt-4 text-4xl font-black tracking-tight sm:text-6xl text-balance [text-shadow:0_2px_20px_rgb(0_0_0/.5)]">{{title}}</h1>

				<div class="mt-5 flex flex-wrap items-center gap-x-4 gap-y-2 font-mono text-xs text-white/70">
					<span class="flex items-center gap-1.5">{{> "icons/calendar"}} {{date published_at format="YYYY"}}</span>
					{{#foreach tags visibility="public" limit="1"}}
					{{#get "posts" filter="tag:hash-episode+tag:{{slug}}" limit="1" as |c|}}
						<span class="flex items-center gap-1.5">{{> "icons/film"}} {{plural pagination.total empty="Episodes coming soon" singular="% episode" plural="% episodes"}}</span>
					{{/get}}
					{{/foreach}}
					<span class="flex items-center gap-1.5">{{> "icons/clock"}} <span id="series-duration" data-duration-tags="{{#foreach tags visibility="internal"}}{{slug}} {{/foreach}}" hidden></span></span>
				</div>

				<p class="mt-5 max-w-xl text-lg leading-relaxed text-white/85">{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{excerpt words="45"}}{{/if}}</p>

				<div class="mt-7 flex flex-wrap items-center gap-3">
					{{#foreach tags visibility="public" limit="1"}}
					{{#get "posts" filter="tag:hash-episode+tag:{{slug}}" order="published_at asc" limit="1" as |firstep|}}
						{{#foreach firstep}}<a href="{{url}}" class="btn-invert">{{> "icons/play"}} Play episode 1</a>{{/foreach}}
					{{/get}}
					{{/foreach}}
					<a href="#episodes" class="btn-glass">Episode list {{> "icons/chevron-down"}}</a>
				</div>
			</div>
		</div>
	</header>

	<div class="container-site py-10">
		<div class="mx-auto max-w-4xl">

			{{!-- Synopsis / body — OUTSIDE any get so {{content}} works --}}
			<section class="gh-content" id="series-content">
				{{content}}
			</section>

			{{> "components/adsense" slot="8939839370" format="auto"}}

			{{!-- Episode list --}}
			<section id="episodes" class="scroll-mt-28">
				<h2 class="section-title mt-14">Episodes</h2>
				{{#foreach tags visibility="public" limit="1"}}
				{{#get "posts" filter="tag:hash-episode+tag:{{slug}}" order="published_at asc" limit="50" as |eps|}}
					{{#if eps}}
						<ol class="mt-6 space-y-3" id="episode-list">
							{{#foreach eps}}
								<li class="reveal">{{> "cards/episode" num=@number}}</li>
							{{/foreach}}
						</ol>
					{{else}}
						<p class="mt-6 rounded-2xl border border-dashed border-line p-8 text-center text-sm text-silver">Episodes drop soon — tag them <code class="rounded bg-mist px-1 font-mono text-xs">#episode</code> with this series' public tag <code class="rounded bg-mist px-1 font-mono text-xs">{{slug}}</code> (first position).</p>
					{{/if}}
				{{/get}}
				{{/foreach}}
			</section>

			{{!-- Gear shelf --}}
			{{#get "posts" filter="tag:hash-product+tag:hash-course-gear" limit="4" include="tags" as |gear|}}
				{{#if gear}}
					<section class="mt-16">
						<h2 class="section-title">Products used to make this webseries</h2>
						<div class="mt-6 grid gap-4 sm:grid-cols-2">
							{{#foreach gear}}
								{{> "cards/product-mini"}}
							{{/foreach}}
						</div>
					</section>
				{{/if}}
			{{/get}}

			{{> "components/adsense" slot="6808134701" format="autorelaxed"}}

			{{#if @site.comments_enabled}}
				<section class="mt-12 border-t border-line pt-10">
					{{> "components/comments" title="Comments"}}
				</section>
			{{/if}}
		</div>
	</div>

	<script>
	(function () {
		var app = document.getElementById('series-app');

		/* ----- Hero video: if the series content opens with a YouTube embed,
		   play it (muted, looping) as the backdrop — home-hero style ----- */
		var content = document.getElementById('series-content');
		var slot = document.getElementById('series-hero-video');
		if (content && slot) {
			var ID_RE = /(?:youtube(?:-nocookie)?\.com\/(?:embed\/|watch\?[^"'\s]*?v=)|youtu\.be\/)([A-Za-z0-9_-]{11})/;
			var found = null;
			var nodes = content.querySelectorAll('iframe[src], a[href]');
			for (var i = 0; i < nodes.length; i++) {
				var m = (nodes[i].src || nodes[i].href || '').match(ID_RE);
				if (m) { found = { id: m[1], el: nodes[i] }; break; }
			}
			var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			/* no embed in the post? fall back to the ambient reel so the hero always moves */
			var heroId = found ? found.id : 'ecOkmTD7KhU';
			/* hide the original embed so it doesn't play twice */
			if (found) {
				var card = found.el.closest('.kg-card, figure, .kg-embed-card, .kg-bookmark-card') || found.el;
				card.style.display = 'none';
			}
			if (!reduce) {
				/* Mount the backdrop reel AFTER load/idle — the poster is the LCP
				   element, so the heavy YouTube iframe must never block it. */
				var mountHero = function () {
					var backdrop = document.getElementById('series-backdrop');
					var f = document.createElement('iframe');
					f.src = 'https://www.youtube-nocookie.com/embed/' + heroId +
						'?autoplay=1&mute=1&loop=1&playlist=' + heroId +
						'&controls=0&playsinline=1&rel=0&modestbranding=1&iv_load_policy=3&disablekb=1';
					f.title = 'Series backdrop';
					f.tabIndex = -1;
					f.setAttribute('allow', 'autoplay; encrypted-media');
					f.setAttribute('frameborder', '0');
					f.className = 'pointer-events-none absolute left-1/2 top-1/2 aspect-video h-[120%] w-auto min-w-full -translate-x-1/2 -translate-y-1/2';
					f.addEventListener('load', function () { if (backdrop) backdrop.classList.add('is-playing'); });
					slot.appendChild(f);
				};
				var idle = function (fn) { ('requestIdleCallback' in window) ? requestIdleCallback(fn, { timeout: 2500 }) : setTimeout(fn, 800); };
				if (document.readyState === 'complete') idle(mountHero);
				else window.addEventListener('load', function () { idle(mountHero); });
			}
		}

		/* ----- Cast: restyle the "Cast" heading + list from the body into avatar chips ----- */
		if (content) {
			var heads = content.querySelectorAll('h2, h3');
			for (var hi = 0; hi < heads.length; hi++) {
				if (!/^cast$/i.test(heads[hi].textContent.trim())) continue;
				var list = heads[hi].nextElementSibling;
				if (!list || !/^(UL|OL)$/.test(list.tagName)) break;
				heads[hi].className = 'section-title !mt-14';
				var wrap = document.createElement('div');
				wrap.className = 'not-prose mt-5 flex flex-wrap gap-3';
				var items = list.querySelectorAll('li');
				for (var j = 0; j < items.length; j++) {
					var raw = items[j].textContent.trim();
					if (!raw) continue;
					var parts = raw.split(/\s*(?:—|–|:|\bas\b)\s*/);
					var person = (parts[0] || raw).trim();
					var role = parts.length > 1 ? parts.slice(1).join(' ').trim() : '';
					var initials = person.split(/\s+/).map(function (w) { return w.charAt(0); }).slice(0, 2).join('').toUpperCase();
					var chip = document.createElement('span');
					chip.className = 'inline-flex items-center gap-2.5 rounded-full border border-line bg-mist/60 py-1.5 pl-1.5 pr-4';
					var av = document.createElement('span');
					av.className = 'flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-ink font-mono text-[11px] font-bold text-paper';
					av.textContent = initials;
					var txt = document.createElement('span');
					txt.className = 'text-sm font-semibold leading-tight';
					txt.textContent = person;
					chip.appendChild(av);
					chip.appendChild(txt);
					if (role) {
						var r = document.createElement('span');
						r.className = 'font-mono text-[11px] text-silver';
						r.textContent = role;
						chip.appendChild(r);
					}
					wrap.appendChild(chip);
				}
				list.parentNode.replaceChild(wrap, list);
				break;
			}
		}

		/* ----- TVSeries JSON-LD, built from the page (episodes read from the DOM) ----- */
		function iso(el) {
			if (!el) return null;
			var m = (el.getAttribute('data-duration-tags') || '').match(/hash-duration-(?:(\d+)h)?-?(?:(\d+)m)?/);
			if (!m || (!m[1] && !m[2])) return null;
			return 'PT' + (m[1] ? m[1] + 'H' : '') + (m[2] ? m[2] + 'M' : '');
		}
		if (app) {
			var epLinks = [].slice.call(document.querySelectorAll('#episode-list a[href]'));
			var seen = {};
			var episodes = [];
			epLinks.forEach(function (a) {
				if (seen[a.href]) return;
				seen[a.href] = 1;
				var t = a.querySelector('h3, .line-clamp-2, strong');
				episodes.push({ url: a.href, name: (t ? t.textContent : a.textContent).trim() });
			});
			var ld = {
				'@context': 'https://schema.org',
				'@type': 'TVSeries',
				name: app.getAttribute('data-title'),
				url: app.getAttribute('data-url'),
				description: app.getAttribute('data-desc')
			};
			if (app.getAttribute('data-image')) ld.image = app.getAttribute('data-image');
			var total = iso(document.getElementById('series-duration'));
			if (total) ld.duration = total;
			if (episodes.length) {
				ld.numberOfEpisodes = episodes.length;
				ld.containsSeason = {
					'@type': 'TVSeason',
					seasonNumber: 1,
					name: app.getAttribute('data-title') + ' — Season 1',
					episode: episodes.map(function (e, i) {
						return { '@type': 'TVEpisode', position: i + 1, episodeNumber: i + 1, name: e.name, url: e.url };
					})
				};
			}
			var tag = document.createElement('script');
			tag.type = 'application/ld+json';
			tag.textContent = JSON.stringify(ld);
			document.head.appendChild(tag);
		}
	})();
	</script>
</article>
