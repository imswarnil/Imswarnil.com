{{!-- Single post/page layout. Use inside {{#post}} … {{/post}}. --}}
<article class="mx-auto max-w-3xl px-4 py-10">
	<header class="mb-8">
		{{#if primary_tag}}
			<a href="{{primary_tag.url}}" class="text-xs font-medium uppercase tracking-wide text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100">{{primary_tag.name}}</a>
		{{/if}}

		<h1 class="mt-2 text-3xl font-semibold leading-tight tracking-tight sm:text-4xl">{{title}}</h1>

		{{#if custom_excerpt}}
			<p class="mt-3 text-lg leading-relaxed text-zinc-600 dark:text-zinc-400">{{custom_excerpt}}</p>
		{{/if}}

		<p class="mt-4 text-sm text-zinc-500">
			{{#primary_author}}<a href="{{url}}" class="hover:underline">{{name}}</a> &middot; {{/primary_author}}
			<time datetime="{{date format="YYYY-MM-DD"}}">{{date format="D MMMM YYYY"}}</time> &middot; {{reading_time}}
		</p>
	</header>

	{{#if feature_image}}
		<img src="{{img_url feature_image size="l"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" class="mb-8 w-full rounded-lg" width="1000" height="563" />
	{{/if}}

	<div class="prose prose-zinc max-w-none dark:prose-invert">
		{{content}}
	</div>

	{{#if tags}}
		<footer class="mt-10 flex flex-wrap gap-2 border-t border-zinc-200 pt-6 dark:border-zinc-800">
			{{#foreach tags}}
				<a href="{{url}}" class="rounded border border-zinc-200 px-2 py-0.5 text-xs text-zinc-600 hover:bg-zinc-100 dark:border-zinc-800 dark:text-zinc-400 dark:hover:bg-zinc-800">{{name}}</a>
			{{/foreach}}
		</footer>
	{{/if}}
</article>
