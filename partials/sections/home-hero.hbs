{{#if hide_title}}
	<h1 class="screen-reader-text">{{title}}</h1>
{{else}}
	<section class="hero-tv" data-hero-tv data-phase="idle">
		<div class="hero-tv-bg" aria-hidden="true">
			<span class="hero-tv-static"></span>
			<span class="hero-tv-scan"></span>
			<span class="hero-tv-noise"></span>
			<span class="hero-tv-roll"></span>
			<span class="hero-tv-vignette"></span>
		</div>

		<div class="hero-tv-content">
			<div class="hero-tv-topbar">
				<span class="hero-tv-live"><span class="hero-tv-live-dot"></span>{{t "On air"}}</span>
			</div>

			<div class="hero-tv-main">
				<div class="hero-tv-meta">
					<h1 class="hero-tv-name">{{title}}</h1>

					{{#if @site.description}}
						<p class="hero-tv-role">{{@site.description}}</p>
					{{/if}}

					{{#if excerpt}}
						<p class="hero-tv-intro">{{excerpt}}</p>
					{{/if}}

					<div class="hero-tv-chips">
						{{#get "posts" limit=1}}
							{{#foreach posts}}
								<a class="hero-tv-chip" href="{{url}}">
									<span class="hero-tv-chip-k">{{t "Latest post"}}</span>
									<span class="hero-tv-chip-v">{{title}}</span>
								</a>
							{{/foreach}}
						{{/get}}

						<button class="hero-tv-chip" type="button" data-play>
							<span class="hero-tv-chip-k">{{> "icons/play"}}{{t "Recent video"}}</span>
							<span class="hero-tv-chip-v">{{t "Watch my story"}}</span>
						</button>
					</div>

					<div class="hero-tv-stats">
						{{#get "posts" limit=1}}
							<div class="hero-tv-stat">
								<span class="hero-tv-stat-n">{{pagination.total}}</span>
								<span class="hero-tv-stat-l">{{t "Posts"}}</span>
							</div>
						{{/get}}
						<span class="hero-tv-stat-rule"></span>
						{{#get "tags" limit=1 filter="visibility:public"}}
							<div class="hero-tv-stat">
								<span class="hero-tv-stat-n">{{pagination.total}}</span>
								<span class="hero-tv-stat-l">{{t "Topics"}}</span>
							</div>
						{{/get}}
					</div>

					<div class="hero-tv-ctas">
						{{#if @site.members_enabled}}
							<a
								class="button hero-tv-btn-solid"
								href="{{#match (t "/signup/") "!=" "false"}}{{t "/signup/"}}{{else}}#/portal/signup{{/match}}"
							>
								<span class="label">{{t "Subscribe"}}</span>
								{{> "icons/arrow-narrow-right"}}
							</a>
						{{/if}}

						<button class="button button-transparent hero-tv-btn-outline" type="button" data-play>
							{{> "icons/play"}}
							<span class="label">{{t "Watch my story"}}</span>
						</button>
					</div>
				</div>

				<div class="hero-tv-photo-wrap">
					{{#get "authors" limit=1 include="count.posts" order="count.posts DESC"}}
						{{#if authors}}
							{{#foreach authors}}
								<div class="hero-tv-photo-rel">
									<div class="hero-tv-photo">
										{{#if ../feature_image}}
											{{> "components/image" fast=true size="600" src=../feature_image alt=../feature_image_alt altElse=../title}}
										{{else if profile_image}}
											{{> "components/image" fast=true size="600" src=profile_image alt=name}}
										{{else}}
											<span class="hero-tv-photo-ph">{{name.[0]}}</span>
										{{/if}}
									</div>

									<div class="hero-tv-social">
										{{> "components/social-links-author"}}
									</div>
								</div>
							{{/foreach}}
						{{/if}}
					{{/get}}
				</div>
			</div>
		</div>

		{{!-- Video layer: takes over the same card in place (CRT power-on/off), never a separate popup. --}}
		<div class="hero-tv-video-layer">
			<div class="hero-tv-video-frame" data-hero-video-frame data-video-id="ecOkmTD7KhU">
				<img class="hero-tv-video-poster" src="https://i.ytimg.com/vi/ecOkmTD7KhU/maxresdefault.jpg" alt="" loading="lazy">
			</div>

			<div class="hero-tv-veil"></div>
			<div class="hero-tv-poweron"></div>
			<div class="hero-tv-vscan"></div>

			<div class="hero-tv-controls">
				<button class="hero-tv-control-btn" type="button" data-close>
					{{> "icons/x-close"}}
					{{t "Close"}}
				</button>
			</div>
		</div>
	</section>
{{/if}}
