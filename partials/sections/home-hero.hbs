{{!-- 
    PARTIAL: sections/hero.hbs
    DESIGN: SEO-Friendly, Pure CSS Floating Badges, Tight Grid Background, 12-Item Bento
--}}

{{#if hide_title}}
    <h1 class="screen-reader-text">{{title}}</h1>
{{else}}
    <style>
        /* === 1. BACKGROUND & LAYOUT === */
        .sw-hero-section {
            position: relative;
            padding: var(--spacing-9) 0 var(--spacing-11);
            overflow: hidden;
        }

        /* Tighter Grid Pattern */
        .sw-hero-bg {
            position: absolute;
            inset: 0;
            z-index: 0;
            pointer-events: none;
            background-image: 
                linear-gradient(to right, var(--color-border) 1px, transparent 1px),
                linear-gradient(to bottom, var(--color-border) 1px, transparent 1px);
            background-size: 24px 24px; /* Smaller squares */
            mask-image: radial-gradient(ellipse at top center, black 0%, transparent 80%);
            -webkit-mask-image: radial-gradient(ellipse at top center, black 0%, transparent 80%);
            opacity: 0.6;
        }

        .sw-container {
            position: relative;
            z-index: 1;
            margin: 0 auto;
            padding: 0 var(--layout--padding);
        }

        .sw-hero-grid {
            display: grid;
            grid-template-columns: 1.15fr 0.85fr;
            gap: var(--spacing-10);
            align-items: center;
        }

        /* === 2. CONTENT COLUMN (LEFT) === */
        .sw-content {
            display: flex;
            flex-direction: column;
            z-index: 2;
        }

        /* Semantic Meta Stack */
        .sw-meta-stack {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-bottom: var(--spacing-7);
            border-left: 2px solid var(--ghost-accent-color);
            padding-left: 16px;
        }
        
        .sw-meta-item {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 0.95rem;
            font-weight: 500;
            color: var(--color-secondary);
        }
        
        .sw-meta-item strong { color: var(--color-contrast); font-weight: 700; }
        .sw-meta-item svg { width: 16px; height: 16px; color: var(--ghost-accent-color); flex-shrink: 0; }

        .sw-title {
            font-size: clamp(2.8rem, 5vw, 4rem);
            font-weight: 800;
            line-height: 1.1;
            letter-spacing: -0.02em;
            color: var(--color-contrast);
            margin-bottom: var(--spacing-5);
        }

        .sw-bio {
            font-size: 1.15rem;
            color: var(--color-secondary);
            line-height: 1.6;
            margin-bottom: var(--spacing-8);
            max-width: 90%;
        }

        /* Actions */
        .sw-actions {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: var(--spacing-5);
            margin-bottom: var(--spacing-8);
        }
        .sw-actions .form-subscribe { margin: 0; max-width: 320px; flex: 1 1 250px; }
        
        .sw-btn-video {
            display: flex; align-items: center; gap: 8px;
            height: 3.125rem; padding: 0 24px;
            border-radius: 30px; background: var(--color-background-100);
            border: 1px solid var(--color-border); color: var(--color-contrast);
            cursor: pointer; font-weight: 600; font-size: var(--font-small);
            transition: all 0.2s ease; white-space: nowrap;
        }
        .sw-btn-video:hover { background: var(--color-background-200); transform: translateY(-2px); border-color: var(--color-contrast); }

        .sw-socials-wrapper { margin-top: 10px; }

        /* === 3. IMAGE & FLOATING BADGES (RIGHT) === */
        .sw-media {
            position: relative;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .sw-image-wrapper {
            position: relative;
            width: 100%;
            max-width: 420px;
            aspect-ratio: 4/5;
            z-index: 2;
        }

        .sw-hero-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: var(--radius-5);
            box-shadow: 0 20px 40px -10px rgba(0,0,0,0.15);
            position: relative;
            z-index: 2;
        }

        /* Pure CSS Floating Badges */
        .sw-badge {
            position: absolute;
            background: var(--color-background-100);
            border: 1px solid var(--color-border);
            padding: 12px 16px;
            border-radius: 12px;
            display: flex;
            flex-direction: column;
            white-space: nowrap;
            box-shadow: var(--shadow);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            z-index: 3; /* Always in front of image */
        }

        /* Background blur fallback for unsupported browsers */
        @supports not (backdrop-filter: blur(10px)) {
            .sw-badge { background: var(--color-background); }
        }

        .sw-badge strong { font-size: 1.1rem; color: var(--color-contrast); line-height: 1.2; font-weight: 800; }
        .sw-badge span { font-size: 0.75rem; color: var(--color-secondary); font-weight: 600; text-transform: uppercase; }

        /* Fixed positions + smooth keyframe float animations */
        .badge-1 { top: 5%; left: -15%; animation: float-vertical 6s ease-in-out infinite; }
        .badge-2 { bottom: 15%; right: -20%; animation: float-vertical 7s ease-in-out infinite reverse; }
        .badge-3 { bottom: -5%; left: 10%; animation: float-horizontal 8s ease-in-out infinite; }

        @keyframes float-vertical {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-15px); }
        }
        @keyframes float-horizontal {
            0%, 100% { transform: translateX(0); }
            50% { transform: translateX(-15px); }
        }

        /* === 4. MASSIVE BENTO QUICK LINKS === */
        .sw-bento-grid {
            margin-top: 80px;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
            grid-auto-rows: 140px;
            gap: 16px;
        }

        @media (min-width: 992px) {
            .sw-bento-grid { grid-template-columns: repeat(5, 1fr); }
            .card-xl { grid-column: span 2; grid-row: span 2; }
            .card-wide { grid-column: span 2; }
        }

        .sw-bento-card {
            background: var(--color-background-100);
            border: 1px solid var(--color-border);
            border-radius: var(--radius-4);
            padding: 20px;
            text-decoration: none;
            color: var(--color-contrast);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            transition: transform 0.2s ease, background 0.2s ease;
            position: relative;
        }
        
        .sw-bento-card:hover {
            transform: translateY(-4px);
            background: var(--color-background-200);
            border-color: var(--color-contrast);
            box-shadow: var(--shadow);
        }

        .sw-bento-icon {
            width: 32px; height: 32px;
            color: var(--ghost-accent-color);
        }

        .sw-bento-text h3 { font-size: 1.05rem; margin: 0; font-weight: 700; line-height: 1.2; }
        .sw-bento-text p { font-size: 0.8rem; margin: 6px 0 0; color: var(--color-secondary); line-height: 1.4; }

        .card-xl .sw-bento-text h3 { font-size: 1.5rem; font-family: var(--font-family-headings); margin-bottom: 8px; }
        .card-xl .sw-bento-text p { font-size: 0.95rem; }
        .card-xl .sw-bento-icon { width: 40px; height: 40px; }

        /* === 5. VIDEO MODAL === */
        .sw-video-modal {
            position: fixed; inset: 0; z-index: 999999;
            display: flex; align-items: center; justify-content: center;
            opacity: 0; visibility: hidden; transition: 0.3s ease;
        }
        .sw-video-modal.is-open { opacity: 1; visibility: visible; }
        .sw-modal-bg { position: absolute; inset: 0; background: var(--color-overlay); backdrop-filter: blur(8px); cursor: pointer; }
        .sw-modal-content {
            position: relative; width: 90%; max-width: 900px; z-index: 1;
            transform: scale(0.95); transition: transform 0.3s cubic-bezier(0.2, 1, 0.2, 1);
        }
        .sw-video-modal.is-open .sw-modal-content { transform: scale(1); }
        .sw-modal-close {
            position: absolute; top: -45px; right: 0; background: transparent; border: none; 
            color: #fff; cursor: pointer; padding: 5px; opacity: 0.7; transition: 0.2s;
        }
        .sw-modal-close:hover { opacity: 1; transform: scale(1.1); }
        .sw-video-wrap {
            position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden;
            border-radius: var(--radius-4); background: #000; box-shadow: 0 30px 60px rgba(0,0,0,0.5);
        }
        .sw-video-wrap iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: 0; }

        /* === 6. RESPONSIVE DESIGN === */
        @media (max-width: 991px) {
            .sw-hero-grid { 
                grid-template-columns: 1fr; gap: 60px; 
                display: flex; flex-direction: column-reverse; /* Image on top */
            }
            .sw-media { padding: 0; max-width: 440px; margin: 0 auto; width: 100%; }
            .sw-content { align-items: flex-start; }
            
            /* Keep badges inside the screen */
            .badge-1 { left: -10px; top: -10px; }
            .badge-2 { right: -10px; bottom: 20%; }
            .badge-3 { left: 5%; bottom: -15px; }

            .sw-actions .form-subscribe { max-width: 100%; }
            .sw-btn-video { justify-content: center; width: 100%; max-width: 320px; }
        }

        @media (max-width: 540px) {
            .sw-bento-grid { grid-template-columns: repeat(2, 1fr); }
            .card-xl, .card-wide { grid-column: span 2; }
            .sw-title { font-size: 2.6rem; }
            .badge-1, .badge-2, .badge-3 { padding: 8px 12px; }
            .sw-badge strong { font-size: 0.95rem; }
        }
    </style>

