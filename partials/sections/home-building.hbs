{{!--
	HOME · Currently building (tools / things in progress)
	================================================================
	#building posts. Renders nothing if there are none.
--}}
{{#get "posts" include="tags" filter="tag:hash-building" order="published_at desc" limit="4" as |building|}}
	{{#if building}}
	<section class="section home-building">
		<div class="home-head">
			<div>
				<span class="home-eyebrow">{{t "In the workshop"}}</span>
				<h2 class="home-head-title">{{t "Currently building"}}</h2>
				<p class="home-head-desc">{{t "Side projects and tools I'm actively working on."}}</p>
			</div>
		</div>

		<ul class="home-building-list">
			{{#foreach building}}
			<li class="home-building-item">
				<a class="home-building-link" href="{{url}}">
					<span class="home-building-status"><span class="home-building-pulse"></span>{{t "In progress"}}</span>
					<h3 class="home-building-name">{{title}}</h3>
					{{#if excerpt}}<p class="home-building-text">{{excerpt words="22"}}</p>{{/if}}
					{{#if primary_tag}}<span class="home-building-tag">{{primary_tag.name}}</span>{{/if}}
				</a>
			</li>
			{{/foreach}}
		</ul>
	</section>
	{{/if}}
{{/get}}
