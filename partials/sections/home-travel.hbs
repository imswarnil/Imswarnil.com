{{!--
	HOME · Travel — globe-styled places visited
	================================================================
	A decorative CSS globe beside a cloud of destination chips built from
	#travel posts (primary tag = the place). Renders nothing if empty.
--}}
{{#get "posts" include="tags" filter="tag:hash-travel" order="published_at desc" limit="14" as |trips|}}
	{{#if trips}}
	<section class="section home-travel">
		<div class="home-travel-inner">
			<div class="home-travel-intro">
				<span class="home-travel-eyebrow">{{> "icons/glob"}} {{t "Travel"}}</span>
				<h2 class="home-travel-title">{{t "Places I've been"}}</h2>
				<p class="home-travel-text">{{t "A growing map of trips — tap a place to read the story behind it."}}</p>
				<a class="button button-sm" href="/travel/">{{t "All trips"}} {{> "icons/arrow-narrow-right"}}</a>
			</div>

			<div class="home-travel-globe">
				<div class="home-travel-sphere" aria-hidden="true">
					<span class="home-travel-ring"></span>
					<span class="home-travel-ring"></span>
					<span class="home-travel-ring"></span>
				</div>
				<ul class="home-travel-places">
					{{#foreach trips}}
					<li>
						<a class="home-travel-pin" href="{{url}}">
							<span class="home-travel-dot"></span>
							{{#if primary_tag}}{{primary_tag.name}}{{else}}{{title}}{{/if}}
						</a>
					</li>
					{{/foreach}}
				</ul>
			</div>
		</div>
	</section>
	{{/if}}
{{/get}}
