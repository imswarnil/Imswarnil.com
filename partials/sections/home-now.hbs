{{!--
	HOME · Now snapshot
	================================================================
	Pulls the Ghost page with slug "now" (excerpt) + the latest #timeline
	entries. Renders nothing if there's no "now" page.
--}}
{{#get "pages" slug="now" limit="1" as |nowpage|}}
	{{#foreach nowpage}}
	<section class="section home-now">
		<div class="home-now-card">
			<span class="home-now-badge"><span class="home-now-dot"></span>{{t "Now"}}</span>
			<h2 class="home-now-title">{{t "What I'm up to right now"}}</h2>
			{{#if custom_excerpt}}<p class="home-now-text">{{custom_excerpt}}</p>{{else}}<p class="home-now-text">{{excerpt words="42"}}</p>{{/if}}
			<a class="button button-sm home-now-link" href="{{url}}">{{t "Read the full Now page"}} {{> "icons/arrow-narrow-right"}}</a>
		</div>

		{{#get "posts" include="tags" filter="tag:hash-timeline" order="published_at desc" limit="4" as |entries|}}
			{{#if entries}}
			<ul class="home-now-timeline">
				{{#foreach entries}}
				<li>
					<time datetime="{{date format="YYYY-MM-DD"}}">{{date format=(t "MMM D")}}</time>
					<a href="{{url}}">{{title}}</a>
				</li>
				{{/foreach}}
			</ul>
			{{/if}}
		{{/get}}
	</section>
	{{/foreach}}
{{/get}}
