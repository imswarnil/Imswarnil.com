{{!--
	HOME · Things I use (products / tools toolkit)
	================================================================
	#product posts rendered as a compact icon grid. Renders nothing if empty.
--}}
{{#get "posts" include="tags" filter="tag:hash-product" order="published_at desc" limit="10" as |uses|}}
	{{#if uses}}
	<section class="section home-uses">
		<div class="section-head">
			<h2 class="section-title">{{t "Things I use"}}</h2>
			<a class="section-button button button-sm button-background-200" href="/products/">
				<span class="label">{{t "Full toolkit"}}</span>{{> "icons/arrow-narrow-right"}}
			</a>
		</div>

		<ul class="home-uses-grid">
			{{#foreach uses}}
			<li>
				<a class="home-uses-item" href="{{url}}">
					<span class="home-uses-icon{{^if feature_image}} home-uses-icon-fallback{{/if}}">
						{{#if feature_image}}<img src="{{feature_image}}" alt="{{title}}" loading="lazy">{{else}}{{title}}{{/if}}
					</span>
					<span class="home-uses-body">
						<span class="home-uses-name">{{title}}</span>
						{{#if primary_tag}}<span class="home-uses-cat">{{primary_tag.name}}</span>{{/if}}
					</span>
				</a>
			</li>
			{{/foreach}}
		</ul>
	</section>
	{{/if}}
{{/get}}
