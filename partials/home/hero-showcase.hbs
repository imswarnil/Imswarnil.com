{{!-- The showcase — a square photo that becomes the film.

     It opens as a 1:1 frame: the still, an icon, and the quote that says what
     this place is. Press "Watch my story" and the frame reshapes 1:1 → 16:9 and
     the video plays inside the same frame.

     ONE {{#get}} in here, on purpose. This partial used to run three (project,
     series, trip) and hero-do ran seven more — eleven API round-trips to paint
     a hero, which is what put the homepage on the floor. Everything that isn't
     the film is now static markup. --}}
<div class="sc" id="sc" data-state="story">

	<div class="sc-stage" id="sc-stage" style="--sc-ar:1/1" data-ratio="1:1">

		{{!-- 1 · the poster: still + one glassy play control, nothing else.
		     The long quote used to live here and collided with the play button;
		     the headline already carries the message, so the poster just needs
		     to look like a film waiting to be played. --}}
		<div class="sc-slide sc-story is-active" id="sc-story">
			<img src="{{asset "images/hero-square.svg"}}" width="1000" height="1000"
				fetchpriority="high" decoding="async" alt="Swarnil, framed" class="sc-story-img" />
			<span class="sc-scrim" aria-hidden="true"></span>

			{{!-- play, centred on the frame like a real player --}}
			<button type="button" class="sc-play" id="sc-watch" aria-label="Play — my story, the frame opens 1:1 to 16:9">
				<span class="sc-play-ring" aria-hidden="true">{{> "icons/play" class="h-6 w-6"}}</span>
			</button>

			{{!-- lower-third caption, clear of the button --}}
			<div class="sc-caption">
				<span class="sc-caption-title">{{> "icons/film" class="h-3.5 w-3.5"}} Watch my story</span>
				<span class="sc-caption-meta">1:1 → 16:9</span>
			</div>
		</div>

		{{!-- 2 · the film: 16:9, plays in the same frame --}}
		<div class="sc-slide sc-film" data-final>
			{{#get "posts" filter="tag:hash-trip" limit="1" order="featured desc,published_at desc" as |film|}}
				{{#if film.length}}
					{{#foreach film}}
						{{> "home/hero-frames" isFilm=true kicker="Now playing"}}
					{{/foreach}}
				{{else}}
					{{> "home/hero-frames" kicker="Now playing"}}
				{{/if}}
			{{/get}}
		</div>
	</div>

</div>

<script>
	(function () {
		var sc = document.getElementById('sc');
		if (!sc) return;
		var stage = document.getElementById('sc-stage');
		var watch = document.getElementById('sc-watch');
		var story = document.getElementById('sc-story');
		var film = sc.querySelector('.sc-film');
		var reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		/* square → widescreen, then roll the tape in the same frame */
		var opened = false;
		watch.addEventListener('click', function () {
			if (opened) return;
			opened = true;
			sc.setAttribute('data-state', 'film');
			stage.style.setProperty('--sc-ar', '16/9');
			stage.setAttribute('data-ratio', '16:9');
			story.classList.remove('is-active');
			film.classList.add('is-active');

			/* let the frame finish reshaping before the video starts, so the
			   two motions read as one gesture rather than a collision */
			setTimeout(function () {
				var play = document.getElementById('vf-play');
				if (play) play.click();
			}, reduced ? 0 : 620);
		});
	})();
</script>
