{{!-- The stage — the featured film, held in a viewfinder card.

     Same visual language as the frame in the headline: accent hairline, four
     crop marks, a ratio chip. The CRT cabinet is gone; the frame IS the chrome
     now, and the tube texture (scanlines, VHS bleed) sits inside it.

     It's a facade: nothing is requested from YouTube until you press play, so
     the hero stays off the critical path and off the third-party-JS budget.
     Playback has real controls — play/pause and mute — because a hero that
     autoplays at you with no way to stop it is a hero people bounce off.

     Params: kicker (what's playing) and isFilm. NOTHING else — when called from
     inside {{#foreach}} this partial inherits the post context and reads
     {{title}} / {{url}} / {{feature_image}} itself. Do not go back to passing
     `link=url`: {{url}} is a helper, not a property, so a hash param can't call
     it — it throws, and a throwing partial makes Handlebars discard the entire
     enclosing block without a word. --}}
<figure class="vf animate-fade-up" id="hero-vf" style="animation-delay:.3s">
	<div class="vf-card">
		<i class="vf-mark"></i><i class="vf-mark"></i><i class="vf-mark"></i><i class="vf-mark"></i>
		<span class="vf-ratio" aria-hidden="true">16:9</span>

		<div class="vf-screen">
			{{!-- the still: always painted, so something is on screen before the
			     embed resolves and if it never does (blocked, offline) --}}
			{{#if isFilm}}
				{{#if feature_image}}
					<img src="{{img_url feature_image size="1600"}}" width="1280" height="720" fetchpriority="high" decoding="async"
						alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" class="vf-still" />
				{{else}}
					<img src="{{asset "images/hero-fallback.svg"}}" width="1280" height="720" fetchpriority="high" decoding="async"
						alt="{{title}}" class="vf-still" />
				{{/if}}
			{{else}}
				<img src="{{asset "images/hero-fallback.svg"}}" width="1280" height="720" fetchpriority="high" decoding="async"
					alt="Swarnil — viewfinder frame" class="vf-still" />
			{{/if}}

			<div class="vf-video" id="vf-video"></div>
			<div class="vf-scanlines" aria-hidden="true"></div>
			<div class="vf-glare" aria-hidden="true"></div>
			<div class="vf-tear" id="vf-tear" aria-hidden="true"></div>

			{{!-- big play target, before the tape rolls --}}
			<button type="button" class="vf-play" id="vf-play" aria-label="Play {{#if isFilm}}{{title}}{{else}}the showreel{{/if}}">
				<span class="vf-play-ring">{{> "icons/play" class="h-5 w-5"}}</span>
				<span class="vf-play-label">Play</span>
			</button>
		</div>

		{{!-- controls: real play/pause + unmute, reachable once it's rolling --}}
		<div class="vf-bar">
			<button type="button" class="vf-btn" id="vf-toggle" aria-label="Pause" hidden>
				<span data-icon-pause>{{> "icons/pause" class="h-3.5 w-3.5"}}</span>
				<span data-icon-play hidden>{{> "icons/play" class="h-3 w-3"}}</span>
			</button>
			{{!-- autoplay is forced-muted by browsers; one tap turns sound on --}}
			<button type="button" class="vf-btn vf-btn-sound" id="vf-sound" aria-label="Unmute" hidden>
				<span data-icon-muted>{{> "icons/volume-x" class="h-3.5 w-3.5"}}</span>
				<span data-icon-sound hidden>{{> "icons/volume" class="h-3.5 w-3.5"}}</span>
			</button>
			<span class="vf-state" id="vf-state">{{#if kicker}}{{kicker}}{{else}}Now playing{{/if}}</span>
			<span class="vf-tc" id="vf-tc">0:00</span>
		</div>
	</div>
	<figcaption class="sr-only">{{#if isFilm}}{{title}}{{else}}Swarnil's showreel{{/if}}</figcaption>
</figure>

<script>
	(function () {
		var root = document.getElementById('hero-vf');
		if (!root) return;
		var play = document.getElementById('vf-play');
		var slot = document.getElementById('vf-video');
		var tear = document.getElementById('vf-tear');
		var bar = document.getElementById('vf-toggle');
		var sound = document.getElementById('vf-sound');
		var state = document.getElementById('vf-state');
		var tc = document.getElementById('vf-tc');
		var reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		if (reduced) root.classList.add('no-fx');

		var player = null, ready = false, playing = false, muted = true, secs = 0, timer = null;

		function setMuted(on) {
			muted = on;
			if (!sound) return;
			sound.setAttribute('aria-label', on ? 'Unmute' : 'Mute');
			sound.querySelector('[data-icon-muted]').hidden = !on;
			sound.querySelector('[data-icon-sound]').hidden = on;
		}

		function pad(n) { return (n < 10 ? '0' : '') + n; }
		function tick() { secs++; tc.textContent = Math.floor(secs / 60) + ':' + pad(secs % 60); }
		function clock(on) {
			clearInterval(timer);
			if (on) timer = setInterval(tick, 1000);
		}

		function setPlaying(on) {
			playing = on;
			root.classList.toggle('is-paused', !on);
			bar.setAttribute('aria-label', on ? 'Pause' : 'Play');
			bar.querySelector('[data-icon-pause]').hidden = !on;
			bar.querySelector('[data-icon-play]').hidden = on;
			state.textContent = on ? 'Now playing' : 'Paused';
			clock(on);
		}

		/* The iframe API gives us real play/pause instead of guessing. It's only
		   fetched after the first click, so the idle hero costs nothing. */
		function loadAPI(then) {
			if (window.YT && window.YT.Player) return then();
			var prev = window.onYouTubeIframeAPIReady;
			window.onYouTubeIframeAPIReady = function () {
				if (typeof prev === 'function') prev();
				then();
			};
			if (!document.querySelector('script[data-yt-api]')) {
				var s = document.createElement('script');
				s.src = 'https://www.youtube.com/iframe_api';
				s.setAttribute('data-yt-api', '');
				document.head.appendChild(s);
			}
		}

		function start() {
			root.classList.add('is-live');
			if (!root.classList.contains('no-fx')) {
				tear.classList.add('is-tearing');
				setTimeout(function () { tear.classList.remove('is-tearing'); }, 900);
			}
			bar.hidden = false;
			if (sound) { sound.hidden = false; setMuted(true); }

			var mount = document.createElement('div');
			slot.appendChild(mount);

			loadAPI(function () {
				player = new YT.Player(mount, {
					videoId: 'ecOkmTD7KhU',
					playerVars: {
						autoplay: 1, mute: 1, loop: 1, playlist: 'ecOkmTD7KhU',
						controls: 0, modestbranding: 1, rel: 0, showinfo: 0,
						iv_load_policy: 3, disablekb: 1, fs: 0, playsinline: 1
					},
					events: {
						onReady: function () {
							ready = true;
							root.classList.add('is-rolling');
							setPlaying(true);
						},
						onStateChange: function (e) {
							if (e.data === YT.PlayerState.PLAYING) setPlaying(true);
							else if (e.data === YT.PlayerState.PAUSED) setPlaying(false);
						}
					}
				});
			});
		}

		play.addEventListener('click', start);

		bar.addEventListener('click', function () {
			if (!ready || !player) return;
			if (playing) player.pauseVideo();
			else player.playVideo();
		});

		/* unmute/mute — the tap IS the user gesture browsers require for sound */
		if (sound) {
			sound.addEventListener('click', function () {
				if (!ready || !player) return;
				if (muted) {
					player.unMute();
					if (player.setVolume) player.setVolume(100);
					if (!playing && player.playVideo) player.playVideo();
					setMuted(false);
				} else {
					player.mute();
					setMuted(true);
				}
			});
		}

		/* Stop the tape when it scrolls away — nobody wants audio-less video
		   burning battery behind them. */
		if ('IntersectionObserver' in window) {
			var io = new IntersectionObserver(function (entries) {
				entries.forEach(function (e) {
					if (!ready || !player) return;
					if (!e.isIntersecting && playing) player.pauseVideo();
				});
			}, { threshold: 0.15 });
			io.observe(root);
		}
	})();
</script>
