{{!-- Hero media — three typed windows, different sizes, kept simple and static:
     main camcorder monitor; typed collection cards are added by hero.hbs.
     Params: frame (poster still), polaroid (unused here), altText. --}}
<div class="relative">
	{{!-- Main frame: camcorder monitor --}}
	<figure class="hero-frame relative overflow-hidden rounded-3xl border border-line bg-mist shadow-lift animate-fade-up" style="animation-delay:.3s">
		<div class="relative aspect-[4/3] sm:aspect-square">
			{{#if frame}}
				<img src="{{img_url frame size="1000"}}" width="1000" height="1000" fetchpriority="high" alt="{{#if altText}}{{altText}}{{else}}Hero media{{/if}}" class="absolute inset-0 h-full w-full object-cover" />
			{{else}}
				<div class="bg-cross absolute inset-0 flex items-center justify-center font-mono text-[10px] uppercase tracking-[0.3em] text-silver">your frame here</div>
			{{/if}}
			{{#if @custom.hero_video_url}}
				<video src="{{@custom.hero_video_url}}" {{#if frame}}poster="{{img_url frame size="1000"}}"{{/if}}
					autoplay muted loop playsinline preload="metadata"
					class="pointer-events-none absolute inset-0 h-full w-full object-cover"></video>
			{{else}}
				<iframe class="pointer-events-none absolute left-1/2 top-1/2 aspect-video h-[102%] w-auto -translate-x-1/2 -translate-y-1/2"
					style="min-width: 180%"
					src="https://www.youtube-nocookie.com/embed/ecOkmTD7KhU?autoplay=1&amp;mute=1&amp;loop=1&amp;playlist=ecOkmTD7KhU&amp;controls=0&amp;modestbranding=1&amp;playsinline=1&amp;rel=0"
					title="Showreel" loading="lazy" frameborder="0"
					allow="autoplay; encrypted-media; picture-in-picture"></iframe>
			{{/if}}

			{{!-- clean frame: just the inset ring --}}
			<div class="pointer-events-none absolute inset-0 rounded-3xl ring-1 ring-inset ring-ink/10" aria-hidden="true"></div>
		</div>
		<figcaption class="sr-only">{{#if altText}}{{altText}}{{else}}Hero media{{/if}}</figcaption>
	</figure>


</div>
