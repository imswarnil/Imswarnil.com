{{!-- Digital downloads & themes — posts tagged #shop. Themes float to the top
     via the public "themes" tag when present. --}}
<section class="reveal relative border-y border-line bg-mist/40 py-16" id="home-shop">
	<div class="bg-cross pointer-events-none absolute inset-0 opacity-60" aria-hidden="true"></div>
	<div class="container-site relative">
		{{> "utility/section-head"
			kicker="The merch table"
			title="Digital downloads & themes"
			sub="Things I made that you can take home. No shipping fees — electrons are free."
			actionUrl=(concat @site.url "/shop/") actionLabel="Browse the shop"}}

		{{#get "posts" filter="tag:hash-shop" limit="4" include="tags" as |goods|}}
			{{#if goods}}
			<div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-4" data-reveal-stagger="90">
				{{#foreach goods}}
				<a href="{{url}}" class="card-surface group flex flex-col overflow-hidden">
					<div class="relative aspect-[4/3] overflow-hidden border-b border-line bg-mist">
						{{#if feature_image}}
							<img src="{{img_url feature_image size="600"}}" alt="{{title}}" loading="lazy" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
						{{else}}
							<div class="bg-dots flex h-full w-full items-center justify-center">{{> "icons/download" class="text-silver"}}</div>
						{{/if}}
						{{#has tag="themes"}}
							<span class="absolute left-3 top-3 chip !border-transparent !bg-paper/90 backdrop-blur">{{> "icons/terminal" class="h-3 w-3"}} Theme</span>
						{{else}}
							<span class="absolute left-3 top-3 chip !border-transparent !bg-paper/90 backdrop-blur">{{> "icons/download" class="h-3 w-3"}} Download</span>
						{{/has}}
						{{#if featured}}<span class="absolute right-3 top-3 chip !border-transparent !bg-paper/90 backdrop-blur">{{> "icons/star" class="h-3 w-3"}} Best seller-ish</span>{{/if}}
					</div>
					<div class="flex flex-1 flex-col p-5">
						<h3 class="text-[15px] font-semibold leading-snug tracking-tight">{{title}}</h3>
						<p class="mt-2 line-clamp-2 text-sm leading-relaxed text-silver">{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{excerpt words="18"}}{{/if}}</p>
						<p class="mt-auto flex items-center gap-1.5 pt-4 font-mono text-[11px] uppercase tracking-[0.15em] text-silver transition group-hover:text-ink">Get it {{> "icons/arrow-up-right" class="h-3.5 w-3.5"}}</p>
					</div>
				</a>
				{{/foreach}}
			</div>
			{{else}}
			<p class="mt-8 rounded-2xl border border-dashed border-line p-10 text-center text-sm text-silver">Tag posts with <code class="rounded bg-mist px-1.5 py-0.5 font-mono text-xs">#shop</code> to stock the shelf. Inventory currently: vibes.</p>
			{{/if}}
		{{/get}}
	</div>
</section>
