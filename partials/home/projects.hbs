<section class="reveal relative border-y border-line bg-mist/40 py-16">
	<div class="bg-grid pointer-events-none absolute inset-0 opacity-60" aria-hidden="true"></div>
	<div class="container-site relative">
		<div class="flex items-end justify-between gap-4">
			<div>
				<p class="kicker">{{> "icons/terminal"}} The workbench</p>
				<h2 class="section-title mt-2">Selected projects</h2>
			</div>
			<a href="{{@site.url}}/projects/" class="btn-ghost shrink-0">All projects {{> "icons/arrow-right"}}</a>
		</div>

		{{#get "posts" filter="tag:hash-project" limit="3" include="tags" as |projects|}}
			{{#if projects}}
			<div class="mt-8 grid gap-6 md:grid-cols-3">
				{{#foreach projects}}
					{{> "cards/project"}}
				{{/foreach}}
			</div>
			{{else}}
			<p class="mt-8 rounded-2xl border border-dashed border-line p-10 text-center text-sm text-silver">Tag posts with <code class="rounded bg-mist px-1.5 py-0.5 font-mono text-xs">#project</code> to showcase them here.</p>
			{{/if}}
		{{/get}}
	</div>
</section>
