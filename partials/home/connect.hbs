{{!-- Work with me / cheer for me — collab, sponsorship and the bucket list,
     three doors into the same room. --}}
<section class="reveal relative py-16" id="home-connect">
	<div class="container-site">
		<div class="grid gap-4 md:grid-cols-3" data-reveal-stagger="100">
			<a href="{{@site.url}}/collab/" class="connect-tile group">
				<span class="connect-ico">{{> "icons/mic" class="h-5 w-5"}}</span>
				<strong>Let's collaborate</strong>
				<span>Videos, guest posts, product walkthroughs — if our audiences overlap, let's make something.</span>
				<em>Start a collab {{> "icons/arrow-right" class="h-3.5 w-3.5 transition group-hover:translate-x-1"}}</em>
			</a>
			<a href="{{@site.url}}/sponsor/" class="connect-tile group">
				<span class="connect-ico">{{> "icons/cash" class="h-5 w-5"}}</span>
				<strong>Sponsor me</strong>
				<span>Put your product in front of people who actually build. Honest reviews, real integrations, no scripts.</span>
				<em>See sponsor deck {{> "icons/arrow-right" class="h-3.5 w-3.5 transition group-hover:translate-x-1"}}</em>
			</a>
			<a href="{{@site.url}}/bucketlist/" class="connect-tile group">
				<span class="connect-ico">{{> "icons/trophy" class="h-5 w-5"}}</span>
				<strong>The bucket list</strong>
				<span>Everything I've promised myself I'll do — ticked off in public, one absurd goal at a time.</span>
				<em>Watch me tick them {{> "icons/arrow-right" class="h-3.5 w-3.5 transition group-hover:translate-x-1"}}</em>
			</a>
		</div>
	</div>
</section>
