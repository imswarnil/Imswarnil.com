{{!-- Experiences — moments that don't fit a resume bullet. Horizontal rail
     of #experience posts; hidden entirely when none exist. --}}
{{#get "posts" filter="tag:hash-experience" limit="6" order="published_at desc" as |exps|}}
	{{#if exps}}
	<section class="reveal relative py-16" id="home-experiences">
		<div class="container-site">
			{{> "components/section-head"
				kicker="Lived, not listed"
				title="Experiences"
				sub="Talks, treks, launches and the occasional beautiful failure — the stories behind the CV."
				actionUrl=(concat @site.url "/experiences/") actionLabel="All experiences"}}
		</div>
		<div class="no-scrollbar mt-8 overflow-x-auto pb-4 [touch-action:pan-x_pan-y]" data-hscroll>
			<div class="container-site">
				<div class="flex w-max snap-x gap-5 pr-8" data-reveal-stagger="80">
					{{#foreach exps}}
					{{> "cards/experience" class="w-[18rem] shrink-0 snap-start sm:w-[20rem]"}}
					{{/foreach}}
				</div>
			</div>
		</div>
	</section>
	{{/if}}
{{/get}}
