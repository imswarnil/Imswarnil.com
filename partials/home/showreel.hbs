{{!-- Showreel band — a tall, edge-to-edge cinematic video that autoplays on
     laptop AND mobile (muted + playsinline via the [data-yt-bg] facade in
     main.js) and parallaxes on scroll. A single quote sits dead-centre with a
     shaky, hand-scribbled vibration. The tag marquee renders directly below
     (home.hbs). Styles: pages/home.css (base) + layout/home.css (.showreel-quote,
     size overrides). --}}
<section class="showreel showreel-tall" id="home-showreel" aria-label="Showreel">
	<div class="showreel-media" id="showreel-media" data-yt-bg="ecOkmTD7KhU" aria-hidden="true">
		<img src="{{asset "images/hero-fallback.svg"}}" width="1280" height="720" alt="" class="showreel-poster" />
	</div>
	<div class="showreel-scrim showreel-scrim-center" aria-hidden="true"></div>

	<figure class="showreel-quote">
		<span class="showreel-mark" aria-hidden="true">&ldquo;</span>
		<blockquote class="showreel-line" aria-label="Curiosity is the whole personality.">
			<span class="showreel-shake" style="--i:0">Curiosity</span>
			<span class="showreel-shake" style="--i:1">is</span>
			<span class="showreel-shake" style="--i:2">the</span>
			<span class="showreel-shake" style="--i:3">whole</span>
			<span class="showreel-shake" style="--i:4">personality.</span>
		</blockquote>
		<figcaption class="showreel-cite">Documenting the journey — one frame at a time.</figcaption>
		<div class="showreel-cta">
			<a href="https://www.youtube.com/@imswarnil" target="_blank" rel="noopener" class="btn-primary btn-sm">{{> "icons/youtube" class="h-3.5 w-3.5"}} Watch on YouTube</a>
			<a href="{{@site.url}}/videos/" class="btn-ghost btn-sm !text-white !border-white/30 hover:!bg-white/10">All videos {{> "icons/arrow-right" class="h-3.5 w-3.5"}}</a>
		</div>
	</figure>

	<script>
		(function () {
			var reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			var sec = document.getElementById('home-showreel');
			var media = document.getElementById('showreel-media');
			if (!sec || !media || reduced) return;
			var raf = null;
			function onScroll() {
				if (raf) return;
				raf = requestAnimationFrame(function () {
					raf = null;
					var r = sec.getBoundingClientRect();
					if (r.bottom < 0 || r.top > window.innerHeight) return; /* off-screen */
					var progress = (r.top + r.height / 2 - window.innerHeight / 2) / window.innerHeight;
					media.style.transform = 'translate3d(0,' + (progress * 16).toFixed(1) + '%,0)';
				});
			}
			window.addEventListener('scroll', onScroll, { passive: true });
			onScroll();
		})();
	</script>
</section>
