{{!-- Webseries — cinematic banner rows. Each series is a full-width poster with
     feature image (or video) background and text overlaid, Netflix billboard style. --}}
{{#get "posts" filter="tag:hash-webseries" limit="2" include="tags" as |series|}}
	{{#if series}}
	<section class="reveal relative py-16" id="home-webseries">
		<div class="container-site">
			{{> "components/section-head"
				kicker="Now streaming (on my own terms)"
				title="Webseries"
				sub="Long-form stories, shot like cinema, budgeted like a student film."
				actionUrl=(concat @site.url "/webseries/") actionLabel="All series"}}

			<div class="mt-8 space-y-6" data-reveal-stagger="140">
				{{#foreach series}}
				<a href="{{url}}" class="group relative block overflow-hidden rounded-[1.75rem] border border-line shadow-card transition-all duration-300 hover:shadow-lift">
					<div class="relative aspect-[16/8] sm:aspect-[16/6]">
						{{#if feature_image}}
							<img src="{{img_url feature_image size="1600"}}" width="1600" height="900" alt="{{title}}" loading="lazy"
								class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" />
						{{else}}
							<div class="bg-cross absolute inset-0 bg-ink"></div>
						{{/if}}
						<div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/35 to-transparent" aria-hidden="true"></div>
						<div class="absolute inset-0 flex flex-col justify-end p-6 sm:justify-center sm:p-12">
							<p class="flex items-center gap-2 font-mono text-[10px] uppercase tracking-[0.3em] text-white/70">{{> "icons/film" class="h-3.5 w-3.5"}} a swarnil original</p>
							<h3 class="mt-2 max-w-lg text-2xl font-bold leading-tight text-white sm:text-4xl [text-shadow:0_2px_12px_rgb(0_0_0/.4)]">{{title}}</h3>
							{{#if custom_excerpt}}<p class="mt-3 hidden max-w-md text-sm leading-relaxed text-white/80 sm:block">{{custom_excerpt}}</p>{{/if}}
							<div class="mt-5 flex items-center gap-3">
								<span class="btn !bg-white !px-5 !py-2 !text-sm !font-semibold !text-black transition group-hover:opacity-90">{{> "icons/play" class="h-4 w-4"}} Watch now</span>
								{{#get "posts" filter="tag:hash-episode+tag:{{primary_tag.slug}}" limit="1" as |e|}}
									<span class="font-mono text-[11px] uppercase tracking-[0.2em] text-white/70">{{plural pagination.total empty="trailer soon" singular="% episode" plural="% episodes"}}</span>
								{{/get}}
							</div>
						</div>
					</div>
				</a>
				{{/foreach}}
			</div>
		</div>
	</section>
	{{/if}}
{{/get}}
