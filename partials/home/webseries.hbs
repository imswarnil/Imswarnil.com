{{!-- Webseries — "Swarnil Originals". A short why-this-exists story first,
     then a Netflix-style rail of 9:16 posters (no rank numbers). Poster
     hover lifts + reveals the watch CTA. Copy is editable from Ghost Admin
     → Design (webseries_intro). --}}
{{#get "posts" filter="tag:hash-webseries" limit="8" include="tags" as |series|}}
	{{#if series}}
	<section class="reveal relative overflow-hidden border-y border-line py-16 ws-band" id="home-webseries">
		<div class="pointer-events-none absolute inset-0 opacity-[0.55]" aria-hidden="true" style="background-image: radial-gradient(80% 60% at 20% 0%, rgb(229 9 20 / 0.08), transparent 60%), radial-gradient(70% 50% at 90% 100%, rgb(229 9 20 / 0.06), transparent 60%)"></div>
		<div class="container-site relative">
			{{!-- the story before the shelf --}}
			<div class="grid items-end gap-8 lg:grid-cols-12">
				<div class="lg:col-span-7">
					<p class="kicker">{{> "icons/film" class="h-3.5 w-3.5"}} Swarnil Originals</p>
					<h2 class="section-title mt-2 text-balance">Why I make webseries</h2>
					<p class="mt-4 max-w-xl text-[15px] leading-relaxed text-silver">
						{{#if @custom.webseries_intro}}{{@custom.webseries_intro}}{{else}}I've always been fascinated by cinema — the titles, the tension, the tudum. So instead of waiting for a studio to call, I became one. These are my originals: I try, I shoot, I cut. Maybe they're not good yet. But they're mine, and every season gets better.{{/if}}
					</p>
				</div>
				<div class="flex flex-wrap items-center gap-3 lg:col-span-5 lg:justify-end">
					<a href="{{@site.url}}/webseries/" class="btn-primary">{{> "icons/tv" class="h-3.5 w-3.5"}} Browse all series</a>
					<a href="{{@custom.youtube_url}}" target="_blank" rel="noopener" class="btn-ghost">{{> "icons/youtube" class="h-3.5 w-3.5"}} On YouTube</a>
				</div>
			</div>

			{{!-- 9:16 poster rail --}}
			<div class="no-scrollbar mt-10 -mx-4 overflow-x-auto px-4 pb-4 [touch-action:pan-x_pan-y]" data-hscroll>
				<div class="flex w-max snap-x snap-mandatory gap-4 sm:gap-5" data-reveal-stagger="80">
					{{#foreach series}}
					<a href="{{url}}" class="ws-poster group snap-start" aria-label="Watch series: {{title}}">
						<span class="relative block aspect-[9/16] w-[11rem] overflow-hidden rounded-2xl border border-line bg-ink shadow-card transition-all duration-300 group-hover:-translate-y-2 group-hover:shadow-lift sm:w-[13rem]">
							{{#if feature_image}}
								<img src="{{img_url feature_image size="600"}}" width="600" height="1067" alt="{{title}}" loading="lazy" class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
							{{else}}
								<span class="bg-cross absolute inset-0 flex items-center justify-center bg-ink">{{> "icons/film" class="h-8 w-8 text-paper/40"}}</span>
							{{/if}}
							<span class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/20 to-black/25" aria-hidden="true"></span>
							<span class="absolute left-0 right-0 top-3 px-3 text-center font-mono text-[8px] font-bold uppercase tracking-[0.32em] text-white/80">A swarnil original</span>
							<span class="absolute inset-x-0 bottom-0 flex flex-col items-center p-4 text-center">
								<strong class="text-[15px] font-bold leading-tight text-white [text-shadow:0_2px_10px_rgb(0_0_0/.6)]">{{title}}</strong>
								{{#foreach tags visibility="public" limit="1"}}{{#get "posts" filter="tag:hash-episode+tag:{{slug}}" limit="1" as |e|}}
									<span class="mt-1.5 font-mono text-[9px] uppercase tracking-[0.2em] text-white/70">{{plural pagination.total empty="trailer soon" singular="% episode" plural="% episodes"}}</span>
								{{/get}}{{/foreach}}
								<span class="mt-3 inline-flex translate-y-2 items-center gap-1.5 rounded-full bg-white px-3.5 py-1.5 text-[11px] font-bold text-black opacity-0 shadow transition-all duration-300 group-hover:translate-y-0 group-hover:opacity-100">{{> "icons/play" class="h-3 w-3"}} Watch now</span>
							</span>
						</span>
					</a>
					{{/foreach}}

					{{!-- trailing "view all" poster --}}
					<a href="{{@site.url}}/webseries/" class="ws-poster group snap-start" aria-label="All webseries">
						<span class="relative flex aspect-[9/16] w-[11rem] flex-col items-center justify-center gap-3 overflow-hidden rounded-2xl border border-dashed border-line bg-mist/60 transition-all duration-300 group-hover:-translate-y-2 group-hover:bg-mist sm:w-[13rem]">
							{{> "icons/arrow-right" class="h-6 w-6 text-silver transition group-hover:translate-x-1 group-hover:text-ink"}}
							<span class="font-mono text-[10px] uppercase tracking-[0.2em] text-silver">All series</span>
						</span>
					</a>
				</div>
			</div>
		</div>
	</section>
	{{/if}}
{{/get}}
