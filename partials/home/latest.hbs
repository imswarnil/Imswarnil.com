{{!-- Latest on YouTube — Netflix-style ranked row of #video posts only,
     most recent first, big outlined numbers, view-all CTA. --}}
<section class="reveal relative overflow-hidden py-16" id="home-latest">
	<div class="container-site">
		{{> "components/section-head"
			kicker="Fresh uploads"
			title="Latest videos"
			sub="Most recent first — the algorithm here is just a calendar."
			actionUrl=(concat @site.url "/videos/") actionLabel="View all"}}
	</div>

	{{#get "posts" filter="tag:hash-video" limit="10" order="published_at desc" include="tags" as |latest|}}
		{{#if latest}}
		{{!-- vertical wheel scrolls the page (data-hscroll in main.js); horizontal
		     gesture scrolls the row. Big rank numbers peek from behind each frame.
		     Snap + arrow paging + progress make the rail actually navigable. --}}
		<div class="no-scrollbar mt-10 snap-x snap-proximity overflow-x-auto pb-6 [touch-action:pan-x_pan-y] [overscroll-behavior-x:contain]" id="latest-rail" data-rank-track data-hscroll>
			<div class="container-site">
				<div class="flex w-max items-end gap-8 pl-4 pr-8 sm:gap-12 sm:pl-8" data-reveal-stagger="70">
					{{#foreach latest}}
					<article class="rank-row-card group snap-start">
						<span class="rank-number" aria-hidden="true">{{@number}}</span>
						<a href="{{url}}" class="rank-row-frame block w-[15rem] shrink-0 sm:w-[18rem]" aria-label="Watch: {{title}}">
							<div class="relative aspect-video overflow-hidden rounded-xl border border-line bg-mist shadow-card transition-all duration-300 group-hover:-translate-y-1.5 group-hover:shadow-lift">
								{{#if feature_image}}
									<img src="{{img_url feature_image size="600"}}" width="600" height="338" alt="{{title}}" loading="lazy" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
								{{else}}
									<div class="bg-dots flex h-full w-full items-center justify-center">{{> "icons/play" class="text-silver"}}</div>
								{{/if}}
								<div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/10 to-transparent" aria-hidden="true"></div>
								<span class="absolute left-3 top-6 flex h-7 w-7 items-center justify-center rounded-full bg-white/90 text-black opacity-0 shadow transition duration-300 group-hover:opacity-100">{{> "icons/play" class="ml-0.5 h-3 w-3"}}</span>
								<span class="absolute bottom-2 right-2 rounded bg-black/75 px-1.5 py-0.5 font-mono text-[10px] font-semibold tabular-nums text-white" data-duration-tags="{{#foreach tags visibility="internal"}}{{slug}} {{/foreach}}" hidden></span>
								<div class="absolute inset-x-0 bottom-0 p-3">
									<h3 class="line-clamp-2 text-[13px] font-semibold leading-snug text-white [text-shadow:0_1px_4px_rgb(0_0_0/.5)]">{{title}}</h3>
									<p class="mt-0.5 font-mono text-[9px] text-white/70">{{date published_at format="DD MMM YYYY"}}</p>
								</div>
							</div>
						</a>
					</article>
					{{/foreach}}
				</div>
			</div>
		</div>

		{{!-- rail controls: paging arrows + scroll progress --}}
		<div class="container-site mt-2 flex items-center gap-3">
			<button type="button" class="icon-btn border border-line" data-rail-prev="#latest-rail" aria-label="Scroll back"><span class="inline-block rotate-180">{{> "icons/arrow-right"}}</span></button>
			<button type="button" class="icon-btn border border-line" data-rail-next="#latest-rail" aria-label="Scroll forward">{{> "icons/arrow-right"}}</button>
			<div class="relative h-0.5 flex-1 overflow-hidden rounded-full bg-line" aria-hidden="true">
				<span class="absolute inset-y-0 left-0 w-0 rounded-full bg-ink transition-[width] duration-200" data-rail-progress="#latest-rail"></span>
			</div>
		</div>

		<script>
			(function () {
				var rail = document.getElementById('latest-rail');
				if (!rail) return;
				function page(dir) {
					rail.scrollBy({ left: dir * Math.round(rail.clientWidth * 0.8), behavior: 'smooth' });
				}
				document.querySelectorAll('[data-rail-prev="#latest-rail"]').forEach(function (b) { b.addEventListener('click', function () { page(-1); }); });
				document.querySelectorAll('[data-rail-next="#latest-rail"]').forEach(function (b) { b.addEventListener('click', function () { page(1); }); });
				var bar = document.querySelector('[data-rail-progress="#latest-rail"]');
				if (bar) {
					var ticking = false;
					rail.addEventListener('scroll', function () {
						if (ticking) return;
						ticking = true;
						requestAnimationFrame(function () {
							var max = rail.scrollWidth - rail.clientWidth;
							bar.style.width = (max > 0 ? (rail.scrollLeft / max * 100) : 0) + '%';
							ticking = false;
						});
					}, { passive: true });
				}
			})();
		</script>
		{{/if}}
	{{/get}}
</section>
