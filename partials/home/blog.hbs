{{!-- Blog — bento grid: first post hero tile (2×2), the rest mixed tiles. --}}
<section class="reveal relative py-16" id="home-blog">
	<div class="container-site">
		{{> "utility/section-head"
			kicker="Field notes"
			title="From the blog"
			sub="Written to be useful, edited to be short."
			actionUrl=(concat @site.url "/blog/") actionLabel="All posts"}}

		{{#get "posts" filter="tag:hash-blog" limit="5" include="tags,authors" as |posts|}}
			{{#if posts}}
			<div class="mt-8 grid auto-rows-[minmax(7.5rem,auto)] grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4" data-reveal-stagger="90">
				{{#foreach posts}}
				{{#if @first}}
				{{!-- hero tile: 2×2 with image backdrop --}}
				<a href="{{url}}" class="group relative overflow-hidden rounded-2xl border border-line shadow-card transition-all duration-300 hover:shadow-lift sm:col-span-2 sm:row-span-2">
					{{#if feature_image}}
						<img src="{{img_url feature_image size="1000"}}" width="1000" height="750" alt="{{title}}" loading="lazy" class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105" />
						<span class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/25 to-transparent" aria-hidden="true"></span>
					{{else}}
						<span class="bg-dots absolute inset-0 bg-mist" aria-hidden="true"></span>
					{{/if}}
					<span class="relative flex h-full min-h-[16rem] flex-col justify-end p-6">
						{{#primary_tag}}<span class="mb-2 w-fit rounded bg-white/90 px-2 py-0.5 font-mono text-[9px] font-bold uppercase tracking-[0.15em] text-black">{{name}}</span>{{/primary_tag}}
						<strong class="max-w-md text-xl font-bold leading-snug {{#if feature_image}}text-white [text-shadow:0_2px_8px_rgb(0_0_0/.4)]{{/if}} sm:text-2xl">{{title}}</strong>
						<span class="mt-2 line-clamp-2 max-w-md text-sm leading-relaxed {{#if feature_image}}text-white/80{{else}}text-silver{{/if}}">{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{excerpt words="25"}}{{/if}}</span>
						<span class="mt-3 font-mono text-[10px] uppercase tracking-[0.18em] {{#if feature_image}}text-white/60{{else}}text-silver{{/if}}">{{date published_at format="DD MMM YYYY"}} · {{reading_time}}</span>
					</span>
				</a>
				{{else}}
				{{!-- small tiles: thumbnail, tag, title, excerpt, meta + read CTA --}}
				<a href="{{url}}" class="group card-surface relative flex flex-col overflow-hidden sm:col-span-1 {{#match @number 3}}lg:row-span-2{{/match}}">
					{{#if feature_image}}
					<span class="relative block {{#match @number 3}}aspect-[16/10]{{else}}aspect-[16/7]{{/match}} overflow-hidden border-b border-line bg-mist">
						<img src="{{img_url feature_image size="600"}}" width="600" height="338" alt="" loading="lazy" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
						{{#primary_tag}}<span class="absolute left-2.5 top-2.5 rounded bg-white/90 px-1.5 py-0.5 font-mono text-[9px] font-bold uppercase tracking-[0.12em] text-black">{{name}}</span>{{/primary_tag}}
					</span>
					{{/if}}
					<span class="flex flex-1 flex-col p-4">
						{{^feature_image}}{{#primary_tag}}<span class="chip mb-2 w-fit !py-0.5 !text-[10px]">{{name}}</span>{{/primary_tag}}{{/feature_image}}
						<strong class="block text-[14.5px] font-semibold leading-snug tracking-tight transition group-hover:underline group-hover:underline-offset-4">{{title}}</strong>
						<span class="mt-1.5 line-clamp-2 block text-[12.5px] leading-relaxed text-silver {{#match @number 3}}!line-clamp-4{{/match}}">{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{excerpt words="20"}}{{/if}}</span>
						<span class="mt-auto flex items-center justify-between pt-3 font-mono text-[10px] uppercase tracking-[0.15em] text-silver">
							<span>{{date published_at format="DD MMM"}} · {{reading_time}}</span>
							<span class="flex items-center gap-1 font-semibold transition group-hover:text-ink">Read {{> "icons/arrow-right" class="h-3 w-3 transition group-hover:translate-x-0.5"}}</span>
						</span>
					</span>
				</a>
				{{/if}}
				{{/foreach}}
			</div>
			{{else}}
			<p class="mt-8 rounded-2xl border border-dashed border-line p-10 text-center text-sm text-silver">Tag posts with <code class="rounded bg-mist px-1.5 py-0.5 font-mono text-xs">#blog</code> to publish them here.</p>
			{{/if}}
		{{/get}}
	</div>
</section>
