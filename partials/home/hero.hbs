{{!-- Hero — "Framed" style. Rule-of-thirds shell, pointer-following accent glow,
     camera HUD, morphing aspect-ratio frame around a rotating word (SEO-critical
     copy lives in the H1), floating 3D post windows + a dashed "that's me" arrow
     over the media stack. Tag marquee below pulls real topics. --}}
<section class="relative overflow-hidden pb-12 pt-6 sm:pt-8" id="hero">
	<div class="container-site relative">
		<div class="hero-shell" id="hero-shell">
			{{!-- camera HUD --}}
			<div class="hx-hud" aria-hidden="true">
				<span class="flex items-center justify-end gap-1.5"><i class="h-1.5 w-1.5 animate-ping rounded-full bg-red-500"></i> <b>REC</b></span>
				<span id="hx-hud-ratio">Frame 16:9</span>
			</div>

			<p class="hx-eyebrow animate-fade-in">Hi, I'm Swarnil — {{@custom.job_title}} @ <a href="{{@custom.workplace_url}}" target="_blank" rel="noopener" class="font-semibold text-ink hover:underline hover:underline-offset-4">{{@custom.workplace}}</a> · documenting life</p>

			<div class="grid items-center gap-10 lg:grid-cols-12 lg:gap-12">
				<div class="lg:col-span-7">
					{{!-- H1 carries the name + the signature line for SEO --}}
					<h1 class="hx-h1">
						<span class="block">Life looks better</span>
						<span class="block">when you frame the
							<span class="hx-frame" id="hx-frame" style="--hx-ar:16/9">
								<i></i><i></i><i></i><i></i>
								<span class="hx-word" id="hx-word">day</span>
								<span class="hx-ratio" id="hx-ratio">16:9</span>
							</span>
						</span>
						<em class="block not-italic text-silver">and crop out the noise. — Swarnil Singhai</em>
					</h1>

					<p class="mt-5 max-w-xl animate-fade-in text-[15px] leading-relaxed text-silver" style="animation-delay:.4s">
						{{@site.description}} Videos, projects, courses and travel diaries — made while actually doing the work, not just theorizing about it.
					</p>

					<div class="mt-8 flex flex-wrap items-center gap-3 animate-fade-up" style="animation-delay:.55s">
						<a href="{{@site.url}}/videos/" class="btn-primary btn-sm !px-4">{{> "icons/play" class="h-3.5 w-3.5"}} Watch my videos</a>
						<button type="button" class="btn-ghost btn-sm !px-4" data-modal-open="#subscribe-backdrop">{{> "icons/bell" class="h-3 w-3"}} Subscribe free</button>
						<span class="mx-1 hidden h-5 w-px bg-line sm:block" aria-hidden="true"></span>
						<span class="flex items-center gap-0.5">
							<a href="{{@custom.youtube_url}}" target="_blank" rel="noopener" class="icon-btn" aria-label="YouTube">{{> "icons/youtube"}}</a>
							<a href="https://github.com/{{@custom.github_repo}}" target="_blank" rel="noopener" class="icon-btn" aria-label="GitHub">{{> "icons/github"}}</a>
							<a href="https://linkedin.com/in/imswarnil" target="_blank" rel="noopener" class="icon-btn" aria-label="LinkedIn">{{> "icons/linkedin"}}</a>
							<a href="https://instagram.com/imswarnil" target="_blank" rel="noopener" class="icon-btn" aria-label="Instagram">{{> "icons/instagram"}}</a>
						</span>
					</div>

					{{> "home/hero-proof"}}
				</div>

				{{!-- Media: main camcorder frame + typed collection cards that reveal
				     around it when their word cycles in (work→VS Code, day→camcorder,
				     trip→map, story→notepad) --}}
				<div class="relative lg:col-span-5" id="hero-scene">
					{{#get "posts" filter="featured:true" limit="1" as |feat|}}
						{{#if feat}}
							{{#foreach feat}}
								{{> "home/hero-frames" frame=feature_image polaroid=@custom.hero_image_alt altText=title}}
							{{/foreach}}
						{{else}}
							{{> "home/hero-frames" frame=@custom.hero_image polaroid=@custom.hero_image_alt altText="Portrait"}}
						{{/if}}
					{{/get}}

					{{!-- badge pills around the video, one per collection --}}
					<a href="{{@site.url}}/videos/" class="hx-pill" style="--hx-tilt:-5deg; left:-0.9rem; top:-0.9rem">{{> "icons/play" class="h-3 w-3"}} videos</a>
					<a href="{{@site.url}}/projects/" class="hx-pill" style="--hx-tilt:4deg; right:-1.1rem; top:2.75rem">{{> "icons/code" class="h-3 w-3"}} projects</a>
					<a href="{{@site.url}}/travel/" class="hx-pill" style="--hx-tilt:-3deg; left:-1.2rem; bottom:3rem">{{> "icons/plane" class="h-3 w-3"}} travel</a>
					<a href="{{@site.url}}/blog/" class="hx-pill" style="--hx-tilt:5deg; right:-0.8rem; bottom:-0.9rem">{{> "icons/pen" class="h-3 w-3"}} blog</a>

				</div>
			</div>
		</div>
	</div>

	{{!-- Tag marquee — every public topic, clickable, pauses on hover --}}
	{{#get "tags" limit="24" include="count.posts" order="count.posts desc" as |topics|}}
	{{#if topics}}
	<div class="group/marquee relative mt-14 overflow-hidden border-y border-line bg-mist/50 py-2.5 fade-mask-x sm:mt-16">
		<div class="animate-marquee flex w-max items-center gap-8 whitespace-nowrap font-mono text-[11px] uppercase tracking-[0.25em] text-silver group-hover/marquee:[animation-play-state:paused]">
			{{#foreach topics}}
				<a href="{{url}}" class="transition hover:text-ink hover:underline hover:underline-offset-4">{{name}}</a><span aria-hidden="true">✦</span>
			{{/foreach}}
			{{#foreach topics}}
				<a href="{{url}}" aria-hidden="true" tabindex="-1" class="transition hover:text-ink hover:underline hover:underline-offset-4">{{name}}</a><span aria-hidden="true">✦</span>
			{{/foreach}}
		</div>
	</div>
	{{/if}}
	{{/get}}

	<script>
		(function () {
			var reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

			/* words mirror the collections; some reveal a card inside the frame */
			var words = ['day', 'work', 'trip', 'story', 'chaos'];
			var ratios = [
				{ ar: '16/9', label: '16:9' },
				{ ar: '1/1', label: '1:1' },
				{ ar: '4/3', label: '4:3' },
				{ ar: '21/9', label: '2.39:1' },
				{ ar: '3/4', label: '9:16' }
			];
			var frame = document.getElementById('hx-frame'),
				word = document.getElementById('hx-word'),
				chip = document.getElementById('hx-ratio'),
				hud = document.getElementById('hx-hud-ratio'),
				i = 0;
			function applyWord(w, r) {
				word.style.animation = 'none';
				void word.offsetWidth; /* restart the entrance animation */
				word.textContent = w;
				word.style.animation = '';
				frame.style.setProperty('--hx-ar', r.ar);
				chip.textContent = r.label;
				if (hud) hud.textContent = 'Frame ' + r.label;
			}
			if (!reduced && frame) {
				setInterval(function () {
					i++;
					applyWord(words[i % words.length], ratios[i % ratios.length]);
				}, 2600);
			}

			/* pointer-following accent glow on the shell */
			var shell = document.getElementById('hero-shell');
			if (shell && !reduced) {
				shell.addEventListener('pointermove', function (e) {
					var b = shell.getBoundingClientRect();
					shell.style.setProperty('--hx-mx', ((e.clientX - b.left) / b.width * 100) + '%');
					shell.style.setProperty('--hx-my', ((e.clientY - b.top) / b.height * 100) + '%');
				});
			}
		})();
	</script>
</section>
