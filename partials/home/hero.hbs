{{!-- Hero — a statement + a screen, over an information band.

     The old design stacked six blocks in one tall left column and read as a
     crowded list. This splits the hero into two zones:

       TOP   · the statement (name → morphing headline → primary actions)
               beside the film screen (home/hero-showcase)
       BAND  · a horizontal bento of three cards — WORK (where I am now),
               STATS (what I make, in numbers), SUBSCRIBE (the newsletter form).
               Information spreads sideways into cards instead of piling up.

     The tag marquee renders AFTER this section (home.hbs) and the hero reserves
     its height, so the strip lands on the fold. --}}
<section class="hx" id="hero">
	{{!-- Grid: lit in the middle, dissolving before the corners. --}}
	<div class="bg-pat-grid-wide fade-mask-bloom pointer-events-none absolute inset-0" style="--pat-opacity:1.9" aria-hidden="true"></div>

	<div class="hx-inner" id="hero-shell">

		{{!-- ============ TOP: statement + screen ============ --}}
		<div class="hx-top">
			<div class="hx-lede">
				<p class="hx-badge hx-enter" style="--d:0s">
					<span class="hx-badge-dot" aria-hidden="true"></span>
					Swarnil Singhai — open to interesting work
				</p>

				{{!-- Three EXPLICIT lines. The frame owns line 2, so an aspect-ratio
				     morph can never re-wrap the headline. --}}
				<h1 class="hx-h1 hx-enter" style="--d:.08s">
					<span class="block">Life looks better when you</span>
					<span class="block">frame the
						<span class="hx-frame" id="hx-frame" style="--hx-ar:16/9">
							<i></i><i></i><i></i><i></i>
							<span class="hx-word" id="hx-word">process</span>
							<span class="hx-ratio" id="hx-ratio">16:9</span>
						</span>
						&nbsp;—
					</span>
					<span class="block">and cut the <span class="hx-noise">noise</span>.</span>
				</h1>

				<div class="hx-cta hx-enter" style="--d:.16s">
					<a href="{{@site.url}}/videos/" class="btn-primary btn-sm !px-4">{{> "icons/play" class="h-3.5 w-3.5"}} Watch my videos</a>
					<a href="{{@site.url}}/resume/" class="btn-ghost btn-sm !px-4">{{> "icons/briefcase" class="h-3 w-3"}} Resume</a>
					<span class="hx-social">
						<a href="https://www.youtube.com/@imswarnil" target="_blank" rel="noopener" class="icon-btn" aria-label="YouTube">{{> "icons/youtube"}}</a>
						<a href="https://github.com/imswarnil" target="_blank" rel="noopener" class="icon-btn" aria-label="GitHub">{{> "icons/github"}}</a>
						<a href="https://linkedin.com/in/imswarnil" target="_blank" rel="noopener" class="icon-btn" aria-label="LinkedIn">{{> "icons/linkedin"}}</a>
						<a href="https://instagram.com/imswarnil" target="_blank" rel="noopener" class="icon-btn" aria-label="Instagram">{{> "icons/instagram"}}</a>
					</span>
				</div>
			</div>

			{{!-- the film screen --}}
			<div class="hx-screen hx-enter-screen">
				{{> "home/hero-showcase"}}
			</div>
		</div>

		{{!-- ============ BAND: the information, as cards ============ --}}
		<div class="hx-band">

			{{!-- WORK — where I am now --}}
			<div class="hx-tile hx-enter" style="--d:.24s">
				<p class="hx-tile-k">{{> "icons/salesforce" class="h-3 w-3"}} Currently</p>
				<p class="hx-tile-lead">Salesforce Engineer</p>
				<p class="hx-tile-sub">
					<a href="https://www.ef.com" target="_blank" rel="noopener">EF Education First</a>
				</p>
				<p class="hx-tile-meta">
					<span>{{> "icons/flag-hu" class="h-3 w-3"}} Budapest</span>
					<span>{{> "icons/flag-in" class="h-3 w-3"}} from India</span>
				</p>
			</div>

			{{!-- STATS — what I make, in numbers. Hardcoded on purpose (live
			     counts cost one {{#get}} each; that's what crashed the old hero). --}}
			<nav class="hx-tile hx-tile-stats hx-enter" style="--d:.3s" aria-label="What I make, in numbers">
				<p class="hx-tile-k">{{> "icons/sparkle" class="h-3 w-3"}} What I make</p>
				<div class="hx-stats">
					<a href="{{@site.url}}/videos/" class="hx-stat"><strong>100+</strong><span>{{> "icons/film" class="h-3 w-3"}} Videos</span></a>
					<a href="{{@site.url}}/courses/" class="hx-stat"><strong>30+</strong><span>{{> "icons/graduation" class="h-3 w-3"}} Lessons</span></a>
					<a href="{{@site.url}}/projects/" class="hx-stat"><strong>12+</strong><span>{{> "icons/terminal" class="h-3 w-3"}} Projects</span></a>
					<a href="{{@site.url}}/timeline/" class="hx-stat"><strong>5+</strong><span>{{> "icons/briefcase" class="h-3 w-3"}} Yrs</span></a>
				</div>
			</nav>

			{{!-- SUBSCRIBE — the newsletter, captured right here --}}
			{{#if @site.members_enabled}}
			<div class="hx-tile hx-tile-sub-card hx-enter" style="--d:.36s">
				<p class="hx-tile-k">{{> "icons/mail" class="h-3 w-3"}} Newsletter</p>
				<p class="hx-tile-lead">Get the next one.</p>
				<form data-members-form class="hx-form">
					<input type="email" name="email" required data-members-email placeholder="you@example.com" aria-label="Email address" class="hx-form-input" />
					<button type="submit" class="btn-primary btn-sm shrink-0" aria-label="Subscribe">{{> "icons/arrow-right" class="h-3.5 w-3.5"}}</button>
				</form>
				<p class="hx-form-note">
					<span data-members-success hidden class="text-green-600">Check your inbox to confirm — welcome aboard.</span>
					<span data-members-error hidden class="text-red-500">That email didn't take — try again?</span>
					<span>New videos, guides and write-ups. No spam.</span>
				</p>
			</div>
			{{/if}}
		</div>
	</div>

	<script>
		(function () {
			var reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

			/* ---------- headline frame: word + aspect ratio morph together ------
			   ONE pass through the list, then it rests on "process". */
			var STOPS = [
				{ w: 'art', ar: '4/5', label: '4:5' },
				{ w: 'story', ar: '2/3', label: '2:3' },
				{ w: 'build', ar: '4/3', label: '4:3' },
				{ w: 'trip', ar: '21/9', label: '2.39:1' },
				{ w: 'process', ar: '16/9', label: '16:9' } /* rest here */
			];
			var frame = document.getElementById('hx-frame');
			var word = document.getElementById('hx-word');
			var chip = document.getElementById('hx-ratio');
			if (frame && !reduced) {
				var i = -1;
				var timer = setInterval(function () {
					i++;
					if (i >= STOPS.length) return clearInterval(timer);
					var s = STOPS[i];
					word.style.animation = 'none';
					void word.offsetWidth;
					word.textContent = s.w;
					word.style.animation = '';
					frame.style.setProperty('--hx-ar', s.ar);
					chip.textContent = s.label;
				}, 2200);
			}
		})();
	</script>
</section>
