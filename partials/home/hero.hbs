{{!-- Home hero — a dark, medium-height cinematic band.

     Composition:
       LEFT  · badge → a personal caption about life + who I am → work details
               → actions → newsletter sign-up
       RIGHT · a still portrait in a viewfinder frame
     Behind it all: a medium background video that parallaxes and blends into
     the page as you scroll. The tag marquee renders after this (home.hbs). --}}
<section class="hx" id="hero">
	{{!-- Grid background effect --}}
	<div class="bg-pat-grid-wide fade-mask-bloom pointer-events-none absolute inset-0" id="hx-grid" style="--pat-opacity:1.9" aria-hidden="true"></div>
	<div class="hx-grain pointer-events-none absolute inset-0" aria-hidden="true"></div>

	{{!-- viewfinder chrome — corner marks + a minimal REC/aspect HUD --}}
	<div class="hx-viewfinder" aria-hidden="true">
		<i class="hx-vf-mark"></i><i class="hx-vf-mark"></i><i class="hx-vf-mark"></i><i class="hx-vf-mark"></i>
		<div class="hx-hud hx-hud-tl">
			<span class="hx-hud-rec"><i></i> REC</span>
			<span class="hx-hud-tc" id="hx-tc">00:00:00:00</span>
		</div>
		<div class="hx-hud hx-hud-tr">16:9 · 24<span class="hx-hud-dim">FPS</span></div>
	</div>

	<div class="hx-inner" id="hero-shell">
		<div class="hx-top">
			<div class="hx-lede">
				<p class="hx-badge hx-enter" style="--d:0s">
					<span class="hx-badge-dot" aria-hidden="true"></span>
					Swarnil Singhai — open to interesting work
				</p>

				<h1 class="hx-h1 hx-enter" style="--d:.1s">Life's better when you<br>make things.</h1>

				{{!-- the caption: who I am, in one warm breath --}}
				<p class="hx-cap hx-enter" style="--d:.2s">
					Engineer by training, filmmaker by obsession, teacher by accident. I build
					Salesforce systems that scale — then turn everyday moments into videos,
					courses and side-projects worth keeping. <em>Curiosity is the whole personality.</em>
				</p>

				<p class="hx-meta hx-enter" style="--d:.3s">
					{{> "icons/salesforce" class="h-3.5 w-3.5"}}
					<span>Salesforce Engineer at <a href="https://www.ef.com" target="_blank" rel="noopener">EF Education First</a></span>
					<span class="hx-meta-dot" aria-hidden="true"></span>
					<span>{{> "icons/map-pin" class="h-3.5 w-3.5"}} Budapest · from India</span>
				</p>

				<div class="hx-cta hx-enter" style="--d:.4s">
					<a href="{{@site.url}}/videos/" class="btn-primary btn-sm !px-4">{{> "icons/play" class="h-3.5 w-3.5"}} Watch my videos</a>
					<a href="{{@site.url}}/resume/" class="btn-ghost btn-sm !px-4">{{> "icons/briefcase" class="h-3 w-3"}} Resume</a>
					<span class="hx-social">
						<a href="https://www.youtube.com/@imswarnil" target="_blank" rel="noopener" class="icon-btn" aria-label="YouTube">{{> "icons/youtube"}}</a>
						<a href="https://github.com/imswarnil" target="_blank" rel="noopener" class="icon-btn" aria-label="GitHub">{{> "icons/github"}}</a>
						<a href="https://linkedin.com/in/imswarnil" target="_blank" rel="noopener" class="icon-btn" aria-label="LinkedIn">{{> "icons/linkedin"}}</a>
						<a href="https://instagram.com/imswarnil" target="_blank" rel="noopener" class="icon-btn" aria-label="Instagram">{{> "icons/instagram"}}</a>
					</span>
				</div>

				{{!-- newsletter: a plain inline field right under the actions --}}
				{{#if @site.members_enabled}}
				<form data-members-form class="hx-form hx-enter" style="--d:.5s">
					<input type="email" name="email" required data-members-email placeholder="Your email — get the next one" aria-label="Email address" class="hx-form-input" />
					<button type="submit" class="btn-primary btn-sm shrink-0">{{> "icons/arrow-right" class="h-3.5 w-3.5"}} Subscribe</button>
				</form>
				<p class="hx-form-note hx-enter" style="--d:.5s">
					<span data-members-success hidden class="text-green-600">Check your inbox to confirm — welcome aboard.</span>
					<span data-members-error hidden class="text-red-500">That email didn't take — try again?</span>
					<span>New videos, guides and write-ups. No spam.</span>
				</p>
				{{/if}}
			</div>

			{{!-- Right: a still portrait in a viewfinder frame --}}
			<figure class="hx-photo hx-enter-screen">
				<img src="{{asset "images/hero-square.svg"}}" width="1000" height="1000" fetchpriority="high" decoding="async" alt="Swarnil Singhai" class="hx-photo-img" />
				<i class="hx-photo-mark"></i><i class="hx-photo-mark"></i><i class="hx-photo-mark"></i><i class="hx-photo-mark"></i>
				<figcaption class="hx-photo-cap">
					<span>{{> "icons/film" class="h-3.5 w-3.5"}} Swarnil</span>
					<span class="hx-photo-ar">1:1</span>
				</figcaption>
			</figure>
		</div>

	</div>

	<script>
		(function () {
			var reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

			/* live REC timecode HH:MM:SS:FF @ 24fps — ~12 writes/sec, only on change */
			var tcEl = document.getElementById('hx-tc');
			if (tcEl && !reduced) {
				var start = null, last = '';
				function pad(n) { return (n < 10 ? '0' : '') + n; }
				function tick(t) {
					if (start === null) start = t;
					var e = (t - start) / 1000;
					var ff = Math.floor((e % 1) * 24);
					var s = Math.floor(e) % 60, m = Math.floor(e / 60) % 60, h = Math.floor(e / 3600);
					var str = pad(h) + ':' + pad(m) + ':' + pad(s) + ':' + pad(ff);
					if (str !== last) { tcEl.textContent = str; last = str; }
					setTimeout(function () { requestAnimationFrame(tick); }, 80);
				}
				requestAnimationFrame(tick);
			}
		})();
	</script>
</section>
