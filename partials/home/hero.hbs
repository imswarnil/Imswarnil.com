{{!-- Hero — "The Director's Viewfinder".

     The whole theme is a filmmaker's OS ("frame the process, cut the noise";
     viewfinder frames everywhere). So the hero IS a viewfinder: crop-mark
     brackets at the corners, a live REC timecode and an aspect/fps readout as
     camera HUD, a filmic grain wash, and a headline that wipes in like a cut.

     Composition:
       LEFT  · badge → headline (morphing frame) → one credits-style meta line
               → primary actions + socials
       RIGHT · the film screen (home/hero-showcase): a still that opens 1:1→16:9
               and plays, with real play/pause/unmute controls

     The tag marquee renders AFTER this section (home.hbs) and the hero reserves
     its height, so the strip lands on the fold. --}}
<section class="hx" id="hero">
	{{!-- lit grid, then a filmic grain wash, both dissolving before the corners --}}
	<div class="bg-pat-grid-wide fade-mask-bloom pointer-events-none absolute inset-0" style="--pat-opacity:1.7" aria-hidden="true"></div>
	<div class="hx-grain pointer-events-none absolute inset-0" aria-hidden="true"></div>

	{{!-- viewfinder chrome: four crop brackets + the camera HUD, sized to the
	     content column so the framing lands on the reading measure --}}
	<div class="hx-viewfinder" aria-hidden="true">
		<i class="hx-vf-mark"></i><i class="hx-vf-mark"></i><i class="hx-vf-mark"></i><i class="hx-vf-mark"></i>
		<div class="hx-hud hx-hud-tl">
			<span class="hx-hud-rec"><i></i> REC</span>
			<span class="hx-hud-tc" id="hx-tc">00:00:00:00</span>
		</div>
		<div class="hx-hud hx-hud-tr">16:9 · 24<span class="hx-hud-fps">FPS</span></div>
	</div>

	<div class="hx-inner" id="hero-shell">
		<div class="hx-top">
			<div class="hx-lede">
				<p class="hx-badge hx-enter" style="--d:0s">
					<span class="hx-badge-dot" aria-hidden="true"></span>
					Swarnil Singhai — open to interesting work
				</p>

				{{!-- Three EXPLICIT lines, each wiping in like a film cut. The frame
				     owns line 2, so an aspect-ratio morph can never re-wrap it. --}}
				<h1 class="hx-h1">
					<span class="hx-line" style="--d:.15s"><span class="hx-line-in">Life looks better when you</span></span>
					<span class="hx-line" style="--d:.28s"><span class="hx-line-in">frame the
						<span class="hx-frame" id="hx-frame" style="--hx-ar:16/9">
							<i></i><i></i><i></i><i></i>
							<span class="hx-word" id="hx-word">process</span>
							<span class="hx-ratio" id="hx-ratio">16:9</span>
						</span>
						&nbsp;—</span></span>
					<span class="hx-line" style="--d:.41s"><span class="hx-line-in">and cut the <span class="hx-noise">noise</span>.</span></span>
				</h1>

				{{!-- identity, set like film credits --}}
				<p class="hx-meta hx-enter" style="--d:.5s">
					{{> "icons/salesforce" class="h-3.5 w-3.5"}}
					<span>Salesforce Engineer at <a href="https://www.ef.com" target="_blank" rel="noopener">EF Education First</a></span>
					<span class="hx-meta-dot" aria-hidden="true"></span>
					<span>{{> "icons/map-pin" class="h-3.5 w-3.5"}} Budapest</span>
				</p>

				<div class="hx-cta hx-enter" style="--d:.58s">
					<a href="{{@site.url}}/videos/" class="btn-primary btn-sm !px-4">{{> "icons/play" class="h-3.5 w-3.5"}} Watch my videos</a>
					<a href="{{@site.url}}/resume/" class="btn-ghost btn-sm !px-4">{{> "icons/briefcase" class="h-3 w-3"}} Resume</a>
					<span class="hx-social">
						<a href="https://www.youtube.com/@imswarnil" target="_blank" rel="noopener" class="icon-btn" aria-label="YouTube">{{> "icons/youtube"}}</a>
						<a href="https://github.com/imswarnil" target="_blank" rel="noopener" class="icon-btn" aria-label="GitHub">{{> "icons/github"}}</a>
						<a href="https://linkedin.com/in/imswarnil" target="_blank" rel="noopener" class="icon-btn" aria-label="LinkedIn">{{> "icons/linkedin"}}</a>
						<a href="https://instagram.com/imswarnil" target="_blank" rel="noopener" class="icon-btn" aria-label="Instagram">{{> "icons/instagram"}}</a>
					</span>
				</div>
			</div>

			{{!-- the film screen --}}
			<div class="hx-screen hx-enter-screen">
				{{> "home/hero-showcase"}}
			</div>
		</div>
	</div>

	<script>
		(function () {
			var reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

			/* ---------- headline frame: word + aspect ratio morph together ------
			   ONE pass through the list, then it rests on "process". */
			var STOPS = [
				{ w: 'art', ar: '4/5', label: '4:5' },
				{ w: 'story', ar: '2/3', label: '2:3' },
				{ w: 'build', ar: '4/3', label: '4:3' },
				{ w: 'trip', ar: '21/9', label: '2.39:1' },
				{ w: 'process', ar: '16/9', label: '16:9' } /* rest here */
			];
			var frame = document.getElementById('hx-frame');
			var word = document.getElementById('hx-word');
			var chip = document.getElementById('hx-ratio');
			if (frame && !reduced) {
				var i = -1;
				var timer = setInterval(function () {
					i++;
					if (i >= STOPS.length) return clearInterval(timer);
					var s = STOPS[i];
					word.style.animation = 'none';
					void word.offsetWidth;
					word.textContent = s.w;
					word.style.animation = '';
					frame.style.setProperty('--hx-ar', s.ar);
					chip.textContent = s.label;
				}, 2200);
			}

			/* ---------- live REC timecode: HH:MM:SS:FF at 24fps ----------------
			   Writes ~12×/sec (throttled), only when the string changes — cheap.
			   Frozen under reduced-motion so it isn't distracting. */
			var tcEl = document.getElementById('hx-tc');
			if (tcEl && !reduced) {
				var start = null, last = '';
				function pad(n) { return (n < 10 ? '0' : '') + n; }
				function frame2(t) {
					if (start === null) start = t;
					var e = (t - start) / 1000;
					var ff = Math.floor((e % 1) * 24);
					var s = Math.floor(e) % 60, m = Math.floor(e / 60) % 60, h = Math.floor(e / 3600);
					var str = pad(h) + ':' + pad(m) + ':' + pad(s) + ':' + pad(ff);
					if (str !== last) { tcEl.textContent = str; last = str; }
					setTimeout(function () { requestAnimationFrame(frame2); }, 80);
				}
				requestAnimationFrame(frame2);
			}
		})();
	</script>
</section>
