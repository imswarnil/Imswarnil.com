{{!-- Home hero — greeting-led, two columns.

     LEFT  · availability badge → a BIG multilingual greeting that swaps word +
             font on a squiggly hand-drawn underline → who I am → a wry one-liner
             → the description → two "moves" (Twilio→EF, India→Budapest) →
             two CTAs → newsletter (expands from an icon) + search.
     RIGHT · the publication cover in a viewfinder frame (falls back to the
             packaged portrait when no cover is set).
     Styles: assets/css/layout/home.css (.hh-*). --}}
<section class="hh" id="hero">
	{{!-- drafting-grid + grain, same ambient treatment as before --}}
	<div class="bg-pat-grid-wide fade-mask-bloom pointer-events-none absolute inset-0" style="--pat-opacity:1.7" aria-hidden="true"></div>
	<div class="hh-grain pointer-events-none absolute inset-0" aria-hidden="true"></div>

	<div class="hh-inner container-site">
		<div class="hh-copy">
			<p class="hh-badge hh-in" style="--d:0s">
				<span class="hh-badge-dot" aria-hidden="true"></span>
				Open to GTM Engineer role
			</p>

			{{!-- BIG greeting: JS cycles the word + font; the squiggle redraws --}}
			<div class="hh-greet hh-in" style="--d:.06s" aria-label="Hello, I'm Swarnil">
				<span class="hh-greet-stage" aria-hidden="true">
					<span class="hh-greet-word" id="hh-greet-word">Hi</span>
					<svg class="hh-greet-line" viewBox="0 0 300 18" preserveAspectRatio="none" aria-hidden="true">
						<path id="hh-greet-path" class="hh-greet-path" d="M4 11 C 40 3, 70 3, 104 10 S 168 17, 200 9 S 262 3, 296 10" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
					</svg>
				</span>
				<span class="hh-greet-wave" aria-hidden="true">👋</span>
			</div>

			<h1 class="hh-name hh-in" style="--d:.12s">
				I'm <span class="hh-name-hi">Swarnil</span> — Salesforce Engineer <span class="hh-amp">&amp;</span> Creator.
			</h1>

			<p class="hh-quip hh-in" style="--d:.18s">
				I build systems by day and document the chaos by night — half engineer, half film crew. <span aria-hidden="true">🎥</span>
			</p>

			<p class="hh-desc hh-in" style="--d:.24s">
				I love making things. By day I do <strong>CRM Analytics</strong> in the Salesforce
				ecosystem — and I'm aiming for a <strong>GTM Engineer</strong> role next. By night I
				make YouTube videos, write blogs, build Ghost themes and curate the odd webseries.
				I like being on the other side of the lens too: recording moments, documenting the
				journey, journaling a life worth rewatching.
			</p>

			{{!-- Role + location --}}
			<div class="hh-moves hh-in" style="--d:.3s">
				<a class="hh-move hh-move-job" href="https://www.ef.com" target="_blank" rel="noopener" title="Salesforce Engineer at EF Education First">
					{{> "icons/briefcase" class="hh-move-arrow h-4 w-4"}}
					<span class="hh-move-text">Salesforce Engineer @</span>
					<span class="hh-move-logo hh-move-logo-ef">{{> "icons/companies/ef" class="h-3.5 w-auto"}}</span>
				</a>
				<span class="hh-move hh-move-plain">
					<span class="hh-move-logo hh-move-logo-now">{{> "icons/map-pin" class="h-4 w-4"}}</span>
					<span class="hh-move-text">Budapest, Hungary</span>
				</span>
			</div>

			{{!-- Actions: two CTAs + social handles --}}
			<div class="hh-actions hh-in" style="--d:.36s">
				<a href="{{@site.url}}/about/" class="btn-primary btn-sm !px-4">{{> "icons/book" class="h-3.5 w-3.5"}} Read my story</a>
				<a href="{{@site.url}}/projects/" class="btn-ghost btn-sm !px-4">{{> "icons/code" class="h-3.5 w-3.5"}} View my projects</a>
				<span class="hh-social">
					<a href="https://www.youtube.com/@imswarnil" target="_blank" rel="noopener" class="hh-social-link" aria-label="YouTube">{{> "icons/youtube" class="h-4 w-4"}}</a>
					<a href="https://github.com/imswarnil" target="_blank" rel="noopener" class="hh-social-link" aria-label="GitHub">{{> "icons/github" class="h-4 w-4"}}</a>
					<a href="https://linkedin.com/in/imswarnil" target="_blank" rel="noopener" class="hh-social-link" aria-label="LinkedIn">{{> "icons/linkedin" class="h-4 w-4"}}</a>
					<a href="https://instagram.com/imswarnil" target="_blank" rel="noopener" class="hh-social-link" aria-label="Instagram">{{> "icons/instagram" class="h-4 w-4"}}</a>
				</span>
			</div>
		</div>

		{{!-- Square photo in its own right column. The play badge reshapes THIS
		     frame into a 16:9 player right here (in place — no modal). --}}
		<figure class="hh-shot hh-in-frame" id="hh-shot">
			<div class="hh-shot-inner" id="hh-shot-inner">
				{{#if @site.cover_image}}
					<img class="hh-shot-img" src="{{img_url @site.cover_image size="1200"}}" width="1000" height="1000" fetchpriority="high" decoding="async" alt="Swarnil Singhai" />
				{{else}}
					<img class="hh-shot-img" src="{{asset "images/hero-square.svg"}}" width="1000" height="1000" fetchpriority="high" decoding="async" alt="Swarnil Singhai" />
				{{/if}}
				<div class="hh-shot-video" id="hh-shot-video" aria-hidden="true"></div>
				<span class="hh-shot-frame" aria-hidden="true"></span>
				<i class="hh-shot-corner hh-c-tl" aria-hidden="true"></i>
				<i class="hh-shot-corner hh-c-tr" aria-hidden="true"></i>
				<i class="hh-shot-corner hh-c-bl" aria-hidden="true"></i>
				<i class="hh-shot-corner hh-c-br" aria-hidden="true"></i>
				<button type="button" class="hh-shot-x" data-story-close aria-label="Close video">{{> "icons/close" class="h-5 w-5"}}</button>
				<button type="button" class="hh-shot-play" data-story-open aria-label="Play my story">
					{{> "icons/play" class="h-5 w-5"}}
					<span class="hh-shot-play-ring" aria-hidden="true"></span>
				</button>
			</div>
			{{!-- caption sits BELOW the frame, revealed while playing --}}
			<figcaption class="hh-shot-cap">My Story</figcaption>
		</figure>
	</div>

	<script>
		(function () {
			var reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

			/* ---- Multilingual greeting: swap word + font on a beat, redraw the
			   squiggle each time. One rAF-free timer, only touching one node. --- */
			var wordEl = document.getElementById('hh-greet-word');
			var pathEl = document.getElementById('hh-greet-path');
			if (wordEl) {
				var GREETS = [
					{ t: 'Hi',      f: "'Geist', system-ui, sans-serif" },
					{ t: 'Hola',    f: "Georgia, 'Times New Roman', serif" },
					{ t: 'Szia',    f: "'Comic Sans MS', 'Brush Script MT', cursive" },
					{ t: 'Bonjour', f: "'Brush Script MT', 'Segoe Script', cursive" },
					{ t: 'नमस्ते',    f: "'Nirmala UI', system-ui, sans-serif" },
					{ t: 'Ciao',    f: "'Courier New', ui-monospace, monospace" },
					{ t: 'Hallo',   f: "Impact, 'Haettenschweiler', sans-serif" }
				];
				var i = 0;
				function show(n) {
					var g = GREETS[n];
					wordEl.style.fontFamily = g.f;
					wordEl.firstChild ? (wordEl.firstChild.nodeValue = g.t) : (wordEl.textContent = g.t);
					if (reduced) return;
					/* replay the entrance + squiggle draw */
					wordEl.classList.remove('is-swap'); void wordEl.offsetWidth; wordEl.classList.add('is-swap');
					if (pathEl) { pathEl.classList.remove('is-draw'); void wordEl.offsetWidth; pathEl.classList.add('is-draw'); }
				}
				show(0);
				/* slower, calmer cadence than before */
				if (!reduced) {
					setInterval(function () { i = (i + 1) % GREETS.length; show(i); }, 3600);
				}
			}

			/* ---- Story: the frame stays exactly where it is and just RESIZES from
			   a 1:1 square to a 16:9 player in place (no popup, no move). The video
			   crossfades in; ✕ / Esc resize it back to the square. ------------- */
			var shot = document.getElementById('hh-shot');
			var shotInner = document.getElementById('hh-shot-inner');
			var shotVideo = document.getElementById('hh-shot-video');
			if (shot && shotInner && shotVideo) {
				var STORY_ID = 'ecOkmTD7KhU';
				var playing = false;
				function openStory() {
					if (playing) return;
					playing = true;
					shotVideo.innerHTML = '<iframe src="https://www.youtube-nocookie.com/embed/' + STORY_ID +
						'?autoplay=1&rel=0&modestbranding=1&playsinline=1" title="My Story" ' +
						'allow="autoplay; encrypted-media; fullscreen" allowfullscreen></iframe>';
					var w = shotInner.offsetWidth;                 /* 1:1 → 16:9, same width */
					shotInner.style.height = shotInner.offsetHeight + 'px';
					shot.classList.add('is-playing');
					if (reduced) { shotInner.style.height = Math.round(w * 9 / 16) + 'px'; shot.classList.add('is-shown'); return; }
					requestAnimationFrame(function () {
						requestAnimationFrame(function () {
							shotInner.style.transition = 'height .5s cubic-bezier(.16,1,.3,1)';
							shotInner.style.height = Math.round(w * 9 / 16) + 'px';
							shot.classList.add('is-shown');
						});
					});
					var x = shot.querySelector('.hh-shot-x');
					if (x) setTimeout(function () { x.focus(); }, 200);
				}
				function finishClose() {
					shot.classList.remove('is-playing', 'is-shown');
					shotInner.style.transition = ''; shotInner.style.height = '';
					shotVideo.innerHTML = ''; /* stop the video */
					playing = false;
					var p = shot.querySelector('.hh-shot-play');
					if (p) p.focus();
				}
				function closeStory() {
					if (!playing) return;
					if (reduced) { finishClose(); return; }
					var settled = false;
					function onEnd(e) {
						if (e.propertyName !== 'height') return;
						settled = true; shotInner.removeEventListener('transitionend', onEnd); finishClose();
					}
					shotInner.addEventListener('transitionend', onEnd);
					shot.classList.remove('is-shown');
					shotInner.style.transition = 'height .45s cubic-bezier(.16,1,.3,1)';
					shotInner.style.height = shotInner.offsetWidth + 'px'; /* back to square */
					setTimeout(function () { if (!settled) { shotInner.removeEventListener('transitionend', onEnd); finishClose(); } }, 600);
				}
				document.querySelectorAll('[data-story-open]').forEach(function (b) {
					b.addEventListener('click', openStory);
				});
				document.querySelectorAll('[data-story-close]').forEach(function (b) {
					b.addEventListener('click', closeStory);
				});
				document.addEventListener('keydown', function (e) {
					if (e.key === 'Escape' && playing) closeStory();
				});
			}
		})();
	</script>
</section>
