{{!-- Hero — "The Director's Viewfinder".

     The whole theme is a filmmaker's OS. So the hero IS a viewfinder, dressed
     with real camera chrome:
       · four crop-mark brackets + faint rule-of-thirds guides
       · a live REC timecode (top-left) and aspect/fps + battery (top-right)
       · exposure readout + a live audio meter (bottom-left), resolution (br)
     Content: badge → headline (morphing frame) → credits meta → actions, beside
     the film screen; then a REEL — a filmstrip of recent work (one {{#get}}). --}}
<section class="hx" id="hero">
	<div class="bg-pat-grid-wide fade-mask-bloom pointer-events-none absolute inset-0" id="hx-grid" style="--pat-opacity:1.7" aria-hidden="true"></div>
	<div class="hx-grain pointer-events-none absolute inset-0" aria-hidden="true"></div>
	{{!-- a lens light-sweep, once, on load --}}
	<div class="hx-sweep pointer-events-none absolute inset-0" aria-hidden="true"></div>

	{{!-- autofocus reticle — tracks the cursor, snaps to a green "lock" when you
	     stop moving (like a camera pulling focus). Desktop, fine-pointer only. --}}
	<div class="hx-af" id="hx-af" aria-hidden="true">
		<i></i><i></i><i></i><i></i>
		<span class="hx-af-tag">AF</span>
	</div>

	{{!-- viewfinder chrome + camera HUD, sized to the content column --}}
	<div class="hx-viewfinder" aria-hidden="true">
		<i class="hx-vf-mark"></i><i class="hx-vf-mark"></i><i class="hx-vf-mark"></i><i class="hx-vf-mark"></i>

		{{!-- faint rule-of-thirds guides --}}
		<div class="hx-guides">
			<span class="hx-guide-v" style="left:33.33%"></span>
			<span class="hx-guide-v" style="left:66.66%"></span>
			<span class="hx-guide-h" style="top:33.33%"></span>
			<span class="hx-guide-h" style="top:66.66%"></span>
		</div>

		<div class="hx-hud hx-hud-tl">
			<span class="hx-hud-rec"><i></i> REC</span>
			<span class="hx-hud-tc" id="hx-tc">00:00:00:00</span>
		</div>
		<div class="hx-hud hx-hud-tr">
			<span>16:9 · 24<span class="hx-hud-dim">FPS</span></span>
			<span class="hx-batt"><i style="width:72%"></i></span>
		</div>
		<div class="hx-hud hx-hud-bl">
			<span>ISO 400 · f/2.8 · 1/50</span>
			<span class="hx-meter" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i></span>
		</div>
		<div class="hx-hud hx-hud-br">4K <span class="hx-hud-dim">CDNG</span></div>
	</div>

	<div class="hx-inner" id="hero-shell">
		<div class="hx-top">
			<div class="hx-lede">
				<p class="hx-badge hx-enter" style="--d:0s">
					<span class="hx-badge-dot" aria-hidden="true"></span>
					Swarnil Singhai — open to interesting work
				</p>

				<h1 class="hx-h1">
					<span class="hx-line" style="--d:.15s"><span class="hx-line-in">Life looks better when you</span></span>
					<span class="hx-line" style="--d:.28s"><span class="hx-line-in">frame the
						<span class="hx-frame" id="hx-frame" style="--hx-ar:16/9">
							<i></i><i></i><i></i><i></i>
							<span class="hx-word" id="hx-word">process</span>
							<span class="hx-ratio" id="hx-ratio">16:9</span>
						</span>
						&nbsp;—</span></span>
					<span class="hx-line" style="--d:.41s"><span class="hx-line-in">and cut the <span class="hx-noise">noise</span>.</span></span>
				</h1>

				<p class="hx-meta hx-enter" style="--d:.5s">
					{{> "icons/salesforce" class="h-3.5 w-3.5"}}
					<span>Salesforce Engineer at <a href="https://www.ef.com" target="_blank" rel="noopener">EF Education First</a></span>
					<span class="hx-meta-dot" aria-hidden="true"></span>
					<span>{{> "icons/map-pin" class="h-3.5 w-3.5"}} Budapest</span>
				</p>

				<div class="hx-cta hx-enter" style="--d:.58s">
					<a href="{{@site.url}}/videos/" class="btn-primary btn-sm !px-4">{{> "icons/play" class="h-3.5 w-3.5"}} Watch my videos</a>
					<a href="{{@site.url}}/resume/" class="btn-ghost btn-sm !px-4">{{> "icons/briefcase" class="h-3 w-3"}} Resume</a>
					<span class="hx-social">
						<a href="https://www.youtube.com/@imswarnil" target="_blank" rel="noopener" class="icon-btn" aria-label="YouTube">{{> "icons/youtube"}}</a>
						<a href="https://github.com/imswarnil" target="_blank" rel="noopener" class="icon-btn" aria-label="GitHub">{{> "icons/github"}}</a>
						<a href="https://linkedin.com/in/imswarnil" target="_blank" rel="noopener" class="icon-btn" aria-label="LinkedIn">{{> "icons/linkedin"}}</a>
						<a href="https://instagram.com/imswarnil" target="_blank" rel="noopener" class="icon-btn" aria-label="Instagram">{{> "icons/instagram"}}</a>
					</span>
				</div>
			</div>

			<div class="hx-screen hx-enter-screen">
				{{> "home/hero-showcase"}}
			</div>
		</div>

		{{!-- ============ REEL: the newest posts, any collection ============
		     ONE {{#get}} on purpose — the latest published across everything
		     (videos, blog, projects, courses …). Each cell leads with the post's
		     feature image; without one it falls back to a lettered slate. A
		     topic chip names the collection/subject. --}}
		<div class="hx-reel hx-enter" style="--d:.7s">
			<div class="hx-reel-head">
				<span class="hx-reel-label">{{> "icons/sparkle" class="h-3 w-3"}} Latest across the site</span>
				<a href="{{@site.url}}/archive/" class="hx-reel-more">All posts {{> "icons/arrow-right" class="h-3 w-3"}}</a>
			</div>
			<div class="hx-reel-track">
				{{#get "posts" limit="8" order="published_at desc" include="tags" as |latest|}}
					{{#foreach latest}}
					<a href="{{url}}" class="hx-cell" aria-label="{{title}}">
						{{#if feature_image}}
							<img src="{{img_url feature_image size="600"}}" width="320" height="180" loading="lazy" decoding="async" alt="" class="hx-cell-img" />
						{{else}}
							<span class="hx-cell-slate"><span class="hx-cell-glyph" data-avatar-initial="{{title}}"></span></span>
						{{/if}}
						<span class="hx-cell-shade" aria-hidden="true"></span>
						{{#primary_tag}}<span class="hx-cell-tag">{{name}}</span>{{/primary_tag}}
						<span class="hx-cell-title">{{title}}</span>
					</a>
					{{/foreach}}
				{{else}}
					<a href="{{@site.url}}/archive/" class="hx-cell hx-cell-empty">Nothing published yet — browse the archive {{> "icons/arrow-right" class="h-3 w-3"}}</a>
				{{/get}}
			</div>
		</div>
	</div>

	<script>
		(function () {
			var reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

			/* headline frame: word + aspect ratio morph together, one pass */
			var STOPS = [
				{ w: 'art', ar: '4/5', label: '4:5' },
				{ w: 'story', ar: '2/3', label: '2:3' },
				{ w: 'build', ar: '4/3', label: '4:3' },
				{ w: 'trip', ar: '21/9', label: '2.39:1' },
				{ w: 'process', ar: '16/9', label: '16:9' }
			];
			var frame = document.getElementById('hx-frame');
			var word = document.getElementById('hx-word');
			var chip = document.getElementById('hx-ratio');
			if (frame && !reduced) {
				var i = -1;
				var timer = setInterval(function () {
					i++;
					if (i >= STOPS.length) return clearInterval(timer);
					var s = STOPS[i];
					word.style.animation = 'none';
					void word.offsetWidth;
					word.textContent = s.w;
					word.style.animation = '';
					frame.style.setProperty('--hx-ar', s.ar);
					chip.textContent = s.label;
				}, 2200);
			}

			/* ---------- cursor parallax + autofocus reticle -------------------
			   ONE rAF-throttled pointermove. It only writes CSS custom props and
			   one element transform (both compositor-friendly), so it can't stall
			   the main thread the way the old per-move style-invalidation did. */
			var hero = document.getElementById('hero');
			var af = document.getElementById('hx-af');
			var fine = window.matchMedia && window.matchMedia('(hover: hover) and (pointer: fine)').matches;
			if (hero && fine && !reduced) {
				var raf = null, ev = null, lockT = null;
				hero.addEventListener('pointermove', function (e) {
					ev = e;
					if (af) {
						af.classList.add('is-on');
						af.classList.remove('is-locked');
						clearTimeout(lockT);
						lockT = setTimeout(function () { af.classList.add('is-locked'); }, 200);
					}
					if (raf) return;
					raf = requestAnimationFrame(function () {
						raf = null;
						var b = hero.getBoundingClientRect();
						var x = (ev.clientX - b.left) / b.width - 0.5;
						var y = (ev.clientY - b.top) / b.height - 0.5;
						hero.style.setProperty('--px', x.toFixed(3));
						hero.style.setProperty('--py', y.toFixed(3));
						{{!-- set `translate` (not transform): the lock pulse animates
					     transform:scale, so keeping them separate lets both apply --}}
					if (af) af.style.translate = (ev.clientX - b.left) + 'px ' + (ev.clientY - b.top) + 'px';
					});
				});
				hero.addEventListener('pointerleave', function () {
					hero.style.setProperty('--px', 0);
					hero.style.setProperty('--py', 0);
					if (af) { af.classList.remove('is-on', 'is-locked'); clearTimeout(lockT); }
				});
			}

			/* live REC timecode HH:MM:SS:FF @ 24fps — ~12 writes/sec, only on change */
			var tcEl = document.getElementById('hx-tc');
			if (tcEl && !reduced) {
				var start = null, last = '';
				function pad(n) { return (n < 10 ? '0' : '') + n; }
				function tick(t) {
					if (start === null) start = t;
					var e = (t - start) / 1000;
					var ff = Math.floor((e % 1) * 24);
					var s = Math.floor(e) % 60, m = Math.floor(e / 60) % 60, h = Math.floor(e / 3600);
					var str = pad(h) + ':' + pad(m) + ':' + pad(s) + ':' + pad(ff);
					if (str !== last) { tcEl.textContent = str; last = str; }
					setTimeout(function () { requestAnimationFrame(tick); }, 80);
				}
				requestAnimationFrame(tick);
			}
		})();
	</script>
</section>
