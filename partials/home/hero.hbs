{{!-- Hero — one cinematic screen.

       left  · who I am, and the two things I want you to do
       right · the showcase: "Life looks better when you frame the [X] … and cut
               the [Y]", where the frame actually reshapes to each thing and
               comes to rest on the film (home/hero-showcase)
       below · what I do, then the tag marquee on the fold --}}
<section class="hx" id="hero">
	{{!-- Grid: lit in the middle, dissolving to nothing before it reaches any
	     corner, so it blends into the page instead of ending on an edge.
	     NOT -z-10: the section sets no stacking context, so a negative z-index
	     drops this behind <body>'s background and the grid vanishes entirely. --}}
	<div class="bg-pat-grid-wide fade-mask-bloom pointer-events-none absolute inset-0" style="--pat-opacity:1.9" aria-hidden="true"></div>

	<div class="hx-inner" id="hero-shell">
		<div class="hx-grid">

			{{!-- ---------- left: who ---------- --}}
			<div class="hx-copy">
				<p class="hx-eyebrow animate-fade-in">
					<span>Hi, I'm Swarnil</span>
					<span class="hx-eyebrow-tail">documenting the process</span>
				</p>

				<h1 class="hx-h1">
					<span class="block">I build, teach</span>
					<span class="block">and film it all.</span>
				</h1>

				{{!-- the subtitle: out of focus until you reach it, then it pulls sharp
				     word by word — the line is about editing, so it edits itself --}}
				<p class="hx-manifesto" id="hx-manifesto">
					<span>Cut</span> <span>the</span> <span>chaos.</span>
					<span>Everything</span> <span>here</span> <span>is</span> <span>the</span>
					<span>part</span> <span>that</span> <span>survived</span> <span>the</span> <span>edit.</span>
				</p>

				<p class="hx-who animate-fade-in" style="animation-delay:.4s">
					{{> "icons/salesforce" class="h-3.5 w-3.5"}} Salesforce Engineer at
					<a href="https://www.ef.com" target="_blank" rel="noopener">EF Education First</a>
					<span class="hx-who-sep" aria-hidden="true">·</span>
					{{> "icons/flag-hu" class="h-3.5 w-3.5"}} Budapest
					<span class="hx-who-sep" aria-hidden="true">·</span>
					{{> "icons/flag-in" class="h-3.5 w-3.5"}} from India
					<span class="hx-who-sep" aria-hidden="true">·</span>
					{{> "icons/youtube" class="h-3.5 w-3.5"}} <a href="https://www.youtube.com/@imswarnil" target="_blank" rel="noopener">I make videos</a>
				</p>

				<div class="hx-cta animate-fade-up" style="animation-delay:.55s">
					<a href="{{@site.url}}/videos/" class="btn-primary btn-sm !px-4">{{> "icons/play" class="h-3.5 w-3.5"}} Watch my videos</a>
					<a href="{{@site.url}}/resume/" class="btn-ghost btn-sm !px-4">{{> "icons/briefcase" class="h-3 w-3"}} Resume</a>
					<button type="button" class="btn-ghost btn-sm !px-4" data-modal-open="#subscribe-backdrop">{{> "icons/bell" class="h-3 w-3"}} Subscribe</button>
					<span class="mx-1 hidden h-5 w-px bg-line sm:block" aria-hidden="true"></span>
					<span class="flex items-center gap-0.5">
						<a href="https://www.youtube.com/@imswarnil" target="_blank" rel="noopener" class="icon-btn" aria-label="YouTube">{{> "icons/youtube"}}</a>
						<a href="https://github.com/imswarnil" target="_blank" rel="noopener" class="icon-btn" aria-label="GitHub">{{> "icons/github"}}</a>
						<a href="https://linkedin.com/in/imswarnil" target="_blank" rel="noopener" class="icon-btn" aria-label="LinkedIn">{{> "icons/linkedin"}}</a>
					</span>
				</div>

				{{> "home/hero-do"}}
			</div>

			{{!-- ---------- right: the showcase ---------- --}}
			<div class="hx-stage">
				{{> "home/hero-showcase"}}
			</div>
		</div>
	</div>

	{{!-- The tag marquee is NOT in here. As a child of this 100dvh section it
	     kept getting pushed under the fold by the hero's own height, so it
	     renders right after the hero in home.hbs instead — a normal full-width
	     block that's always on screen, whatever the copy does. --}}

	<script>
		(function () {
			var reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

			/* pointer-following accent glow on the shell */
			var shell = document.getElementById('hero-shell');
			if (shell && !reduced) {
				shell.addEventListener('pointermove', function (e) {
					var b = shell.getBoundingClientRect();
					shell.style.setProperty('--hx-mx', ((e.clientX - b.left) / b.width * 100) + '%');
					shell.style.setProperty('--hx-my', ((e.clientY - b.top) / b.height * 100) + '%');
				});
			}

			/* the subtitle sharpens once you reach it */
			var mani = document.getElementById('hx-manifesto');
			if (mani) {
				var words = mani.querySelectorAll('span');
				if (reduced || !('IntersectionObserver' in window)) {
					words.forEach(function (s) { s.classList.add('is-sharp'); });
				} else {
					var io = new IntersectionObserver(function (entries) {
						entries.forEach(function (e) {
							if (!e.isIntersecting) return;
							io.disconnect();
							words.forEach(function (s, idx) {
								setTimeout(function () { s.classList.add('is-sharp'); }, 70 * idx + 300);
							});
						});
					}, { threshold: 0.6 });
					io.observe(mani);
				}
			}
		})();
	</script>
</section>
