{{!-- Motion-graphics hero. Content source: post with slug "hero" if it exists, else built-in default.
     Media column: layered floating frames with pointer parallax (see home/hero-frames). --}}
<section class="relative overflow-hidden pb-14 pt-10 sm:pb-20 sm:pt-16" id="hero">
	<div class="bg-grid pointer-events-none absolute inset-0 fade-mask-b" aria-hidden="true"></div>
	<div class="bg-dots pointer-events-none absolute inset-x-0 top-0 h-64 opacity-70" aria-hidden="true"></div>

	{{#get "posts" filter="slug:hero" limit="1" as |heropost|}}
	<div class="container-site relative grid items-center gap-10 lg:grid-cols-12 lg:gap-14">
		{{#if heropost}}
			{{#foreach heropost}}
			{{!-- Copy — sourced from the "hero" post --}}
			<div class="lg:col-span-7">
				<p class="chip animate-fade-in">
					<span class="relative flex h-2 w-2"><span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-500 opacity-60"></span><span class="relative inline-flex h-2 w-2 rounded-full bg-green-500"></span></span>
					{{@custom.job_title}} @ <a href="{{@custom.workplace_url}}" class="font-semibold text-ink" target="_blank" rel="noopener">{{@custom.workplace}}</a>
				</p>

				<h1 class="mt-7 text-[clamp(2.4rem,6.5vw,4.75rem)] font-semibold leading-[1.06] tracking-[-0.03em]">
					<span class="hero-line"><span style="--d:.05s">{{title}}</span></span>
					<span class="hero-line"><span style="--d:.2s" class="text-silver">
						<span class="hero-typewriter font-mono text-[0.5em] uppercase tracking-[0.15em]" data-typewriter data-words="frame it|crop it|ship it|repeat"></span><span class="hero-caret font-mono text-[0.5em] text-silver" aria-hidden="true">▍</span>
					</span></span>
				</h1>

				<p class="mt-6 max-w-xl animate-fade-in text-lg leading-relaxed text-silver" style="animation-delay:.5s">
					{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{excerpt}}{{/if}}
				</p>

				<div class="mt-9 flex flex-wrap items-center gap-3 animate-fade-up" style="animation-delay:.6s">
					<a href="{{@site.url}}/videos/" class="btn-primary !px-6 !py-3">{{> "icons/play"}} Watch my videos</a>
					<a href="{{url}}" class="btn-ghost !px-6 !py-3">The full story {{> "icons/arrow-right"}}</a>
					<a href="{{@site.url}}/resume/" class="text-sm font-medium text-silver underline decoration-line underline-offset-4 transition hover:text-ink hover:decoration-ink">View resume</a>
				</div>

				{{> "home/hero-proof"}}
			</div>

			<div class="relative lg:col-span-5">
				{{> "home/hero-frames" frame=feature_image polaroid=@custom.hero_image_alt altText=feature_image_alt}}
			</div>
			{{/foreach}}
		{{else}}
			{{!-- Copy — built-in default --}}
			<div class="lg:col-span-7">
				<p class="chip animate-fade-in">
					<span class="relative flex h-2 w-2"><span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-500 opacity-60"></span><span class="relative inline-flex h-2 w-2 rounded-full bg-green-500"></span></span>
					{{@custom.job_title}} @ <a href="{{@custom.workplace_url}}" class="font-semibold text-ink" target="_blank" rel="noopener">{{@custom.workplace}}</a>
				</p>

				<h1 class="mt-7 text-[clamp(2.4rem,6.5vw,4.75rem)] font-semibold leading-[1.06] tracking-[-0.03em]">
					<span class="hero-line"><span style="--d:.05s">Life looks better</span></span>
					<span class="hero-line"><span style="--d:.15s">when you make it</span></span>
					<span class="hero-line"><span style="--d:.25s"><em class="not-italic underline decoration-line decoration-[6px] underline-offset-8"><span data-typewriter data-words="cinematic|measurable|automated|memorable"></span></em><span class="hero-caret text-silver" aria-hidden="true">▍</span></span></span>
				</h1>

				<p class="mt-6 max-w-xl animate-fade-in text-lg leading-relaxed text-silver" style="animation-delay:.5s">
					{{@site.description}} Marketer by trade, filmmaker by delusion — everything here is framed 1:1 and shipped before it's ready.
				</p>

				<div class="mt-9 flex flex-wrap items-center gap-3 animate-fade-up" style="animation-delay:.6s">
					<a href="{{@site.url}}/videos/" class="btn-primary !px-6 !py-3">{{> "icons/play"}} Watch my videos</a>
					<a href="{{@site.url}}/blog/" class="btn-ghost !px-6 !py-3">Read the blog {{> "icons/arrow-right"}}</a>
					{{#if @custom.topmate_url}}
						<a href="{{@custom.topmate_url}}" target="_blank" rel="noopener" class="text-sm font-medium text-silver underline decoration-line underline-offset-4 transition hover:text-ink hover:decoration-ink tooltip tooltip-bottom" data-tip="1:1 on Topmate">Book a call</a>
					{{/if}}
					<a href="{{@site.url}}/resume/" class="text-sm font-medium text-silver underline decoration-line underline-offset-4 transition hover:text-ink hover:decoration-ink">View resume</a>
				</div>

				{{> "home/hero-proof"}}
			</div>

			<div class="relative lg:col-span-5">
				{{> "home/hero-frames" frame=@custom.hero_image polaroid=@custom.hero_image_alt altText="Portrait"}}
			</div>
		{{/if}}
	</div>
	{{/get}}

	{{!-- Marquee strip --}}
	<div class="relative mt-16 overflow-hidden border-y border-line bg-mist/50 py-3 fade-mask-x sm:mt-20">
		<div class="animate-marquee flex w-max items-center gap-10 whitespace-nowrap font-mono text-[11px] uppercase tracking-[0.3em] text-silver">
			<span>marketing technology</span><span>✦</span><span>google ads</span><span>✦</span><span>analytics</span><span>✦</span><span>web design</span><span>✦</span><span>ghost cms</span><span>✦</span><span>video</span><span>✦</span><span>automation</span><span>✦</span><span>seo</span><span>✦</span><span>creative code</span><span>✦</span>
			<span aria-hidden="true">marketing technology</span><span aria-hidden="true">✦</span><span aria-hidden="true">google ads</span><span aria-hidden="true">✦</span><span aria-hidden="true">analytics</span><span aria-hidden="true">✦</span><span aria-hidden="true">web design</span><span aria-hidden="true">✦</span><span aria-hidden="true">ghost cms</span><span aria-hidden="true">✦</span><span aria-hidden="true">video</span><span aria-hidden="true">✦</span><span aria-hidden="true">automation</span><span aria-hidden="true">✦</span><span aria-hidden="true">seo</span><span aria-hidden="true">✦</span><span aria-hidden="true">creative code</span><span aria-hidden="true">✦</span>
		</div>
	</div>

	{{!-- Scroll cue --}}
	<div class="pointer-events-none absolute bottom-1 left-1/2 hidden -translate-x-1/2 flex-col items-center gap-1 text-silver sm:flex animate-fade-in" style="animation-delay:1.2s" aria-hidden="true">
		<span class="font-mono text-[9px] uppercase tracking-[0.3em]">scroll</span>
		<span class="animate-bounce">{{> "icons/chevron-down" class="h-3.5 w-3.5"}}</span>
	</div>

	<style>
		.hero-caret { animation: hero-blink 1s steps(1) infinite; }
		@keyframes hero-blink { 50% { opacity: 0; } }
		@media (prefers-reduced-motion: reduce) {
			#hero video { animation: none !important; }
		}
	</style>
	<script>
		(function () {
			var reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			document.querySelectorAll('[data-typewriter]').forEach(function (el) {
				var words = (el.getAttribute('data-words') || '').split('|').filter(Boolean);
				if (!words.length) return;
				if (reduce) { el.textContent = words[0]; return; }
				var w = 0, i = 0, del = false;
				(function tick() {
					var word = words[w];
					el.textContent = word.slice(0, i);
					var wait = del ? 45 : 90;
					if (!del && i === word.length) { del = true; wait = 1800; }
					else if (del && i === 0) { del = false; w = (w + 1) % words.length; wait = 350; }
					else { i += del ? -1 : 1; }
					setTimeout(tick, wait);
				})();
			});
			// If any hero video fails to load, hide it so the poster/image shows through.
			document.querySelectorAll('#hero video').forEach(function (v) {
				v.addEventListener('error', function () { v.style.display = 'none'; }, true);
			});
		})();
	</script>
</section>
