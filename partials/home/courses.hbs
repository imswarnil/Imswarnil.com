<section class="reveal relative py-16">
	<div class="container-site">
		<div class="flex items-end justify-between gap-4">
			<div>
				<p class="kicker">{{> "icons/book"}} The classroom</p>
				<h2 class="section-title mt-2">Courses &amp; webseries</h2>
			</div>
			<div class="flex shrink-0 gap-2">
				<a href="{{@site.url}}/courses/" class="btn-ghost">Courses</a>
				<a href="{{@site.url}}/webseries/" class="btn-ghost">Webseries</a>
			</div>
		</div>

		<div class="mt-8 grid gap-6 lg:grid-cols-2">
			{{#get "posts" filter="tag:hash-course" limit="2" include="tags" as |courses|}}
				{{#foreach courses}}
					{{> "cards/course"}}
				{{/foreach}}
			{{/get}}
			{{#get "posts" filter="tag:hash-webseries" limit="2" include="tags" as |series|}}
				{{#foreach series}}
					{{> "cards/course"}}
				{{/foreach}}
			{{/get}}
		</div>
	</div>
</section>
