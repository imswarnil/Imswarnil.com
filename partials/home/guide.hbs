{{!-- Homepage — the field guide, given a full-width section of its own.
     Left: why the guide exists. Right: the guide card with its live route
     rendered as the same stepper the guide pages use, so the homepage shows
     the actual shape of the thing rather than a teaser. --}}
{{#get "posts" filter="tag:hash-guide" limit="1" order="published_at desc" include="tags" as |guides|}}
{{#if guides}}
<section class="reveal guide-shell relative border-y border-line py-16 sm:py-20" id="home-guide">
	<div class="bg-pat-grid-wide fade-mask-bloom pointer-events-none absolute inset-0" style="--pat-opacity:1.1" aria-hidden="true"></div>

	<div class="container-site relative">
		<div class="grid gap-10 lg:grid-cols-12 lg:gap-12">

			{{!-- why --}}
			<div class="lg:col-span-4">
				<p class="guide-kicker">{{> "icons/compass" class="h-3 w-3"}} Field guide</p>
				<h2 class="section-title mt-4">The guide I wish I'd had</h2>
				<p class="mt-4 text-sm leading-relaxed text-silver">Nobody hands you a map when you land in a new city with a laptop and a plan. So I wrote the one I needed — every step, in order, including the parts that went badly.</p>
				<ul class="mt-5 space-y-2.5 text-sm">
					<li class="flex gap-2.5">{{> "icons/check" class="mt-0.5 h-4 w-4 shrink-0 text-ink"}} <span><strong class="font-semibold">Walk it in order</strong> — or jump to where you're stuck.</span></li>
					<li class="flex gap-2.5">{{> "icons/check" class="mt-0.5 h-4 w-4 shrink-0 text-ink"}} <span><strong class="font-semibold">Actually specific</strong> — real numbers, real timelines.</span></li>
					<li class="flex gap-2.5">{{> "icons/check" class="mt-0.5 h-4 w-4 shrink-0 text-ink"}} <span><strong class="font-semibold">Free, start to finish</strong> — no gate at step 4.</span></li>
				</ul>
				<a href="{{@site.url}}/guide/" class="btn-primary mt-6">All guides {{> "icons/arrow-right"}}</a>
			</div>

			{{!-- the guide itself --}}
			<div class="lg:col-span-8">
				{{#foreach guides}}
				<article class="card-surface overflow-hidden !transform-none">
					<div class="grid sm:grid-cols-12">
						<a href="{{url}}" class="relative block sm:col-span-5" aria-label="Open guide: {{title}}">
							<div class="relative h-full min-h-[190px] overflow-hidden bg-mist">
								{{#if feature_image}}
									<img src="{{img_url feature_image size="1000"}}" width="1000" height="563"
										alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
										loading="lazy" class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 hover:scale-[1.03]" />
								{{else}}
									<span class="bg-pat-grid absolute inset-0 flex items-center justify-center">{{> "icons/compass" class="h-8 w-8 text-silver"}}</span>
								{{/if}}
							</div>
						</a>

						<div class="p-6 sm:col-span-7 sm:p-7">
							<h3 class="text-xl font-semibold leading-snug tracking-tight text-balance"><a href="{{url}}" class="hover:underline hover:underline-offset-4">{{title}}</a></h3>
							<p class="mt-2 line-clamp-2 text-[13px] leading-relaxed text-silver">{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{excerpt words="24"}}{{/if}}</p>

							{{#primary_tag}}
							<div class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-[10px] uppercase tracking-[0.12em] text-silver">
								{{#get "posts" filter="tag:hash-guide-content+tags:{{slug}}" limit="1" as |s|}}
									<span class="flex items-center gap-1">{{> "icons/route" class="h-3 w-3"}} {{plural pagination.total empty="soon" singular="% step" plural="% steps"}}</span>
								{{/get}}
								<span class="flex items-center gap-1">{{> "icons/check" class="h-3 w-3"}} Free</span>
							</div>

							<div class="mt-5 border-t border-line pt-5">
								{{> "components/guide-stepper" tagSlug=slug active=""}}
							</div>
							{{/primary_tag}}

							<div class="mt-5 flex flex-wrap items-center gap-2">
								<a href="{{url}}" class="btn-primary btn-sm">{{> "icons/compass" class="h-3 w-3"}} Open guide</a>
								{{#primary_tag}}{{#get "posts" filter="tag:hash-guide-content+tags:{{slug}}" limit="1" order="published_at asc" as |first|}}
									{{#foreach first}}<a href="{{url}}" class="btn-ghost btn-sm">{{> "icons/play" class="h-3 w-3"}} Step 1</a>{{/foreach}}
								{{/get}}{{/primary_tag}}
							</div>
						</div>
					</div>
				</article>
				{{/foreach}}
			</div>
		</div>
	</div>
</section>
{{/if}}
{{/get}}
