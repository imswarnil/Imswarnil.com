{{!-- Guestbook teaser — points to /guestbook/ where Ghost comments act as the wall. --}}
<section class="reveal relative py-16" id="home-guestbook">
	<div class="container-site">
		<div class="relative overflow-hidden rounded-[2rem] border border-line bg-paper p-8 shadow-card sm:p-12">
			<div class="bg-dots pointer-events-none absolute inset-0 opacity-50" aria-hidden="true"></div>
			<div class="relative grid items-center gap-8 lg:grid-cols-12">
				<div class="lg:col-span-7">
					<p class="kicker">{{> "icons/heart"}} The guestbook</p>
					<h2 class="section-title mt-2 text-balance">Sign the wall. Everyone who was anyone did.</h2>
					<p class="mt-3 max-w-lg text-[15px] leading-relaxed text-silver">A guestbook in {{date format="YYYY"}}? Absolutely. Websites used to have souls — mine still does. Leave a note, a hot take, or just proof you were here before it was cool.</p>
					<div class="mt-6 flex flex-wrap gap-3">
						<a href="{{@site.url}}/guestbook/" class="btn-primary">{{> "icons/heart"}} Sign the guestbook</a>
						<a href="{{@site.url}}/guestbook/#ghost-comments-root" class="btn-ghost">Read the entries {{> "icons/arrow-right"}}</a>
					</div>
				</div>
				<div class="hidden lg:col-span-5 lg:block" aria-hidden="true">
					<div class="relative mx-auto max-w-xs">
						<div class="float-frame rotate-[-3deg] rounded-2xl border border-line bg-mist p-4 shadow-card" style="--tilt:-3deg">
							<p class="font-mono text-[10px] uppercase tracking-[0.2em] text-silver">entry #001</p>
							<p class="mt-2 text-sm font-medium">"Great site. Would scroll again." — a visitor, probably</p>
						</div>
						<div class="float-frame-alt ml-10 mt-4 rotate-[2deg] rounded-2xl border border-line bg-paper p-4 shadow-lift" style="--tilt:2deg">
							<p class="font-mono text-[10px] uppercase tracking-[0.2em] text-silver">entry #002</p>
							<p class="mt-2 text-sm font-medium">"I came for the Netflix theme mode. I stayed for the Netflix theme mode."</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
