{{!-- Portfolio strip — the "dear recruiter" section. Dense, scannable, CTA-heavy. --}}
<section class="reveal relative border-y border-line bg-mist/40 py-16" id="home-portfolio">
	<div class="bg-grid pointer-events-none absolute inset-0 opacity-50" aria-hidden="true"></div>
	<div class="container-site relative">
		<div class="grid gap-10 lg:grid-cols-12">
			<div class="lg:col-span-5">
				<p class="kicker">{{> "icons/briefcase"}} Dear recruiter</p>
				<h2 class="section-title mt-2 text-balance">The professional bit, minus the buzzwords*</h2>
				<p class="mt-4 max-w-md text-[15px] leading-relaxed text-silver">{{@custom.job_title}} at <a href="{{@custom.workplace_url}}" class="font-medium text-ink underline decoration-line underline-offset-4 hover:decoration-ink" target="_blank" rel="noopener">{{@custom.workplace}}</a>. I sit where marketing meets engineering: ad platforms, analytics pipelines, landing pages, automation — and the occasional camera.</p>
				<p class="mt-2 font-mono text-[10px] uppercase tracking-[0.2em] text-silver">*okay, one: "synergy". sorry.</p>
				<div class="mt-7 flex flex-wrap gap-3">
					<a href="{{@site.url}}/resume/" class="btn-primary">{{> "icons/briefcase"}} Full resume</a>
					<a href="{{@site.url}}/contact/" class="btn-ghost">{{> "icons/mail"}} Contact me</a>
					{{#if @custom.topmate_url}}<a href="{{@custom.topmate_url}}" target="_blank" rel="noopener" class="btn-ghost">{{> "icons/calendar" class="h-3.5 w-3.5"}} Book 1:1</a>{{/if}}
				</div>
			</div>
			<div class="lg:col-span-7">
				<div class="grid gap-4 sm:grid-cols-2" data-reveal-stagger="90">
					<div class="card-surface !transform-none p-5">
						<p class="kicker !text-[10px]">{{> "icons/zap"}} Core stack</p>
						<div class="mt-3 flex flex-wrap gap-1.5">
							<span class="chip">Google Ads</span><span class="chip">GA4</span><span class="chip">GTM</span><span class="chip">Looker Studio</span><span class="chip">SQL</span><span class="chip">JavaScript</span><span class="chip">Ghost</span><span class="chip">Tailwind</span>
						</div>
					</div>
					<div class="card-surface !transform-none p-5">
						<p class="kicker !text-[10px]">{{> "icons/trophy"}} Highlights</p>
						<ul class="mt-3 space-y-2 text-sm leading-relaxed text-silver">
							<li class="flex gap-2">{{> "icons/check" class="mt-0.5 h-3.5 w-3.5 shrink-0 text-ink"}} Senior MarTech at {{@custom.workplace}} — ed-tech scale</li>
							<li class="flex gap-2">{{> "icons/check" class="mt-0.5 h-3.5 w-3.5 shrink-0 text-ink"}} 10k+ subscribers teaching marketing tech</li>
							<li class="flex gap-2">{{> "icons/check" class="mt-0.5 h-3.5 w-3.5 shrink-0 text-ink"}} Ships own tools, themes &amp; automations</li>
						</ul>
					</div>
					<div class="card-surface !transform-none p-5">
						<p class="kicker !text-[10px]">{{> "icons/map-pin"}} Logistics</p>
						<ul class="mt-3 space-y-2 text-sm leading-relaxed text-silver">
							<li>Based in India · works in any timezone with coffee</li>
							<li>B.Tech CSE · marketer who reads stack traces</li>
							<li>Notice period: reasonable · humor: unreasonable</li>
						</ul>
					</div>
					<div class="card-surface !transform-none p-5">
						<p class="kicker !text-[10px]">{{> "icons/heart"}} References</p>
						<p class="mt-3 text-sm leading-relaxed text-silver">"He measures everything, including how long this section took to build." — a colleague, allegedly. Real references on request; the guestbook doesn't count.</p>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>
