{{!-- Dear recruiter — cinematic pitch. Tall band: big type + CTA stack on
     the left, an auto-playing illustration slideshow (code → camera →
     dashboard) on the right, receipts (filterable project grid) below, and
     a half-visible resume rising behind mountains as the closer. --}}
<section class="reveal relative overflow-hidden border-y border-line bg-mist/40" id="home-portfolio">
	<div class="bg-grid pointer-events-none absolute inset-0 opacity-50" aria-hidden="true"></div>
	<div class="container-site relative pt-20 sm:pt-28">
		<div class="grid items-center gap-12 lg:min-h-[60vh] lg:grid-cols-12">
			{{!-- the pitch: less detail, more direction --}}
			<div class="lg:col-span-6">
				<p class="kicker">{{> "icons/briefcase"}} Dear recruiter</p>
				<h2 class="mt-3 text-balance text-4xl font-bold leading-[1.05] tracking-tight sm:text-5xl lg:text-6xl">The professional bit, <span class="text-silver">with receipts.</span></h2>
				<p class="mt-5 max-w-md text-[16px] leading-relaxed text-silver">Salesforce Engineer at <a href="https://www.ef.com" class="font-medium text-ink underline decoration-line underline-offset-4 hover:decoration-ink" target="_blank" rel="noopener">EF Education First</a>. I sit where marketing meets engineering — and everything below this line is proof, not promise.</p>

				<div class="mt-4 flex flex-wrap gap-1.5">
					<span class="chip !border-transparent !bg-ink !text-paper">GTM</span>
					<span class="chip !border-transparent !bg-ink !text-paper">Salesforce</span>
					<span class="chip !border-transparent !bg-ink !text-paper">CRM</span>
					<span class="chip !border-transparent !bg-ink !text-paper">Analytics</span>
					<span class="chip">SQL</span>
					<span class="chip">JavaScript</span>
				</div>

				<div class="mt-8 flex flex-wrap items-center gap-3">
					<a href="{{@site.url}}/resume/" class="btn-primary btn-lg">{{> "icons/briefcase"}} View the resume</a>
					<a href="{{@site.url}}/contact/" class="btn-ghost">{{> "icons/mail"}} Hire me before someone else does</a>
				</div>
				<div class="mt-3 flex flex-wrap items-center gap-3">
					<a href="{{@site.url}}/experiences/" class="btn-ghost btn-sm">{{> "icons/star" class="h-3 w-3"}} Experiences</a>
					<a href="{{@site.url}}/timeline/" class="btn-ghost btn-sm">{{> "icons/calendar" class="h-3 w-3"}} Career timeline</a>
					<a href="https://linkedin.com/in/imswarnil" target="_blank" rel="noopener" class="btn-ghost btn-sm">{{> "icons/linkedin" class="h-3 w-3"}} LinkedIn</a>
				</div>
			</div>

			{{!-- illustration slideshow — the three hats, crossfading --}}
			<div class="relative hidden lg:col-span-6 lg:block" aria-hidden="true">
				<div class="pf-stage">
					{{!-- scene 1: the engineer — VS Code window --}}
					<div class="pf-scene" style="--s:0">
						<div class="pf-window">
							<div class="pf-winbar"><i></i><i></i><i></i><em>campaign-sync.js — imswarnil</em></div>
							<div class="pf-code">
								<span style="--w:62%"></span><span style="--w:84%"></span><span style="--w:48%"></span>
								<span style="--w:72%"></span><span style="--w:38%"></span><span style="--w:66%"></span>
							</div>
						</div>
						<p class="pf-caption">ships the landing pages himself</p>
					</div>
					{{!-- scene 2: the creator — camcorder frame --}}
					<div class="pf-scene" style="--s:1">
						<div class="pf-window pf-cam">
							<div class="pf-camhud"><b>● REC</b><em>00:04:47</em></div>
							<div class="pf-camlens">{{> "icons/play" class="h-8 w-8"}}</div>
							<div class="pf-cambar"><em>10k+ learn marketing tech from my videos</em></div>
						</div>
						<p class="pf-caption">teaches what he ships</p>
					</div>
					{{!-- scene 3: the analyst — dashboard bars --}}
					<div class="pf-scene" style="--s:2">
						<div class="pf-window">
							<div class="pf-winbar"><i></i><i></i><i></i><em>gtm-dashboard — looker studio</em></div>
							<div class="pf-bars">
								<span style="--h:42%"></span><span style="--h:68%"></span><span style="--h:55%"></span>
								<span style="--h:88%"></span><span style="--h:73%"></span><span style="--h:96%"></span>
							</div>
						</div>
						<p class="pf-caption">measures everything, twice</p>
					</div>
				</div>
			</div>
		</div>

		{{!-- receipts: skill filter + project grid --}}
		<div class="mt-16 flex flex-wrap items-center gap-1.5" id="project-skill-filters" hidden>
			<span class="kicker mr-1 !text-[10px]">{{> "icons/zap" class="h-3 w-3"}} Filter</span>
		</div>

		{{#get "posts" filter="tag:hash-project" limit="6" include="tags" as |projects|}}
			{{#if projects}}
			<div class="mt-6 grid gap-5 md:grid-cols-2 xl:grid-cols-3" id="home-projects-grid" data-reveal-stagger="90">
				{{#foreach projects}}
				<div class="home-project" data-skills="{{#foreach tags visibility="internal"}}{{slug}} {{/foreach}}">
					{{> "project/card"}}
				</div>
				{{/foreach}}
			</div>
			{{else}}
			<p class="mt-8 rounded-2xl border border-dashed border-line p-10 text-center text-sm text-silver">Tag posts with <code class="rounded bg-mist px-1.5 py-0.5 font-mono text-xs">#project</code> to showcase them here.</p>
			{{/if}}
		{{/get}}
	</div>

	{{!-- (mountain-styled resume peek removed) --}}
	<div class="pb-20 sm:pb-28"></div>

	<script>
		(function () {
			/* skill filter, built from each card's internal #skill-* tags */
			var wrap = document.getElementById('project-skill-filters');
			var cards = [].slice.call(document.querySelectorAll('.home-project'));
			if (!wrap || !cards.length) return;
			var skills = {};
			cards.forEach(function (c) {
				(c.getAttribute('data-skills') || '').split(/\s+/).forEach(function (t) {
					if (t.indexOf('hash-skill-') === 0) {
						skills[t] = t.replace('hash-skill-', '').replace(/-/g, ' ');
					}
				});
			});
			var keys = Object.keys(skills);
			if (!keys.length) return;
			wrap.hidden = false;
			function chip(label, tag) {
				var b = document.createElement('button');
				b.type = 'button';
				b.className = 'chip transition hover:bg-mist' + (tag ? '' : ' !bg-ink !text-paper');
				b.textContent = label;
				b.addEventListener('click', function () {
					[].forEach.call(wrap.querySelectorAll('button'), function (x) { x.classList.remove('!bg-ink', '!text-paper'); });
					b.classList.add('!bg-ink', '!text-paper');
					cards.forEach(function (c) {
						c.style.display = !tag || (c.getAttribute('data-skills') || '').indexOf(tag) > -1 ? '' : 'none';
					});
				});
				wrap.appendChild(b);
			}
			chip('Everything', null);
			keys.sort().forEach(function (t) { chip(skills[t], t); });
		})();
	</script>
</section>
