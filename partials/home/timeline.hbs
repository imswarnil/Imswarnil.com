{{!-- Life, in commits — compact journey strip. Featured #timeline moments
     first; falls back to the latest ones when nothing is featured. --}}
<section class="reveal relative border-y border-line bg-mist/40 py-14" id="home-timeline">
	<div class="bg-dots pointer-events-none absolute inset-0 opacity-50" aria-hidden="true"></div>
	<div class="container-site relative">
		{{> "components/section-head"
			kicker="The long game"
			title="Life, in commits"
			sub="The milestones that shaped the work — highlights only."
			actionUrl=(concat @site.url "/timeline/") actionLabel="Full timeline"}}

		{{#get "posts" filter="tag:hash-timeline+featured:true" limit="4" as |moments|}}
			{{#if moments}}
			<ol class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-4" data-reveal-stagger="80">
				{{#foreach moments}}
				<li>
					<a href="{{@site.url}}/timeline/#tl-{{slug}}" class="group flex h-full flex-col rounded-xl border border-line bg-paper p-4 transition hover:-translate-y-0.5 hover:shadow-card">
						<span class="font-mono text-[10px] uppercase tracking-[0.2em] text-silver">{{date published_at format="MMM YYYY"}} · {{> "icons/star" class="inline h-3 w-3"}}</span>
						<strong class="mt-1.5 text-[13.5px] font-semibold leading-snug tracking-tight">{{title}}</strong>
						<span class="mt-1 line-clamp-2 text-[12px] leading-snug text-silver">{{custom_excerpt}}{{^custom_excerpt}}{{excerpt words="12"}}{{/custom_excerpt}}</span>
					</a>
				</li>
				{{/foreach}}
			</ol>
			{{else}}
			{{#get "posts" filter="tag:hash-timeline" limit="4" as |fallback|}}
				{{#if fallback}}
				<ol class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-4" data-reveal-stagger="80">
					{{#foreach fallback}}
					<li>
						<a href="{{@site.url}}/timeline/#tl-{{slug}}" class="group flex h-full flex-col rounded-xl border border-line bg-paper p-4 transition hover:-translate-y-0.5 hover:shadow-card">
							<span class="font-mono text-[10px] uppercase tracking-[0.2em] text-silver">{{date published_at format="MMM YYYY"}}</span>
							<strong class="mt-1.5 text-[13.5px] font-semibold leading-snug tracking-tight">{{title}}</strong>
							<span class="mt-1 line-clamp-2 text-[12px] leading-snug text-silver">{{custom_excerpt}}{{^custom_excerpt}}{{excerpt words="12"}}{{/custom_excerpt}}</span>
						</a>
					</li>
					{{/foreach}}
				</ol>
				{{else}}
				<p class="mt-8 rounded-2xl border border-dashed border-line p-10 text-center text-sm text-silver">Tag posts with <code class="rounded bg-mist px-1.5 py-0.5 font-mono text-xs">#timeline</code> to log your story here.</p>
				{{/if}}
			{{/get}}
			{{/if}}
		{{/get}}
	</div>
</section>
