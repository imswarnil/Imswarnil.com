{{!-- Latest videos — scroll-snap carousel with player-style thumbnail cards, prev/next controls and a subscribe CTA. --}}
<section class="reveal relative py-16" id="home-videos">
	<div class="container-site">
		<div class="flex flex-wrap items-end justify-between gap-4">
			<div>
				<p class="kicker">{{> "icons/film"}} The screening room</p>
				<h2 class="section-title mt-2">Latest videos</h2>
			</div>
			<div class="flex shrink-0 items-center gap-2">
				{{#if @custom.youtube_url}}
					<a href="{{@custom.youtube_url}}" target="_blank" rel="noopener" class="btn-primary tooltip tooltip-bottom" data-tip="New video every week">{{> "icons/youtube"}} Subscribe</a>
				{{/if}}
				<a href="{{@site.url}}/videos/" class="btn-ghost">All videos {{> "icons/arrow-right"}}</a>
				<span class="mx-1 hidden h-6 w-px bg-line sm:block" aria-hidden="true"></span>
				<button type="button" class="icon-btn hidden sm:inline-flex" data-videos-prev aria-label="Previous videos"><span class="rotate-180">{{> "icons/arrow-right"}}</span></button>
				<button type="button" class="icon-btn hidden sm:inline-flex" data-videos-next aria-label="Next videos">{{> "icons/arrow-right"}}</button>
			</div>
		</div>
	</div>

	{{#get "posts" filter="tag:hash-video" limit="8" include="tags" as |videos|}}
		{{#if videos}}
		<div class="no-scrollbar mt-8 snap-x snap-proximity scroll-smooth overflow-x-auto pb-4 fade-mask-x [touch-action:pan-x_pan-y] [overscroll-behavior-x:contain]" data-videos-track style="scroll-padding-left: max(1.5rem, calc((100vw - 72rem) / 2 + 1.5rem))">
			<div class="container-site">
				<div class="flex w-max gap-5 pr-8">
					{{#foreach videos}}
					<article class="group w-[17rem] shrink-0 snap-start sm:w-[20rem]" data-videos-card>
						<a href="{{url}}" class="block" aria-label="Watch: {{title}}">
							<div class="relative aspect-video overflow-hidden rounded-2xl border border-line bg-mist shadow-card transition-all duration-300 group-hover:shadow-lift">
								{{#if feature_image}}
									<img src="{{img_url feature_image size="600"}}"
										srcset="{{img_url feature_image size="300"}} 300w, {{img_url feature_image size="600"}} 600w, {{img_url feature_image size="1000"}} 1000w"
										sizes="(max-width: 640px) 80vw, 320px"
										alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
										loading="lazy"
										class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
								{{else}}
									<div class="bg-dots flex h-full w-full items-center justify-center">{{> "icons/film" class="text-silver"}}</div>
								{{/if}}
								<div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-60 transition-opacity duration-300 group-hover:opacity-90" aria-hidden="true"></div>
								<span class="absolute left-3 top-3 flex h-9 w-9 items-center justify-center rounded-full bg-white/90 text-black shadow-lg backdrop-blur transition-transform duration-300 group-hover:scale-110">{{> "icons/play" class="ml-0.5 h-4 w-4"}}</span>
								{{#if featured}}<span class="absolute right-3 top-3 chip !border-transparent !bg-white/90 !text-black backdrop-blur">{{> "icons/zap"}} Featured</span>{{/if}}
								<span class="absolute bottom-2.5 right-2.5 rounded-md bg-black/75 px-1.5 py-0.5 font-mono text-[11px] font-semibold tabular-nums text-white backdrop-blur" data-duration-tags="{{#foreach tags visibility="internal"}}{{slug}} {{/foreach}}" hidden></span>
							</div>
							<div class="mt-3 px-0.5">
								<h3 class="line-clamp-2 text-[15px] font-semibold leading-snug tracking-tight transition group-hover:text-silver">{{title}}</h3>
								<p class="mt-1.5 flex flex-wrap items-center gap-x-2 gap-y-1 font-mono text-[11px] text-silver">
									{{> "icons/calendar" class="h-3.5 w-3.5"}} {{date published_at format="DD MMM YYYY"}}
									{{#primary_tag}}
										<span class="opacity-40">·</span>
										<span class="rounded bg-mist px-1.5 py-0.5 text-[10px] uppercase tracking-[0.12em]">{{name}}</span>
									{{/primary_tag}}
								</p>
							</div>
						</a>
					</article>
					{{/foreach}}
				</div>
			</div>
		</div>

		<script>
			(function () {
				var section = document.getElementById('home-videos');
				if (!section) return;
				var track = section.querySelector('[data-videos-track]');
				var card = section.querySelector('[data-videos-card]');
				if (!track || !card) return;
				var step = function () { return card.getBoundingClientRect().width + 20; };
				var prev = section.querySelector('[data-videos-prev]');
				var next = section.querySelector('[data-videos-next]');
				if (prev) prev.addEventListener('click', function () { track.scrollBy({ left: -step() * 2, behavior: 'smooth' }); });
				if (next) next.addEventListener('click', function () { track.scrollBy({ left: step() * 2, behavior: 'smooth' }); });
			})();
		</script>
		{{else}}
		<div class="container-site mt-8"><p class="rounded-2xl border border-dashed border-line p-10 text-center text-sm text-silver">Tag posts with <code class="rounded bg-mist px-1.5 py-0.5 font-mono text-xs">#video</code> and they premiere here.</p></div>
		{{/if}}
	{{/get}}
</section>
