{{!-- Products I use — promo band, not a listing. Real product thumbnails
     float around the copy like gear on a desk; one big CTA sends people to
     /products/ where the full toolkit lives. --}}
<section class="reveal relative py-16" id="home-products">
	<div class="container-site">
		<div class="prod-teaser">
			<div class="bg-dots pointer-events-none absolute inset-0 opacity-40" aria-hidden="true"></div>

			{{!-- floating gear — pulled from real #product posts --}}
			{{#get "posts" filter="tag:hash-product" limit="8" order="published_at desc" as |gear|}}
				{{#if gear}}
				<div class="prod-float" aria-hidden="true">
					{{#foreach gear}}
					<span class="prod-chip" style="--i:{{@index}}">
						{{#if feature_image}}
							<img src="{{img_url feature_image size="100"}}" width="44" height="44" alt="" loading="lazy" />
						{{else}}
							{{> "icons/cart" class="h-4 w-4"}}
						{{/if}}
					</span>
					{{/foreach}}
				</div>
				{{/if}}
			{{/get}}

			<div class="relative mx-auto max-w-xl py-14 text-center sm:py-20">
				<p class="kicker justify-center">{{> "icons/cart" class="h-3.5 w-3.5"}} The toolkit</p>
				<h2 class="section-title mt-3 text-balance">Every camera, cable &amp; app behind this site</h2>
				<p class="mx-auto mt-4 max-w-md text-[15px] leading-relaxed text-silver">Reviewed after real miles, not unboxing day. The full desk tour — hardware, software and the services that keep the lights on — lives on one page.</p>
				<div class="mt-8 flex flex-wrap items-center justify-center gap-3">
					<a href="{{@site.url}}/products/" class="btn-primary btn-lg">{{> "icons/zap" class="h-4 w-4"}} Browse the full toolkit</a>
					<a href="{{@site.url}}/shop/" class="btn-ghost">{{> "icons/cart" class="h-3.5 w-3.5"}} Shop picks</a>
				</div>
				<p class="mt-5 font-mono text-[10px] uppercase tracking-[0.2em] text-silver">affiliate links keep the lights on · opinions stay mine</p>
			</div>
		</div>
	</div>
</section>
