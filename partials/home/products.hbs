{{!-- Products I use to create — grouped shelves: recent purchase first, then
     "Tools I love" (services), "Products I use" (setup), "Recommendations"
     (everything else). Compact horizontal cards, image first, 3 per row. --}}
<section class="reveal relative py-16" id="home-products">
	<div class="container-site">
		{{> "components/section-head"
			kicker="The toolkit"
			title="Products I use to create"
			sub="I keep sharing what I actually use and love — reviewed after real miles, affiliate links keep the lights on."
			actionUrl=(concat @site.url "/products/") actionLabel="Full toolkit"}}

		{{!-- Recent purchase — the newest thing on the shelf --}}
		{{#get "posts" filter="tag:hash-product" limit="3" order="published_at desc" include="tags" as |fresh|}}
			{{#if fresh}}
			<p class="kicker mt-8 !text-[10px]">{{> "icons/cart" class="h-3 w-3"}} Recent purchases</p>
			<div class="mt-3 grid gap-4 sm:grid-cols-2 xl:grid-cols-3" data-reveal-stagger="70">
				{{#foreach fresh}}
					{{> "cards/product-mini" latest=@first}}
				{{/foreach}}
			</div>
			{{/if}}
		{{/get}}

		{{!-- Tools I love — services --}}
		{{#get "posts" filter="tag:hash-product+tag:hash-group-services" limit="3" include="tags" as |tools|}}
			{{#if tools}}
			<p class="kicker mt-10 !text-[10px]">{{> "icons/heart" class="h-3 w-3"}} Tools I love</p>
			<div class="mt-3 grid gap-4 sm:grid-cols-2 xl:grid-cols-3" data-reveal-stagger="70">
				{{#foreach tools}}
					{{> "cards/product-mini"}}
				{{/foreach}}
			</div>
			{{/if}}
		{{/get}}

		{{!-- Products I use — the physical setup --}}
		{{#get "posts" filter="tag:hash-product+tag:hash-group-my-setup" limit="3" include="tags" as |setup|}}
			{{#if setup}}
			<p class="kicker mt-10 !text-[10px]">{{> "icons/zap" class="h-3 w-3"}} Products I use</p>
			<div class="mt-3 grid gap-4 sm:grid-cols-2 xl:grid-cols-3" data-reveal-stagger="70">
				{{#foreach setup}}
					{{> "cards/product-mini"}}
				{{/foreach}}
			</div>
			{{/if}}
		{{/get}}

		{{!-- Recommendations — everything else worth sharing --}}
		{{#get "posts" filter="tag:hash-product+tag:-[hash-group-services,hash-group-my-setup]" limit="3" include="tags" as |recs|}}
			{{#if recs}}
			<p class="kicker mt-10 !text-[10px]">{{> "icons/sparkle" class="h-3 w-3"}} Recommendations</p>
			<div class="mt-3 grid gap-4 sm:grid-cols-2 xl:grid-cols-3" data-reveal-stagger="70">
				{{#foreach recs}}
					{{> "cards/product-mini"}}
				{{/foreach}}
			</div>
			{{/if}}
		{{/get}}
	</div>
</section>
