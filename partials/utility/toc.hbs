{{!-- Table of contents — the ONE toc module for the whole theme.

     Built client-side by main.js from h2/h3 in .gh-content (scrollspy
     included: the observer toggles .is-active and keeps the current link in
     view). Stays hidden until main.js finds at least two headings.

     Params:
       title — heading label (default "On this page")
       class — extra classes for placement (width, order, sticky wrapper) --}}
<nav class="toc {{class}}" id="toc" hidden aria-label="Table of contents">
	<p class="kicker !text-[10px]">{{> "icons/book" class="h-3 w-3"}} {{#if title}}{{title}}{{else}}On this page{{/if}}</p>
	<nav class="toc-list" id="toc-list"></nav>
	<script
  src="https://no-ai-content-2v24d1lp7-imswarnil-projects.vercel.app/widget.js"
  data-message="This content is written by a human. No AI-generated content."
  data-theme="light"
  async
></script>
</nav>
