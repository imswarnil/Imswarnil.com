{{!-- Collection header. Copy sits left; on xl+ a 728×90 leaderboard fills the
     empty right half (renders only when AdSense is enabled — no placeholder here
     so the header stays clean when ads are off). --}}
<header class="relative overflow-hidden border-b border-line py-8 sm:py-10">
	<div class="bg-grid pointer-events-none absolute inset-0 fade-mask-b" aria-hidden="true"></div>
	<div class="container-site relative flex items-end justify-between gap-10">
		<div class="min-w-0">
			{{!-- breadcrumbs: Home → this collection --}}
			<nav class="mb-2.5 flex items-center gap-1.5 font-mono text-[10px] font-semibold uppercase tracking-[0.16em] text-silver animate-fade-in" aria-label="Breadcrumb">
				<a href="{{@site.url}}" class="inline-flex items-center gap-1 transition hover:text-ink">{{> "icons/home" class="h-3 w-3"}} Home</a>
				{{> "icons/arrow-right" class="h-2.5 w-2.5 opacity-40"}}
				<span class="text-ink">{{title}}</span>
			</nav>
			<p class="kicker animate-fade-in">{{kicker}}</p>
			<h1 class="mt-2.5 max-w-3xl text-3xl font-semibold tracking-tight sm:text-4xl animate-fade-up text-balance">{{title}}</h1>
			{{#if desc}}<p class="mt-3 max-w-xl text-base leading-relaxed text-silver animate-fade-in" style="animation-delay:.2s">{{desc}}</p>{{/if}}
		</div>
		{{#unless @member}}
		<div class="hidden w-[728px] shrink-0 xl:block">
			<ins class="adsbygoogle block" style="width:728px;height:90px"
				data-ad-client="ca-pub-1291242080282540"
				data-ad-slot="8939839370"></ins>
			{{> "components/ad-optout" class="mt-1 justify-end"}}
		</div>
		{{/unless}}
	</div>
</header>
