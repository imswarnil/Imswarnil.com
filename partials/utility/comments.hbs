{{!-- Themed Ghost comments. The comments UI lives in an iframe, so CSS can't
     reach inside — but its script tag reads data-accent-color / data-color-scheme
     at init. The inline script below runs during parse (before the deferred
     comments-ui bundle executes) and rewrites those attributes to match the
     active theme mode, so avatars/buttons/links follow the switcher.
     Usage: {{> "utility/comments" title="Discussion"}} --}}
<div class="comments-shell rounded-2xl border border-line bg-mist/30 p-5 sm:p-7">
	{{#if title}}
		{{comments title=title count=true}}
	{{else}}
		{{comments count=true}}
	{{/if}}
</div>
<script>
	(function () {
		var tags = document.querySelectorAll('script[data-ghost-comments]');
		var s = tags[tags.length - 1];
		if (!s) return;
		var root = document.documentElement;
		var cs = getComputedStyle(root);
		var accent = cs.getPropertyValue('--ghost-accent-color').trim();
		if (accent) s.setAttribute('data-accent-color', accent);
		/* dark whenever the active mode says so (covers .dark AND dark modes
		   like netflix) — color-scheme is set per mode in tailwind.css */
		var dark = root.classList.contains('dark') || (cs.colorScheme || '').indexOf('dark') > -1;
		s.setAttribute('data-color-scheme', dark ? 'dark' : 'light');
	})();
</script>
