<footer class="relative mt-24 border-t border-line">
	<div class="bg-dots pointer-events-none absolute inset-0 opacity-60" aria-hidden="true"></div>
	<div class="container-site relative py-16">
		<div class="grid gap-12 md:grid-cols-12">
			<div class="md:col-span-5">
				{{> "utility/logo"}}
				<p class="mt-5 max-w-sm text-[15px] leading-relaxed text-silver">Framing the color 1:1, cropping out the noise.</p>
				<p class="mt-4 text-sm text-silver">Salesforce Engineer · <a href="https://www.ef.com" class="font-medium text-ink underline decoration-line underline-offset-4 hover:decoration-ink" target="_blank" rel="noopener">EF Education First</a></p>
				<div class="mt-6 flex items-center gap-1">
					{{#if @site.facebook}}<a href="{{social_url type="facebook"}}" class="icon-btn" target="_blank" rel="noopener" aria-label="Facebook">{{> "icons/heart"}}</a>{{/if}}
					{{#if @site.twitter}}<a href="{{social_url type="twitter"}}" class="icon-btn" target="_blank" rel="noopener" aria-label="X (Twitter)">{{> "icons/x-twitter"}}</a>{{/if}}
					<a href="https://github.com/imswarnil/imswarnil.com" class="icon-btn" target="_blank" rel="noopener" aria-label="GitHub">{{> "icons/github"}}</a>
					<a href="https://www.youtube.com/@imswarnil" class="icon-btn" target="_blank" rel="noopener" aria-label="YouTube">{{> "icons/youtube"}}</a>
					<a href="https://www.linkedin.com/in/imswarnil" class="icon-btn" target="_blank" rel="noopener" aria-label="LinkedIn">{{> "icons/linkedin"}}</a>
					<a href="{{@site.url}}/rss/" class="icon-btn" aria-label="RSS feed">{{> "icons/rss"}}</a>
				</div>
			</div>

			<nav class="md:col-span-2" aria-label="Explore">
				<h3 class="kicker">Explore</h3>
				<ul class="mt-4 space-y-2.5 text-sm">
					<li><a class="flex items-center gap-2 text-silver transition hover:text-ink" href="{{@site.url}}/videos/">{{> "icons/play" class="h-3.5 w-3.5"}} Videos</a></li>
					<li><a class="flex items-center gap-2 text-silver transition hover:text-ink" href="{{@site.url}}/blog/">{{> "icons/pen" class="h-3.5 w-3.5"}} Blog</a></li>
					<li><a class="flex items-center gap-2 text-silver transition hover:text-ink" href="{{@site.url}}/projects/">{{> "icons/code" class="h-3.5 w-3.5"}} Projects</a></li>
					<li><a class="flex items-center gap-2 text-silver transition hover:text-ink" href="{{@site.url}}/courses/">{{> "icons/graduation" class="h-3.5 w-3.5"}} Courses</a></li>
					<li><a class="flex items-center gap-2 text-silver transition hover:text-ink" href="{{@site.url}}/webseries/">{{> "icons/tv" class="h-3.5 w-3.5"}} Webseries</a></li>
				</ul>
			</nav>

			<nav class="md:col-span-2" aria-label="Life">
				<h3 class="kicker">Life</h3>
				<ul class="mt-4 space-y-2.5 text-sm">
					<li><a class="flex items-center gap-2 text-silver transition hover:text-ink" href="{{@site.url}}/timeline/">{{> "icons/calendar" class="h-3.5 w-3.5"}} Timeline</a></li>
					<li><a class="flex items-center gap-2 text-silver transition hover:text-ink" href="{{@site.url}}/resume/">{{> "icons/briefcase" class="h-3.5 w-3.5"}} Resume</a></li>
					<li><a class="flex items-center gap-2 text-silver transition hover:text-ink" href="{{@site.url}}/products/">{{> "icons/cart" class="h-3.5 w-3.5"}} Products I use</a></li>
					<li><a class="flex items-center gap-2 text-silver transition hover:text-ink" href="{{@site.url}}/changelog/">{{> "icons/zap" class="h-3.5 w-3.5"}} Changelog</a></li>
				</ul>
			</nav>

			<nav class="md:col-span-3" aria-label="Connect">
				<h3 class="kicker">Connect</h3>
				<ul class="mt-4 space-y-2.5 text-sm">
					<li><a class="flex items-center gap-2 text-silver transition hover:text-ink" href="{{@site.url}}/newsletters/">{{> "icons/mail" class="h-3.5 w-3.5"}} Newsletter</a></li>
					<li><a class="flex items-center gap-2 text-silver transition hover:text-ink" href="{{@site.url}}/guestbook/">{{> "icons/heart" class="h-3.5 w-3.5"}} Sign the guestbook</a></li>
					<li><a class="flex items-center gap-2 text-silver transition hover:text-ink" href="{{@site.url}}/sponsor/">{{> "icons/cash" class="h-3.5 w-3.5"}} Sponsor me</a></li>
					<li><a class="flex items-center gap-2 text-silver transition hover:text-ink" href="mailto:swarnilsinghaicse@gmail.com">{{> "icons/contact" class="h-3.5 w-3.5"}} Say hello</a></li>
					<li><a class="flex items-center gap-2 text-silver transition hover:text-ink" href="{{@site.url}}/sitemap-visual/">{{> "icons/map-pin" class="h-3.5 w-3.5"}} Sitemap</a></li>
				</ul>
				{{#if @site.members_enabled}}
				<button type="button" class="btn-ghost btn-sm mt-6" data-modal-open="#subscribe-backdrop">{{> "icons/bell" class="h-3 w-3"}} Why subscribe?</button>
				{{/if}}
			</nav>
		</div>

		<div class="mt-14 flex flex-col items-center justify-between gap-4 border-t border-line pt-8 font-mono text-xs text-silver sm:flex-row">
			<p>© {{date format="YYYY"}} {{@site.title}} — {{t "All rights reserved"}}.</p>
			<p class="flex items-center gap-1.5">crafted 1:1 · noise cropped out {{> "icons/sparkle" class="text-silver"}}</p>
			<p><a href="https://ghost.org" target="_blank" rel="noopener" class="transition hover:text-ink">{{t "Published with Ghost"}}</a></p>
		</div>
	</div>
</footer>
