{{#if pagination.pages}}
	<nav class="mt-10 flex items-center justify-between border-t border-zinc-200 pt-6 text-sm dark:border-zinc-800" aria-label="Pagination">
		{{#if prev}}
			<a href="{{page_url prev}}" class="rounded-md border border-zinc-300 px-3 py-1.5 hover:bg-zinc-100 dark:border-zinc-700 dark:hover:bg-zinc-800">Newer</a>
		{{else}}
			<span></span>
		{{/if}}

		<span class="text-zinc-500">Page {{page}} of {{pages}}</span>

		{{#if next}}
			<a href="{{page_url next}}" class="rounded-md border border-zinc-300 px-3 py-1.5 hover:bg-zinc-100 dark:border-zinc-700 dark:hover:bg-zinc-800">Older</a>
		{{else}}
			<span></span>
		{{/if}}
	</nav>
{{/if}}
