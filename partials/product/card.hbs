{{!-- Product shelf-item card — image on a shelf, name, one-liner, group chip, affiliate hint --}}
<article class="card-surface group relative overflow-hidden {{class}}">
	<a href="{{url}}" class="flex h-full flex-col" aria-label="View product: {{title}}">
		{{!-- Shelf: image sits on a line, like an object on a shelf --}}
		<div class="bg-dots relative flex aspect-[4/3] items-end justify-center overflow-hidden border-b border-line px-8 pt-6">
			{{#if feature_image}}
				<img src="{{img_url feature_image size="600"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" loading="lazy"
					class="max-h-[85%] w-auto max-w-full rounded-t-xl border border-b-0 border-line object-contain shadow-lift transition-transform duration-500 group-hover:-translate-y-1.5" />
			{{else}}
				<div class="flex h-full w-full items-center justify-center pb-6">{{> "icons/zap" class="text-silver"}}</div>
			{{/if}}
		</div>
		<div class="flex flex-1 flex-col p-5">
			<div class="flex items-start justify-between gap-2">
				<h3 class="text-[15px] font-semibold leading-snug tracking-tight">{{title}}</h3>
				{{> "icons/arrow-up-right" class="mt-0.5 shrink-0 text-silver transition group-hover:text-ink"}}
			</div>
			<p class="mt-1.5 line-clamp-2 text-[13px] leading-relaxed text-silver">{{custom_excerpt}}{{^custom_excerpt}}{{excerpt words="18"}}{{/custom_excerpt}}</p>
			<div class="mt-auto flex items-center justify-between gap-2 pt-4">
				{{!-- Group chip — derived from the internal #group-* tag --}}
				{{#has tag="#group-services"}}
					<span class="chip">Services</span>
				{{else has tag="#group-my-setup"}}
					<span class="chip">My setup</span>
				{{else has tag="#group-skin-care"}}
					<span class="chip">Skin care</span>
				{{else has tag="#group-travel"}}
					<span class="chip">Travel kit</span>
				{{else}}
					{{#primary_tag}}<span class="chip">{{name}}</span>{{/primary_tag}}
				{{/has}}
				<span class="inline-flex items-center gap-1 font-mono text-[10px] uppercase tracking-[0.2em] text-silver/80 transition group-hover:text-accent">affiliate {{> "icons/arrow-up-right" class="!h-3 !w-3"}}</span>
			</div>
		</div>
	</a>
</article>
