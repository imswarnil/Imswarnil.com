{{!-- Snippet detail — the code in an editor-chrome card with a Copy button,
     plus notes. The body's first <pre> is the snippet; the rest is commentary. --}}
<article class="{{post_class}}">
	<header class="relative overflow-hidden border-b border-line py-12">
		<div class="bg-cross pointer-events-none absolute inset-0 fade-mask-b" aria-hidden="true"></div>
		<div class="container-site relative">
			<nav class="flex flex-wrap items-center gap-2 font-mono text-[11px] uppercase tracking-[0.15em] text-silver" aria-label="Breadcrumb">
				<a href="{{@site.url}}/prompts/" class="transition hover:text-ink">Prompts &amp; snippets</a>
				<span aria-hidden="true">/</span><span class="text-ink">{{slug}}</span>
			</nav>
			<h1 class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl text-balance">{{title}}</h1>
			{{#if custom_excerpt}}<p class="mt-3 max-w-2xl text-lg leading-relaxed text-silver">{{custom_excerpt}}</p>{{/if}}
			<div class="mt-4 flex flex-wrap items-center gap-2">
				{{#foreach tags visibility="public"}}<a href="{{url}}" class="chip transition hover:border-ink hover:text-ink">{{name}}</a>{{/foreach}}
				<span class="chip">{{> "icons/calendar"}} {{date published_at format="MMM YYYY"}}</span>
			</div>
		</div>
	</header>

	<div class="container-site py-10">
		<div class="mx-auto max-w-3xl">
			{{!-- the snippet card (code injected by JS from the body) --}}
			<div class="snippet-card">
				<div class="snippet-bar">
					<span class="dot" style="background:#ff5f57"></span>
					<span class="dot" style="background:#febc2e"></span>
					<span class="dot" style="background:#28c840"></span>
					<span class="ml-1.5 min-w-0 truncate">{{slug}}</span>
					<button type="button" class="ml-auto inline-flex items-center gap-1 rounded bg-white/10 px-2 py-1 font-mono text-[11px] text-[#d4d4d4] transition hover:bg-white/20" data-copy="#snippet-raw" data-copied="Copied ✓"><span data-copy-label>Copy</span></button>
				</div>
				<div id="snippet-code"></div>
			</div>

			{{!-- raw body (hidden; JS pulls the first <pre> into the card, rest as notes) --}}
			<div id="snippet-content" hidden class="gh-content">{{content}}</div>
			<div id="snippet-notes" class="gh-content mt-8"></div>

			<div class="mt-8 flex flex-wrap items-center justify-between gap-3 border-t border-line pt-6">
				<a href="{{@site.url}}/prompts/" class="btn-ghost btn-sm">{{> "icons/arrow-right" class="h-3.5 w-3.5 rotate-180"}} All snippets</a>
				{{> "post/share"}}
			</div>

			{{#get "posts" filter="tag:hash-snippet+id:-{{id}}" limit="3" include="tags" as |more|}}
				{{#if more}}
				<section class="mt-14 border-t border-line pt-10">
					<p class="kicker mb-5">{{> "icons/code" class="h-3.5 w-3.5"}} More snippets</p>
					<div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">{{#foreach more}}{{> "cards/snippet"}}{{/foreach}}</div>
				</section>
				{{/if}}
			{{/get}}
		</div>
	</div>

	<script>
	(function () {
		var src = document.getElementById('snippet-content');
		var codeBox = document.getElementById('snippet-code');
		var notes = document.getElementById('snippet-notes');
		if (!src || !codeBox) return;
		var pre = src.querySelector('pre');
		var raw = document.createElement('pre');
		raw.id = 'snippet-raw';
		raw.textContent = pre ? (pre.innerText || pre.textContent) : (src.innerText || '').trim();
		codeBox.appendChild(raw);
		if (pre) { (pre.closest('.kg-card, figure') || pre).remove(); }
		var rest = src.innerHTML.trim();
		if (rest && notes) notes.innerHTML = rest;
	})();
	</script>
</article>
