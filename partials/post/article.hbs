{{!-- Standard article layout: header, feature image, content + sticky sidebar --}}
<article class="{{post_class}}">
	<header class="relative overflow-hidden border-b border-line py-14 sm:py-18">
		<div class="bg-grid pointer-events-none absolute inset-0 fade-mask-b" aria-hidden="true"></div>
		<div class="container-site relative">
			<div class="mx-auto max-w-3xl text-center">
				<div class="flex items-center justify-center gap-2 animate-fade-in">
					{{#primary_tag}}<a href="{{url}}" class="chip transition hover:border-ink hover:text-ink">{{name}}</a>{{/primary_tag}}
					{{#if featured}}<span class="chip">{{> "icons/zap"}} Featured</span>{{/if}}
				</div>
				<h1 class="mt-5 text-3xl font-semibold leading-tight tracking-tight sm:text-5xl text-balance animate-fade-up">{{title}}</h1>
				{{#if custom_excerpt}}<p class="mx-auto mt-5 max-w-2xl text-lg leading-relaxed text-silver animate-fade-in" style="animation-delay:.15s">{{custom_excerpt}}</p>{{/if}}
				<div class="mt-7 flex items-center justify-center gap-4 animate-fade-in" style="animation-delay:.25s">
					{{#primary_author}}
						<a href="{{url}}" class="flex items-center gap-2.5">
							{{#if profile_image}}<img src="{{img_url profile_image size="100"}}" alt="{{name}}" class="h-10 w-10 rounded-full border border-line object-cover" />{{/if}}
							<span class="text-sm font-semibold">{{name}}</span>
						</a>
					{{/primary_author}}
					<span class="font-mono text-[11px] text-silver">{{date published_at format="DD MMM YYYY"}} · {{reading_time}}</span>
				</div>
			</div>
		</div>
	</header>

	{{#if feature_image}}
	<div class="container-site -mt-0 py-10">
		<figure class="mx-auto max-w-5xl">
			<img src="{{img_url feature_image size="1600"}}"
				srcset="{{img_url feature_image size="600"}} 600w, {{img_url feature_image size="1000"}} 1000w, {{img_url feature_image size="1600"}} 1600w, {{img_url feature_image size="2000"}} 2000w"
				sizes="(max-width: 1200px) 100vw, 1200px"
				alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
				class="w-full rounded-3xl border border-line shadow-lift" />
			{{#if feature_image_caption}}<figcaption class="mt-3 text-center font-mono text-xs text-silver">{{{feature_image_caption}}}</figcaption>{{/if}}
		</figure>
	</div>
	{{/if}}

	<div class="container-site py-8">
		<div class="mx-auto grid max-w-5xl gap-12 lg:grid-cols-12">
			<div class="lg:col-span-8">
				<section class="gh-content">
					{{content}}
				</section>

				{{> "components/adsense"}}

				{{!-- Tags + share --}}
				<footer class="mt-10 flex flex-wrap items-center justify-between gap-4 border-t border-line pt-8">
					<div class="flex flex-wrap gap-2">
						{{#foreach tags visibility="public"}}<a href="{{url}}" class="chip transition hover:border-ink hover:text-ink">{{name}}</a>{{/foreach}}
					</div>
					{{> "post/share"}}
				</footer>

				{{#if comments}}
					<section class="mt-12 border-t border-line pt-10">
						<h2 class="section-title mb-8">Join the conversation</h2>
						{{comments}}
					</section>
				{{/if}}
			</div>

			<aside class="hidden lg:col-span-4 lg:block">
				<div class="sticky top-28 space-y-8">
					{{> "post/toc"}}
					{{!-- Author card --}}
					{{#primary_author}}
					<div class="card-surface p-6 !transform-none">
						<p class="kicker">Written by</p>
						<div class="mt-4 flex items-center gap-3">
							{{#if profile_image}}<img src="{{img_url profile_image size="100"}}" alt="{{name}}" class="h-12 w-12 rounded-2xl border border-line object-cover" />{{/if}}
							<div>
								<p class="font-semibold">{{name}}</p>
								<p class="text-xs text-silver">{{@custom.job_title}}</p>
							</div>
						</div>
						{{#if bio}}<p class="mt-3 text-sm leading-relaxed text-silver">{{bio}}</p>{{/if}}
						<a href="{{url}}" class="btn-ghost mt-4 w-full">All posts {{> "icons/arrow-right"}}</a>
					</div>
					{{/primary_author}}
					{{> "components/adsense"}}
				</div>
			</aside>
		</div>
	</div>
</article>

{{> "post/related"}}
