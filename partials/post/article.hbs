{{!-- Standard article layout: tight editorial header, mobile TOC, content + sticky sidebar --}}
<div class="fixed inset-x-0 top-0 z-[70] h-0.5 bg-transparent" aria-hidden="true">
	<div id="read-progress" class="h-full w-0 bg-accent transition-[width] duration-150 ease-out"></div>
</div>
<article class="{{post_class}}">
	<header class="relative overflow-hidden border-b border-line py-9 sm:py-12">
		<div class="bg-grid pointer-events-none absolute inset-0 fade-mask-b" aria-hidden="true"></div>
		<div class="container-site relative">
			<div class="mx-auto max-w-3xl text-center">
				<div class="flex items-center justify-center gap-2 animate-fade-in">
					{{#primary_tag}}<a href="{{url}}" class="chip transition hover:border-ink hover:text-ink">{{name}}</a>{{/primary_tag}}
					{{#if featured}}<span class="chip">{{> "icons/zap"}} Featured</span>{{/if}}
				</div>
				<h1 class="mt-4 text-3xl font-semibold leading-tight tracking-tight sm:text-4xl text-balance animate-fade-up">{{title}}</h1>
				{{#if custom_excerpt}}<p class="mx-auto mt-3 max-w-2xl text-base leading-relaxed text-silver animate-fade-in" style="animation-delay:.15s">{{custom_excerpt}}</p>{{/if}}
				<div class="mt-5 flex items-center justify-center gap-4 animate-fade-in" style="animation-delay:.25s">
					{{#primary_author}}
						<a href="{{url}}" class="flex items-center gap-2.5">
							{{#if profile_image}}<img src="{{img_url profile_image size="100"}}" alt="{{name}}" class="h-8 w-8 rounded-full border border-line object-cover" />{{/if}}
							<span class="text-sm font-semibold">{{name}}</span>
						</a>
					{{/primary_author}}
					<span class="font-mono text-[11px] text-silver">{{date published_at format="DD MMM YYYY"}} · {{reading_time}}</span>
				</div>
			</div>
		</div>
	</header>

	{{!-- Mobile table of contents — mirrors the sidebar #toc-list, collapsible --}}
	<div class="container-site mt-6 lg:hidden" id="toc-mobile" hidden>
		<div class="collapse collapse-arrow rounded-2xl border border-line bg-mist/40">
			<input type="checkbox" aria-label="Toggle table of contents" />
			<div class="collapse-title font-mono text-[11px] font-semibold uppercase tracking-widest text-silver">On this page</div>
			<div class="collapse-content">
				<div id="toc-mobile-list"></div>
			</div>
		</div>
	</div>

	{{#if feature_image}}
	<div class="container-site py-7">
		<figure class="mx-auto max-w-5xl">
			<img src="{{img_url feature_image size="1600"}}"
				srcset="{{img_url feature_image size="600"}} 600w, {{img_url feature_image size="1000"}} 1000w, {{img_url feature_image size="1600"}} 1600w, {{img_url feature_image size="2000"}} 2000w"
				sizes="(max-width: 1200px) 100vw, 1200px"
				alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
				class="w-full rounded-3xl border border-line shadow-lift" />
			{{#if feature_image_caption}}<figcaption class="mt-3 text-center font-mono text-xs text-silver">{{{feature_image_caption}}}</figcaption>{{/if}}
		</figure>
	</div>
	{{/if}}

	<div class="container-site py-8">
		<div class="mx-auto grid max-w-5xl gap-12 lg:grid-cols-12">
			<div class="lg:col-span-8">
				<section class="gh-content">
					{{content}}
				</section>

				{{> "components/adsense" slot="6501428979" layout="in-article" format="fluid"}}

				{{!-- Tags + share --}}
				<footer class="mt-10 flex flex-wrap items-center justify-between gap-4 border-t border-line pt-8">
					<div class="flex flex-wrap gap-2">
						{{#foreach tags visibility="public"}}<a href="{{url}}" class="chip transition hover:border-ink hover:text-ink">{{name}}</a>{{/foreach}}
					</div>
					{{> "post/share"}}
				</footer>

				{{#if @site.comments_enabled}}
					<section class="mt-12 border-t border-line pt-10">
						{{comments title="Join the discussion" count=true}}
					</section>
				{{/if}}
			</div>

			<aside class="hidden lg:col-span-4 lg:block">
				<div class="sticky top-28 space-y-8">
					{{> "post/toc"}}

					{{!-- Author card --}}
					{{#primary_author}}
					<div class="card-surface p-6 !transform-none">
						<p class="kicker">{{> "icons/user"}} Written by</p>
						<div class="mt-4 flex items-center gap-3">
							{{#if profile_image}}<img src="{{img_url profile_image size="100"}}" alt="{{name}}" class="h-12 w-12 rounded-2xl border border-line object-cover" />{{/if}}
							<div>
								<p class="font-semibold">{{name}}</p>
								<p class="text-xs text-silver">{{@custom.job_title}}</p>
							</div>
						</div>
						{{#if bio}}<p class="mt-3 text-sm leading-relaxed text-silver">{{bio}}</p>{{/if}}
						<a href="{{url}}" class="btn-ghost mt-4 w-full">All posts {{> "icons/arrow-right"}}</a>
					</div>
					{{/primary_author}}

					{{!-- Newsletter mini-form --}}
					{{#if @site.members_enabled}}
					<div class="card-surface p-6 !transform-none">
						<p class="kicker">{{> "icons/mail"}} Newsletter</p>
						<p class="mt-3 text-sm leading-relaxed text-silver">New posts, straight to your inbox. No noise, unsubscribe anytime.</p>
						<form data-members-form class="mt-4 space-y-2">
							<input type="email" name="email" required data-members-email placeholder="you@example.com"
								class="w-full rounded-xl border border-line bg-paper px-3 py-2 text-sm text-ink outline-none transition placeholder:text-silver/60 focus:border-ink" />
							<button type="submit" class="btn btn-primary w-full">Subscribe</button>
						</form>
					</div>
					{{/if}}

					{{!-- Vertical skyscraper ad --}}
					{{> "components/adsense" slot="3487917390" format="auto"}}

					{{!-- Share --}}
					<div class="card-surface p-6 !transform-none">
						<p class="kicker mb-4">{{> "icons/arrow-up-right"}} Spread the word</p>
						{{> "post/share"}}
					</div>

					{{!-- Popular tags --}}
					<div class="card-surface p-6 !transform-none">
						<p class="kicker">{{> "icons/book"}} Popular tags</p>
						<div class="mt-4 flex flex-wrap gap-2">
							{{#get "tags" limit="10" order="count.posts desc" include="count.posts" as |pop|}}
								{{#foreach pop}}<a href="{{url}}" class="chip transition hover:border-ink hover:text-ink">{{name}}</a>{{/foreach}}
							{{/get}}
						</div>
					</div>
				</div>
			</aside>
		</div>
	</div>
</article>

{{> "post/related"}}

<script>
	(function () {
		var bar = document.getElementById('read-progress');
		var article = document.querySelector('.gh-content');
		if (!bar || !article) return;
		function update() {
			var rect = article.getBoundingClientRect();
			var total = rect.height - window.innerHeight * 0.5;
			var done = -rect.top;
			var pct = total > 0 ? Math.min(100, Math.max(0, (done / total) * 100)) : 0;
			bar.style.width = pct + '%';
		}
		window.addEventListener('scroll', update, { passive: true });
		window.addEventListener('resize', update);
		update();
	})();
</script>

{{!-- Mirror the sidebar TOC (built by site JS) into the mobile collapse --}}
<script>
	(function () {
		var wrap = document.getElementById('toc-mobile');
		var dst = document.getElementById('toc-mobile-list');
		if (!wrap || !dst) return;
		function mirror() {
			var src = document.getElementById('toc-list');
			if (!src || !src.children.length) return false;
			dst.innerHTML = src.innerHTML;
			wrap.hidden = false;
			if ('MutationObserver' in window) {
				new MutationObserver(function () {
					dst.innerHTML = src.innerHTML;
				}).observe(src, { attributes: true, subtree: true, attributeFilter: ['class'] });
			}
			return true;
		}
		var tries = 0;
		(function tick() {
			if (mirror() || ++tries > 50) return;
			setTimeout(tick, 120);
		})();
	})();
</script>
