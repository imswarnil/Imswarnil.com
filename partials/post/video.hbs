{{!-- Video detail — CRT-style theater for #video posts.
     JS extracts the first YouTube embed/link from the post body, renders an
     autoplaying (muted) player at the top with a TV turn-on animation,
     enhances timestamp tables into clickable chapters (YouTube IFrame API,
     loaded lazily) and emits VideoObject + Clip JSON-LD. --}}
<article class="{{post_class}}" id="vd-app"
	data-title="{{title}}"
	data-url="{{url absolute="true"}}"
	data-published="{{date published_at format="YYYY-MM-DD"}}"
	data-thumb="{{#if feature_image}}{{img_url feature_image size="1200"}}{{/if}}"
	data-desc="{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{excerpt words="50"}}{{/if}}">

	<style>
		#vd-shell { opacity: 0; will-change: transform, filter; }
		#vd-shell.tv-on { animation: vd-tv-on .75s cubic-bezier(.2, .8, .25, 1) forwards; }
		#vd-shell.tv-off { opacity: 1; animation: vd-tv-off .28s ease-in forwards; }
		@keyframes vd-tv-on {
			0%   { opacity: 1; transform: scaleY(.004) scaleX(.25); filter: brightness(9) saturate(0); }
			35%  { opacity: 1; transform: scaleY(.004) scaleX(1);   filter: brightness(12) saturate(0); }
			65%  { opacity: 1; transform: scaleY(1) scaleX(1);      filter: brightness(1.9); }
			100% { opacity: 1; transform: none;                     filter: none; }
		}
		@keyframes vd-tv-off {
			0%   { transform: none; filter: none; }
			55%  { transform: scaleY(.006) scaleX(1); filter: brightness(9); }
			100% { opacity: 0; transform: scaleY(.006) scaleX(.05); filter: brightness(12); }
		}
		.vd-scan {
			pointer-events: none; position: absolute; inset: 0; z-index: 10;
			background: repeating-linear-gradient(to bottom, rgba(255,255,255,.08) 0 1px, transparent 1px 3px);
			animation: vd-scan-fade 1.8s ease-out forwards;
		}
		@keyframes vd-scan-fade { from { opacity: 1; } to { opacity: 0; } }
		@media (prefers-reduced-motion: reduce) {
			#vd-shell { opacity: 1 !important; animation: none !important; }
			.vd-scan { display: none; }
		}
		/* Unmute pill over the player */
		.vd-unmute {
			position: absolute; z-index: 20; left: 50%; bottom: 14px; transform: translateX(-50%);
			display: inline-flex; align-items: center; gap: .5rem;
			padding: .5rem .9rem; border-radius: 9999px;
			background: rgb(0 0 0 / .68); color: #fff; -webkit-backdrop-filter: blur(6px); backdrop-filter: blur(6px);
			border: 1px solid rgb(255 255 255 / .2);
			font-size: .78rem; font-weight: 600; letter-spacing: .01em; cursor: pointer;
			box-shadow: 0 8px 24px -8px rgb(0 0 0 / .7);
			transition: background .2s ease;
			animation: vd-unmute-pulse 2.6s ease-in-out infinite;
		}
		.vd-unmute:hover { background: rgb(0 0 0 / .85); }
		.vd-unmute svg { width: 1rem; height: 1rem; }
		@keyframes vd-unmute-pulse { 0%,100% { box-shadow: 0 8px 24px -8px rgb(0 0 0 / .7), 0 0 0 0 rgb(255 255 255 / .35); } 50% { box-shadow: 0 8px 24px -8px rgb(0 0 0 / .7), 0 0 0 6px rgb(255 255 255 / 0); } }
		@media (prefers-reduced-motion: reduce) { .vd-unmute { animation: none; } }

		/* Chapters — list-like rows, tappable, with a jump affordance */
		.vd-chapters { width: 100%; font-size: .82rem; border-collapse: separate; border-spacing: 0 3px; }
		.vd-chapters thead { display: none; }
		.vd-chapters td { padding: .5rem .55rem; border: 0; vertical-align: middle; color: rgb(var(--ink) / .88); line-height: 1.35; }
		.vd-chapters .vd-chapter { cursor: pointer; }
		.vd-chapters .vd-chapter td { transition: background .15s ease, color .15s ease; }
		.vd-chapters .vd-chapter td:first-child {
			font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-variant-numeric: tabular-nums;
			white-space: nowrap; width: 1%; color: rgb(var(--silver));
			border-radius: .55rem 0 0 .55rem; padding-left: .7rem;
		}
		.vd-chapters .vd-chapter td:last-child { border-radius: 0 .55rem .55rem 0; padding-right: .7rem; }
		.vd-chapters .vd-chapter:hover td { background: rgb(var(--mist)); color: rgb(var(--ink)); }
		.vd-chapters .vd-chapter:hover td:first-child { color: rgb(var(--accent)); }
		.vd-chapters .vd-active td { background: rgb(var(--accent) / .1); font-weight: 650; color: rgb(var(--ink)); }
		.vd-chapters .vd-active td:first-child { color: rgb(var(--accent)); box-shadow: inset 3px 0 0 rgb(var(--accent)); }
		/* Inline tappable timestamps (works on mobile, any description format) */
		.vd-ts { font: inherit; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-variant-numeric: tabular-nums; cursor: pointer; color: rgb(var(--accent)); background: rgb(var(--mist)); border: 0; padding: 0 .3em; margin: 0 .05em; border-radius: .3rem; -webkit-tap-highlight-color: transparent; }
		.vd-ts:hover, .vd-ts:focus-visible { background: rgb(var(--accent) / .14); outline: none; }
	</style>

	{{!-- Theater band: true full-width, zero padding — player 70% left,
	     chapters 30% right as a plain column (no box). Mobile: video
	     edge-to-edge tucked under the navbar, chapters inline below. --}}
	<div class="-mt-2 border-b border-line sm:mt-0" id="vd-band">
		<div id="vd-grid" class="grid w-full gap-0 lg:grid-cols-[7fr_3fr]">
			<div id="vd-shell" class="relative">
				<div id="vd-stage" class="relative aspect-video overflow-hidden bg-black">
					<div class="vd-scan" aria-hidden="true"></div>
					{{!-- Browsers force autoplay to start muted; one tap turns sound on --}}
					<button type="button" id="vd-unmute" class="vd-unmute" aria-label="Unmute — play with sound" hidden>
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 5 6 9H2v6h4l5 4V5z"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></svg>
						Tap for sound
					</button>
				</div>
			</div>
			<aside id="vd-chapters-slot" class="hidden overflow-y-auto border-line px-3 py-2 lg:block lg:max-h-[calc((100vw*0.7)*9/16)] lg:border-l">
				<p class="px-2 pb-2 pt-1 font-mono text-[10px] uppercase tracking-[0.25em] text-silver">{{> "icons/clock" class="inline h-3 w-3"}} Chapters — tap to jump</p>
			</aside>
		</div>
	</div>

	<div class="container-site py-10">
		<div class="mx-auto max-w-4xl">
			<header>
				<p class="kicker">{{> "icons/film" class="h-3.5 w-3.5"}} Now playing</p>
				<h1 class="mt-3 text-3xl font-semibold leading-tight tracking-tight sm:text-4xl text-balance">{{title}}</h1>
				<div class="mt-5 flex flex-wrap items-center gap-x-4 gap-y-2 font-mono text-xs text-silver">
					<span class="flex items-center gap-1.5">{{> "icons/calendar" class="h-3.5 w-3.5"}} {{date published_at format="DD MMM YYYY"}}</span>
					<span class="flex items-center gap-1.5">{{> "icons/clock" class="h-3.5 w-3.5"}} <span data-duration-tags="{{#foreach tags visibility="internal"}}{{slug}} {{/foreach}}" hidden></span> {{reading_time minute="1 min"}}</span>
					<span class="chip">{{> "icons/youtube" class="h-3.5 w-3.5"}} YouTube</span>
					{{#primary_tag}}<a href="{{url}}" class="chip transition hover:border-ink hover:text-ink">{{name}}</a>{{/primary_tag}}
				</div>
			</header>

			{{!-- Description / notes (the first YouTube embed inside is hidden by JS once hoisted) --}}
			<section class="gh-content mt-10" id="vd-content">
				{{content}}
			</section>

			{{> "components/adsense" slot="6501428979" layout="in-article" format="fluid"}}

			{{!-- Gear: #product posts tagged #product-video = "kit I use for videos" --}}
			{{#get "posts" filter="tag:hash-product+tag:hash-product-video" limit="4" include="tags" as |gear|}}
				{{#if gear}}
				<section class="mt-12 border-t border-line pt-10">
					<p class="kicker">{{> "icons/cart" class="h-3.5 w-3.5"}} Products I use to make videos</p>
					<div class="mt-5 grid gap-4 sm:grid-cols-2" data-reveal-stagger="80">
						{{#foreach gear}}
							{{> "cards/product-mini"}}
						{{/foreach}}
					</div>
				</section>
				{{/if}}
			{{/get}}

			{{!-- Turn it deeper: #course posts tagged #course-video --}}
			{{#get "posts" filter="tag:hash-course+tag:hash-course-video" limit="2" include="tags" as |vcourses|}}
				{{#if vcourses}}
				<section class="mt-12 border-t border-line pt-10">
					<p class="kicker">{{> "icons/graduation" class="h-3.5 w-3.5"}} Go deeper — full course</p>
					<div class="mt-5 grid gap-4 sm:grid-cols-2" data-reveal-stagger="80">
						{{#foreach vcourses}}{{> "cards/course"}}{{/foreach}}
					</div>
				</section>
				{{/if}}
			{{/get}}

			{{!-- Companion reading: #blog posts tagged #blog-video --}}
			{{#get "posts" filter="tag:hash-blog+tag:hash-blog-video" limit="3" include="tags" as |vblog|}}
				{{#if vblog}}
				<section class="mt-12 border-t border-line pt-10">
					<p class="kicker">{{> "icons/newspaper" class="h-3.5 w-3.5"}} Read the write-up</p>
					<ul class="mt-5 divide-y divide-line">
						{{#foreach vblog}}
						<li>
							<a href="{{url}}" class="group flex items-center justify-between gap-4 py-3.5">
								<span class="min-w-0">
									<span class="block truncate text-[15px] font-semibold tracking-tight transition group-hover:text-silver">{{title}}</span>
									<span class="mt-0.5 block font-mono text-[11px] text-silver">{{reading_time}} · {{date published_at format="DD MMM YYYY"}}</span>
								</span>
								{{> "icons/arrow-right" class="h-4 w-4 shrink-0 text-silver transition group-hover:translate-x-0.5 group-hover:text-ink"}}
							</a>
						</li>
						{{/foreach}}
					</ul>
				</section>
				{{/if}}
			{{/get}}

			{{!-- Audience CTA: converts YouTube viewers into site subscribers --}}
			<section class="mt-12 border-t border-line pt-10">
				<div class="rounded-2xl border border-line bg-mist/40 p-6 text-center">
					<p class="kicker !text-accent justify-center">{{> "icons/youtube" class="h-3.5 w-3.5"}} Came from YouTube?</p>
					<h2 class="mx-auto mt-3 max-w-md text-xl font-semibold tracking-tight text-balance">Get the next one before the algorithm does.</h2>
					<p class="mx-auto mt-2 max-w-md text-sm leading-relaxed text-silver">Subscribe to the site for new videos, write-ups and behind-the-scenes — no algorithm, just your inbox.</p>
					<div class="mt-5 flex flex-wrap items-center justify-center gap-2.5">
						<button type="button" class="btn-primary btn-sm" data-modal-open="#subscribe-backdrop">{{> "icons/mail" class="h-3.5 w-3.5"}} Subscribe to my site</button>
						<a href="https://www.youtube.com/@imswarnil?sub_confirmation=1" target="_blank" rel="noopener" class="btn-ghost btn-sm">{{> "icons/youtube" class="h-3.5 w-3.5"}} Subscribe on YouTube</a>
						<a href="{{@site.url}}/contact/" class="btn-ghost btn-sm">{{> "icons/mic" class="h-3.5 w-3.5"}} Send feedback</a>
					</div>
				</div>
			</section>

			{{!-- Sponsor / collab --}}
			<div class="mt-8">{{> "components/collab-cta" compact=true}}</div>

			<footer class="mt-8 flex flex-wrap gap-2 border-t border-line pt-6">
				{{#foreach tags visibility="public"}}<a href="{{url}}" class="chip transition hover:border-ink hover:text-ink">{{name}}</a>{{/foreach}}
			</footer>

			{{#if @site.comments_enabled}}
				<section class="mt-12 border-t border-line pt-10">
					{{> "components/comments" title="Comments"}}
				</section>
			{{/if}}
		</div>

		{{!-- Related videos --}}
		{{#get "posts" filter="tag:hash-video+id:-{{id}}" limit="6" as |related|}}
			{{#if related}}
				<section class="mx-auto mt-16 max-w-6xl border-t border-line pt-12">
					<p class="kicker mb-8">{{> "icons/play" class="h-3.5 w-3.5"}} Up next</p>
					<div class="grid gap-x-6 gap-y-10 sm:grid-cols-2 lg:grid-cols-3">
						{{#foreach related}}
							{{> "cards/video"}}
						{{/foreach}}
					</div>
					<div class="mt-10 text-center">
						<a href="{{@site.url}}/videos/" class="btn-ghost">Browse all videos {{> "icons/arrow-right" class="h-4 w-4"}}</a>
					</div>
				</section>
			{{/if}}
		{{/get}}
	</div>

	<script>
	(function () {
		var app = document.getElementById('vd-app');
		var content = document.getElementById('vd-content');
		var shell = document.getElementById('vd-shell');
		var stage = document.getElementById('vd-stage');
		var unmuteBtn = document.getElementById('vd-unmute');
		if (!app || !content || !shell) return;

		/* ---------- 1. Find the first YouTube embed/link in the post ---------- */
		var ID_RE = /(?:youtube(?:-nocookie)?\.com\/(?:embed\/|shorts\/|live\/|watch\?[^"'\s]*?v=)|youtu\.be\/)([A-Za-z0-9_-]{11})/;
		var found = null;
		var nodes = content.querySelectorAll('iframe[src], a[href]');
		for (var i = 0; i < nodes.length; i++) {
			var m = (nodes[i].src || nodes[i].href || '').match(ID_RE);
			if (m) { found = { id: m[1], el: nodes[i] }; break; }
		}
		if (!found) { shell.parentNode.parentNode.remove(); return; }
		var vid = found.id;

		/* Hide the original embed so it doesn't render twice */
		if (found.el.tagName === 'IFRAME') {
			(found.el.closest('.kg-card, figure') || found.el).style.display = 'none';
		} else {
			var card = found.el.closest('.kg-bookmark-card, .kg-embed-card, figure');
			if (card) { card.style.display = 'none'; }
			else {
				var p = found.el.closest('p');
				if (p && p.textContent.trim() === found.el.textContent.trim()) p.style.display = 'none';
			}
		}

		/* ---------- 2. Build the theater player (autoplay, muted) ---------- */
		var iframe = document.createElement('iframe');
		iframe.id = 'vd-iframe';
		iframe.src = 'https://www.youtube.com/embed/' + vid +
			'?autoplay=1&mute=1&playsinline=1&rel=0&modestbranding=1&enablejsapi=1&origin=' +
			encodeURIComponent(location.origin);
		iframe.title = app.getAttribute('data-title') || 'Video';
		iframe.allow = 'autoplay; encrypted-media; picture-in-picture; fullscreen';
		iframe.setAttribute('allowfullscreen', '');
		iframe.className = 'absolute inset-0 h-full w-full';
		stage.appendChild(iframe);
		shell.classList.add('tv-on'); /* TV turn-on */

		/* Autoplay is forced-muted by browsers; offer a one-tap unmute. The tap
		   IS the user gesture browsers require, so sound is allowed after it. */
		function hideUnmute() { if (unmuteBtn) { unmuteBtn.hidden = true; } }
		if (unmuteBtn) {
			unmuteBtn.hidden = false;
			unmuteBtn.addEventListener('click', function () {
				loadAPI();
				(function tryUnmute(n) {
					if (player && player.unMute) {
						player.unMute();
						if (player.setVolume) player.setVolume(100);
						if (player.playVideo) player.playVideo();
						hideUnmute();
					} else if (n < 40) {
						setTimeout(function () { tryUnmute(n + 1); }, 150);
					}
				})(0);
			});
		}

		/* ---------- 3. Timestamp table -> clickable chapters ---------- */
		var TIME_RE = /^(\d{1,2}:)?\d{1,2}:\d{2}$/;
		function toSec(t) {
			return t.split(':').reduce(function (a, b) { return a * 60 + parseInt(b, 10); }, 0);
		}
		var chapters = [];
		var chapterTable = null;
		var tables = content.querySelectorAll('table');
		for (var ti = 0; ti < tables.length && !chapters.length; ti++) {
			var rows = tables[ti].querySelectorAll('tr');
			var hits = [];
			for (var ri = 0; ri < rows.length; ri++) {
				var cells = rows[ri].cells;
				if (!cells || !cells.length) continue;
				var t0 = cells[0].textContent.trim();
				if (TIME_RE.test(t0)) {
					hits.push({
						row: rows[ri],
						start: toSec(t0),
						name: cells.length > 1 ? cells[1].textContent.trim() : ''
					});
				}
			}
			if (hits.length >= 2 && hits.length * 2 >= rows.length) {
				chapters = hits;
				tables[ti].classList.add('vd-chapters');
				chapterTable = tables[ti];
			}
		}

		/* Move the chapter table into the sidebar next to the player (desktop);
		   on mobile the same element still renders, just stacked below via CSS. */
		var chaptersSlot = document.getElementById('vd-chapters-slot');
		if (chapterTable && chaptersSlot) {
			chaptersSlot.appendChild(chapterTable);
			chaptersSlot.classList.remove('hidden');
			chaptersSlot.classList.add('block');
		} else if (chaptersSlot) {
			chaptersSlot.remove();
			var grid = document.getElementById('vd-grid');
			if (grid) grid.classList.remove('lg:grid-cols-[7fr_3fr]');
		}

		/* ---------- 4. YouTube IFrame API, loaded lazily ---------- */
		var player = null, pendingSeek = null, apiRequested = false;
		function onPlayerReady() {
			if (pendingSeek != null) { doSeek(pendingSeek); pendingSeek = null; }
		}
		function loadAPI() {
			if (apiRequested) return;
			apiRequested = true;
			function boot() { player = new YT.Player('vd-iframe', { events: { onReady: onPlayerReady } }); }
			if (window.YT && window.YT.Player) { boot(); return; }
			var prev = window.onYouTubeIframeAPIReady;
			window.onYouTubeIframeAPIReady = function () { if (prev) prev(); boot(); };
			var s = document.createElement('script');
			s.src = 'https://www.youtube.com/iframe_api';
			s.async = true;
			document.head.appendChild(s);
		}
		function doSeek(sec) {
			player.seekTo(sec, true);
			if (player.unMute) player.unMute();
			if (player.playVideo) player.playVideo();
			hideUnmute();
		}
		function seek(sec) {
			if (player && player.seekTo) doSeek(sec);
			else { pendingSeek = sec; loadAPI(); }
			shell.scrollIntoView({ behavior: 'smooth', block: 'center' });
		}

		if (chapters.length) {
			chapters.forEach(function (c) {
				c.row.classList.add('vd-chapter');
				c.row.tabIndex = 0;
				c.row.setAttribute('role', 'button');
				c.row.setAttribute('aria-label', 'Jump to ' + (c.name || c.start + ' seconds'));
				c.row.addEventListener('click', function () { seek(c.start); });
				c.row.addEventListener('keydown', function (e) {
					if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); seek(c.start); }
				});
			});
			/* Warm the API off the critical path so active-chapter tracking works */
			if ('requestIdleCallback' in window) requestIdleCallback(loadAPI, { timeout: 4000 });
			else setTimeout(loadAPI, 2500);
			setInterval(function () {
				if (!player || !player.getCurrentTime) return;
				var t, active = null;
				try { t = player.getCurrentTime(); } catch (e) { return; }
				chapters.forEach(function (c) { if (c.start <= t + 0.5) active = c; });
				chapters.forEach(function (c) { c.row.classList.toggle('vd-active', c === active); });
			}, 1000);
		}

		/* ---------- 4b. Linkify inline timestamps in the description so they're
		   tappable on mobile too (covers timestamps written as lists/paragraphs,
		   not just the chapter table). ---------- */
		(function linkifyTimestamps() {
			var GTS = /\b((?:\d{1,2}:)?\d{1,2}:\d{2})\b/g;
			var walker = document.createTreeWalker(content, NodeFilter.SHOW_TEXT, null);
			var nodes = [], node;
			while ((node = walker.nextNode())) {
				if (!/\d{1,2}:\d{2}/.test(node.nodeValue)) continue;
				if (node.parentNode.closest('a, button, .vd-chapters, .vd-ts, pre, code')) continue;
				nodes.push(node);
			}
			nodes.forEach(function (tn) {
				var text = tn.nodeValue, frag = document.createDocumentFragment(), last = 0, m, any = false;
				GTS.lastIndex = 0;
				while ((m = GTS.exec(text))) {
					any = true;
					if (m.index > last) frag.appendChild(document.createTextNode(text.slice(last, m.index)));
					var b = document.createElement('button');
					b.type = 'button'; b.className = 'vd-ts'; b.textContent = m[1];
					b.setAttribute('aria-label', 'Jump to ' + m[1]);
					(function (secs) { b.addEventListener('click', function () { seek(secs); }); })(toSec(m[1]));
					frag.appendChild(b);
					last = m.index + m[0].length;
				}
				if (last < text.length) frag.appendChild(document.createTextNode(text.slice(last)));
				if (any) tn.parentNode.replaceChild(frag, tn);
			});
		})();

		/* ---------- 5. JSON-LD: VideoObject + Clip chapters ---------- */
		var watch = 'https://www.youtube.com/watch?v=' + vid;
		var ld = {
			'@context': 'https://schema.org',
			'@type': 'VideoObject',
			name: app.getAttribute('data-title'),
			description: app.getAttribute('data-desc') || app.getAttribute('data-title'),
			thumbnailUrl: app.getAttribute('data-thumb')
				? [app.getAttribute('data-thumb')]
				: ['https://i.ytimg.com/vi/' + vid + '/maxresdefault.jpg', 'https://i.ytimg.com/vi/' + vid + '/hqdefault.jpg'],
			uploadDate: app.getAttribute('data-published'),
			embedUrl: 'https://www.youtube.com/embed/' + vid,
			contentUrl: watch,
			url: app.getAttribute('data-url')
		};
		if (chapters.length) {
			ld.hasPart = chapters.map(function (c, i) {
				var clip = {
					'@type': 'Clip',
					name: c.name || ('Chapter ' + (i + 1)),
					startOffset: c.start,
					url: watch + '&t=' + c.start + 's'
				};
				if (chapters[i + 1]) clip.endOffset = chapters[i + 1].start;
				return clip;
			});
		}
		var ldTag = document.createElement('script');
		ldTag.type = 'application/ld+json';
		ldTag.textContent = JSON.stringify(ld);
		document.head.appendChild(ldTag);

		/* ---------- 6. TV turn-off when navigating away (internal links) ---------- */
		document.addEventListener('click', function (e) {
			if (e.defaultPrevented || e.button !== 0 || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
			var a = e.target.closest ? e.target.closest('a[href]') : null;
			if (!a || a.target === '_blank' || a.host !== location.host) return;
			if (a.pathname === location.pathname && a.hash) return; /* same-page anchors */
			if (shell.classList.contains('tv-off')) return;
			e.preventDefault();
			shell.classList.remove('tv-on');
			shell.classList.add('tv-off');
			setTimeout(function () { location.href = a.href; }, 260);
		});
	})();
	</script>
