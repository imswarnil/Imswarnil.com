{{!-- Repo-page layout for #project posts.
     Derived links: repo = github.com/imswarnil/{slug}; live = {slug minus dashes}.imswarnil.com
     (hrefs + skill chips + gallery strip + TOC placement wired by the inline script below). --}}
<article class="{{post_class}}">

	{{!-- ============ Repo-style header ============ --}}
	<header class="relative overflow-hidden border-b border-line py-12">
		<div class="bg-grid pointer-events-none absolute inset-0 fade-mask-b" aria-hidden="true"></div>
		<div class="container-site relative">
			<nav class="flex flex-wrap items-center gap-2 font-mono text-sm" aria-label="Breadcrumb">
				{{> "icons/repo" class="h-4 w-4 text-silver"}}
				<a href="{{@site.url}}/projects/" class="text-silver transition hover:text-ink hover:underline">imswarnil</a>
				<span class="text-silver" aria-hidden="true">/</span>
				<span class="font-semibold text-ink">{{slug}}</span>
				<span class="chip !px-2 !text-[10px]">Public</span>
			</nav>

			<h1 class="mt-4 text-3xl font-semibold tracking-tight sm:text-4xl text-balance">{{title}}</h1>
			{{#if custom_excerpt}}<p class="mt-4 max-w-2xl text-lg leading-relaxed text-silver">{{custom_excerpt}}</p>{{/if}}

			{{!-- Skill badges from internal #skill-* tags (built client-side) --}}
			<div class="mt-5 flex flex-wrap gap-1.5" data-skill-chips data-skill-names="{{#foreach tags visibility="internal"}}{{name}},{{/foreach}}"></div>

			<div class="mt-6 flex flex-wrap items-center gap-3">
				<a href="https://github.com/imswarnil/{{slug}}" target="_blank" rel="noopener" class="btn">{{> "icons/github" class="h-4 w-4"}} View source</a>
				<a href="{{url}}" data-live-from-slug="{{slug}}" target="_blank" rel="noopener" class="btn-primary">{{> "icons/external" class="h-4 w-4"}} Live site</a>
				<a href="https://github.com/imswarnil/{{slug}}/stargazers" target="_blank" rel="noopener" class="btn-ghost tooltip" data-tip="It's free, and it makes my day">{{> "icons/star" class="h-4 w-4"}} Star</a>
			</div>

			<div class="mt-6 flex flex-wrap items-center gap-2">
				{{#foreach tags visibility="public"}}<a href="{{url}}" class="chip transition hover:border-ink hover:text-ink">{{name}}</a>{{/foreach}}
				<span class="chip">{{> "icons/calendar"}} {{date published_at format="MMM YYYY"}}</span>
				<span class="chip">{{> "icons/clock"}} {{reading_time}}</span>
			</div>
		</div>
	</header>

	{{!-- Mobile: TOC lands here (moved from the sidebar by script below) --}}
	<div id="toc-mobile-slot" class="container-site mt-8 empty:mt-0 lg:hidden"></div>

	{{#if feature_image}}
	<div class="container-site pt-10">
		<img src="{{img_url feature_image size="1600"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" class="mx-auto w-full max-w-5xl rounded-3xl border border-line shadow-lift" />
	</div>
	{{/if}}

	{{!-- ============ Content + sidebar ============ --}}
	<div class="container-site py-10">
		<div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_320px]">

			<div class="min-w-0">
				<section class="gh-content">
					{{content}}
				</section>

				{{> "components/adsense" slot="6501428979" layout="in-article" format="fluid"}}

				{{!-- Build log: #project-detail steps, start → ship, with overall span --}}
				{{#foreach tags visibility="public" limit="1"}}
				{{#get "posts" filter="tag:hash-project-detail+tags:{{slug}}" order="published_at asc" limit="50" as |steps|}}
					{{#if steps}}
					<section class="mt-12 border-t border-line pt-10" id="buildlog">
						<div class="flex flex-wrap items-end justify-between gap-3">
							<div>
								<p class="kicker">{{> "icons/pen" class="h-3.5 w-3.5"}} How I built it</p>
								<h2 class="section-title mt-2">Build log</h2>
							</div>
							<p class="font-mono text-[11px] text-silver" id="buildlog-span" hidden></p>
						</div>
						<ol class="buildlog mt-6" id="buildlog-overview">
							{{#foreach steps}}
							<li class="buildlog-item {{#if @first}}is-start{{/if}} {{#if @last}}is-end{{/if}}">
								<a href="{{url}}" data-step-date="{{date published_at format="YYYY-MM-DD"}}" class="buildlog-link group">
									<span class="buildlog-dot" aria-hidden="true">{{#if @first}}{{> "icons/play" class="h-3 w-3"}}{{else if @last}}{{> "icons/check" class="h-3 w-3"}}{{else}}<span class="buildlog-num">{{@number}}</span>{{/if}}</span>
									<span class="min-w-0">
										<span class="buildlog-title transition group-hover:text-accent">{{title}}</span>
										<span class="buildlog-meta">{{#if @first}}Start · {{else if @last}}Shipped · {{/if}}{{date published_at format="DD MMM YYYY"}}</span>
									</span>
								</a>
							</li>
							{{/foreach}}
						</ol>
						<script>
						(function () {
							var items = [].slice.call(document.querySelectorAll('#buildlog-overview [data-step-date]'));
							if (items.length < 2) return;
							var a = items[0].getAttribute('data-step-date');
							var b = items[items.length - 1].getAttribute('data-step-date');
							var d = Math.round((new Date(b) - new Date(a)) / 86400000);
							var el = document.getElementById('buildlog-span');
							if (el) { el.textContent = items.length + ' steps · ' + (d <= 0 ? 'in a day' : d + ' days start to ship'); el.hidden = false; }
						})();
						</script>
					</section>
					{{/if}}
				{{/get}}
				{{/foreach}}

				{{!-- Companion writing: #blog posts tagged #blog-project --}}
				{{#get "posts" filter="tag:hash-blog+tag:hash-blog-project" limit="3" include="tags" as |bp|}}
					{{#if bp}}
					<section class="mt-12 border-t border-line pt-10">
						<p class="kicker">{{> "icons/newspaper" class="h-3.5 w-3.5"}} Wrote about it</p>
						<ul class="mt-5 divide-y divide-line">
							{{#foreach bp}}
							<li><a href="{{url}}" class="group flex items-center justify-between gap-4 py-3.5">
								<span class="min-w-0"><span class="block truncate text-[15px] font-semibold tracking-tight transition group-hover:text-silver">{{title}}</span><span class="mt-0.5 block font-mono text-[11px] text-silver">{{reading_time}} · {{date published_at format="DD MMM YYYY"}}</span></span>
								{{> "icons/arrow-right" class="h-4 w-4 shrink-0 text-silver transition group-hover:translate-x-0.5 group-hover:text-ink"}}
							</a></li>
							{{/foreach}}
						</ul>
					</section>
					{{/if}}
				{{/get}}

				<footer class="mt-10 flex items-center justify-between border-t border-line pt-6">
					<a href="{{@site.url}}/projects/" class="btn-ghost">{{> "icons/arrow-right" class="rotate-180"}} All projects</a>
					{{> "post/share"}}
				</footer>

				{{!-- Issues & feedback (comments, GitHub-issue vibe) --}}
				{{#if @site.comments_enabled}}
				<section class="mt-12 border-t border-line pt-10" id="issues">
					<p class="kicker"><span class="inline-block h-2.5 w-2.5 rounded-full border-2 border-current" aria-hidden="true"></span> Open thread</p>
					<h2 class="section-title mt-2">Issues &amp; feedback</h2>
					<p class="mt-2 max-w-xl text-sm leading-relaxed text-silver">Found a bug? Have a feature request? Open an issue below — no GitHub account required, and yes, I actually triage these.</p>
					<div class="mt-6">
						{{> "components/comments" title="Issues & feedback"}}
					</div>
				</section>
				{{/if}}
			</div>

			{{!-- ============ Right sidebar ============ --}}
			<aside class="space-y-6">
				{{!-- About box, GitHub-style --}}
				<div class="card-surface p-6 !transform-none">
					<p class="kicker">About</p>
					{{#if custom_excerpt}}<p class="mt-3 text-sm leading-relaxed text-silver">{{custom_excerpt}}</p>{{/if}}
					<ul class="mt-4 space-y-3 text-sm">
						<li class="flex items-center gap-2 text-silver">
							{{> "icons/github" class="h-4 w-4 shrink-0"}}
							<a href="https://github.com/imswarnil/{{slug}}" target="_blank" rel="noopener" class="min-w-0 truncate font-mono text-xs text-ink transition hover:text-accent hover:underline">github.com/imswarnil/{{slug}}</a>
						</li>
						<li class="flex items-center gap-2 text-silver">
							{{> "icons/external" class="h-4 w-4 shrink-0"}}
							<a href="{{url}}" data-live-from-slug="{{slug}}" target="_blank" rel="noopener" class="min-w-0 truncate font-mono text-xs text-ink transition hover:text-accent hover:underline"><span data-live-label>Live site</span></a>
						</li>
						<li class="flex items-center gap-2 text-silver">{{> "icons/calendar" class="h-4 w-4 shrink-0"}} Shipped {{date published_at format="MMM DD, YYYY"}}</li>
						<li class="flex items-center gap-2 text-silver">{{> "icons/clock" class="h-4 w-4 shrink-0"}} {{reading_time}}</li>
					</ul>
					<p class="mt-5 font-mono text-[10px] uppercase tracking-[0.3em] text-silver">Skills</p>
					<div class="mt-2 flex flex-wrap gap-1.5" data-skill-chips data-skill-names="{{#foreach tags visibility="internal"}}{{name}},{{/foreach}}"></div>
				</div>

				{{!-- Screenshots strip (filled from in-body galleries by script) --}}
				<div class="card-surface p-6 !transform-none" id="project-gallery" hidden>
					<p class="kicker">Screenshots</p>
					<div class="mt-4 grid grid-cols-3 gap-2" id="project-gallery-strip"></div>
				</div>

				{{!-- TOC (moved to #toc-mobile-slot on small screens) --}}
				<div id="toc-desktop-slot">
					{{> "post/toc"}}
				</div>

				{{> "components/adsense" slot="3487917390" format="auto" class="!my-0"}}
			</aside>
		</div>

		{{!-- ============ Closing CTA ============ --}}
		<section class="relative mt-16 overflow-hidden rounded-3xl border border-line px-6 py-14 text-center">
			<div class="bg-dots pointer-events-none absolute inset-0" aria-hidden="true"></div>
			<div class="relative mx-auto max-w-2xl">
				<p class="kicker justify-center">{{> "icons/sparkle"}} The end. Or is it?</p>
				<h2 class="section-title mt-3">Liked this? There's more where that came from.</h2>
				<p class="mt-3 text-sm leading-relaxed text-silver">I build things like this for fun — and, occasionally, for money.</p>
				<div class="mt-8 flex flex-wrap items-center justify-center gap-3">
					<a href="{{@site.url}}/projects/" class="btn-primary">Browse more projects {{> "icons/arrow-right" class="h-4 w-4"}}</a>
					<a href="{{@site.url}}/resume/" class="btn">Read my resume</a>
					<a href="{{@site.url}}/contact/" class="btn-ghost">Hire me before someone else does</a>
				</div>
				<p class="mt-6 font-mono text-xs text-silver">No projects were harmed in the making of this page.</p>
			</div>
		</section>
	</div>
</article>

{{!-- Related projects --}}
{{#get "posts" filter="tag:hash-project+id:-{{id}}" include="tags" limit="3" as |related|}}
	{{#if related}}
	<section class="border-t border-line bg-mist/40 py-16">
		<div class="container-site">
			<p class="kicker">{{> "icons/sparkle"}} More from the workbench</p>
			<h2 class="section-title mt-2">Related projects</h2>
			<div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
				{{#foreach related}}
					{{> "cards/project"}}
				{{/foreach}}
			</div>
		</div>
	</section>
	{{/if}}
{{/get}}

{{!-- Lightbox for sidebar screenshot strip --}}
<dialog id="project-lightbox" class="m-auto max-h-[90vh] max-w-[90vw] rounded-2xl border border-line bg-paper p-2 backdrop:bg-ink/80">
	<img id="project-lightbox-img" src="" alt="Project screenshot" class="max-h-[82vh] w-auto max-w-full rounded-xl" />
</dialog>

{{!-- Structured data --}}
<script type="application/ld+json">
{
	"@context": "https://schema.org",
	"@type": "SoftwareSourceCode",
	"name": "{{title}}",
	"description": "{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{excerpt words="30"}}{{/if}}",
	"url": "{{url absolute="true"}}",
	"codeRepository": "https://github.com/imswarnil/{{slug}}",
	"datePublished": "{{date published_at format="YYYY-MM-DD"}}",
	"dateModified": "{{date updated_at format="YYYY-MM-DD"}}",
	{{#if feature_image}}"image": "{{img_url feature_image size="1600" absolute="true"}}",{{/if}}
	"author": {
		"@type": "Person",
		"name": "Swarnil Singhai",
		"url": "{{@site.url}}"
	}
}
</script>

{{!-- Derived live links, skill chips, TOC placement, gallery strip + lightbox --}}
<script>
	(function () {
		if (window.__projectDetail) return;
		window.__projectDetail = true;

		function wireLinksAndChips() {
			document.querySelectorAll('a[data-live-from-slug]').forEach(function (a) {
				var slug = a.getAttribute('data-live-from-slug') || '';
				var url = 'https://' + slug.replace(/-/g, '') + '.imswarnil.com';
				a.href = url;
				var label = a.querySelector('[data-live-label]');
				if (label) label.textContent = url.replace('https://', '');
			});
			document.querySelectorAll('[data-skill-chips]').forEach(function (box) {
				if (box.dataset.built) return;
				box.dataset.built = '1';
				(box.getAttribute('data-skill-names') || '').split(',').forEach(function (name) {
					name = name.trim();
					if (name.indexOf('#skill-') !== 0) return;
					var label = name.slice(7);
					var hue = 0;
					for (var i = 0; i < label.length; i++) hue = (hue * 31 + label.charCodeAt(i)) % 360;
					var chip = document.createElement('span');
					chip.className = 'chip';
					var dot = document.createElement('span');
					dot.className = 'inline-block h-2 w-2 shrink-0 rounded-full';
					dot.style.backgroundColor = 'hsl(' + hue + ', 45%, 52%)';
					chip.appendChild(dot);
					chip.appendChild(document.createTextNode(' ' + label));
					box.appendChild(chip);
				});
			});
		}

		function placeToc() {
			var toc = document.getElementById('toc');
			var mobile = document.getElementById('toc-mobile-slot');
			var desktop = document.getElementById('toc-desktop-slot');
			if (!toc || !mobile || !desktop) return;
			var mq = window.matchMedia('(min-width: 1024px)');
			var move = function () {
				(mq.matches ? desktop : mobile).appendChild(toc);
			};
			move();
			if (mq.addEventListener) mq.addEventListener('change', move);
			else mq.addListener(move);
		}

		function buildGallery() {
			var imgs = document.querySelectorAll('.gh-content .kg-gallery-image img');
			if (!imgs.length) return;
			var box = document.getElementById('project-gallery');
			var strip = document.getElementById('project-gallery-strip');
			var lightbox = document.getElementById('project-lightbox');
			var lightboxImg = document.getElementById('project-lightbox-img');
			if (!box || !strip) return;
			box.hidden = false;
			Array.prototype.slice.call(imgs, 0, 6).forEach(function (img) {
				var btn = document.createElement('button');
				btn.type = 'button';
				btn.className = 'group overflow-hidden rounded-lg border border-line';
				btn.setAttribute('aria-label', 'View screenshot');
				var thumb = img.cloneNode(false);
				thumb.className = 'aspect-square w-full object-cover transition duration-300 group-hover:scale-105';
				thumb.loading = 'lazy';
				thumb.removeAttribute('srcset');
				thumb.removeAttribute('sizes');
				btn.appendChild(thumb);
				btn.addEventListener('click', function () {
					if (!lightbox || !lightboxImg || !lightbox.showModal) {
						img.scrollIntoView({ behavior: 'smooth', block: 'center' });
						return;
					}
					lightboxImg.src = img.currentSrc || img.src;
					lightbox.showModal();
				});
				strip.appendChild(btn);
			});
			if (lightbox) lightbox.addEventListener('click', function () { lightbox.close(); });
		}

		function init() {
			wireLinksAndChips();
			placeToc();
			buildGallery();
		}
		if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
		else init();
	})();
</script>
