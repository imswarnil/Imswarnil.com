{{!-- Course overview — full-width, box-free: sections stack and are divided by
     hairline borders (same language as the video page). Lessons are #lesson
     posts whose PUBLIC primary tag equals this course's primary tag — all
     queries key off primary_tag.slug (the old {{slug}} filter only worked when
     the post slug happened to match the tag). --}}
<article class="{{post_class}}">

	{{!-- Hero --}}
	<header class="relative overflow-hidden border-b border-line py-14">
		<div class="bg-cross pointer-events-none absolute inset-0" aria-hidden="true"></div>
		<a href="{{@site.url}}/courses/" class="icon-btn absolute right-4 top-4 z-10 !border !border-line !bg-paper/80 backdrop-blur tooltip tooltip-left" data-tip="All courses" aria-label="Close course, back to all courses">{{> "icons/close"}}</a>
		<div class="container-site relative grid items-center gap-10 lg:grid-cols-12">
			<div class="lg:col-span-7">
				<p class="kicker">{{> "icons/graduation"}} Course</p>
				<h1 class="mt-3 text-4xl font-semibold tracking-tight sm:text-5xl text-balance">{{title}}</h1>
				{{#if custom_excerpt}}<p class="mt-5 max-w-xl text-lg leading-relaxed text-silver">{{custom_excerpt}}</p>{{/if}}

				<div class="mt-6 flex flex-wrap items-center gap-2">
					{{#match visibility "public"}}<span class="chip tooltip" data-tip="Free — no account needed">{{> "icons/check"}} Free</span>{{/match}}
					{{#match visibility "members"}}<span class="chip tooltip" data-tip="Sign up free to unlock">{{> "icons/star"}} Members</span>{{/match}}
					{{#match visibility "paid"}}<span class="chip !border-transparent !bg-ink !text-paper tooltip" data-tip="Requires a paid plan">{{> "icons/lock"}} Paid</span>{{/match}}
					<span class="chip" data-duration-tags="{{#foreach tags visibility="internal"}}{{slug}} {{/foreach}}" hidden></span>
					{{#primary_tag}}
					{{#get "posts" filter="tag:hash-lesson+tags:{{slug}}" limit="1" as |firstpage counter|}}
						{{#if firstpage}}<span class="chip">{{> "icons/play"}} {{plural counter.total empty="No lessons yet" singular="% lesson" plural="% lessons"}}</span>{{/if}}
					{{/get}}
					{{/primary_tag}}
					<span class="chip">{{> "icons/calendar" class="h-3 w-3"}} Updated {{date updated_at format="MMM YYYY"}}</span>
				</div>

				<div class="mt-8 flex flex-wrap gap-3">
					{{#primary_tag}}
					{{#get "posts" filter="tag:hash-lesson+tags:{{slug}}" limit="1" order="published_at asc" as |first|}}
						{{#foreach first}}<a href="{{url}}" class="btn-primary">{{> "icons/play"}} Start course</a>{{/foreach}}
					{{/get}}
					{{/primary_tag}}
					<a href="#curriculum" class="btn-ghost">{{> "icons/book"}} Curriculum</a>
					<a href="#course-gear" class="btn-ghost">{{> "icons/zap"}} Gear</a>
				</div>
			</div>
			<div class="lg:col-span-5">
				{{#if feature_image}}<img src="{{img_url feature_image size="1000"}}" width="1000" height="750" alt="{{title}}" class="w-full rounded-3xl border border-line shadow-lift" />{{/if}}
			</div>
		</div>
	</header>

	{{!-- About --}}
	<section class="border-b border-line py-12">
		<div class="container-site">
			<div class="mx-auto max-w-3xl">
				<p class="kicker">{{> "icons/book"}} About this course</p>
				<div class="gh-content course-body mt-6">
					{{content}}
				</div>
			</div>
		</div>
	</section>

	{{!-- Curriculum — full-width rows, no box --}}
	<section id="curriculum" class="scroll-mt-24 border-b border-line py-12">
		<div class="container-site">
			<div class="mx-auto max-w-3xl">
				<p class="kicker">{{> "icons/play"}} Curriculum</p>
				<h2 class="section-title mt-2">Lesson by lesson</h2>
				{{#primary_tag}}
				{{#get "posts" filter="tag:hash-lesson+tags:{{slug}}" limit="50" order="published_at asc" include="tags" as |lessons|}}
					{{#if lessons}}
					<ol class="mt-6 divide-y divide-line border-y border-line">
						{{#foreach lessons}}
						<li>
							<a href="{{url}}" class="group flex items-center gap-4 px-1 py-4 transition hover:bg-mist/60 sm:px-3">
								<span class="w-8 shrink-0 text-center font-mono text-lg font-bold tabular-nums text-silver transition group-hover:text-ink">{{@number}}</span>
								<span class="min-w-0 flex-1">
									<span class="block text-[15px] font-semibold leading-snug tracking-tight">{{title}}</span>
									{{#if custom_excerpt}}<span class="mt-0.5 line-clamp-1 block text-[13px] text-silver">{{custom_excerpt}}</span>{{/if}}
								</span>
								<span class="hidden shrink-0 font-mono text-[10px] uppercase tracking-wide text-silver sm:block" data-duration-tags="{{#foreach tags visibility="internal"}}{{slug}} {{/foreach}}" hidden></span>
								{{#match visibility "!=" "public"}}
									<span class="tooltip shrink-0 text-silver" data-tip="{{#match visibility "paid"}}Paid members only{{else}}Members only{{/match}}">{{> "icons/lock"}}</span>
								{{else}}
									{{> "icons/play" class="shrink-0 text-silver opacity-0 transition group-hover:opacity-100"}}
								{{/match}}
							</a>
						</li>
						{{/foreach}}
					</ol>

					{{!-- Course JSON-LD: syllabus built server-side --}}
					<script type="application/ld+json" id="course-schema">
					{
						"@context": "https://schema.org",
						"@type": "Course",
						"name": "{{title}}",
						{{#if custom_excerpt}}"description": "{{custom_excerpt}}",{{/if}}
						"url": "{{url absolute="true"}}",
						{{#if feature_image}}"image": "{{img_url feature_image size="1000" absolute="true"}}",{{/if}}
						"isAccessibleForFree": {{#match visibility "public"}}true{{else}}false{{/match}},
						"provider": {
							"@type": "Person",
							"name": "{{primary_author.name}}",
							"url": "{{@site.url}}"
						},
						"hasCourseInstance": {
							"@type": "CourseInstance",
							"courseMode": "Online"
						},
						"syllabusSections": [
							{{#foreach lessons}}
							{ "@type": "Syllabus", "name": "{{title}}", "url": "{{url absolute="true"}}" }{{#unless @last}},{{/unless}}
							{{/foreach}}
						]
					}
					</script>
					{{else}}
					<p class="mt-6 text-sm text-silver">Lessons coming soon. Tag lesson posts with <code class="rounded bg-mist px-1 font-mono text-xs">#lesson</code> and give them this course's public tag <code class="rounded bg-mist px-1 font-mono text-xs">{{slug}}</code> as their FIRST tag.</p>
					{{/if}}
				{{/get}}
				{{/primary_tag}}
			</div>
		</div>
	</section>

	{{!-- Why I made this / how I teach --}}
	<section class="border-b border-line py-12">
		<div class="container-site">
			<div class="mx-auto grid max-w-3xl gap-8 sm:grid-cols-3">
				<div>
					<p class="kicker">{{> "icons/zap" class="h-3 w-3"}} Hands-on</p>
					<p class="mt-2 text-sm leading-relaxed text-silver">Every lesson ends with something working. No theory marathons.</p>
				</div>
				<div>
					<p class="kicker">{{> "icons/check" class="h-3 w-3"}} Battle-tested</p>
					<p class="mt-2 text-sm leading-relaxed text-silver">Built from real production mistakes — you get the shortcut.</p>
				</div>
				<div>
					<p class="kicker">{{> "icons/heart" class="h-3 w-3"}} Questions answered</p>
					<p class="mt-2 text-sm leading-relaxed text-silver">Ask in the discussion below — I reply to every comment.</p>
				</div>
			</div>
		</div>
	</section>

	{{!-- Instructor --}}
	<section class="border-b border-line py-12">
		<div class="container-site">
			<div class="mx-auto max-w-3xl">
				<p class="kicker">{{> "icons/user" class="h-3 w-3"}} Your instructor</p>
				<div class="mt-5 flex flex-wrap items-center gap-5">
					{{#primary_author}}
					{{#if profile_image}}
						<img src="{{img_url profile_image size="100"}}" width="72" height="72" alt="{{name}}" class="h-18 w-18 rounded-full border border-line object-cover" loading="lazy" style="width:72px;height:72px" />
					{{else}}
						<span class="flex h-16 w-16 items-center justify-center rounded-full border border-line bg-mist">{{> "icons/user" class="h-6 w-6 text-silver"}}</span>
					{{/if}}
					<div class="min-w-0 flex-1">
						<a href="{{url}}" class="text-lg font-semibold tracking-tight hover:underline hover:underline-offset-4">{{name}}</a>
						<p class="mt-1 text-sm leading-relaxed text-silver">{{#if bio}}{{bio}}{{else}}{{@custom.job_title}} at {{@custom.workplace}} — teaching what production taught first.{{/if}}</p>
					</div>
					{{/primary_author}}
					<a href="{{@site.url}}/about/" class="btn-ghost btn-sm shrink-0">About me {{> "icons/arrow-right" class="h-3 w-3"}}</a>
				</div>
			</div>
		</div>
	</section>

	{{!-- Gear used to build the course --}}
	{{#get "posts" filter="tag:hash-product+tag:hash-course-gear" limit="4" include="tags" as |gear|}}
		{{#if gear}}
		<section id="course-gear" class="scroll-mt-24 border-b border-line py-12">
			<div class="container-site">
				<div class="mx-auto max-w-3xl">
					<p class="kicker">{{> "icons/zap" class="h-3 w-3"}} Made with this gear</p>
					<p class="mt-2 text-sm text-silver">Everything used to record, edit and ship this course. Affiliate links keep the lessons free.</p>
					<div class="mt-5 grid gap-4 sm:grid-cols-2" data-reveal-stagger="80">
						{{#foreach gear}}
							{{> "cards/product-mini"}}
						{{/foreach}}
					</div>
				</div>
			</div>
		</section>
		{{/if}}
	{{/get}}

	{{!-- Ad --}}
	<section class="border-b border-line">
		<div class="container-site">
			<div class="mx-auto max-w-3xl">
				{{> "components/adsense" slot="6501428979" layout="in-article" format="fluid"}}
			</div>
		</div>
	</section>

	{{!-- Prev / next course pagination --}}
	<nav class="border-b border-line" aria-label="Course pagination">
		<div class="container-site">
			<div class="mx-auto grid max-w-3xl sm:grid-cols-2 sm:divide-x sm:divide-line">
				{{#prev_post}}
				<a href="{{url}}" class="group flex items-center gap-3 py-6 pr-4 transition hover:bg-mist/60">
					{{> "icons/arrow-right" class="shrink-0 rotate-180 text-silver transition group-hover:text-ink"}}
					<span class="min-w-0">
						<span class="block font-mono text-[10px] uppercase tracking-[0.2em] text-silver">Previous course</span>
						<span class="block truncate text-sm font-semibold">{{title}}</span>
					</span>
				</a>
				{{/prev_post}}
				{{#next_post}}
				<a href="{{url}}" class="group flex items-center justify-end gap-3 py-6 text-right transition hover:bg-mist/60 sm:pl-4">
					<span class="min-w-0">
						<span class="block font-mono text-[10px] uppercase tracking-[0.2em] text-silver">Next course</span>
						<span class="block truncate text-sm font-semibold">{{title}}</span>
					</span>
					{{> "icons/arrow-right" class="shrink-0 text-silver transition group-hover:text-ink"}}
				</a>
				{{/next_post}}
			</div>
		</div>
	</nav>

	{{!-- More courses --}}
	<section class="border-b border-line bg-mist/40 py-12">
		<div class="container-site">
			<p class="kicker">{{> "icons/sparkle"}} Keep learning</p>
			<h2 class="section-title mt-2">More courses</h2>
			{{#get "posts" filter="tag:hash-course+id:-{{id}}" limit="3" include="tags,authors" as |related|}}
				{{#if related}}
				<div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
					{{#foreach related}}
						{{> "cards/course"}}
					{{/foreach}}
				</div>
				{{else}}
				<p class="mt-6 text-sm text-silver">This is the only course so far — more on the way.</p>
				{{/if}}
			{{/get}}
		</div>
	</section>

	{{!-- Discussion --}}
	{{#if @site.comments_enabled}}
	<section class="py-12">
		<div class="container-site">
			<div class="mx-auto max-w-3xl">
				{{> "components/comments" title="Discussion"}}
			</div>
		</div>
	</section>
	{{/if}}
</article>

<style>
	/* "What you'll learn" / "Prerequisites" callouts (wrapped by the script below) */
	.course-callout { margin: 2rem 0; border: 1px solid rgb(var(--line)); border-radius: 1.25rem; padding: 1.5rem 1.5rem 1.25rem; background: rgb(var(--mist) / .45); }
	.course-callout > h2, .course-callout > h3 { margin: 0 0 .75rem !important; font-size: 1.05rem !important; }
	.course-callout ul, .course-callout ol { margin: 0 !important; padding-left: 0 !important; list-style: none !important; }
	.course-callout li { position: relative; padding-left: 1.85rem; margin: .4rem 0 !important; }
	.course-callout li::marker { content: ''; }
	.course-callout--learn li::before { content: '\2713'; position: absolute; left: .1rem; top: 0; font-weight: 700; color: #22c55e; }
	.course-callout--prereq { border-left: 3px solid #3b82f6; }
	.course-callout--prereq li::before { content: '\2139'; position: absolute; left: .15rem; top: 0; font-weight: 700; color: #3b82f6; }
</style>

<script>
	(function () {
		/* Wrap "Prerequisites" / "What you'll learn" heading + following list in callout boxes */
		var body = document.querySelector('.course-body');
		if (body) {
			body.querySelectorAll('h2, h3').forEach(function (h) {
				var t = h.textContent.trim().toLowerCase();
				var kind = null;
				if (/what you.{0,3}ll learn|what you will learn/.test(t)) kind = 'learn';
				else if (/prerequisite/.test(t)) kind = 'prereq';
				if (!kind) return;
				var list = h.nextElementSibling;
				if (!list || !/^(UL|OL)$/.test(list.tagName)) return;
				var box = document.createElement('div');
				box.className = 'course-callout course-callout--' + kind;
				h.parentNode.insertBefore(box, h);
				box.appendChild(h);
				box.appendChild(list);
			});
		}

		/* Patch timeRequired into the Course JSON-LD from the duration internal tag */
		var schema = document.getElementById('course-schema');
		var span = document.querySelector('[data-duration-tags]');
		if (!schema || !span) return;
		var m = (span.getAttribute('data-duration-tags') || '').match(/hash-duration-([\w-]+)/);
		if (!m) return;
		var h = (m[1].match(/(\d+)h/) || [])[1];
		var min = (m[1].match(/(\d+)m/) || [])[1];
		var iso = 'PT' + (h ? h + 'H' : '') + (min ? min + 'M' : '');
		if (iso === 'PT') return;
		try {
			var data = JSON.parse(schema.textContent);
			data.timeRequired = iso;
			if (data.hasCourseInstance) data.hasCourseInstance.courseWorkload = iso;
			schema.textContent = JSON.stringify(data);
		} catch (e) { /* leave schema as-is */ }
	})();
</script>
