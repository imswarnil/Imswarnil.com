{{!-- Course overview: syllabus is every #lesson post whose primary (public) tag is this course's primary tag --}}
<article class="{{post_class}}">
	<header class="relative overflow-hidden border-b border-line py-16">
		<div class="bg-cross pointer-events-none absolute inset-0" aria-hidden="true"></div>
		{{!-- ✕ leaves the course, back to the catalogue --}}
		<a href="{{@site.url}}/courses/" class="icon-btn absolute right-4 top-4 z-10 !border !border-line !bg-paper/80 backdrop-blur tooltip tooltip-left" data-tip="All courses" aria-label="Close course, back to all courses">{{> "icons/close"}}</a>
		<div class="container-site relative grid items-center gap-10 lg:grid-cols-12">
			<div class="lg:col-span-7">
				<p class="kicker">{{> "icons/book"}} Course</p>
				<h1 class="mt-3 text-4xl font-semibold tracking-tight sm:text-5xl text-balance">{{title}}</h1>
				{{#if custom_excerpt}}<p class="mt-5 max-w-xl text-lg leading-relaxed text-silver">{{custom_excerpt}}</p>{{/if}}

				<div class="mt-6 flex flex-wrap items-center gap-2">
					{{#match visibility "public"}}<span class="chip tooltip" data-tip="Free — no account needed">{{> "icons/check"}} Free</span>{{/match}}
					{{#match visibility "members"}}<span class="chip tooltip" data-tip="Sign up free to unlock">{{> "icons/star"}} Members</span>{{/match}}
					{{#match visibility "paid"}}<span class="chip !border-transparent !bg-ink !text-paper tooltip" data-tip="Requires a paid plan">{{> "icons/lock"}} Paid</span>{{/match}}
					<span class="chip" data-duration-tags="{{#foreach tags visibility="internal"}}{{slug}} {{/foreach}}" hidden></span>
					{{#get "posts" filter="tag:hash-lesson+tags:{{slug}}" limit="1" as |firstpage counter|}}
						{{#if firstpage}}<span class="chip">{{> "icons/play"}} {{plural counter.total empty="No lessons yet" singular="% lesson" plural="% lessons"}}</span>{{/if}}
					{{/get}}
				</div>

				{{!-- Instructors: every author on the course post --}}
				<div class="mt-7 flex flex-wrap gap-x-8 gap-y-4">
					{{#foreach authors}}
					<a href="{{url}}" class="group flex items-center gap-3">
						{{#if profile_image}}
							<img src="{{img_url profile_image size="100"}}" alt="{{name}}" class="h-11 w-11 rounded-full border border-line object-cover" loading="lazy" />
						{{else}}
							<span class="flex h-11 w-11 items-center justify-center rounded-full border border-line bg-mist">{{> "icons/user" class="text-silver"}}</span>
						{{/if}}
						<span>
							<span class="block text-sm font-semibold leading-tight group-hover:underline group-hover:underline-offset-4">{{name}}</span>
							<span class="block text-xs text-silver">{{#if bio}}{{bio}}{{else}}Instructor{{/if}}</span>
						</span>
					</a>
					{{/foreach}}
				</div>

				<div class="mt-8 flex flex-wrap gap-3">
					{{#get "posts" filter="tag:hash-lesson+tags:{{slug}}" limit="1" order="published_at asc" as |first|}}
						{{#foreach first}}<a href="{{url}}" class="btn-primary btn-lg">{{> "icons/play"}} Start course</a>{{/foreach}}
					{{/get}}
					<a href="#curriculum" class="btn-ghost btn-lg">{{> "icons/book"}} Curriculum</a>
				</div>
			</div>
			<div class="lg:col-span-5">
				{{#if feature_image}}<img src="{{img_url feature_image size="1000"}}" alt="{{title}}" class="w-full rounded-3xl border border-line shadow-lift" />{{/if}}
			</div>
		</div>
	</header>

	<div class="container-site py-10">
		<div class="mx-auto grid max-w-5xl gap-12 lg:grid-cols-12">
			<div class="lg:col-span-7">
				<section class="gh-content course-body">
					{{content}}
				</section>

				{{!-- Curriculum lives in the main column now (sidebar holds gear + ad) --}}
				<div id="curriculum" class="mt-12 card-surface p-6 !transform-none">
					<p class="kicker">{{> "icons/book"}} Curriculum</p>
					{{#get "posts" filter="tag:hash-lesson+tags:{{slug}}" limit="50" order="published_at asc" include="tags" as |lessons|}}
						{{#if lessons}}
						<ol class="mt-4 space-y-1">
							{{#foreach lessons}}
							<li>
								<a href="{{url}}" class="group flex items-center gap-3 rounded-xl px-3 py-2.5 transition hover:bg-mist">
									<span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full border border-line font-mono text-[11px] font-semibold text-silver transition group-hover:border-ink group-hover:text-ink">{{@number}}</span>
									<span class="min-w-0 flex-1">
										<span class="block text-sm font-medium leading-snug">{{title}}</span>
										<span class="font-mono text-[10px] uppercase tracking-wide text-silver" data-duration-tags="{{#foreach tags visibility="internal"}}{{slug}} {{/foreach}}" hidden></span>
									</span>
									{{#match visibility "!=" "public"}}
										<span class="tooltip shrink-0 text-silver" data-tip="{{#match visibility "paid"}}Paid members only{{else}}Members only{{/match}}">{{> "icons/lock"}}</span>
									{{else}}
										{{> "icons/play" class="ml-auto shrink-0 text-silver opacity-0 transition group-hover:opacity-100"}}
									{{/match}}
								</a>
							</li>
							{{/foreach}}
						</ol>

						{{!-- Course JSON-LD: syllabus built server-side; timeRequired patched in by JS from the duration tag --}}
						<script type="application/ld+json" id="course-schema">
						{
							"@context": "https://schema.org",
							"@type": "Course",
							"name": "{{title}}",
							{{#if custom_excerpt}}"description": "{{custom_excerpt}}",{{/if}}
							"url": "{{url absolute="true"}}",
							{{#if feature_image}}"image": "{{img_url feature_image size="1000" absolute="true"}}",{{/if}}
							"isAccessibleForFree": {{#match visibility "public"}}true{{else}}false{{/match}},
							"provider": {
								"@type": "Person",
								"name": "{{primary_author.name}}"{{#primary_author}},
								"url": "{{url absolute="true"}}"{{/primary_author}}
							},
							"hasCourseInstance": {
								"@type": "CourseInstance",
								"courseMode": "Online"
							},
							"syllabusSections": [
								{{#foreach lessons}}
								{ "@type": "Syllabus", "name": "{{title}}", "url": "{{url absolute="true"}}" }{{#unless @last}},{{/unless}}
								{{/foreach}}
							]
						}
						</script>
						{{else}}
						<p class="mt-4 text-sm text-silver">Lessons coming soon. Tag lesson posts with <code class="rounded bg-mist px-1 font-mono text-xs">#lesson</code> and make <code class="rounded bg-mist px-1 font-mono text-xs">{{slug}}</code> a public tag on the lesson (any position).</p>
						{{/if}}
					{{/get}}
				</div>

				{{> "components/adsense" slot="6501428979" layout="in-article" format="fluid"}}
			</div>

			{{!-- Sidebar: gear used to make the course + sticky ad --}}
			<aside class="lg:col-span-5">
				<div class="sticky top-24 space-y-6">
					{{#get "posts" filter="tag:hash-product+tag:hash-course-gear" limit="4" include="tags" as |gear|}}
						{{#if gear}}
						<div class="card-surface p-6 !transform-none">
							<p class="kicker">{{> "icons/zap"}} Made with this gear</p>
							<p class="mt-2 text-xs leading-relaxed text-silver">Everything used to record, edit and ship this course. Affiliate links keep the lessons free.</p>
							<ul class="mt-4 space-y-2">
								{{#foreach gear}}
								<li>
									<a href="{{url}}" class="group flex items-center gap-3 rounded-xl border border-line p-2.5 transition hover:bg-mist">
										<span class="relative h-12 w-12 shrink-0 overflow-hidden rounded-lg border border-line bg-mist">
											{{#if feature_image}}<img src="{{img_url feature_image size="100"}}" width="100" height="100" alt="" loading="lazy" class="h-full w-full object-cover" />{{else}}<span class="flex h-full w-full items-center justify-center">{{> "icons/zap" class="h-4 w-4 text-silver"}}</span>{{/if}}
										</span>
										<span class="min-w-0">
											<span class="block truncate text-[13px] font-semibold">{{title}}</span>
											<span class="block truncate text-[11px] text-silver">{{custom_excerpt}}</span>
										</span>
										{{> "icons/arrow-up-right" class="ml-auto h-3.5 w-3.5 shrink-0 text-silver transition group-hover:text-ink"}}
									</a>
								</li>
								{{/foreach}}
							</ul>
							<a href="{{@site.url}}/products/" class="btn-ghost mt-4 w-full justify-center !text-xs">Full toolkit {{> "icons/arrow-right" class="h-3.5 w-3.5"}}</a>
						</div>
						{{/if}}
					{{/get}}
					{{> "components/adsense" slot="3487917390" format="auto" class="!my-0"}}
					{{> "components/adsense" slot="9619442326" format="auto" class="!my-0 hidden xl:block"}}
				</div>
			</aside>
		</div>
	</div>

	{{!-- Related courses --}}
	<section class="border-t border-line bg-mist/40 py-16">
		<div class="container-site">
			<p class="kicker">{{> "icons/sparkle"}} Keep learning</p>
			<h2 class="section-title mt-2">More courses</h2>
			{{#get "posts" filter="tag:hash-course+id:-{{id}}" limit="3" include="tags,authors" as |related|}}
				{{#if related}}
				<div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
					{{#foreach related}}
						{{> "cards/course"}}
					{{/foreach}}
				</div>
				{{else}}
				<p class="mt-6 text-sm text-silver">This is the only course so far — more on the way.</p>
				{{/if}}
			{{/get}}
		</div>
	</section>

	{{#if @site.comments_enabled}}
	<section class="container-site py-16">
		<div class="mx-auto max-w-3xl">
			{{> "components/comments" title="Discussion"}}
		</div>
	</section>
	{{/if}}
</article>

<style>
	/* "What you'll learn" / "Prerequisites" callouts (wrapped by the script below) */
	.course-callout { margin: 2rem 0; border: 1px solid rgb(var(--line)); border-radius: 1.25rem; padding: 1.5rem 1.5rem 1.25rem; background: rgb(var(--mist) / .45); }
	.course-callout > h2, .course-callout > h3 { margin: 0 0 .75rem !important; font-size: 1.05rem !important; }
	.course-callout ul, .course-callout ol { margin: 0 !important; padding-left: 0 !important; list-style: none !important; }
	.course-callout li { position: relative; padding-left: 1.85rem; margin: .4rem 0 !important; }
	.course-callout li::marker { content: ''; }
	.course-callout--learn li::before { content: '\2713'; position: absolute; left: .1rem; top: 0; font-weight: 700; color: #22c55e; }
	.course-callout--prereq { border-left: 3px solid #3b82f6; }
	.course-callout--prereq li::before { content: '\2139'; position: absolute; left: .15rem; top: 0; font-weight: 700; color: #3b82f6; }

	/* Bookmark / product cards inside the course body → testimonial look */
	.course-body .kg-bookmark-container,
	.course-body .kg-product-card > .kg-product-card-container {
		border: 1px solid rgb(var(--line)); border-radius: 1.25rem; background: rgb(var(--mist) / .5);
		padding: 1.5rem; box-shadow: none; position: relative; text-decoration: none;
	}
	.course-body .kg-bookmark-container::before,
	.course-body .kg-product-card > .kg-product-card-container::before {
		content: '\201C'; position: absolute; top: .35rem; right: 1.1rem;
		font-family: Georgia, 'Times New Roman', serif; font-size: 3.25rem; line-height: 1;
		color: rgb(var(--silver) / .35); pointer-events: none;
	}
	.course-body .kg-bookmark-content { padding: 0 3rem 0 0; }
	.course-body .kg-bookmark-title,
	.course-body .kg-product-card-title { color: rgb(var(--ink)); font-weight: 600; }
	.course-body .kg-bookmark-description,
	.course-body .kg-product-card-description { color: rgb(var(--silver)); font-style: italic; }
	.course-body .kg-bookmark-thumbnail { align-self: center; margin: 0 0 0 1rem; width: 3.5rem; height: 3.5rem; min-width: 0; flex-shrink: 0; }
	.course-body .kg-bookmark-thumbnail img { border-radius: 9999px; width: 100%; height: 100%; object-fit: cover; border: 1px solid rgb(var(--line)); }
	.course-body .kg-bookmark-metadata { margin-top: .85rem; font-size: .8rem; color: rgb(var(--silver)); }
	.course-body .kg-bookmark-icon { border-radius: 9999px; }
	.course-body .kg-product-card-image { border-radius: 9999px; width: 3.5rem; height: 3.5rem; object-fit: cover; border: 1px solid rgb(var(--line)); }
</style>

<script>
	(function () {
		/* Wrap "Prerequisites" / "What you'll learn" heading + following list in callout boxes */
		var body = document.querySelector('.course-body');
		if (body) {
			body.querySelectorAll('h2, h3').forEach(function (h) {
				var t = h.textContent.trim().toLowerCase();
				var kind = null;
				if (/what you.{0,3}ll learn|what you will learn/.test(t)) kind = 'learn';
				else if (/prerequisite/.test(t)) kind = 'prereq';
				if (!kind) return;
				var list = h.nextElementSibling;
				if (!list || !/^(UL|OL)$/.test(list.tagName)) return;
				var box = document.createElement('div');
				box.className = 'course-callout course-callout--' + kind;
				h.parentNode.insertBefore(box, h);
				box.appendChild(h);
				box.appendChild(list);
			});
		}

		/* Patch timeRequired into the Course JSON-LD from the duration internal tag */
		var schema = document.getElementById('course-schema');
		var span = document.querySelector('[data-duration-tags]');
		if (!schema || !span) return;
		var m = (span.getAttribute('data-duration-tags') || '').match(/hash-duration-([\w-]+)/);
		if (!m) return;
		var h = (m[1].match(/(\d+)h/) || [])[1];
		var min = (m[1].match(/(\d+)m/) || [])[1];
		var iso = 'PT' + (h ? h + 'H' : '') + (min ? min + 'M' : '');
		if (iso === 'PT') return;
		try {
			var data = JSON.parse(schema.textContent);
			data.timeRequired = iso;
			if (data.hasCourseInstance) data.hasCourseInstance.courseWorkload = iso;
			schema.textContent = JSON.stringify(data);
		} catch (e) { /* leave schema as-is */ }
	})();
</script>
