{{!-- Course overview — professional course-platform layout.
     Lessons = #lesson posts whose PUBLIC primary tag equals this course's
     primary tag (all queries key off primary_tag.slug).
     Optional internal tags: #duration-2h-30m (total), #level-beginner|
     intermediate|advanced. Total curriculum time is summed client-side from
     each lesson's duration tag. --}}
<article class="{{post_class}}" id="course-app"
	data-title="{{title}}"
	data-url="{{url absolute="true"}}"
	data-desc="{{custom_excerpt}}"
	data-image="{{#if feature_image}}{{img_url feature_image size="1000" absolute="true"}}{{/if}}"
	data-free="{{#match visibility "public"}}true{{else}}false{{/match}}"
	data-author="{{primary_author.name}}">

	{{!-- Hero --}}
	<header class="relative overflow-hidden border-b border-line py-12 sm:py-14">
		<div class="bg-cross pointer-events-none absolute inset-0" aria-hidden="true"></div>
		<div class="container-site relative">

			{{!-- breadcrumb + close --}}
			<div class="mb-7 flex items-center justify-between gap-4">
				<nav class="flex min-w-0 items-center gap-2 font-mono text-[11px] uppercase tracking-[0.15em] text-silver" aria-label="Breadcrumb">
					<a href="{{@site.url}}/courses/" class="transition hover:text-ink">Courses</a>
					<span aria-hidden="true">/</span>
					<span class="truncate text-ink">{{title}}</span>
				</nav>
				<a href="{{@site.url}}/courses/" class="icon-btn shrink-0 !border !border-line !bg-paper/80 backdrop-blur tooltip tooltip-left" data-tip="All courses" aria-label="Close course, back to all courses">{{> "icons/close"}}</a>
			</div>

			<div class="grid items-start gap-10 lg:grid-cols-12">
				{{!-- left: the pitch --}}
				<div class="lg:col-span-7">
					<p class="kicker">{{> "icons/graduation"}} Course</p>
					<h1 class="mt-3 text-3xl font-semibold tracking-tight sm:text-5xl text-balance">{{title}}</h1>
					{{#if custom_excerpt}}<p class="mt-4 max-w-xl text-lg leading-relaxed text-silver">{{custom_excerpt}}</p>{{/if}}

					{{!-- meta row --}}
					<div class="mt-6 flex flex-wrap items-center gap-x-5 gap-y-2 font-mono text-[11px] uppercase tracking-[0.12em] text-silver">
						{{#primary_author}}<span class="flex items-center gap-1.5">{{> "icons/user" class="h-3.5 w-3.5"}} {{name}}</span>{{/primary_author}}
						<span class="flex items-center gap-1.5" id="course-total-duration">{{> "icons/clock" class="h-3.5 w-3.5"}} <span data-duration-tags="{{#foreach tags visibility="internal"}}{{slug}} {{/foreach}}" hidden></span></span>
						<span class="flex items-center gap-1.5">{{> "icons/calendar" class="h-3.5 w-3.5"}} Updated {{date updated_at format="MMM YYYY"}}</span>
						{{#has tag="#level-beginner"}}<span class="flex items-center gap-1.5">{{> "icons/zap" class="h-3.5 w-3.5"}} Beginner</span>{{/has}}
						{{#has tag="#level-intermediate"}}<span class="flex items-center gap-1.5">{{> "icons/zap" class="h-3.5 w-3.5"}} Intermediate</span>{{/has}}
						{{#has tag="#level-advanced"}}<span class="flex items-center gap-1.5">{{> "icons/zap" class="h-3.5 w-3.5"}} Advanced</span>{{/has}}
					</div>

					{{!-- instructor inline --}}
					{{#primary_author}}
					<a href="{{url}}" class="group mt-6 inline-flex items-center gap-3">
						{{#if profile_image}}
							<img src="{{img_url profile_image size="100"}}" width="40" height="40" alt="{{name}}" class="h-10 w-10 rounded-full border border-line object-cover" loading="lazy" />
						{{else}}
							<span class="flex h-10 w-10 items-center justify-center rounded-full border border-line bg-mist">{{> "icons/user" class="h-4 w-4 text-silver"}}</span>
						{{/if}}
						<span>
							<span class="block text-sm font-semibold leading-tight group-hover:underline group-hover:underline-offset-4">{{name}}</span>
							<span class="block text-xs text-silver">Instructor</span>
						</span>
					</a>
					{{/primary_author}}
				</div>

				{{!-- right: enrolment card --}}
				<div class="lg:col-span-5">
					<div class="overflow-hidden rounded-2xl border border-line bg-paper shadow-card">
						{{#foreach tags visibility="public" limit="1"}}
						{{#get "posts" filter="tag:hash-lesson+tags:{{slug}}" limit="1" order="published_at asc" as |first|}}
						{{#foreach first}}
						<a href="{{url}}" class="group relative block aspect-video overflow-hidden border-b border-line bg-mist" aria-label="Preview the first lesson">
							{{#if feature_image}}
								<img src="{{img_url feature_image size="1000"}}" width="1000" height="563" alt="{{title}}" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
							{{else}}
								<span class="bg-dots absolute inset-0"></span>
							{{/if}}
							<span class="absolute inset-0 flex items-center justify-center bg-black/25 transition group-hover:bg-black/35">
								<span class="flex h-14 w-14 items-center justify-center rounded-full bg-white text-black shadow-lg transition group-hover:scale-110">{{> "icons/play" class="ml-0.5 h-5 w-5"}}</span>
							</span>
							<span class="absolute bottom-3 left-3 rounded bg-black/70 px-2 py-0.5 font-mono text-[10px] uppercase tracking-[0.15em] text-white backdrop-blur">Preview lesson 1</span>
						</a>
						{{/foreach}}
						{{/get}}
						{{/foreach}}

						<div class="p-5 sm:p-6">
							<div class="flex items-baseline justify-between gap-3">
								{{#match visibility "public"}}<p class="text-2xl font-bold tracking-tight">Free</p><span class="font-mono text-[10px] uppercase tracking-[0.15em] text-silver">no account needed</span>{{/match}}
								{{#match visibility "members"}}<p class="text-2xl font-bold tracking-tight">Members</p><span class="font-mono text-[10px] uppercase tracking-[0.15em] text-silver">free signup unlocks</span>{{/match}}
								{{#match visibility "paid"}}<p class="text-2xl font-bold tracking-tight">Paid</p><span class="font-mono text-[10px] uppercase tracking-[0.15em] text-silver">supporters only</span>{{/match}}
							</div>

							{{#foreach tags visibility="public" limit="1"}}
							{{#get "posts" filter="tag:hash-lesson+tags:{{slug}}" limit="1" order="published_at asc" as |first|}}
								{{#foreach first}}<a href="{{url}}" class="btn-primary mt-4 w-full justify-center !py-2.5">{{> "icons/play"}} Start the course</a>{{/foreach}}
							{{/get}}
							{{/foreach}}
							<a href="#curriculum" class="btn-ghost mt-2 w-full justify-center">{{> "icons/book"}} Browse curriculum</a>

							<p class="kicker mt-6 !text-[10px]">This course includes</p>
							<ul class="mt-3 space-y-2 text-[13px] text-silver">
								{{#foreach tags visibility="public" limit="1"}}
								{{#get "posts" filter="tag:hash-lesson+tags:{{slug}}" limit="1" as |l counter|}}
								<li class="flex items-center gap-2.5">{{> "icons/play" class="h-3.5 w-3.5 shrink-0"}} {{plural counter.total empty="Lessons on the way" singular="% structured lesson" plural="% structured lessons"}}</li>
								{{/get}}
								{{/foreach}}
								<li class="flex items-center gap-2.5">{{> "icons/clock" class="h-3.5 w-3.5 shrink-0"}} <span id="course-includes-duration">Self-paced — watch anytime</span></li>
								<li class="flex items-center gap-2.5">{{> "icons/check" class="h-3.5 w-3.5 shrink-0"}} Progress tracking in your browser</li>
								<li class="flex items-center gap-2.5">{{> "icons/heart" class="h-3.5 w-3.5 shrink-0"}} Every question answered in the discussion</li>
								<li class="flex items-center gap-2.5">{{> "icons/zap" class="h-3.5 w-3.5 shrink-0"}} Lifetime access, free updates</li>
							</ul>

							<div class="mt-5 border-t border-line pt-4">
								{{> "post/share"}}
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</header>

	{{!-- Stats band --}}
	<section class="border-b border-line bg-mist/40">
		<div class="container-site">
			<div class="mx-auto grid max-w-4xl grid-cols-2 divide-x divide-line sm:grid-cols-4">
				{{#foreach tags visibility="public" limit="1"}}
				{{#get "posts" filter="tag:hash-lesson+tags:{{slug}}" limit="1" as |l counter|}}
				<div class="px-4 py-5 text-center"><p class="text-xl font-bold tabular-nums">{{counter.total}}</p><p class="mt-0.5 font-mono text-[9px] uppercase tracking-[0.18em] text-silver">lessons</p></div>
				{{/get}}
				{{/foreach}}
				<div class="px-4 py-5 text-center"><p class="text-xl font-bold tabular-nums" id="course-stat-duration">—</p><p class="mt-0.5 font-mono text-[9px] uppercase tracking-[0.18em] text-silver">total runtime</p></div>
				<div class="px-4 py-5 text-center"><p class="text-xl font-bold">{{#match visibility "public"}}Free{{else}}Members{{/match}}</p><p class="mt-0.5 font-mono text-[9px] uppercase tracking-[0.18em] text-silver">access</p></div>
				<div class="px-4 py-5 text-center"><p class="text-xl font-bold">{{date updated_at format="MMM YYYY"}}</p><p class="mt-0.5 font-mono text-[9px] uppercase tracking-[0.18em] text-silver">last updated</p></div>
			</div>
		</div>
	</section>

	{{!-- About --}}
	<section class="border-b border-line py-12">
		<div class="container-site">
			<div class="mx-auto max-w-3xl">
				<p class="kicker">{{> "icons/book"}} About this course</p>
				<div class="gh-content course-body mt-6">
					{{content}}
				</div>
			</div>
		</div>
	</section>

	{{!-- Curriculum --}}
	<section id="curriculum" class="scroll-mt-24 border-b border-line py-12">
		<div class="container-site">
			<div class="mx-auto max-w-3xl">
				<div class="flex flex-wrap items-end justify-between gap-3">
					<div>
						<p class="kicker">{{> "icons/play"}} Curriculum</p>
						<h2 class="section-title mt-2">Lesson by lesson</h2>
					</div>
					<p class="font-mono text-[11px] uppercase tracking-[0.15em] text-silver" id="curriculum-summary"></p>
				</div>
				{{#foreach tags visibility="public" limit="1"}}
				{{#get "posts" filter="tag:hash-lesson+tags:{{slug}}" limit="50" order="published_at asc" include="tags" as |lessons|}}
					{{#if lessons}}
					<ol class="mt-6 divide-y divide-line border-y border-line" id="curriculum-list">
						{{#foreach lessons}}
						<li>
							<a href="{{url}}" class="lesson-row group flex items-center gap-4 px-1 py-4 transition hover:bg-mist/60 sm:px-3" data-lesson-slug="{{slug}}">
								<span class="w-8 shrink-0 text-center font-mono text-lg font-bold tabular-nums text-silver transition group-hover:text-ink">{{@number}}</span>
								<span class="min-w-0 flex-1">
									<span class="flex items-center gap-2">
										<span class="truncate text-[15px] font-semibold leading-snug tracking-tight">{{title}}</span>
										<span class="lesson-row-done hidden shrink-0 items-center gap-1 rounded-full bg-green-500/15 px-1.5 py-0.5 font-mono text-[8px] font-bold uppercase tracking-[0.1em] text-green-600">{{> "icons/check" class="h-2.5 w-2.5"}} done</span>
									</span>
									{{#if custom_excerpt}}<span class="mt-0.5 line-clamp-1 block text-[13px] text-silver">{{custom_excerpt}}</span>{{/if}}
								</span>
								<span class="hidden shrink-0 font-mono text-[10px] uppercase tracking-wide text-silver sm:block" data-duration-tags="{{#foreach tags visibility="internal"}}{{slug}} {{/foreach}}" hidden></span>
								{{#match visibility "!=" "public"}}
									<span class="tooltip shrink-0 text-silver" data-tip="{{#match visibility "paid"}}Paid members only{{else}}Members only{{/match}}">{{> "icons/lock"}}</span>
								{{else}}
									<span class="shrink-0 rounded-full border border-line px-2 py-0.5 font-mono text-[9px] uppercase tracking-[0.12em] text-silver opacity-0 transition group-hover:opacity-100">preview</span>
								{{/match}}
							</a>
						</li>
						{{/foreach}}
					</ol>

					{{else}}
					<p class="mt-6 text-sm text-silver">Lessons coming soon. Tag lesson posts with <code class="rounded bg-mist px-1 font-mono text-xs">#lesson</code> and give them this course's public tag <code class="rounded bg-mist px-1 font-mono text-xs">{{slug}}</code> as their FIRST tag.</p>
					{{/if}}
				{{/get}}
				{{/foreach}}
			</div>
		</div>
	</section>

	{{!-- How I teach --}}
	<section class="border-b border-line py-12">
		<div class="container-site">
			<div class="mx-auto grid max-w-3xl gap-8 sm:grid-cols-3">
				<div>
					<p class="kicker">{{> "icons/zap" class="h-3 w-3"}} Hands-on</p>
					<p class="mt-2 text-sm leading-relaxed text-silver">Every lesson ends with something working. No theory marathons.</p>
				</div>
				<div>
					<p class="kicker">{{> "icons/check" class="h-3 w-3"}} Battle-tested</p>
					<p class="mt-2 text-sm leading-relaxed text-silver">Built from real production mistakes — you get the shortcut.</p>
				</div>
				<div>
					<p class="kicker">{{> "icons/heart" class="h-3 w-3"}} Questions answered</p>
					<p class="mt-2 text-sm leading-relaxed text-silver">Ask in the discussion below — I reply to every comment.</p>
				</div>
			</div>
		</div>
	</section>

	{{!-- Instructor --}}
	<section class="border-b border-line py-12">
		<div class="container-site">
			<div class="mx-auto max-w-3xl">
				<p class="kicker">{{> "icons/user" class="h-3 w-3"}} Your instructor</p>
				<div class="mt-5 flex flex-wrap items-center gap-5">
					{{#primary_author}}
					{{#if profile_image}}
						<img src="{{img_url profile_image size="100"}}" width="72" height="72" alt="{{name}}" class="rounded-full border border-line object-cover" loading="lazy" style="width:72px;height:72px" />
					{{else}}
						<span class="flex h-16 w-16 items-center justify-center rounded-full border border-line bg-mist">{{> "icons/user" class="h-6 w-6 text-silver"}}</span>
					{{/if}}
					<div class="min-w-0 flex-1">
						<a href="{{url}}" class="text-lg font-semibold tracking-tight hover:underline hover:underline-offset-4">{{name}}</a>
						<p class="mt-1 text-sm leading-relaxed text-silver">{{#if bio}}{{bio}}{{else}}{{@custom.job_title}} at {{@custom.workplace}} — teaching what production taught first.{{/if}}</p>
					</div>
					{{/primary_author}}
					<a href="{{@site.url}}/about/" class="btn-ghost btn-sm shrink-0">About me {{> "icons/arrow-right" class="h-3 w-3"}}</a>
				</div>
			</div>
		</div>
	</section>

	{{!-- FAQ --}}
	<section class="border-b border-line py-12">
		<div class="container-site">
			<div class="mx-auto max-w-3xl">
				<p class="kicker">{{> "icons/sparkle" class="h-3 w-3"}} Frequently asked</p>
				<div class="mt-5 divide-y divide-line border-y border-line">
					<details class="group py-4">
						<summary class="flex cursor-pointer items-center justify-between gap-3 text-[15px] font-semibold [&::-webkit-details-marker]:hidden">Do I need an account? {{> "icons/chevron-down" class="shrink-0 text-silver transition group-open:rotate-180"}}</summary>
						<p class="mt-3 text-sm leading-relaxed text-silver">{{#match visibility "public"}}No — this course is free and open. Signing up just adds progress across devices, email updates and an ad-free experience.{{else}}Yes — a free membership unlocks it (and turns ads off). Sign up with just an email, no password.{{/match}}</p>
					</details>
					<details class="group py-4">
						<summary class="flex cursor-pointer items-center justify-between gap-3 text-[15px] font-semibold [&::-webkit-details-marker]:hidden">How is progress tracked? {{> "icons/chevron-down" class="shrink-0 text-silver transition group-open:rotate-180"}}</summary>
						<p class="mt-3 text-sm leading-relaxed text-silver">In your browser — lessons mark themselves complete as you finish them, and you can toggle completion manually inside each lesson. No servers watching you study.</p>
					</details>
					<details class="group py-4">
						<summary class="flex cursor-pointer items-center justify-between gap-3 text-[15px] font-semibold [&::-webkit-details-marker]:hidden">Is there a certificate? {{> "icons/chevron-down" class="shrink-0 text-silver transition group-open:rotate-180"}}</summary>
						<p class="mt-3 text-sm leading-relaxed text-silver">No certificate — just the skill. Which, between us, is the part interviews check.</p>
					</details>
					<details class="group py-4">
						<summary class="flex cursor-pointer items-center justify-between gap-3 text-[15px] font-semibold [&::-webkit-details-marker]:hidden">I'm stuck. Where do I ask? {{> "icons/chevron-down" class="shrink-0 text-silver transition group-open:rotate-180"}}</summary>
						<p class="mt-3 text-sm leading-relaxed text-silver">The discussion at the bottom of any lesson — I answer every comment. For anything longer, <a href="{{@site.url}}/contact/" class="underline underline-offset-4">the contact page</a>.</p>
					</details>
				</div>
			</div>
		</div>
	</section>

	{{!-- Gear --}}
	{{#get "posts" filter="tag:hash-product+tag:hash-course-gear" limit="4" include="tags" as |gear|}}
		{{#if gear}}
		<section id="course-gear" class="scroll-mt-24 border-b border-line py-12">
			<div class="container-site">
				<div class="mx-auto max-w-3xl">
					<p class="kicker">{{> "icons/zap" class="h-3 w-3"}} Made with this gear</p>
					<p class="mt-2 text-sm text-silver">Everything used to record, edit and ship this course. Affiliate links keep the lessons free.</p>
					<div class="mt-5 grid gap-4 sm:grid-cols-2" data-reveal-stagger="80">
						{{#foreach gear}}
							{{> "cards/product-mini"}}
						{{/foreach}}
					</div>
				</div>
			</div>
		</section>
		{{/if}}
	{{/get}}

	{{!-- Ad --}}
	<section class="border-b border-line">
		<div class="container-site"><div class="mx-auto max-w-3xl">
			{{> "components/adsense" slot="6501428979" layout="in-article" format="fluid"}}
		</div></div>
	</section>

	{{!-- Prev / next course --}}
	<nav class="border-b border-line" aria-label="Course pagination">
		<div class="container-site">
			<div class="mx-auto grid max-w-3xl sm:grid-cols-2 sm:divide-x sm:divide-line">
				{{#prev_post}}
				<a href="{{url}}" class="group flex items-center gap-3 py-6 pr-4 transition hover:bg-mist/60">
					{{> "icons/arrow-right" class="shrink-0 rotate-180 text-silver transition group-hover:text-ink"}}
					<span class="min-w-0">
						<span class="block font-mono text-[10px] uppercase tracking-[0.2em] text-silver">Previous course</span>
						<span class="block truncate text-sm font-semibold">{{title}}</span>
					</span>
				</a>
				{{/prev_post}}
				{{#next_post}}
				<a href="{{url}}" class="group flex items-center justify-end gap-3 py-6 text-right transition hover:bg-mist/60 sm:pl-4">
					<span class="min-w-0">
						<span class="block font-mono text-[10px] uppercase tracking-[0.2em] text-silver">Next course</span>
						<span class="block truncate text-sm font-semibold">{{title}}</span>
					</span>
					{{> "icons/arrow-right" class="shrink-0 text-silver transition group-hover:text-ink"}}
				</a>
				{{/next_post}}
			</div>
		</div>
	</nav>

	{{!-- More courses --}}
	<section class="border-b border-line bg-mist/40 py-12">
		<div class="container-site">
			<p class="kicker">{{> "icons/sparkle"}} Keep learning</p>
			<h2 class="section-title mt-2">More courses</h2>
			{{#get "posts" filter="tag:hash-course+id:-{{id}}" limit="3" include="tags,authors" as |related|}}
				{{#if related}}
				<div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
					{{#foreach related}}
						{{> "cards/course"}}
					{{/foreach}}
				</div>
				{{else}}
				<p class="mt-6 text-sm text-silver">This is the only course so far — more on the way.</p>
				{{/if}}
			{{/get}}
		</div>
	</section>

	{{!-- Discussion --}}
	{{#if @site.comments_enabled}}
	<section class="py-12">
		<div class="container-site"><div class="mx-auto max-w-3xl">
			{{> "components/comments" title="Discussion"}}
		</div></div>
	</section>
	{{/if}}
</article>

<style>
	.course-callout { margin: 2rem 0; border: 1px solid rgb(var(--line)); border-radius: 1.25rem; padding: 1.5rem 1.5rem 1.25rem; background: rgb(var(--mist) / .45); }
	.course-callout > h2, .course-callout > h3 { margin: 0 0 .75rem !important; font-size: 1.05rem !important; }
	.course-callout ul, .course-callout ol { margin: 0 !important; padding-left: 0 !important; list-style: none !important; }
	.course-callout li { position: relative; padding-left: 1.85rem; margin: .4rem 0 !important; }
	.course-callout li::marker { content: ''; }
	.course-callout--learn li::before { content: '\2713'; position: absolute; left: .1rem; top: 0; font-weight: 700; color: #22c55e; }
	.course-callout--prereq { border-left: 3px solid #3b82f6; }
	.course-callout--prereq li::before { content: '\2139'; position: absolute; left: .15rem; top: 0; font-weight: 700; color: #3b82f6; }
</style>

<script>
	(function () {
		/* "What you'll learn" / "Prerequisites" → callout boxes */
		var body = document.querySelector('.course-body');
		if (body) {
			body.querySelectorAll('h2, h3').forEach(function (h) {
				var t = h.textContent.trim().toLowerCase();
				var kind = null;
				if (/what you.{0,3}ll learn|what you will learn/.test(t)) kind = 'learn';
				else if (/prerequisite/.test(t)) kind = 'prereq';
				if (!kind) return;
				var list = h.nextElementSibling;
				if (!list || !/^(UL|OL)$/.test(list.tagName)) return;
				var box = document.createElement('div');
				box.className = 'course-callout course-callout--' + kind;
				h.parentNode.insertBefore(box, h);
				box.appendChild(h);
				box.appendChild(list);
			});
		}

		/* Sum lesson durations → curriculum summary, stat band, includes list */
		function tagMinutes(el) {
			var m = (el.getAttribute('data-duration-tags') || '').match(/hash-duration-(?:(\d+)h)?-?(?:(\d+)m)?/);
			if (!m || (!m[1] && !m[2])) return 0;
			return (parseInt(m[1] || 0, 10) * 60) + parseInt(m[2] || 0, 10);
		}
		function fmt(mins) {
			if (!mins) return null;
			var h = Math.floor(mins / 60), mm = mins % 60;
			return (h ? h + 'h ' : '') + (mm ? mm + 'm' : '');
		}
		var rows = document.querySelectorAll('#curriculum-list [data-duration-tags]');
		var total = 0;
		rows.forEach(function (r) { total += tagMinutes(r); });
		var totalText = fmt(total);
		var summary = document.getElementById('curriculum-summary');
		if (summary) summary.textContent = rows.length + ' lessons' + (totalText ? ' · ' + totalText + ' total' : '');
		var stat = document.getElementById('course-stat-duration');
		if (stat && totalText) stat.textContent = totalText;
		var includes = document.getElementById('course-includes-duration');
		if (includes && totalText) includes.textContent = totalText + ' of focused content, self-paced';

		/* Mark curriculum rows the visitor already completed (shared localStorage) */
		var courseTag = '{{#foreach tags visibility="public" limit="1"}}{{slug}}{{/foreach}}';
		try {
			var done = JSON.parse(localStorage.getItem('swarnil-progress-' + courseTag)) || [];
			document.querySelectorAll('.lesson-row').forEach(function (row) {
				if (done.indexOf(row.getAttribute('data-lesson-slug')) > -1) {
					var b = row.querySelector('.lesson-row-done');
					if (b) { b.classList.remove('hidden'); b.classList.add('inline-flex'); }
				}
			});
		} catch (e) {}

		/* Course JSON-LD, built from the page itself (robust to tag order) */
		var app = document.getElementById('course-app');
		var rowsAll = [].slice.call(document.querySelectorAll('.lesson-row'));
		if (app) {
			var ld = {
				'@context': 'https://schema.org',
				'@type': 'Course',
				name: app.getAttribute('data-title'),
				url: app.getAttribute('data-url'),
				isAccessibleForFree: app.getAttribute('data-free') === 'true',
				provider: { '@type': 'Person', name: app.getAttribute('data-author'), url: location.origin },
				hasCourseInstance: { '@type': 'CourseInstance', courseMode: 'Online' }
			};
			if (app.getAttribute('data-desc')) ld.description = app.getAttribute('data-desc');
			if (app.getAttribute('data-image')) ld.image = app.getAttribute('data-image');
			if (rowsAll.length) {
				ld.syllabusSections = rowsAll.map(function (r) {
					return { '@type': 'Syllabus', name: (r.querySelector('.truncate') || r).textContent.trim(), url: r.href };
				});
			}
			if (total) {
				var iso = 'PT' + (Math.floor(total / 60) ? Math.floor(total / 60) + 'H' : '') + (total % 60 ? (total % 60) + 'M' : '');
				ld.timeRequired = iso;
				ld.hasCourseInstance.courseWorkload = iso;
			}
			var tag = document.createElement('script');
			tag.type = 'application/ld+json';
			tag.textContent = JSON.stringify(ld);
			document.head.appendChild(tag);
		}
	})();
</script>
