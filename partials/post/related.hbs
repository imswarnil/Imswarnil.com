{{!-- Related posts — cross-collection discovery on the public primary tag.
     A blog post tagged "travel" surfaces travel videos, courses and projects too. --}}
{{#if primary_tag}}
<section class="border-t border-line bg-mist/40 py-14">
	<div class="container-site">
		<p class="kicker">{{> "icons/sparkle"}} Keep exploring</p>
		<h2 class="section-title mt-2">More on “{{primary_tag.name}}”</h2>
		{{#get "posts" filter="tags:[{primary_tag.slug}]+id:-{id}" limit="6" include="tags" as |related|}}
			{{#if related}}
			<div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
				{{#foreach related}}
				<a href="{{url}}" class="card-surface group flex flex-col gap-3 p-5 !transform-none">
					<div class="flex items-center justify-between gap-2">
						{{#has tag="#video"}}
							<span class="chip !border-transparent !bg-ink !text-paper">{{> "icons/film" class="h-3.5 w-3.5"}} Related video</span>
						{{else has tag="#course"}}
							<span class="chip !border-transparent !bg-ink !text-paper">{{> "icons/book" class="h-3.5 w-3.5"}} Related course</span>
						{{else has tag="#project"}}
							<span class="chip !border-transparent !bg-ink !text-paper">{{> "icons/zap" class="h-3.5 w-3.5"}} Related project</span>
						{{else has tag="#webseries"}}
							<span class="chip !border-transparent !bg-ink !text-paper">{{> "icons/play" class="h-3.5 w-3.5"}} Related series</span>
						{{else}}
							<span class="chip">Related article</span>
						{{/has}}
						<span class="font-mono text-[10px] text-silver">{{date published_at format="MMM YYYY"}}</span>
					</div>
					<h3 class="text-base font-semibold leading-snug tracking-tight transition group-hover:text-silver">{{title}}</h3>
					<p class="line-clamp-2 text-sm leading-relaxed text-silver">{{custom_excerpt}}{{^custom_excerpt}}{{excerpt words="18"}}{{/custom_excerpt}}</p>
					<span class="mt-auto flex items-center gap-1.5 font-mono text-[11px] text-silver">Read {{> "icons/arrow-right" class="h-3.5 w-3.5 transition group-hover:translate-x-0.5"}}</span>
				</a>
				{{/foreach}}
			</div>
			{{else}}
			{{#get "posts" filter="id:-{id}" limit="3" include="tags" as |fallback|}}
			<div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
				{{#foreach fallback}}
				<a href="{{url}}" class="card-surface group flex flex-col gap-3 p-5 !transform-none">
					<div class="flex items-center justify-between gap-2">
						<span class="chip">Latest</span>
						<span class="font-mono text-[10px] text-silver">{{date published_at format="MMM YYYY"}}</span>
					</div>
					<h3 class="text-base font-semibold leading-snug tracking-tight transition group-hover:text-silver">{{title}}</h3>
					<p class="line-clamp-2 text-sm leading-relaxed text-silver">{{custom_excerpt}}{{^custom_excerpt}}{{excerpt words="18"}}{{/custom_excerpt}}</p>
				</a>
				{{/foreach}}
			</div>
			{{/get}}
			{{/if}}
		{{/get}}
	</div>
</section>
{{/if}}
