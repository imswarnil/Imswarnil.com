{{!-- Product-page layout for #shop posts --}}
<article class="{{post_class}}">
	<header class="relative overflow-hidden border-b border-line py-16">
		<div class="bg-grid pointer-events-none absolute inset-0 fade-mask-b" aria-hidden="true"></div>
		<div class="container-site relative">
			<div class="mx-auto max-w-5xl">
				<p class="kicker">{{> "icons/download"}} Shop</p>
				<h1 class="mt-3 max-w-3xl text-4xl font-semibold tracking-tight sm:text-5xl text-balance">{{title}}</h1>
				{{#if custom_excerpt}}<p class="mt-5 max-w-2xl text-lg leading-relaxed text-silver">{{custom_excerpt}}</p>{{/if}}
				<div class="mt-6 flex flex-wrap items-center gap-2">
					{{#match visibility "public"}}
						<span class="chip">Free</span>
					{{else}}
						<span class="chip bg-ink text-paper">{{> "icons/star" class="h-3 w-3"}} Premium</span>
					{{/match}}
					{{#foreach tags visibility="public"}}<a href="{{url}}" class="chip transition hover:border-ink hover:text-ink">{{name}}</a>{{/foreach}}
					<span class="chip">{{> "icons/calendar"}} {{date published_at format="MMM YYYY"}}</span>
				</div>
			</div>
		</div>
	</header>

	<div class="container-site py-10">
		<div class="mx-auto grid max-w-5xl gap-10 lg:grid-cols-[minmax(0,1fr)_320px]">
			{{!-- Main column --}}
			<div class="min-w-0">
				{{#if feature_image}}
					<img src="{{img_url feature_image size="1600"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" class="mb-10 w-full rounded-3xl border border-line shadow-lift" />
				{{/if}}

				<h2 id="included" class="section-title mb-6">What's included</h2>
				<section class="gh-content">
					{{content}}
				</section>

				{{> "components/adsense" slot="7663977887" format="auto"}}

				<footer class="mt-10 flex items-center justify-between border-t border-line pt-6">
					<a href="{{@site.url}}/shop/" class="btn-ghost">{{> "icons/arrow-right" class="rotate-180"}} All goodies</a>
					{{> "post/share"}}
				</footer>
			</div>

			{{!-- Sticky purchase / download box --}}
			<aside class="lg:pt-0">
				<div class="card-surface sticky top-24 p-6 shadow-lift">
					<p class="font-mono text-[11px] uppercase tracking-[0.25em] text-silver">Get this</p>
					<div class="mt-3 flex items-baseline gap-2">
						{{#match visibility "public"}}
							<span class="text-3xl font-semibold tracking-tight">Free</span>
						{{else}}
							<span class="text-3xl font-semibold tracking-tight">Premium</span>
						{{/match}}
					</div>
					<p class="mt-2 text-[13px] leading-relaxed text-silver">
						{{#match visibility "public"}}
							Instant download — no signup needed.
						{{else}}
							Available to members. Join to unlock this and every other premium download.
						{{/match}}
					</p>
					<div class="mt-5">
						{{#match visibility "public"}}
							<a id="shop-download-cta" href="#included" class="btn btn-primary w-full justify-center">{{> "icons/download"}} Download free</a>
						{{else}}
							<a href="#/portal/signup" data-portal="signup" class="btn btn-primary w-full justify-center">{{> "icons/zap"}} Unlock with membership</a>
						{{/match}}
					</div>
					<ul class="mt-6 space-y-2.5 border-t border-line pt-5 text-[13px] text-silver">
						<li class="flex items-center gap-2">{{> "icons/check" class="shrink-0"}} Digital delivery</li>
						<li class="flex items-center gap-2">{{> "icons/check" class="shrink-0"}} Free updates</li>
						<li class="flex items-center gap-2">{{> "icons/check" class="shrink-0"}} Made by {{primary_author.name}}</li>
					</ul>
				</div>
			</aside>
		</div>
	</div>
</article>

{{> "post/related"}}

{{#match visibility "public"}}
<script>
	/* Point the free-download CTA at the first link inside the post body.
	   Falls back to the same-page #included anchor if no link exists. */
	(function () {
		var cta = document.getElementById('shop-download-cta');
		if (!cta) return;
		var link = document.querySelector('.gh-content a[href]');
		if (link) {
			cta.href = link.href;
			if (/^https?:/.test(link.href) && link.host !== location.host) {
				cta.target = '_blank';
				cta.rel = 'noopener';
			}
		}
	})();
</script>
{{/match}}

<script type="application/ld+json">
{
	"@context": "https://schema.org",
	"@type": "Product",
	"name": "{{title}}",
	"url": "{{url absolute="true"}}",
	{{#if feature_image}}"image": "{{img_url feature_image size="1600" absolute="true"}}",{{/if}}
	"brand": { "@type": "Brand", "name": "{{@site.title}}" }{{#match visibility "public"}},
	"offers": {
		"@type": "Offer",
		"price": "0",
		"priceCurrency": "USD",
		"availability": "https://schema.org/InStock",
		"url": "{{url absolute="true"}}"
	}{{/match}}
}
</script>
