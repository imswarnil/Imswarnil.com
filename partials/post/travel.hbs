{{!-- Travel story — a single day/place inside a trip. Full-bleed photo header
     with the title and a pull-quote overlaid; prev/next walk the itinerary. --}}
<article class="{{post_class}}">
	<header class="relative -mt-20 flex min-h-[56vh] items-end overflow-hidden">
		<div class="absolute inset-0" aria-hidden="true">
			{{#if feature_image}}
				<img src="{{img_url feature_image size="2000"}}" alt="{{title}}" class="h-full w-full object-cover" />
			{{else}}
				<div class="bg-dots h-full w-full bg-mist"></div>
			{{/if}}
			<div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/25 to-black/25"></div>
		</div>
		<div class="container-site relative pb-12 pt-40">
			<p class="flex items-center gap-2 font-mono text-[10px] uppercase tracking-[0.3em] text-white/80">
				{{> "icons/map-pin" class="h-3.5 w-3.5"}}
				{{#primary_tag}}<a href="{{@site.url}}/travel/{{slug}}/" class="underline underline-offset-4 hover:text-white">{{name}}</a>{{/primary_tag}}
				· {{date published_at format="DD MMM YYYY"}}
			</p>
			<h1 class="mt-3 max-w-3xl text-4xl font-black tracking-tight text-white sm:text-5xl text-balance">{{title}}</h1>
			{{#if custom_excerpt}}<p class="mt-4 max-w-xl text-lg italic leading-relaxed text-white/85">"{{custom_excerpt}}"</p>{{/if}}
		</div>
	</header>

	<div class="container-site py-12">
		<div class="mx-auto max-w-prose">
			{{> "post/toc"}}
			<section class="gh-content">
				{{content}}
			</section>

			{{!-- Prev / next stop on the itinerary --}}
			<nav class="mt-12 grid gap-4 border-t border-line pt-6 sm:grid-cols-2" aria-label="Itinerary">
				{{#prev_post in="primary_tag"}}
				<a href="{{url}}" class="card-surface group flex items-center gap-3 p-4 !transform-none">
					<span class="text-lg">🛬</span>
					<span class="min-w-0">
						<span class="block font-mono text-[10px] uppercase tracking-[0.2em] text-silver">Previous stop</span>
						<span class="block truncate text-sm font-semibold">{{title}}</span>
					</span>
				</a>
				{{/prev_post}}
				{{#next_post in="primary_tag"}}
				<a href="{{url}}" class="card-surface group flex items-center justify-end gap-3 p-4 text-right !transform-none sm:col-start-2">
					<span class="min-w-0">
						<span class="block font-mono text-[10px] uppercase tracking-[0.2em] text-silver">Next stop</span>
						<span class="block truncate text-sm font-semibold">{{title}}</span>
					</span>
					<span class="text-lg">🛫</span>
				</a>
				{{/next_post}}
			</nav>

			{{> "components/adsense" slot="6501428979" layout="in-article" format="fluid"}}

			<footer class="mt-6 flex items-center justify-between border-t border-line pt-6">
				{{#primary_tag}}<a href="{{@site.url}}/travel/{{slug}}/" class="btn-ghost">{{> "icons/arrow-right" class="rotate-180"}} Back to {{name}}</a>{{/primary_tag}}
				{{> "post/share"}}
			</footer>

			{{#if @site.comments_enabled}}
			<div class="mt-12">{{comments title="Postcards" count=true}}</div>
			{{/if}}
		</div>
	</div>

	<script type="application/ld+json">
	{
		"@context": "https://schema.org",
		"@type": "Article",
		"headline": "{{title}}",
		"url": "{{url absolute="true"}}",
		"datePublished": "{{date published_at format="YYYY-MM-DD"}}",
		"description": "{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{excerpt words="40"}}{{/if}}"{{#if feature_image}},
		"image": "{{img_url feature_image size="1600" absolute="true"}}"{{/if}},
		"isPartOf": { "@type": "TouristTrip", "name": "{{primary_tag.name}}", "url": "{{@site.url}}/travel/{{primary_tag.slug}}/" }
	}
	</script>
</article>
