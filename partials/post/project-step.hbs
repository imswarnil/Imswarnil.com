{{!-- Project build-log (#project-detail). The PARENT project's repo-style hero
     stays constant across every step; only the body + rail change. The project
     is this post's primary (public) tag. Steps are ordered by date; the first is
     the "start", the last is the "ship". --}}
<article class="{{post_class}}">

	{{!-- ===== Parent project hero (project context, fetched by tag) — stays the
	     same on every build-log so it reads like one continuous project ===== --}}
	{{#primary_tag}}
	{{#get "posts" filter="tag:hash-project+tag:{{slug}}" limit="1" as |proj|}}
	{{#foreach proj}}
	<header class="relative overflow-hidden border-b border-line py-10">
		<div class="bg-grid pointer-events-none absolute inset-0 fade-mask-b" aria-hidden="true"></div>
		<div class="container-site relative">
			<nav class="flex flex-wrap items-center gap-2 font-mono text-sm" aria-label="Breadcrumb">
				{{> "icons/repo" class="h-4 w-4 text-silver"}}
				<a href="{{@site.url}}/projects/" class="text-silver transition hover:text-ink hover:underline">imswarnil</a>
				<span class="text-silver" aria-hidden="true">/</span>
				<a href="{{url}}" class="font-semibold text-ink transition hover:text-accent hover:underline">{{slug}}</a>
				<span class="text-silver" aria-hidden="true">/</span>
				<span class="chip !px-2 !text-[10px]">{{> "icons/pen" class="h-3 w-3"}} build log</span>
			</nav>
			<div class="mt-4 flex flex-wrap items-end justify-between gap-4">
				<h2 class="text-2xl font-semibold tracking-tight sm:text-3xl text-balance">{{title}}</h2>
				<a href="{{url}}" class="btn-ghost btn-sm shrink-0">{{> "icons/arrow-right" class="rotate-180"}} Back to project</a>
			</div>
			{{#if custom_excerpt}}<p class="mt-3 max-w-2xl text-sm leading-relaxed text-silver">{{custom_excerpt}}</p>{{/if}}
		</div>
	</header>
	{{/foreach}}
	{{/get}}
	{{/primary_tag}}

	{{!-- ===== Body: build-log rail (left) + this step (right) ===== --}}
	<div class="container-site py-10">
		<div class="grid gap-10 lg:grid-cols-[300px_minmax(0,1fr)]">

			{{!-- Build-log rail: every step of THIS project, start→ship --}}
			<aside class="rail-sticky">
				<p class="kicker">{{> "icons/pen" class="h-3.5 w-3.5"}} Build log</p>
				{{#primary_tag}}
				{{#get "posts" filter="tag:hash-project-detail+tags:{{slug}}" order="published_at asc" limit="50" include="tags" as |steps|}}
				<ol class="buildlog mt-4" id="buildlog-rail">
					{{#foreach steps}}
					<li class="buildlog-item {{#if @first}}is-start{{/if}} {{#if @last}}is-end{{/if}}">
						<a href="{{url}}" data-step-slug="{{slug}}" data-step-date="{{date published_at format="YYYY-MM-DD"}}" class="buildlog-link group">
							<span class="buildlog-dot" aria-hidden="true">
								{{#if @first}}{{> "icons/play" class="h-3 w-3"}}{{else if @last}}{{> "icons/check" class="h-3 w-3"}}{{else}}<span class="buildlog-num">{{@number}}</span>{{/if}}
							</span>
							<span class="min-w-0">
								<span class="buildlog-title">{{title}}</span>
								<span class="buildlog-meta">{{#if @first}}Start · {{else if @last}}Shipped · {{/if}}{{date published_at format="DD MMM YYYY"}}</span>
							</span>
						</a>
					</li>
					{{/foreach}}
				</ol>
				{{/get}}
				{{/primary_tag}}
			</aside>

			{{!-- The step itself --}}
			<div class="min-w-0">
				<div class="flex flex-wrap items-center gap-x-3 gap-y-2 font-mono text-[11px] text-silver">
					<span class="chip !py-0.5" id="step-pos">Build log</span>
					<span class="flex items-center gap-1.5">{{> "icons/calendar" class="h-3.5 w-3.5"}} {{date published_at format="DD MMM YYYY"}}</span>
					<span class="flex items-center gap-1.5" id="step-dayn" hidden>{{> "icons/clock" class="h-3.5 w-3.5"}} <span></span></span>
					<span class="flex items-center gap-1.5">{{> "icons/clock" class="h-3.5 w-3.5"}} {{reading_time}}</span>
				</div>

				<h1 class="mt-4 text-3xl font-semibold tracking-tight sm:text-4xl text-balance">{{title}}</h1>

				<section class="gh-content mt-8">
					{{content}}
				</section>

				{{> "components/adsense" slot="6501428979" layout="in-article" format="fluid"}}

				{{!-- Prev / next within this project (filled from the rail by JS) --}}
				<nav class="mt-10 grid border-y border-line sm:grid-cols-2 sm:divide-x sm:divide-line" aria-label="Build-log pagination">
					<a href="#" data-nav-prev hidden class="group flex items-center gap-3 py-5 pr-4 transition hover:bg-mist/60">
						{{> "icons/arrow-right" class="shrink-0 rotate-180 text-silver transition group-hover:text-ink"}}
						<span class="min-w-0">
							<span class="block font-mono text-[10px] uppercase tracking-[0.2em] text-silver">Previous step</span>
							<span class="block truncate text-sm font-semibold" data-nav-prev-title></span>
						</span>
					</a>
					<a href="#" data-nav-next hidden class="group flex items-center justify-end gap-3 py-5 text-right transition hover:bg-mist/60 sm:col-start-2 sm:pl-4">
						<span class="min-w-0">
							<span class="block font-mono text-[10px] uppercase tracking-[0.2em] text-silver">Next step</span>
							<span class="block truncate text-sm font-semibold" data-nav-next-title></span>
						</span>
						{{> "icons/arrow-right" class="shrink-0 text-silver transition group-hover:text-ink"}}
					</a>
					<span data-nav-end hidden class="flex items-center justify-center gap-2 py-5 font-semibold text-green-600 sm:col-span-2">{{> "icons/check" class="h-4 w-4"}} That's the ship. Project complete.</span>
				</nav>

				<footer class="mt-6 flex items-center justify-between border-t border-line pt-6">
					{{#primary_tag}}{{#get "posts" filter="tag:hash-project+tag:{{slug}}" limit="1" as |proj|}}{{#foreach proj}}<a href="{{url}}" class="btn-ghost">{{> "icons/arrow-right" class="rotate-180"}} Back to {{title}}</a>{{/foreach}}{{/get}}{{/primary_tag}}
					{{> "post/share"}}
				</footer>

				{{#if @site.comments_enabled}}
				<section class="mt-12 border-t border-line pt-10">{{> "components/comments" title="Notes & questions"}}</section>
				{{/if}}
			</div>
		</div>
	</div>
</article>

<script>
	(function () {
		var CURRENT = '{{slug}}';
		var links = [].slice.call(document.querySelectorAll('#buildlog-rail [data-step-slug]'));
		if (!links.length) return;
		var idx = links.findIndex(function (a) { return a.getAttribute('data-step-slug') === CURRENT; });

		/* highlight current step in the rail */
		if (idx > -1) {
			links[idx].closest('.buildlog-item').classList.add('is-current');
			links[idx].setAttribute('aria-current', 'page');
		}

		/* Step X of Y */
		var pos = document.getElementById('step-pos');
		if (pos && idx > -1) pos.textContent = 'Step ' + (idx + 1) + ' of ' + links.length;

		/* day-N since the project's first log, + overall span */
		function days(a, b) { return Math.round((new Date(b) - new Date(a)) / 86400000); }
		var firstDate = links[0].getAttribute('data-step-date');
		var curDate = idx > -1 ? links[idx].getAttribute('data-step-date') : null;
		var dayn = document.getElementById('step-dayn');
		if (dayn && firstDate && curDate) {
			var n = days(firstDate, curDate);
			dayn.querySelector('span').textContent = n <= 0 ? 'Day 1 (kickoff)' : 'Day ' + (n + 1);
			dayn.hidden = false;
		}

		/* prev / next from the rail; last step shows the "shipped" marker */
		function fill(sel, item, titleSel) {
			document.querySelectorAll(sel).forEach(function (a) {
				if (!item) { a.remove(); return; }
				a.href = item.href; a.hidden = false;
				var t = titleSel && a.querySelector(titleSel);
				if (t) t.textContent = (item.querySelector('.buildlog-title') || item).textContent.trim();
			});
		}
		fill('[data-nav-prev]', idx > 0 ? links[idx - 1] : null, '[data-nav-prev-title]');
		var isLast = idx > -1 && idx === links.length - 1;
		fill('[data-nav-next]', !isLast && idx > -1 ? links[idx + 1] : null, '[data-nav-next-title]');
		if (isLast) document.querySelectorAll('[data-nav-end]').forEach(function (e) { e.hidden = false; });
	})();
</script>
