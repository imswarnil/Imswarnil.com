{{!-- Product review layout for #product posts.
     Affiliate convention: the FIRST http(s) link inside the post body is the
     affiliate link — the inline script below pins it to the hero BUY button and
     the sticky sidebar "Get it here" CTA (both stay hidden if no link exists). --}}
<article class="{{post_class}}">

	{{!-- Hero: product on a pedestal --}}
	<header class="relative overflow-hidden border-b border-line py-14">
		<div class="bg-grid pointer-events-none absolute inset-0 fade-mask-b" aria-hidden="true"></div>
		<div class="container-site relative">
			<div class="grid items-center gap-10 lg:grid-cols-2">
				<div class="order-2 lg:order-1">
					<p class="kicker">{{> "icons/zap"}} Product review</p>
					<h1 class="mt-3 text-4xl font-semibold tracking-tight sm:text-5xl text-balance">{{title}}</h1>
					{{#if custom_excerpt}}<p class="mt-5 max-w-xl text-lg leading-relaxed text-silver">{{custom_excerpt}}</p>{{/if}}
					{{!-- Static 5-star rating visual --}}
					<div class="mt-5 flex items-center gap-2" role="img" aria-label="Rated 5 out of 5 stars">
						<span class="flex items-center gap-0.5 text-accent">
							{{> "icons/star"}}{{> "icons/star"}}{{> "icons/star"}}{{> "icons/star"}}{{> "icons/star"}}
						</span>
						<span class="font-mono text-xs uppercase tracking-[0.2em] text-silver">5.0 · I use this daily</span>
					</div>
					<div class="mt-7 flex flex-wrap items-center gap-3">
						<a href="#" data-affiliate-cta target="_blank" rel="noopener sponsored" class="btn btn-primary hidden">Buy it {{> "icons/arrow-up-right"}}</a>
						<a href="{{@site.url}}/products/" class="btn-ghost">All products</a>
					</div>
				</div>
				<div class="order-1 lg:order-2">
					{{#if feature_image}}
					<div class="bg-dots relative mx-auto flex max-w-md flex-col items-center rounded-3xl border border-line px-10 pt-10 pb-6">
						<img src="{{img_url feature_image size="1000"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
							class="relative z-10 max-h-72 w-auto max-w-full object-contain drop-shadow-xl" />
						{{!-- Pedestal --}}
						<div class="mt-3 h-3 w-3/4 rounded-full border border-line bg-mist shadow-lift" aria-hidden="true"></div>
					</div>
					{{/if}}
				</div>
			</div>
		</div>
	</header>

	<div class="container-site py-10">
		<div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_320px]">

			{{!-- Main column --}}
			<div class="min-w-0">
				<section class="gh-content">
					{{content}}
				</section>

				<footer class="mt-10 flex items-center justify-between border-t border-line pt-6">
					<a href="{{@site.url}}/products/" class="btn-ghost">{{> "icons/arrow-right" class="rotate-180"}} All products</a>
					{{> "post/share"}}
				</footer>

				{{#if @site.comments_enabled}}
				<section class="mt-12 border-t border-line pt-10">
					{{comments title="Questions about this?" count=true}}
				</section>
				{{/if}}
			</div>

			{{!-- Sticky sidebar --}}
			<aside class="space-y-6 lg:sticky lg:top-24 lg:self-start">

				{{!-- Affiliate CTA box (revealed by the script when a link is found) --}}
				<div data-affiliate-box class="card-surface hidden p-5">
					<p class="kicker">{{> "icons/heart"}} Like it?</p>
					<a href="#" data-affiliate-cta target="_blank" rel="noopener sponsored" class="btn btn-primary mt-4 w-full justify-center hidden">Get it here {{> "icons/external"}}</a>
					<p class="mt-3 text-center text-[11px] leading-relaxed text-silver">Affiliate link — costs you nothing, may earn me a coffee.</p>
				</div>

				{{!-- Product facts --}}
				<div class="card-surface p-5">
					<p class="kicker mb-4">{{> "icons/check"}} Facts</p>
					<dl class="space-y-3 text-sm">
						<div class="flex items-center justify-between gap-3">
							<dt class="text-silver">Group</dt>
							<dd>
								{{#has tag="#group-services"}}<span class="chip">Services</span>
								{{else has tag="#group-my-setup"}}<span class="chip">My setup</span>
								{{else has tag="#group-skin-care"}}<span class="chip">Skin care</span>
								{{else has tag="#group-travel"}}<span class="chip">Travel kit</span>
								{{else}}{{#primary_tag}}<span class="chip">{{name}}</span>{{/primary_tag}}{{/has}}
							</dd>
						</div>
						<div class="flex items-center justify-between gap-3">
							<dt class="text-silver">Added</dt>
							<dd class="font-medium">{{date published_at format="DD MMM YYYY"}}</dd>
						</div>
						<div class="flex items-center justify-between gap-3">
							<dt class="text-silver">Reviewed by</dt>
							<dd class="font-medium">{{primary_author.name}}</dd>
						</div>
					</dl>
				</div>

				{{> "components/adsense" slot="7663977887" format="auto"}}

				{{!-- Related products: same #group-* section when determinable, else any product --}}
				<div class="card-surface p-5">
					<p class="kicker mb-4">{{> "icons/sparkle"}} Also on the shelf</p>
					{{#has tag="#group-services"}}
						{{#get "posts" filter="id:-{{id}}+tag:hash-product+tag:hash-group-services" limit="3" as |related|}}
							{{#foreach related}}
								<a href="{{url}}" class="group -mx-2 flex items-center gap-3 rounded-xl px-2 py-2 transition hover:bg-mist">
									<span class="h-11 w-11 shrink-0 overflow-hidden rounded-lg border border-line bg-mist">{{#if feature_image}}<img src="{{img_url feature_image size="300"}}" alt="{{title}}" loading="lazy" class="h-full w-full object-cover" />{{/if}}</span>
									<span class="min-w-0"><span class="block truncate text-sm font-medium group-hover:text-accent">{{title}}</span><span class="block truncate text-xs text-silver">{{excerpt words="6"}}</span></span>
								</a>
							{{/foreach}}
						{{/get}}
					{{else has tag="#group-my-setup"}}
						{{#get "posts" filter="id:-{{id}}+tag:hash-product+tag:hash-group-my-setup" limit="3" as |related|}}
							{{#foreach related}}
								<a href="{{url}}" class="group -mx-2 flex items-center gap-3 rounded-xl px-2 py-2 transition hover:bg-mist">
									<span class="h-11 w-11 shrink-0 overflow-hidden rounded-lg border border-line bg-mist">{{#if feature_image}}<img src="{{img_url feature_image size="300"}}" alt="{{title}}" loading="lazy" class="h-full w-full object-cover" />{{/if}}</span>
									<span class="min-w-0"><span class="block truncate text-sm font-medium group-hover:text-accent">{{title}}</span><span class="block truncate text-xs text-silver">{{excerpt words="6"}}</span></span>
								</a>
							{{/foreach}}
						{{/get}}
					{{else has tag="#group-skin-care"}}
						{{#get "posts" filter="id:-{{id}}+tag:hash-product+tag:hash-group-skin-care" limit="3" as |related|}}
							{{#foreach related}}
								<a href="{{url}}" class="group -mx-2 flex items-center gap-3 rounded-xl px-2 py-2 transition hover:bg-mist">
									<span class="h-11 w-11 shrink-0 overflow-hidden rounded-lg border border-line bg-mist">{{#if feature_image}}<img src="{{img_url feature_image size="300"}}" alt="{{title}}" loading="lazy" class="h-full w-full object-cover" />{{/if}}</span>
									<span class="min-w-0"><span class="block truncate text-sm font-medium group-hover:text-accent">{{title}}</span><span class="block truncate text-xs text-silver">{{excerpt words="6"}}</span></span>
								</a>
							{{/foreach}}
						{{/get}}
					{{else has tag="#group-travel"}}
						{{#get "posts" filter="id:-{{id}}+tag:hash-product+tag:hash-group-travel" limit="3" as |related|}}
							{{#foreach related}}
								<a href="{{url}}" class="group -mx-2 flex items-center gap-3 rounded-xl px-2 py-2 transition hover:bg-mist">
									<span class="h-11 w-11 shrink-0 overflow-hidden rounded-lg border border-line bg-mist">{{#if feature_image}}<img src="{{img_url feature_image size="300"}}" alt="{{title}}" loading="lazy" class="h-full w-full object-cover" />{{/if}}</span>
									<span class="min-w-0"><span class="block truncate text-sm font-medium group-hover:text-accent">{{title}}</span><span class="block truncate text-xs text-silver">{{excerpt words="6"}}</span></span>
								</a>
							{{/foreach}}
						{{/get}}
					{{else}}
						{{#get "posts" filter="id:-{{id}}+tag:hash-product" limit="3" as |related|}}
							{{#foreach related}}
								<a href="{{url}}" class="group -mx-2 flex items-center gap-3 rounded-xl px-2 py-2 transition hover:bg-mist">
									<span class="h-11 w-11 shrink-0 overflow-hidden rounded-lg border border-line bg-mist">{{#if feature_image}}<img src="{{img_url feature_image size="300"}}" alt="{{title}}" loading="lazy" class="h-full w-full object-cover" />{{/if}}</span>
									<span class="min-w-0"><span class="block truncate text-sm font-medium group-hover:text-accent">{{title}}</span><span class="block truncate text-xs text-silver">{{excerpt words="6"}}</span></span>
								</a>
							{{/foreach}}
						{{/get}}
					{{/has}}
				</div>
			</aside>
		</div>
	</div>
</article>

{{!-- JSON-LD Product --}}
<script type="application/ld+json">
{
	"@context": "https://schema.org",
	"@type": "Product",
	"name": "{{title}}",
	{{#if feature_image}}"image": "{{img_url feature_image size="1200" absolute="true"}}",{{/if}}
	"description": "{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{excerpt words="40"}}{{/if}}",
	"review": {
		"@type": "Review",
		"reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
		"author": { "@type": "Person", "name": "{{primary_author.name}}" }
	}
}
</script>

{{!-- Affiliate pin: first external link in the body becomes the CTA target --}}
<script>
	(function () {
		var link = document.querySelector('.gh-content a[href^="http"]');
		if (!link) return;
		document.querySelectorAll('[data-affiliate-cta]').forEach(function (el) {
			el.href = link.href;
			el.classList.remove('hidden');
		});
		var box = document.querySelector('[data-affiliate-box]');
		if (box) box.classList.remove('hidden');
	})();
</script>
