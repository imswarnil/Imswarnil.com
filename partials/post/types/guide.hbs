{{!--
	GUIDE  (#guide)
	================================================================
	A reference-style, long-form layout: a compact header noting when it was
	last updated, the feature image, then the body with its TOC (the standard
	content partial already renders a sticky TOC when a sidebar isn't shown).
--}}
<header class="post-header container-wide ptype-header ptype-guide-header">
	<span class="ptype-eyebrow">{{t "Guide"}}</span>
	<h1 class="post-title">{{title}}</h1>
	{{#if custom_excerpt}}<p class="ptype-lede">{{custom_excerpt}}</p>{{/if}}
	<ul class="post-meta">
		{{#if authors}}{{> "post/meta-author"}}<li class="separator">&bull;</li>{{/if}}
		<li class="ptype-updated">{{t "Updated"}} <time datetime="{{date updated_at format="YYYY-MM-DD"}}">{{date updated_at format=(t "MMMM D, YYYY")}}</time></li>
		{{#if reading_time}}<li class="separator">&bull;</li><li>{{reading_time minute=(t "1 min read") minutes=(t "% min read")}}</li>{{/if}}
	</ul>
	<div class="post-header-buttons">{{> "post/button-comments"}}{{> "post/button-share"}}</div>
</header>

{{> "post/media"}}

{{> "monetization/adsense" slot="8939839370" class="ad-post-top container" cta=true}}

{{> "post/content"}}

{{> "monetization/adsense" slot="6501428979" format="fluid" layout="in-article" class="ad-post-bottom container"}}

{{> "post/read-next"}}
{{> "sections/subscription"}}
{{> "post/comments"}}
