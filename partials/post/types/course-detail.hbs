{{!--
	COURSE landing  (#course)
	================================================================
	A course overview page: eyebrow + title + lede, feature image, the course
	description (post content), then the auto-built lesson list (every #lesson
	post sharing this course's primary tag) and an enrol CTA.
--}}
<header class="post-header container-wide ptype-header ptype-course-header">
	<span class="ptype-eyebrow">{{> "icons/flame"}} {{t "Course"}}</span>
	<h1 class="post-title">{{title}}</h1>
	{{#if custom_excerpt}}<p class="ptype-lede">{{custom_excerpt}}</p>{{/if}}
	<ul class="post-meta">
		{{#if authors}}{{> "post/meta-author"}}<li class="separator">&bull;</li>{{/if}}
		<li><time class="post-meta-date" datetime="{{date format="YYYY-MM-DD"}}">{{date format=(t "MMMM D, YYYY")}}</time></li>
	</ul>
</header>

{{> "post/media"}}

{{!-- Ad: top of course page. --}}
{{> "monetization/adsense" slot="8939839370" class="ad-post-top container" cta=true}}

{{!-- Course overview (post body). --}}
{{> "post/content" hide_tags=true}}

{{!-- Lessons in this course (shared primary tag + #lesson). --}}
<section class="container ptype-lessons">
	<h2 class="ptype-section-title">{{t "Lessons"}}</h2>
	{{#get "posts" filter="tag:hash-lesson+primary_tag:{{primary_tag.slug}}" order="published_at asc" limit="50" as |lessons|}}
		{{#if lessons}}
			<ol class="ptype-lesson-list">
				{{#foreach lessons}}
				<li>
					<a class="ptype-lesson" href="{{url}}">
						<span class="ptype-lesson-index">{{@number}}</span>
						<span class="ptype-lesson-body">
							<span class="ptype-lesson-title">{{title}}</span>
							{{#if excerpt}}<span class="ptype-lesson-excerpt">{{excerpt words="18"}}</span>{{/if}}
						</span>
						{{#if reading_time}}<span class="ptype-lesson-time">{{reading_time}}</span>{{/if}}
					</a>
				</li>
				{{/foreach}}
			</ol>
			{{#foreach lessons}}{{#if @first}}
				<a class="button button-lg ptype-cta" href="{{url}}">{{t "Start the course"}} {{> "icons/arrow-narrow-right"}}</a>
			{{/if}}{{/foreach}}
		{{else}}
			<p class="ptype-empty">{{t "Lessons are coming soon."}}</p>
		{{/if}}
	{{/get}}
</section>

{{!-- Tags + comments. --}}
{{> "post/tags" class="container"}}
{{> "post/comments"}}
