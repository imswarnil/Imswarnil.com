{{!--
	VIDEO detail  (#video-detail)
	================================================================
	A single video: the player/feature media up top (PVS upgrades an embedded
	YouTube/Vimeo in the feature area to an inline player), title + meta, the
	description (post body) and more videos from the same playlist.
--}}
<nav class="container-wide ptype-breadcrumb" aria-label="{{t "Breadcrumb"}}">
	{{#get "posts" filter="tag:hash-video+primary_tag:{{primary_tag.slug}}" limit="1" as |playlist|}}
		{{#foreach playlist}}
			<a href="{{url}}">{{> "icons/arrow-narrow-right" class="ptype-breadcrumb-back"}} {{title}}</a>
		{{/foreach}}
	{{/get}}
</nav>

<div class="ptype-video-stage">
	{{> "post/media"}}
</div>

<header class="post-header container-wide ptype-header">
	<h1 class="post-title">{{title}}</h1>
	<ul class="post-meta">
		{{#if authors}}{{> "post/meta-author"}}<li class="separator">&bull;</li>{{/if}}
		<li><time class="post-meta-date" datetime="{{date format="YYYY-MM-DD"}}">{{date format=(t "MMMM D, YYYY")}}</time></li>
	</ul>
	<div class="post-header-buttons">{{> "post/button-comments"}}{{> "post/button-share"}}</div>
</header>

{{> "post/content"}}

<section class="container-wide ptype-video-grid-wrap">
	<h2 class="ptype-section-title">{{t "More from this playlist"}}</h2>
	{{#get "posts" include="authors,tags" filter="tag:hash-video-detail+primary_tag:{{primary_tag.slug}}+id:-{{id}}" order="published_at asc" limit="6" as |more|}}
		{{#if more}}
			<ul class="posts-list ptype-video-grid">
				{{#foreach more}}<li>{{> "components/card-post" style="Classic"}}</li>{{/foreach}}
			</ul>
		{{/if}}
	{{/get}}
</section>

{{> "post/comments"}}
