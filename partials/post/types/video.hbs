{{!--
	VIDEO playlist / collection landing  (#video)
	================================================================
	A landing page for a set of videos: intro + a grid of the individual
	videos (#video-detail) that share this playlist's primary tag.
--}}
<header class="post-header container-wide ptype-header ptype-video-header">
	<span class="ptype-eyebrow">{{> "icons/video"}} {{t "Videos"}}</span>
	<h1 class="post-title">{{title}}</h1>
	{{#if custom_excerpt}}<p class="ptype-lede">{{custom_excerpt}}</p>{{/if}}
</header>

{{> "post/media"}}

{{#if html}}{{> "post/content" hide_tags=true}}{{/if}}

<section class="container-wide ptype-video-grid-wrap">
	<h2 class="ptype-section-title">{{t "Episodes"}}</h2>
	{{#get "posts" include="authors,tags" filter="tag:hash-video-detail+primary_tag:{{primary_tag.slug}}" order="published_at asc" limit="50" as |videos|}}
		{{#if videos}}
			<ul class="posts-list ptype-video-grid">
				{{#foreach videos}}
					<li>{{> "components/card-post" style="Classic"}}</li>
				{{/foreach}}
			</ul>
		{{else}}
			<p class="ptype-empty">{{t "Videos are coming soon."}}</p>
		{{/if}}
	{{/get}}
</section>

{{> "monetization/adsense" slot="3375031396" format="autorelaxed" class="ad-post-multiplex container"}}
{{> "post/comments"}}
