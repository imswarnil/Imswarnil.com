{{!--
	TRAVEL post  (#travel)
	================================================================
	Image-forward: a full-bleed hero with the title overlaid, a destination /
	date meta strip, then the story (post body) with TOC and tags.
--}}
<header class="ptype-travel-hero{{#unless feature_image}} ptype-travel-hero-plain{{/unless}}">
	{{#if feature_image}}
		<div class="ptype-travel-hero-media">
			{{> "components/image" fast="true" src=feature_image alt=feature_image_alt altElse=title}}
		</div>
	{{/if}}
	<div class="ptype-travel-hero-body container-wide">
		<span class="ptype-eyebrow ptype-eyebrow-onmedia">{{> "icons/glob"}} {{t "Travel"}}</span>
		<h1 class="post-title">{{title}}</h1>
		<ul class="post-meta ptype-travel-meta">
			{{#if primary_tag}}<li class="ptype-place">{{primary_tag.name}}</li><li class="separator">&bull;</li>{{/if}}
			<li><time datetime="{{date format="YYYY-MM-DD"}}">{{date format=(t "MMMM D, YYYY")}}</time></li>
			{{#if reading_time}}<li class="separator">&bull;</li><li>{{reading_time minute=(t "1 min read") minutes=(t "% min read")}}</li>{{/if}}
		</ul>
	</div>
</header>

{{> "monetization/adsense" slot="8939839370" class="ad-post-top container"}}

{{> "post/content"}}

{{> "post/read-next"}}
{{> "sections/subscription"}}
{{> "post/comments"}}
