{{!-- Newsletter issue — the whole post reads as an opened email inside a mac
     window. The red traffic light folds the window into an envelope, then
     returns to /newsletters/. Rendered inside {{#post}} from post.hbs. --}}

<style>
	/* ---- Close choreography (~700ms): window folds away, envelope seals ---- */
	#nl-stage { perspective: 1400px; }
	@keyframes nl-window-close {
		0% { transform: none; opacity: 1; }
		55% { transform: rotateX(32deg) scale(.6); opacity: .9; }
		100% { transform: rotateX(74deg) scale(.06) translateY(40%); opacity: 0; }
	}
	@keyframes nl-env-in {
		from { opacity: 0; transform: scale(.35); }
		to { opacity: 1; transform: scale(1); }
	}
	@keyframes nl-flap-close {
		from { transform: rotateX(150deg); }
		to { transform: rotateX(0deg); }
	}
	@keyframes nl-env-caption { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }
	.nl-closing #nl-window { animation: nl-window-close .45s cubic-bezier(.5, 0, .7, .3) forwards; }
	#nl-envelope { opacity: 0; pointer-events: none; }
	.nl-closing #nl-envelope { animation: nl-env-in .28s cubic-bezier(.2, .9, .3, 1.2) .28s forwards; }
	#nl-flap { transform-origin: 50% 0%; transform: rotateX(150deg); }
	.nl-closing #nl-flap { animation: nl-flap-close .24s ease-in .44s forwards; }
	#nl-env-caption { opacity: 0; }
	.nl-closing #nl-env-caption { animation: nl-env-caption .3s ease .5s forwards; }
	@media (prefers-reduced-motion: reduce) {
		.nl-closing #nl-window, .nl-closing #nl-envelope, .nl-closing #nl-flap, .nl-closing #nl-env-caption { animation: none; }
	}

	/* Members form states — Portal toggles .success/.error/.loading on the form */
	.nl-form [data-members-success], .nl-form [data-members-error] { display: none; }
	.nl-form.success [data-members-success] { display: flex; }
	.nl-form.error [data-members-error] { display: block; }
	.nl-form.success .nl-form-fields { display: none; }
	.nl-form.loading button[type='submit'] { opacity: .6; pointer-events: none; }

	/* Red light shows an × on hover, like the real thing */
	#nl-close .nl-x { opacity: 0; transition: opacity .15s ease; }
	#nl-close:hover .nl-x { opacity: 1; }
</style>

<article class="{{post_class}}">
	<section class="relative overflow-hidden py-10 sm:py-16">
		<div class="bg-dots pointer-events-none absolute inset-0 fade-mask-b" aria-hidden="true"></div>
		<div class="container-site relative">
			<div id="nl-stage" class="mx-auto max-w-4xl">
				<p class="mb-6 flex items-center justify-center gap-2 kicker">{{> "icons/mail"}} {{#if @custom.newsletter_title}}{{@custom.newsletter_title}}{{else}}The Signal{{/if}} · issue</p>

				<div id="nl-window" class="mockup-window before:hidden !pt-0 overflow-hidden rounded-2xl border border-line bg-paper shadow-lift">
					{{!-- mac title bar --}}
					<div class="flex items-center gap-2 border-b border-line bg-mist/60 px-4 py-3">
						<a id="nl-close" href="{{@site.url}}/newsletters/" class="tooltip tooltip-right relative flex h-3.5 w-3.5 items-center justify-center rounded-full bg-[#ff5f57]" data-tip="Close — back to all issues" aria-label="Close and go back to all issues">
							<span class="nl-x text-[9px] font-bold leading-none text-black/60" aria-hidden="true">&times;</span>
						</a>
						<span class="h-3.5 w-3.5 rounded-full bg-[#febc2e]" aria-hidden="true"></span>
						<span class="h-3.5 w-3.5 rounded-full bg-[#28c840]" aria-hidden="true"></span>
						<p class="ml-3 min-w-0 flex-1 truncate text-center font-mono text-[11px] text-silver">{{title}} — Inbox</p>
						<span class="chip !py-0.5 shrink-0">{{reading_time}}</span>
					</div>

					{{!-- email header --}}
					<header class="border-b border-line px-6 py-6 sm:px-10">
						<div class="flex items-start gap-4">
							{{#primary_author}}
								{{#if profile_image}}<img src="{{img_url profile_image size="100"}}" alt="{{name}}" class="h-11 w-11 rounded-full border border-line object-cover" />{{/if}}
							{{/primary_author}}
							<div class="min-w-0 flex-1 space-y-1 text-sm leading-6">
								<p><span class="mr-2 inline-block w-16 font-mono text-[10px] uppercase tracking-[0.18em] text-silver">From</span><span class="font-medium">Swarnil</span> <span class="text-silver">&lt;hello@imswarnil.com&gt;</span></p>
								<p><span class="mr-2 inline-block w-16 font-mono text-[10px] uppercase tracking-[0.18em] text-silver">To</span>You <span class="chip !py-0.5">subscriber</span></p>
								<p><span class="mr-2 inline-block w-16 font-mono text-[10px] uppercase tracking-[0.18em] text-silver">Date</span><span class="text-silver">{{date published_at format="dddd, DD MMMM YYYY"}}</span></p>
							</div>
						</div>
						<h1 class="mt-5 text-2xl font-semibold leading-tight tracking-tight text-balance sm:text-4xl"><span class="mr-3 hidden align-middle font-mono text-[10px] uppercase tracking-[0.18em] text-silver sm:inline-block">Subject</span>{{title}}</h1>
						{{#if custom_excerpt}}<p class="mt-3 max-w-2xl text-base leading-relaxed text-silver">{{custom_excerpt}}</p>{{/if}}
					</header>

					{{#if feature_image}}
					<figure class="border-b border-line">
						<img src="{{img_url feature_image size="1600"}}"
							srcset="{{img_url feature_image size="600"}} 600w, {{img_url feature_image size="1000"}} 1000w, {{img_url feature_image size="1600"}} 1600w"
							sizes="(max-width: 896px) 100vw, 896px"
							alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
							class="max-h-[28rem] w-full object-cover" />
						{{#if feature_image_caption}}<figcaption class="px-6 py-3 text-center font-mono text-xs text-silver sm:px-10">{{{feature_image_caption}}}</figcaption>{{/if}}
					</figure>
					{{/if}}

					{{!-- email body --}}
					<div class="px-6 py-10 sm:px-10">
						<section class="gh-content mx-auto max-w-prose">
							{{content}}
						</section>

						{{!-- signature --}}
						<div class="mx-auto mt-12 max-w-prose border-t border-line pt-6">
							<p class="text-sm text-silver">Talk soon,</p>
							<p class="mt-1 text-lg font-semibold tracking-tight">— Swarnil</p>
							<div class="mt-3 flex flex-wrap gap-2">
								{{#foreach tags visibility="public"}}<a href="{{url}}" class="chip transition hover:border-ink hover:text-ink">{{name}}</a>{{/foreach}}
							</div>
						</div>
					</div>

					{{!-- email footer: subscribe --}}
					<footer class="border-t border-line bg-mist/40 px-6 py-8 sm:px-10">
						<div class="mx-auto max-w-prose">
							<p class="kicker">{{> "icons/mail"}} Was this forwarded to you?</p>
							<p class="mt-2 text-sm leading-relaxed text-silver">Get the next issue of {{#if @custom.newsletter_title}}{{@custom.newsletter_title}}{{else}}The Signal{{/if}} straight from the source — no algorithm in between.</p>
							{{#if @site.members_enabled}}
							<form data-members-form class="nl-form mt-4 max-w-md">
								<div class="nl-form-fields flex overflow-hidden rounded-full border border-line bg-paper transition focus-within:border-ink">
									<input type="email" name="email" data-members-email placeholder="you@email.com" required class="w-full bg-transparent px-5 py-2.5 text-sm outline-none placeholder:text-silver" aria-label="Email address" />
									<button type="submit" class="shrink-0 bg-ink px-5 text-sm font-medium text-paper transition hover:opacity-85">Subscribe</button>
								</div>
								<p data-members-success class="items-center gap-2 text-sm font-medium">{{> "icons/check" class="text-accent"}} Check your inbox to confirm!</p>
								<p data-members-error class="mt-2 text-xs text-red-500">Something went wrong — try again.</p>
							</form>
							{{else}}
							<a href="{{@site.url}}/rss/" class="btn-ghost mt-4">{{> "icons/rss"}} Follow via RSS</a>
							{{/if}}
						</div>
					</footer>
				</div>

				{{!-- envelope the window folds into --}}
				<div id="nl-envelope" class="fixed inset-0 z-50 flex flex-col items-center justify-center gap-4" aria-hidden="true">
					<div style="perspective: 900px">
						<svg viewBox="0 0 200 140" class="w-40 drop-shadow-xl">
							<path d="M12 30 h176 v92 a10 10 0 0 1 -10 10 h-156 a10 10 0 0 1 -10 -10 Z" class="fill-mist stroke-ink" stroke-width="3" stroke-linejoin="round" />
							<path d="M12 34 l88 54 88 -54" fill="none" class="stroke-ink" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
							<g id="nl-flap">
								<path d="M12 30 L100 84 L188 30 Z" class="fill-paper stroke-ink" stroke-width="3" stroke-linejoin="round" />
							</g>
						</svg>
					</div>
					<p id="nl-env-caption" class="font-mono text-xs text-silver">Filed away — back to the archive…</p>
				</div>
			</div>

			{{!-- ad below the window --}}
			<div class="mx-auto max-w-4xl">
				{{> "components/adsense" slot="8939839370" format="auto"}}
			</div>

			{{#if comments}}
			<section class="mx-auto mt-4 max-w-3xl border-t border-line pt-10">
				<h2 class="section-title mb-8">Replies</h2>
				{{comments}}
			</section>
			{{/if}}
		</div>
	</section>
</article>

<script>
	(function () {
		var stage = document.getElementById('nl-stage');
		var close = document.getElementById('nl-close');
		if (!stage || !close) return;
		close.addEventListener('click', function (e) {
			e.preventDefault();
			var dest = close.getAttribute('href');
			if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
				window.location.href = dest;
				return;
			}
			if (stage.classList.contains('nl-closing')) return;
			stage.classList.add('nl-closing');
			window.setTimeout(function () { window.location.href = dest; }, 700);
		});
	})();
</script>
