{{!-- Theater layout for #episode posts. Siblings share this episode's PUBLIC
     primary tag (= the series tag). Post {{content}} and helpers stay OUTSIDE
     any {{#get}} block (inside one, post context breaks → "undefined").
     Episode numbers are filled client-side from the queue. --}}

{{!-- Player chrome: replaces the global navbar (hidden via body.tag-hash-episode CSS) --}}
<div class="player-bar" id="episode-bar">
	<a href="{{@site.url}}/webseries/{{primary_tag.slug}}/" data-container-link class="icon-btn shrink-0 tooltip tooltip-bottom" data-tip="Back to series" aria-label="Close episode">{{> "icons/close"}}</a>
	<div class="min-w-0 flex-1">
		<p class="truncate font-mono text-[9px] uppercase tracking-[0.2em] text-silver">{{primary_tag.name}} · <span data-ep-pos>episode</span></p>
		<p class="truncate text-sm font-semibold leading-tight">{{title}}</p>
	</div>
	<div class="flex shrink-0 items-center gap-1">
		<a href="#" data-nav-prev hidden class="icon-btn tooltip tooltip-bottom hidden sm:inline-flex" data-tip="Previous episode" aria-label="Previous episode"><span class="rotate-180">{{> "icons/arrow-right"}}</span></a>
		<button type="button" class="icon-btn tooltip tooltip-bottom hidden sm:inline-flex" data-tip="Theater fullscreen" id="episode-bar-max" aria-label="Fullscreen">{{> "icons/maximize"}}</button>
		<a href="#" data-nav-next hidden class="btn-primary btn-sm">Next ep {{> "icons/arrow-right" class="h-3.5 w-3.5"}}</a>
	</div>
</div>

{{!-- resolve the series POST's real URL (tag slug ≠ post slug) --}}
{{#foreach tags visibility="public" limit="1"}}{{#get "posts" filter="tag:hash-webseries+tag:{{slug}}" limit="1" as |ss|}}{{#foreach ss}}<span id="container-post" data-url="{{url}}" hidden></span>{{/foreach}}{{/get}}{{/foreach}}

<article class="{{post_class}} pt-14">

	{{!-- Full-bleed theater player --}}
	<div class="w-full" style="background:#08080a;">
		<div id="episode-stage" class="relative w-full" style="background:#08080a;">
			<div id="episode-player" class="relative w-full" style="aspect-ratio:16/9; max-height:85vh;">
				{{!-- iframe injected here: first YouTube embed found in the body --}}
			</div>
			<button id="episode-maximize" type="button" class="icon-btn absolute bottom-4 right-4 z-10 !border-white/20 !bg-black/60 !text-white backdrop-blur transition hover:!bg-black/80" data-tip="Maximize" aria-label="Maximize player">
				{{> "icons/maximize"}}
			</button>
		</div>
	</div>

	<div class="container-site py-10">
		<div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-12">

			{{!-- Main column — post context, no get wrapper --}}
			<div class="lg:col-span-8">
				<p class="kicker">
					{{> "icons/film"}}
					<span data-ep-pos>Episode</span>
					<span class="opacity-50">·</span>
					<a href="{{@site.url}}/webseries/{{primary_tag.slug}}/" data-container-link class="underline underline-offset-4 transition hover:text-ink">{{primary_tag.name}}</a>
				</p>
				<h1 class="mt-3 text-3xl font-semibold leading-tight tracking-tight sm:text-4xl text-balance">{{title}}</h1>

				<div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2 font-mono text-xs text-silver">
					<span class="flex items-center gap-1.5">{{> "icons/clock"}} <span id="episode-duration" data-duration-tags="{{#foreach tags visibility="internal"}}{{slug}} {{/foreach}}" hidden></span></span>
					<span class="flex items-center gap-1.5">{{> "icons/calendar"}} {{date published_at format="DD MMM YYYY"}}</span>
					{{#primary_author}}<span class="flex items-center gap-1.5">{{> "icons/user"}} {{name}}</span>{{/primary_author}}
				</div>

				<section class="gh-content mt-8" id="episode-content">
					{{content}}
				</section>

				{{!-- Prev / next episode — filled from the queue so it never leaves this series --}}
				<nav class="mt-10 grid border-y border-line sm:grid-cols-2 sm:divide-x sm:divide-line" aria-label="Episode navigation">
					<a href="#" data-nav-prev hidden class="group flex items-center gap-3 py-5 pr-4 transition hover:bg-mist/60">
						<span class="rotate-180 text-silver transition group-hover:text-ink">{{> "icons/arrow-right"}}</span>
						<span class="min-w-0">
							<span class="kicker !text-[10px]">Previous episode</span>
							<span class="mt-0.5 block truncate text-sm font-semibold" data-nav-prev-title></span>
						</span>
					</a>
					<a href="#" data-nav-next hidden class="group flex items-center justify-end gap-3 py-5 text-right transition hover:bg-mist/60 sm:col-start-2 sm:pl-4">
						<span class="min-w-0">
							<span class="kicker !text-[10px] justify-end">Next episode</span>
							<span class="mt-0.5 block truncate text-sm font-semibold" data-nav-next-title></span>
						</span>
						<span class="text-silver transition group-hover:text-ink">{{> "icons/arrow-right"}}</span>
					</a>
				</nav>

				{{> "components/adsense" slot="8939839370" format="auto"}}

				{{#if @site.comments_enabled}}
					<section class="mt-12 border-t border-line pt-10">
						{{> "components/comments" title="Comments"}}
					</section>
				{{/if}}
			</div>

			{{!-- Sidebar: full episode queue, current highlighted client-side --}}
			<aside class="lg:col-span-4">
				<div class="rail-sticky">
					<p class="kicker mb-4">{{> "icons/play"}} Next episodes</p>
					{{#foreach tags visibility="public" limit="1"}}
					{{#get "posts" filter="tag:hash-episode+tag:{{slug}}" order="published_at asc" limit="50" include="tags" as |eps|}}
					<ol class="max-h-[70vh] space-y-2 overflow-y-auto pr-1" id="episode-queue">
						{{#foreach eps}}
						<li>
							<a href="{{url}}" data-ep-slug="{{slug}}" class="ep-queue-item group flex items-center gap-3 rounded-2xl border border-transparent p-2.5 transition hover:border-line hover:bg-mist">
								<span class="ep-num w-6 shrink-0 text-center font-mono text-sm text-silver">{{@number}}</span>
								<span class="relative aspect-video w-24 shrink-0 overflow-hidden rounded-lg border border-line bg-mist">
									{{#if feature_image}}<img src="{{img_url feature_image size="300"}}" width="300" height="169" alt="" loading="lazy" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />{{/if}}
									<span class="ep-playing absolute inset-0 hidden items-center justify-center bg-black/40 text-white">{{> "icons/play"}}</span>
								</span>
								<span class="min-w-0">
									<span class="line-clamp-2 text-[13px] font-medium leading-snug">{{title}}</span>
									<span class="ep-now mt-0.5 hidden font-mono text-[10px] uppercase tracking-widest text-silver">Now playing</span>
								</span>
							</a>
						</li>
						{{/foreach}}
					</ol>
					{{/get}}
					{{/foreach}}
					<a href="{{@site.url}}/webseries/{{primary_tag.slug}}/" data-container-link class="btn btn-ghost mt-5 w-full">{{> "icons/film"}} Series overview</a>
					{{> "components/adsense" slot="3487917390" format="auto" class="!my-4"}}
				</div>
			</aside>
		</div>
	</div>

	{{!-- TVEpisode structured data; number/duration/series-url patched by JS --}}
	<script type="application/ld+json" id="episode-jsonld">
	{
		"@context": "https://schema.org",
		"@type": "TVEpisode",
		"name": "{{title}}",
		"url": "{{url absolute="true"}}",
		"datePublished": "{{date published_at format="YYYY-MM-DD"}}",
		"description": "{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{excerpt words="45"}}{{/if}}",
		{{#if feature_image}}"image": "{{img_url feature_image size="1600" absolute="true"}}",{{/if}}
		"partOfSeries": {
			"@type": "TVSeries",
			"name": "{{primary_tag.name}}",
			"url": "{{@site.url}}/webseries/{{primary_tag.slug}}/"
		}
	}
	</script>

	<script>
	(function () {
		var CURRENT = '{{slug}}';

		/* ----- Hoist the first video embed from the body into the theater player ----- */
		var player = document.getElementById('episode-player');
		var stage = document.getElementById('episode-stage');
		var content = document.getElementById('episode-content');
		var src = '';
		if (content) {
			var found = content.querySelector('iframe[src*="youtube.com/embed"], iframe[src*="youtube-nocookie.com/embed"], iframe[src*="player.vimeo.com"]');
			if (found) {
				src = found.getAttribute('src');
				var card = found.closest('figure, .kg-card') || found;
				card.style.display = 'none';
			}
		}
		if (!src) {
			src = 'https://www.youtube-nocookie.com/embed/ecOkmTD7KhU?rel=0&modestbranding=1';
		}
		var iframe = document.createElement('iframe');
		iframe.src = src;
		iframe.title = 'Episode player';
		iframe.setAttribute('allow', 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; fullscreen');
		iframe.setAttribute('allowfullscreen', '');
		iframe.setAttribute('frameborder', '0');
		iframe.className = 'absolute inset-0 h-full w-full';
		player.appendChild(iframe);

		/* ----- Fullscreen toggles ----- */
		function toggleFullscreen() {
			if (document.fullscreenElement) {
				document.exitFullscreen();
			} else if (stage.requestFullscreen) {
				stage.requestFullscreen();
			} else if (stage.webkitRequestFullscreen) {
				stage.webkitRequestFullscreen();
			}
		}
		var btn = document.getElementById('episode-maximize');
		if (btn) btn.addEventListener('click', toggleFullscreen);
		var barBtn = document.getElementById('episode-bar-max');
		if (barBtn) barBtn.addEventListener('click', toggleFullscreen);

		/* ----- Queue: highlight the current episode + fill "episode N of T" ----- */
		var items = [].slice.call(document.querySelectorAll('.ep-queue-item'));
		var epNumber = null;
		items.forEach(function (a, i) {
			if (a.getAttribute('data-ep-slug') !== CURRENT) return;
			epNumber = i + 1;
			a.classList.add('!border-ink', 'bg-mist');
			a.setAttribute('aria-current', 'true');
			var p = a.querySelector('.ep-playing'); if (p) { p.classList.remove('hidden'); p.classList.add('flex'); }
			var n = a.querySelector('.ep-now'); if (n) n.classList.remove('hidden');
		});
		if (epNumber) {
			document.querySelectorAll('[data-ep-pos]').forEach(function (el) {
				el.textContent = 'Episode ' + epNumber + ' of ' + items.length;
			});
		}

		/* prev/next strictly from THIS series' queue */
		function fillNav(sel, item, titleSel) {
			document.querySelectorAll(sel).forEach(function (a) {
				if (!item) { a.remove(); return; }
				a.href = item.href;
				a.hidden = false;
				var t = a.querySelector(titleSel);
				if (t) t.textContent = (item.querySelector('.line-clamp-2') || item).textContent.trim();
			});
		}
		var idx0 = epNumber ? epNumber - 1 : -1;
		fillNav('[data-nav-prev]', idx0 > 0 ? items[idx0 - 1] : null, '[data-nav-prev-title]');
		fillNav('[data-nav-next]', idx0 > -1 && items[idx0 + 1] ? items[idx0 + 1] : null, '[data-nav-next-title]');

		/* ----- Fix container links (series post slug ≠ tag slug) ----- */
		var cp = document.getElementById('container-post');
		var curl = cp && cp.getAttribute('data-url');
		if (curl) {
			document.querySelectorAll('[data-container-link]').forEach(function (a) { a.href = curl; });
		}

		/* ----- JSON-LD: duration, episode number, corrected series url ----- */
		var script = document.getElementById('episode-jsonld');
		if (script) {
			try {
				var data = JSON.parse(script.textContent);
				var span = document.getElementById('episode-duration');
				var m = span && (span.getAttribute('data-duration-tags') || '').match(/hash-duration-(?:(\d+)h)?-?(?:(\d+)m)?/);
				if (m && (m[1] || m[2])) data.duration = 'PT' + (m[1] ? m[1] + 'H' : '') + (m[2] ? m[2] + 'M' : '');
				if (epNumber) data.episodeNumber = epNumber;
				if (curl && data.partOfSeries) data.partOfSeries.url = new URL(curl, location.origin).href;
				script.textContent = JSON.stringify(data);
			} catch (e) { /* leave as-is */ }
		}
	})();
	</script>
</article>
