{{!-- Lesson page — app mode. On lg+ the whole thing locks to the viewport like a
     course player: course navigation rail on the left, lesson pane on the right,
     each scrolling independently (body scroll is disabled via .lesson-app-mode).
     On mobile it degrades to normal document flow with a collapsible nav.
     The parent course is the lesson's primary (public) tag. --}}
{{!-- Course-player chrome: full-width bar aligned to the lesson grid (container),
     replaces the global navbar (hidden via body.tag-hash-lesson CSS).
     Left: logo + course · middle: progress · right: github, theme, ✕ close. --}}
<div class="lesson-topbar" id="lesson-bar">
	<div class="lesson-topbar-row">
		{{> "components/logo"}}
		{{#primary_tag}}
		<span class="hidden h-5 w-px shrink-0 bg-line sm:block" aria-hidden="true"></span>
		<a href="{{@site.url}}/courses/{{slug}}/" data-container-link class="hidden min-w-0 truncate text-[13px] font-semibold tracking-tight hover:underline hover:underline-offset-4 sm:block">{{name}}</a>
		{{/primary_tag}}

		{{!-- progress: fills as lessons complete --}}
		<div class="lesson-progress-track" aria-hidden="true">
			<span class="lesson-progress-fill" id="lesson-bar-progress"></span>
		</div>
		<span class="hidden shrink-0 font-mono text-[9px] uppercase tracking-[0.18em] text-silver md:block" id="lesson-pos">lesson</span>

		<div class="ml-auto flex shrink-0 items-center gap-0.5">
			<a href="#" data-nav-prev hidden class="icon-btn tooltip tooltip-bottom hidden sm:inline-flex" data-tip="Previous lesson" aria-label="Previous lesson"><span class="rotate-180">{{> "icons/arrow-right"}}</span></a>
			<a href="#" data-nav-next hidden class="icon-btn tooltip tooltip-bottom hidden sm:inline-flex" data-tip="Next lesson" aria-label="Next lesson">{{> "icons/arrow-right"}}</a>
			<button type="button" id="course-finish" hidden class="btn-primary btn-sm">Complete course ✦</button>
			<a href="https://github.com/{{@custom.github_repo}}" target="_blank" rel="noopener" class="icon-btn tooltip tooltip-bottom hidden sm:inline-flex" data-tip="Star on GitHub" aria-label="Star on GitHub">{{> "icons/github"}}</a>
			<button type="button" data-mode-cycle class="icon-btn" aria-label="Switch theme mode"></button>
			{{!-- mobile: hamburger opens the course-navigation panel --}}
			<button type="button" class="icon-btn lg:hidden" data-modal-open="#lesson-menu-backdrop" aria-label="Open course navigation">{{> "icons/menu"}}</button>
			{{#primary_tag}}
			<a href="{{@site.url}}/courses/{{slug}}/" data-container-link class="icon-btn tooltip tooltip-left" data-tip="Close course" aria-label="Close course, back to {{name}}">{{> "icons/close"}}</a>
			{{/primary_tag}}
		</div>
	</div>
</div>

{{!-- Mobile course navigation — panel-style modal, like the site menu panel --}}
<div class="fixed inset-0 z-[60] hidden items-start justify-center overflow-y-auto bg-ink/40 p-4 pt-16 backdrop-blur-sm" id="lesson-menu-backdrop" data-modal>
	<div class="w-full max-w-md rounded-[2rem] border border-line bg-paper p-6 shadow-lift" role="dialog" aria-modal="true" aria-label="Course navigation">
		<div class="mb-5 flex items-center justify-between">
			{{> "components/logo"}}
			<button type="button" class="icon-btn" data-modal-close aria-label="Close">{{> "icons/close"}}</button>
		</div>
		{{#primary_tag}}
		<p class="kicker">{{> "icons/book"}} Course</p>
		<a href="{{@site.url}}/courses/{{slug}}/" data-container-link class="mt-1 block text-base font-semibold tracking-tight hover:underline hover:underline-offset-4">{{name}}</a>
		{{#get "posts" filter="tag:hash-lesson+tags:{{slug}}" limit="50" order="published_at asc" include="tags" as |siblings|}}
		<ol class="mt-4 space-y-1">
			{{#foreach siblings}}
			<li>
				<a href="{{url}}" data-lesson-slug="{{slug}}" class="lesson-link group flex items-center gap-3 rounded-xl px-3 py-2 transition hover:bg-mist">
					<span class="lesson-num flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-line font-mono text-[10px] font-semibold text-silver">{{@number}}</span>
					<span class="lesson-tick hidden h-6 w-6 shrink-0 items-center justify-center rounded-full bg-ink text-paper">{{> "icons/check"}}</span>
					<span class="line-clamp-2 text-[13px] font-medium leading-snug">{{title}}</span>
					{{#match visibility "!=" "public"}}{{> "icons/lock" class="ml-auto shrink-0 text-silver"}}{{/match}}
				</a>
			</li>
			{{/foreach}}
		</ol>
		{{/get}}
		{{/primary_tag}}
	</div>
</div>

{{!-- resolve the course POST's real URL (tag slug ≠ post slug) --}}
{{#foreach tags visibility="public" limit="1"}}{{#get "posts" filter="tag:hash-course+tag:{{slug}}" limit="1" as |cc|}}{{#foreach cc}}<span id="container-post" data-url="{{url}}" hidden></span>{{/foreach}}{{/get}}{{/foreach}}

<article class="{{post_class}} pt-16">
	<div class="container-site grid gap-6 py-6 lg:grid-cols-12 lg:gap-0">

		{{!-- Course navigation rail (desktop; mobile uses the panel modal) --}}
		<aside class="hidden lg:sticky lg:top-16 lg:col-span-4 lg:block lg:max-h-[calc(100dvh-5rem)] lg:self-start lg:overflow-y-auto lg:pr-8 xl:col-span-3">
			<details class="lesson-nav lesson-pane" open>
				<summary class="flex cursor-pointer list-none items-center justify-between gap-2 border-b border-line px-1 py-4 [&::-webkit-details-marker]:hidden lg:pointer-events-none">
					<span class="kicker !mb-0">{{> "icons/book"}} Course navigation</span>
					{{> "icons/chevron-down" class="text-silver lg:hidden"}}
				</summary>
				<div class="px-1 py-4">
					{{#primary_tag}}
					<a href="{{@site.url}}/courses/{{slug}}/" data-container-link class="block text-base font-semibold tracking-tight hover:underline hover:underline-offset-4">{{name}}</a>
					{{/primary_tag}}

					<div class="mt-4">
						<progress id="course-progress" class="progress w-full" value="0" max="100"></progress>
						<p class="mt-1 font-mono text-[10px] uppercase tracking-[0.2em] text-silver"><span id="course-progress-label">0%</span> complete — no certificate, just glory</p>
					</div>

					{{#primary_tag}}
					{{#get "posts" filter="tag:hash-lesson+tags:{{slug}}" limit="50" order="published_at asc" include="tags" as |siblings|}}
					<ol id="lesson-list" class="mt-4 space-y-1">
						{{#foreach siblings}}
						<li>
							<a href="{{url}}" data-lesson-slug="{{slug}}" class="lesson-link group flex items-center gap-3 rounded-xl px-3 py-2 transition hover:bg-mist">
								<span class="lesson-num flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-line font-mono text-[10px] font-semibold text-silver group-hover:border-ink group-hover:text-ink">{{@number}}</span>
								<span class="lesson-tick hidden h-6 w-6 shrink-0 items-center justify-center rounded-full bg-ink text-paper">{{> "icons/check"}}</span>
								<span class="min-w-0 flex-1">
									<span class="line-clamp-2 block text-[13px] font-medium leading-snug">{{title}}</span>
									<span class="font-mono text-[9px] uppercase tracking-[0.12em] text-silver" data-duration-tags="{{#foreach tags visibility="internal"}}{{slug}} {{/foreach}}" hidden></span>
								</span>
								{{#match visibility "!=" "public"}}{{> "icons/lock" class="ml-auto shrink-0 text-silver"}}{{/match}}
							</a>
						</li>
						{{/foreach}}
					</ol>
					{{/get}}
					{{#primary_tag}}
					<a href="{{@site.url}}/courses/{{slug}}/" data-container-link class="btn-ghost mt-5 w-full justify-center !text-xs">{{> "icons/arrow-right" class="rotate-180"}} Back to course</a>
					{{/primary_tag}}
					{{/primary_tag}}
				</div>
			</details>
		</aside>

		{{!-- Lesson pane --}}
		<div class="lesson-pane min-w-0 lg:col-span-8 lg:border-l lg:border-line lg:pl-8 xl:col-span-9">
			<header class="border-b border-line px-0 py-6">
				<nav class="flex flex-wrap items-center gap-2 font-mono text-[10px] uppercase tracking-[0.15em] text-silver" aria-label="Breadcrumb">
					<a href="{{@site.url}}/courses/" class="transition hover:text-ink">Courses</a>
					<span aria-hidden="true">/</span>
					{{#primary_tag}}<a href="{{@site.url}}/courses/{{slug}}/" data-container-link class="transition hover:text-ink">{{name}}</a>{{/primary_tag}}
					<span aria-hidden="true">/</span>
					<span class="text-ink" id="lesson-crumb">this lesson</span>
				</nav>
				<h1 class="mt-3 text-2xl font-semibold tracking-tight sm:text-3xl text-balance">{{title}}</h1>
				<p class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-1.5 font-mono text-[11px] text-silver">
					<span class="flex items-center gap-1.5">{{> "icons/calendar" class="h-3.5 w-3.5"}} {{date published_at format="DD MMM YYYY"}}</span>
					<span class="flex items-center gap-1.5">{{> "icons/clock" class="h-3.5 w-3.5"}} {{reading_time minute="1 min"}} <span data-duration-tags="{{#foreach tags visibility="internal"}}{{slug}} {{/foreach}}" hidden></span></span>
					{{#primary_author}}<span class="flex items-center gap-1.5">{{> "icons/user" class="h-3.5 w-3.5"}} {{name}}</span>{{/primary_author}}
					<button type="button" id="lesson-complete-toggle" class="chip !gap-1.5 !py-0.5 transition hover:border-ink hover:text-ink">
						{{> "icons/check" class="h-3 w-3"}} <span id="lesson-complete-label">Mark complete</span>
					</button>
				</p>
			</header>

			<div class="px-0 py-8">
				{{!-- auto-TOC: "In this lesson" (built from h2/h3 by main.js) --}}
				<aside id="toc" hidden class="mb-8 border-y border-line py-4">
					<p class="kicker !text-[10px]">{{> "icons/book" class="h-3 w-3"}} In this lesson</p>
					<nav id="toc-list" class="mt-3" aria-label="Lesson contents"></nav>
				</aside>
				<section class="gh-content video-theater">
					{{content}}
				</section>

				{{!-- Prev / next lesson — filled from the rail, never leaves this course --}}
				<nav class="mt-10 grid border-y border-line sm:grid-cols-2 sm:divide-x sm:divide-line" aria-label="Lesson pagination">
					<a href="#" data-nav-prev hidden class="group flex items-center gap-3 py-5 pr-4 transition hover:bg-mist/60">
						{{> "icons/arrow-right" class="shrink-0 rotate-180 text-silver transition group-hover:text-ink"}}
						<span class="min-w-0">
							<span class="block font-mono text-[10px] uppercase tracking-[0.2em] text-silver">Previous</span>
							<span class="block truncate text-sm font-semibold" data-nav-prev-title></span>
						</span>
					</a>
					<a href="#" data-nav-next hidden class="group flex items-center justify-end gap-3 py-5 text-right transition hover:bg-mist/60 sm:col-start-2 sm:pl-4">
						<span class="min-w-0">
							<span class="block font-mono text-[10px] uppercase tracking-[0.2em] text-silver">Next</span>
							<span class="block truncate text-sm font-semibold" data-nav-next-title></span>
						</span>
						{{> "icons/arrow-right" class="shrink-0 text-silver transition group-hover:text-ink"}}
					</a>
					<button type="button" data-course-finish hidden class="group flex w-full items-center justify-center gap-3 py-5 font-semibold transition hover:bg-mist/60 sm:col-span-2">
						{{> "icons/check" class="h-4 w-4 text-green-600"}} You made it — complete the course ✦
					</button>
				</nav>

				{{> "components/adsense" slot="6501428979" layout="in-article" format="fluid"}}

				<footer class="mt-6 flex items-center justify-between border-t border-line pt-6">
					{{#primary_tag}}<a href="{{@site.url}}/courses/{{slug}}/" data-container-link class="btn-ghost">{{> "icons/arrow-right" class="rotate-180"}} Back to {{name}}</a>{{/primary_tag}}
					{{> "post/share"}}
				</footer>

				{{#if @site.comments_enabled}}
				<div class="mt-12">
					{{> "components/comments" title="Discussion"}}
				</div>
				{{/if}}
			</div>
		</div>
	</div>
</article>

<script>
	(function () {
		var KEY = 'swarnil-progress-{{primary_tag.slug}}';
		var CURRENT = '{{slug}}';
		var links = [].slice.call(document.querySelectorAll('.lesson-link'));

		function load() { try { return JSON.parse(localStorage.getItem(KEY)) || []; } catch (e) { return []; } }
		function save(a) { try { localStorage.setItem(KEY, JSON.stringify(a)); } catch (e) {} }

		function paint() {
			var done = load();
			var doneCount = 0;
			links.forEach(function (a) {
				var slug = a.getAttribute('data-lesson-slug');
				var isDone = done.indexOf(slug) > -1;
				if (isDone) doneCount++;
				var tick = a.querySelector('.lesson-tick');
				var num = a.querySelector('.lesson-num');
				if (tick && num) {
					tick.classList.toggle('hidden', !isDone);
					tick.classList.toggle('flex', isDone);
					num.classList.toggle('hidden', isDone);
				}
				if (slug === CURRENT) {
					a.classList.add('bg-mist');
					a.setAttribute('aria-current', 'page');
				}
			});
			/* progress = where you ARE in the course (position / total) */
			var railAll = [].slice.call(document.querySelectorAll('#lesson-list .lesson-link'));
			var posIdx = railAll.findIndex(function (a) { return a.getAttribute('data-lesson-slug') === CURRENT; });
			var pct = railAll.length && posIdx > -1 ? Math.round(((posIdx + 1) / railAll.length) * 100) : 0;
			var bar = document.getElementById('course-progress');
			var label = document.getElementById('course-progress-label');
			if (bar) bar.value = pct;
			if (label) label.textContent = pct + '%';
			var topbar = document.getElementById('lesson-bar-progress');
			if (topbar) topbar.style.width = pct + '%';
			/* "Lesson x of y" in the player chrome (count the sidebar list only —
			   the mobile panel duplicates the links for ticking) */
			var pos = document.getElementById('lesson-pos');
			var railLinks = [].slice.call(document.querySelectorAll('#lesson-list .lesson-link'));
			if (railLinks.length) {
				var idx = railLinks.findIndex(function (a) { return a.getAttribute('data-lesson-slug') === CURRENT; });
				if (idx > -1) {
					if (pos) pos.textContent = 'lesson ' + (idx + 1) + ' of ' + railLinks.length;
					var crumb = document.getElementById('lesson-crumb');
					if (crumb) crumb.textContent = 'lesson ' + (idx + 1);
				}
			}
			/* manual complete toggle reflects stored state */
			var label = document.getElementById('lesson-complete-label');
			var toggle = document.getElementById('lesson-complete-toggle');
			if (label && toggle) {
				var isDone = done.indexOf(CURRENT) > -1;
				label.textContent = isDone ? 'Completed — undo' : 'Mark complete';
				toggle.classList.toggle('!border-green-600', isDone);
				toggle.classList.toggle('!text-green-600', isDone);
			}
		}

		/* manual complete / undo */
		var toggleBtn = document.getElementById('lesson-complete-toggle');
		if (toggleBtn) {
			toggleBtn.addEventListener('click', function () {
				var done = load();
				var at = done.indexOf(CURRENT);
				if (at > -1) { done.splice(at, 1); marked = false; }
				else { done.push(CURRENT); marked = true; }
				save(done);
				paint();
			});
		}

		/* Auto-complete the current lesson once the reader passes 60% */
		var marked = false;
		function markSeen(seen) {
			if (marked || seen < 0.6) return;
			marked = true;
			var done = load();
			if (done.indexOf(CURRENT) < 0) { done.push(CURRENT); save(done); }
			paint();
		}
		function onWinScroll() {
			var doc = document.documentElement;
			markSeen((window.scrollY + window.innerHeight) / Math.max(doc.scrollHeight, 1));
		}
		window.addEventListener('scroll', onWinScroll, { passive: true });
		paint();
		onWinScroll();

		/* Prev / next strictly from THIS course's rail; first lesson has no prev,
		   last lesson swaps "next" for a confetti-powered course finish */
		var railNav = [].slice.call(document.querySelectorAll('#lesson-list .lesson-link'));
		var navIdx = railNav.findIndex(function (a) { return a.getAttribute('data-lesson-slug') === CURRENT; });
		function fillNav(sel, item, titleSel) {
			document.querySelectorAll(sel).forEach(function (a) {
				if (!item) { a.remove(); return; }
				a.href = item.href;
				a.hidden = false;
				var t = titleSel && a.querySelector(titleSel);
				if (t) t.textContent = (item.querySelector('.line-clamp-2') || item).textContent.trim();
			});
		}
		fillNav('[data-nav-prev]', navIdx > 0 ? railNav[navIdx - 1] : null, '[data-nav-prev-title]');
		var isLast = navIdx > -1 && navIdx === railNav.length - 1;
		fillNav('[data-nav-next]', !isLast && navIdx > -1 ? railNav[navIdx + 1] : null, '[data-nav-next-title]');

		function confetti(then) {
			var wrap = document.createElement('div');
			wrap.className = 'confetti-wrap';
			var hues = ['#22c55e', '#3b82f6', '#eab308', '#ef4444', '#a855f7'];
			for (var i = 0; i < 90; i++) {
				var p = document.createElement('i');
				p.style.left = Math.random() * 100 + 'vw';
				p.style.background = hues[i % hues.length];
				p.style.animationDelay = (Math.random() * 0.4) + 's';
				p.style.animationDuration = (0.9 + Math.random() * 0.9) + 's';
				p.style.transform = 'rotate(' + Math.random() * 360 + 'deg)';
				wrap.appendChild(p);
			}
			document.body.appendChild(wrap);
			setTimeout(then, 1400);
		}
		function finishCourse() {
			var done = load();
			if (done.indexOf(CURRENT) < 0) { done.push(CURRENT); save(done); }
			var cp = document.getElementById('container-post');
			confetti(function () {
				location.href = cp ? cp.getAttribute('data-url') : '{{@site.url}}/courses/';
			});
		}
		if (isLast) {
			document.querySelectorAll('#course-finish, [data-course-finish]').forEach(function (b) {
				b.hidden = false;
				b.addEventListener('click', finishCourse);
			});
		}

		/* Scroll the current lesson into view inside the rail (desktop only —
		   on mobile this would yank the whole page down to the nav) */
		var mqDesktop = window.matchMedia ? window.matchMedia('(min-width: 1024px)') : null;
		var current = document.querySelector('.lesson-link[aria-current="page"]');
		if (current && mqDesktop && mqDesktop.matches) {
			var rail = current.closest('aside');
			if (rail) rail.scrollTop = Math.max(0, current.offsetTop - rail.clientHeight / 2);
		}

		/* Fix container links: course POST url resolved server-side (tag slug != post slug) */
		var cp = document.getElementById('container-post');
		if (cp) {
			document.querySelectorAll('[data-container-link]').forEach(function (a) {
				a.href = cp.getAttribute('data-url');
			});
		}

		/* Course nav: collapsed by default on mobile, always open on lg+ */
		var nav = document.querySelector('.lesson-nav');
		if (nav && mqDesktop) {
			function syncNav() { nav.open = mqDesktop.matches; }
			syncNav();
			if (mqDesktop.addEventListener) mqDesktop.addEventListener('change', syncNav);
		}
	})();
</script>
