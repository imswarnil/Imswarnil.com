{{!-- Lesson / episode player page: content + course rail. The parent course/series
     is the public tag shared between them. --}}
<article class="{{post_class}}">
	<header class="border-b border-line py-10">
		<div class="container-site">
			<div class="mx-auto max-w-5xl">
				<p class="kicker">{{#has tag="#lesson"}}{{> "icons/book"}} Lesson{{else}}{{> "icons/film"}} Episode{{/has}}
					{{#primary_tag}}<a href="{{url}}" class="ml-2 underline underline-offset-4 hover:text-ink">{{name}}</a>{{/primary_tag}}
				</p>
				<h1 class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl text-balance">{{title}}</h1>
				<p class="mt-3 font-mono text-xs text-silver">{{date published_at format="DD MMM YYYY"}} · {{reading_time minute="1 min"}}</p>
			</div>
		</div>
	</header>

	<div class="container-site py-10">
		<div class="mx-auto grid max-w-5xl gap-12 lg:grid-cols-12">
			<div class="lg:col-span-8">
				<section class="gh-content video-theater">
					{{content}}
				</section>
				<footer class="mt-10 flex items-center justify-between border-t border-line pt-6">
					{{#primary_tag}}<a href="{{url}}" class="btn-ghost">{{> "icons/arrow-right" class="rotate-180"}} Back to {{name}}</a>{{/primary_tag}}
					{{> "post/share"}}
				</footer>
			</div>
			<aside class="lg:col-span-4">
				<div class="sticky top-28 card-surface p-5 !transform-none">
					<p class="kicker">{{> "icons/play"}} In this series</p>
					{{#primary_tag}}
					{{#get "posts" filter="tag:{slug}+tag:[hash-lesson,hash-episode]" limit="all" order="published_at asc" as |siblings|}}
						<ol class="mt-4 space-y-1">
							{{#foreach siblings}}
							<li>
								<a href="{{url}}" class="group flex items-center gap-3 rounded-xl px-3 py-2 transition hover:bg-mist">
									<span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-line font-mono text-[10px] font-semibold text-silver group-hover:border-ink group-hover:text-ink">{{@number}}</span>
									<span class="line-clamp-2 text-[13px] font-medium leading-snug">{{title}}</span>
								</a>
							</li>
							{{/foreach}}
						</ol>
					{{/get}}
					{{/primary_tag}}
				</div>
			</aside>
		</div>
	</div>
</article>
