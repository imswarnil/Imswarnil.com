<aside class="post-sidebar">
	{{!-- Author card (hide on --breakpoint-max-lg). --}}
	{{> "post/card-author"}}

	<div class="post-sidebar-sticky toc-scroll">
		{{!-- TOC. --}}
		{{^has tag="#hide-toc"}}
			{{> "post/toc"}}
		{{/has}}

		{{!-- Form subscribe (hide on --breakpoint-max-lg). --}}
		{{> "form-subscribe" label="true"}}

		{{!-- Ad: sidebar (Vertical responsive skyscraper). --}}
		{{> "monetization/adsense" slot="3487917390" class="ad-sidebar"}}

		{{!-- Advertise-with-us house promo. --}}
		{{> "monetization/advertise"}}
	</div>
</aside>
