{{!-- First-load intro — the signature line as a short title card, animated
     once per session (sessionStorage), skipped for reduced-motion. The quote
     moved here from the hero H1 so the hero stays clean. --}}
<div class="intro-veil" id="intro-veil" hidden aria-hidden="true">
	<p class="intro-line">
		<span class="intro-word" style="--l:0">Life looks better</span>
		<span class="intro-word" style="--l:1">when you frame the
			<em class="intro-frame">chaos<i></i><i></i><i></i><i></i><b>9:16</b></em>
		</span>
		<span class="intro-word" style="--l:2">and crop out the noise.</span>
		<span class="intro-word intro-sign" style="--l:3">— Swarnil Singhai</span>
	</p>
</div>
<script>
	(function () {
		var v = document.getElementById('intro-veil');
		if (!v) return;
		var reduced = window.matchMedia && matchMedia('(prefers-reduced-motion: reduce)').matches;
		var seen = false;
		try { seen = !!sessionStorage.getItem('sw-intro'); } catch (e) {}
		if (reduced || seen) { v.remove(); return; }
		try { sessionStorage.setItem('sw-intro', '1'); } catch (e) {}
		v.hidden = false;
		function done() {
			if (!v.parentNode) return;
			v.remove();
			document.documentElement.classList.remove('intro-lock');
		}
		document.documentElement.classList.add('intro-lock');
		setTimeout(function () { v.classList.add('intro-out'); }, 2700);
		v.addEventListener('transitionend', done);
		setTimeout(done, 3800); /* safety net */
	})();
</script>
