{{!-- First-load intro — Netflix "tudum"-style title card.
     Shows once per browser session (the early boot script in default.hbs
     decides and adds .intro-playing to <html>; skipped under
     prefers-reduced-motion). The overlay's own CSS animation shows the
     card, then fades + lifts itself away, so the site is never trapped
     behind it even if JS fails. main.js adds the synthesized "tudum" and
     the coordinated navbar/hero reveal. --}}
<div id="intro" class="intro" role="presentation">
	<span class="intro-line" aria-hidden="true"></span>
	<span class="intro-word" aria-label="{{@site.title}}">
		<i style="--i:0">s</i><i style="--i:1">w</i><i style="--i:2">a</i><i style="--i:3">r</i><i style="--i:4">n</i><i style="--i:5">i</i><i style="--i:6">l</i>
	</span>
	<button type="button" class="intro-skip" data-intro-skip aria-label="Skip intro">Skip</button>
</div>
