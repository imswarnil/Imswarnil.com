<a href="{{@site.url}}" class="logo group flex items-center gap-2.5" aria-label="{{@site.title}} — home">
	{{!-- The mark: S inside a camcorder viewfinder frame, red REC bubble.
	     Static SVG (no drawing choreography) — only the REC dot pulses,
	     which is a cheap composited opacity/transform animation. --}}
	<svg width="32" height="32" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" class="logo-mark shrink-0 transition-transform duration-500 group-hover:rotate-[-6deg]" aria-hidden="true">
		<rect x="1.5" y="1.5" width="45" height="45" rx="13" class="fill-ink" />
		{{!-- camcorder viewfinder corners --}}
		<g class="stroke-paper" stroke-width="2.6" stroke-linecap="round" opacity=".6" fill="none">
			<path d="M9 14v-2a3 3 0 0 1 3-3h2" /><path d="M39 14v-2a3 3 0 0 0-3-3h-2" />
			<path d="M9 34v2a3 3 0 0 0 3 3h2" /><path d="M39 34v2a3 3 0 0 1-3 3h-2" />
		</g>
		{{!-- the S --}}
		<path d="M31.5 17.5c-1-2.2-3.6-3.4-7.2-3.4-4.3 0-7.4 2-7.4 5.4 0 6.8 15 3.2 15 10.4 0 3.5-3.2 5.6-7.8 5.6-4 0-6.7-1.4-8-3.9" class="stroke-paper" stroke-width="3.4" stroke-linecap="round" fill="none" />
		{{!-- red recording bubble --}}
		<circle cx="37" cy="11" r="2.6" fill="#ef4444" class="logo-rec" />
	</svg>
	<span class="flex min-w-0 flex-col leading-none">
		<span class="text-base font-bold tracking-tight">Swarnil</span>
		{{!-- tagline: desktop only — mobile shows just the wordmark --}}
		<span class="mt-[3px] hidden items-center gap-1 font-mono text-[8px] uppercase tracking-[0.22em] text-silver sm:flex">
			documenting
			<span class="logo-rotator relative inline-block h-[1.4em] overflow-hidden align-bottom">
				<span class="logo-rotator-track flex flex-col">
					<i class="not-italic">life</i><i class="not-italic">chaos</i><i class="not-italic">trips</i><i class="not-italic">emotions</i><i class="not-italic">happiness</i><i class="not-italic" aria-hidden="true">life</i>
				</span>
			</span>
		</span>
	</span>
</a>
