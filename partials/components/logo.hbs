<a href="{{@site.url}}" class="group flex items-center gap-2.5" aria-label="{{@site.title}} — home">
	{{!-- Morphing mark: 1:1 frame → S stroke draws in → crop corners + rec dot pulse.
	     Pure SVG/CSS, loops gently, honors reduced motion. --}}
	<svg width="30" height="30" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" class="logo-mark shrink-0 transition-transform duration-500 group-hover:rotate-[-6deg]" aria-hidden="true">
		<rect x="1.5" y="1.5" width="45" height="45" rx="13" class="fill-ink" />
		{{!-- Crop corner brackets --}}
		<g class="stroke-paper logo-corners" stroke-width="2.6" stroke-linecap="round" opacity=".65">
			<path d="M9 14v-2a3 3 0 0 1 3-3h2" /><path d="M39 14v-2a3 3 0 0 0-3-3h-2" />
			<path d="M9 34v2a3 3 0 0 0 3 3h2" /><path d="M39 34v2a3 3 0 0 1-3 3h-2" />
		</g>
		{{!-- S stroke, draws itself --}}
		<path class="stroke-paper logo-s" d="M32.5 16.5c-1.2-2.4-4-3.8-8-3.8-4.8 0-8.2 2.3-8.2 6 0 7.6 16.6 3.6 16.6 11.6 0 3.9-3.6 6.2-8.6 6.2-4.4 0-7.4-1.6-8.8-4.3" stroke-width="3.4" stroke-linecap="round" fill="none" pathLength="100" />
		{{!-- rec dot --}}
		<circle cx="37" cy="11" r="2.4" fill="#ef4444" class="logo-rec" />
	</svg>
	<span class="flex flex-col leading-none">
		<span class="text-[16px] font-bold tracking-tight">Swarnil</span>
		<span class="mt-0.5 font-mono text-[8px] uppercase tracking-[0.28em] text-silver">frame 1:1 · crop noise</span>
	</span>
	<style>
		.logo-s { stroke-dasharray: 100; stroke-dashoffset: 0; animation: logoDraw 7s ease-in-out infinite; }
		.logo-corners { animation: logoCorners 7s ease-in-out infinite; }
		.logo-rec { animation: logoRec 2.2s ease-in-out infinite; transform-origin: 37px 11px; }
		@keyframes logoDraw { 0%, 8% { stroke-dashoffset: 100; } 28%, 100% { stroke-dashoffset: 0; } }
		@keyframes logoCorners { 0%, 20% { opacity: 0; } 40%, 85% { opacity: .65; } 100% { opacity: .65; } }
		@keyframes logoRec { 50% { opacity: .25; transform: scale(.75); } }
		@media (prefers-reduced-motion: reduce) { .logo-s, .logo-corners, .logo-rec { animation: none; } }
	</style>
</a>
