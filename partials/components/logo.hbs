<a href="{{@site.url}}" class="logo group flex items-center gap-2" aria-label="{{@site.title}} — home">
	{{!-- The mark: one-shot line-drawing choreography on page load —
	     S draws itself → its ending stroke draws the play button → play draws
	     into code lines → a code line re-draws the S → CRT off/on blip →
	     live dot pulses (play/pause) and settles. Stroke-drawn, never faded.
	     Runs ONCE per page (no loop); reduced-motion gets the static S. --}}
	<svg width="28" height="28" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" class="logo-mark shrink-0 transition-transform duration-500 group-hover:rotate-[-6deg]" aria-hidden="true">
		<rect x="1.5" y="1.5" width="45" height="45" rx="13" class="fill-ink" />
		{{!-- recording frame corners (static) --}}
		<g class="stroke-paper" stroke-width="2.4" stroke-linecap="round" opacity=".55" fill="none">
			<path d="M9 14v-2a3 3 0 0 1 3-3h2" /><path d="M39 14v-2a3 3 0 0 0-3-3h-2" />
			<path d="M9 34v2a3 3 0 0 0 3 3h2" /><path d="M39 34v2a3 3 0 0 1-3 3h-2" />
		</g>
		{{!-- CRT group: everything inside collapses/reopens for the tv blip --}}
		<g class="logo-crt">
			<g class="stroke-paper" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round" fill="none">
				{{!-- act 1 · S draws in, then its line runs onward --}}
				<path class="logo-seg logo-seg-s1" pathLength="100" d="M31.5 17.5c-1-2.2-3.6-3.4-7.2-3.4-4.3 0-7.4 2-7.4 5.4 0 6.8 15 3.2 15 10.4 0 3.5-3.2 5.6-7.8 5.6-4 0-6.7-1.4-8-3.9" />
				{{!-- act 2 · play triangle drawn as one continuous stroke --}}
				<path class="logo-seg logo-seg-play" pathLength="100" d="M19 15.5l14 8.5-14 8.5z" />
				{{!-- act 3 · code lines draw --}}
				<path class="logo-seg logo-seg-c1" pathLength="100" d="M18 17l-6 7 6 7" />
				<path class="logo-seg logo-seg-c2" pathLength="100" d="M30 17l6 7-6 7" />
				<path class="logo-seg logo-seg-c3" pathLength="100" d="M26 14l-4 20" />
				{{!-- act 4 · the S returns, drawn by the last code line, and stays --}}
				<path class="logo-seg logo-seg-s2" pathLength="100" d="M31.5 17.5c-1-2.2-3.6-3.4-7.2-3.4-4.3 0-7.4 2-7.4 5.4 0 6.8 15 3.2 15 10.4 0 3.5-3.2 5.6-7.8 5.6-4 0-6.7-1.4-8-3.9" />
			</g>
			{{!-- CRT flash line --}}
			<rect class="logo-crt-flash" x="6" y="23" width="36" height="2" rx="1" fill="#fff" opacity="0" />
		</g>
		{{!-- live dot: waits, does a play/pause double-pulse, then blinks slow --}}
		<circle cx="37" cy="11" r="2.5" fill="#3b82f6" class="logo-rec" />
	</svg>
	<span class="flex min-w-0 flex-col leading-none">
		<span class="text-[15px] font-bold tracking-tight">Swarnil</span>
		{{!-- documenting <life|chaos|trips|emotions|happiness> --}}
		<span class="mt-[3px] flex items-center gap-1 font-mono text-[8px] uppercase tracking-[0.22em] text-silver">
			documenting
			<span class="logo-rotator relative inline-block h-[1.4em] overflow-hidden align-bottom">
				<span class="logo-rotator-track flex flex-col">
					<i class="not-italic">life</i><i class="not-italic">chaos</i><i class="not-italic">trips</i><i class="not-italic">emotions</i><i class="not-italic">happiness</i><i class="not-italic" aria-hidden="true">life</i>
				</span>
			</span>
		</span>
	</span>
</a>
