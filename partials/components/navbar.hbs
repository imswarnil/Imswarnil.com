{{!-- Navbar: compact flat bar at page top; morphs into a floating island pill on
     scroll. Menu is theme-defined (iconified) — Ghost Admin nav is ignored on
     purpose: the admin default ("Home / Getting started") looked broken here.
     Secondary admin nav still feeds the "More" dropdown if set. --}}
<header class="fixed inset-x-0 top-0 z-50 px-4 pt-2 sm:pt-3" id="site-header">
	<nav class="container-site !px-0">
		<div class="nav-shell" id="nav-island">

			{{> "components/logo"}}

			{{!-- Desktop nav — theme-defined, iconified --}}
			<div class="hidden items-center gap-0.5 lg:flex" role="navigation" aria-label="Primary">
				<a href="{{@site.url}}/videos/" class="nav-link">{{> "icons/play" class="h-3.5 w-3.5"}} Videos</a>
				<a href="{{@site.url}}/webseries/" class="nav-link">{{> "icons/film" class="h-3.5 w-3.5"}} Series</a>
				<a href="{{@site.url}}/blog/" class="nav-link">{{> "icons/book" class="h-3.5 w-3.5"}} Blog</a>
				<a href="{{@site.url}}/courses/" class="nav-link">{{> "icons/graduation" class="h-3.5 w-3.5"}} Courses</a>
				<a href="{{@site.url}}/projects/" class="nav-link">{{> "icons/terminal" class="h-3.5 w-3.5"}} Projects</a>
				<a href="{{@site.url}}/travel/" class="nav-link">{{> "icons/map-pin" class="h-3.5 w-3.5"}} Travel</a>

				<div class="relative" data-dropdown>
					<button type="button" class="nav-link" aria-expanded="false" aria-haspopup="true" data-dropdown-toggle>
						More {{> "icons/chevron-down" class="h-3 w-3 transition-transform duration-200"}}
					</button>
					<div class="invisible absolute right-0 top-full mt-2 w-56 origin-top-right scale-95 rounded-2xl border border-line bg-paper p-1.5 opacity-0 shadow-lift transition-all duration-200 data-[open]:visible data-[open]:scale-100 data-[open]:opacity-100" data-dropdown-menu>
						<a href="{{@site.url}}/shop/" class="panel-link">{{> "icons/download" class="h-3.5 w-3.5"}} Shop &amp; downloads</a>
						<a href="{{@site.url}}/products/" class="panel-link">{{> "icons/zap" class="h-3.5 w-3.5"}} Things I use</a>
						<a href="{{@site.url}}/timeline/" class="panel-link">{{> "icons/calendar" class="h-3.5 w-3.5"}} Timeline</a>
						<a href="{{@site.url}}/guestbook/" class="panel-link">{{> "icons/heart" class="h-3.5 w-3.5"}} Guestbook</a>
						<a href="{{@site.url}}/about/" class="panel-link">{{> "icons/user" class="h-3.5 w-3.5"}} About</a>
						<a href="{{@site.url}}/contact/" class="panel-link">{{> "icons/mail" class="h-3.5 w-3.5"}} Contact</a>
						{{#foreach @site.secondary_navigation}}
							<a href="{{url absolute="true"}}" class="panel-link">{{> "icons/arrow-up-right" class="h-3.5 w-3.5"}} {{label}}</a>
						{{/foreach}}
					</div>
				</div>
			</div>

			{{!-- Actions --}}
			<div class="flex items-center gap-1">
				<a href="https://github.com/{{@custom.github_repo}}" target="_blank" rel="noopener" class="group hidden h-8 items-center gap-1.5 rounded-full border border-line bg-mist/60 px-2.5 text-xs font-semibold transition hover:bg-mist xl:inline-flex" aria-label="Star on GitHub">
					{{> "icons/github" class=""}}
					{{> "icons/star" class="text-silver transition group-hover:scale-110 group-hover:text-ink"}}
				</a>

				<button type="button" class="icon-btn tooltip tooltip-bottom" data-tip="Search" data-ghost-search aria-label="Search">
					{{> "icons/search"}}
				</button>

				{{!-- Mode cycle switch: click to hop light → dark → sfdc → yt → flix → claude (with sounds) --}}
				<button type="button" id="mode-cycle" class="tooltip tooltip-bottom" aria-label="Switch theme mode"></button>

				{{!-- Everything panel shortcut --}}
				<button type="button" class="icon-btn tooltip tooltip-bottom" data-tip="Menu panel" id="panel-toggle" aria-expanded="false" aria-controls="mega-panel-backdrop" aria-label="Open menu panel">
					<svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><circle cx="3" cy="3" r="1.6"/><circle cx="8" cy="3" r="1.6"/><circle cx="13" cy="3" r="1.6"/><circle cx="3" cy="8" r="1.6"/><circle cx="8" cy="8" r="1.6"/><circle cx="13" cy="8" r="1.6"/><circle cx="3" cy="13" r="1.6"/><circle cx="8" cy="13" r="1.6"/><circle cx="13" cy="13" r="1.6"/></svg>
				</button>

				{{#if @site.members_enabled}}
					{{#if @member}}
						<a href="#/portal/account" class="ml-1 inline-flex items-center" aria-label="Your account" data-portal="account">
							{{#if @member.avatar_image}}
								<img src="{{@member.avatar_image}}" alt="{{@member.name}}" class="h-8 w-8 rounded-full border-2 border-line object-cover transition hover:border-ink" />
							{{else}}
								<span class="flex h-8 w-8 items-center justify-center rounded-full bg-ink text-sm font-bold text-paper" data-avatar-initial="{{@member.name}}">{{> "icons/user"}}</span>
							{{/if}}
						</a>
					{{else}}
						<a href="/signin/" class="btn-primary ml-1 !px-3.5 !py-1.5 !text-[12px]">Sign in</a>
					{{/if}}
				{{/if}}

				<button type="button" class="icon-btn lg:hidden" id="mobile-menu-toggle" aria-expanded="false" aria-controls="mobile-menu" aria-label="Open menu">
					<span class="menu-open">{{> "icons/menu"}}</span>
					<span class="menu-close hidden">{{> "icons/close"}}</span>
				</button>
			</div>
		</div>

		{{!-- Mega menu — centered modal with the full site map --}}
		<div class="fixed inset-0 z-[60] hidden items-start justify-center overflow-y-auto bg-ink/40 p-4 pt-20 backdrop-blur-sm sm:pt-28" id="mega-panel-backdrop">
			<div class="w-full max-w-3xl rounded-[2rem] border border-line bg-paper p-6 shadow-lift sm:p-8" id="mega-panel" role="dialog" aria-modal="true" aria-label="Site menu">
				<div class="mb-6 flex items-center justify-between">
					{{> "components/logo"}}
					<button type="button" class="icon-btn" id="panel-close" aria-label="Close menu">{{> "icons/close"}}</button>
				</div>
				<div class="grid grid-cols-2 gap-x-6 gap-y-6 sm:grid-cols-4">
					<div>
						<p class="kicker mb-2">Watch</p>
						<a href="/videos/" class="panel-link">{{> "icons/play" class="h-3.5 w-3.5"}} Videos</a>
						<a href="/webseries/" class="panel-link">{{> "icons/film" class="h-3.5 w-3.5"}} Webseries</a>
					</div>
					<div>
						<p class="kicker mb-2">Learn</p>
						<a href="/courses/" class="panel-link">{{> "icons/graduation" class="h-3.5 w-3.5"}} Courses</a>
						<a href="/blog/" class="panel-link">{{> "icons/book" class="h-3.5 w-3.5"}} Blog</a>
						<a href="/newsletters/" class="panel-link">{{> "icons/mail" class="h-3.5 w-3.5"}} Newsletters</a>
						<a href="/archive/" class="panel-link">{{> "icons/search" class="h-3.5 w-3.5"}} Archive</a>
						<a href="/tags/" class="panel-link">{{> "icons/sparkle" class="h-3.5 w-3.5"}} Topics</a>
					</div>
					<div>
						<p class="kicker mb-2">Work &amp; life</p>
						<a href="/projects/" class="panel-link">{{> "icons/github" class="h-3.5 w-3.5"}} Projects</a>
						<a href="/travel/" class="panel-link">{{> "icons/map-pin" class="h-3.5 w-3.5"}} Travel</a>
						<a href="/timeline/" class="panel-link">{{> "icons/calendar" class="h-3.5 w-3.5"}} Timeline</a>
						<a href="/resume/" class="panel-link">{{> "icons/briefcase" class="h-3.5 w-3.5"}} Resume</a>
						<a href="/changelog/" class="panel-link">{{> "icons/terminal" class="h-3.5 w-3.5"}} Changelog</a>
					</div>
					<div>
						<p class="kicker mb-2">More</p>
						<a href="/products/" class="panel-link">{{> "icons/zap" class="h-3.5 w-3.5"}} Things I use</a>
						<a href="/shop/" class="panel-link">{{> "icons/download" class="h-3.5 w-3.5"}} Shop</a>
						<a href="/guestbook/" class="panel-link">{{> "icons/heart" class="h-3.5 w-3.5"}} Guestbook</a>
						<a href="/about/" class="panel-link">{{> "icons/user" class="h-3.5 w-3.5"}} About</a>
						<a href="/sponsor/" class="panel-link">{{> "icons/trophy" class="h-3.5 w-3.5"}} Sponsor</a>
						<a href="/contact/" class="panel-link">{{> "icons/mail" class="h-3.5 w-3.5"}} Contact</a>
					</div>
				</div>
				<div class="mt-6 flex flex-wrap items-center justify-between gap-3 border-t border-line pt-5">
					<div class="flex items-center gap-1">
						<a href="{{@custom.youtube_url}}" target="_blank" rel="noopener" class="icon-btn" aria-label="YouTube">{{> "icons/youtube"}}</a>
						<a href="https://github.com/{{@custom.github_repo}}" target="_blank" rel="noopener" class="icon-btn" aria-label="GitHub">{{> "icons/github"}}</a>
						<a href="https://linkedin.com/in/imswarnil" target="_blank" rel="noopener" class="icon-btn" aria-label="LinkedIn">{{> "icons/linkedin"}}</a>
						<a href="{{@site.url}}/rss/" class="icon-btn" aria-label="RSS">{{> "icons/rss"}}</a>
					</div>
					{{#if @custom.topmate_url}}<a href="{{@custom.topmate_url}}" target="_blank" rel="noopener" class="btn-ghost text-xs">{{> "icons/calendar" class="h-3.5 w-3.5"}} Book a call</a>{{/if}}
				</div>
			</div>
		</div>

		{{!-- Mobile menu --}}
		<div class="mx-auto mt-2 hidden max-w-5xl overflow-hidden rounded-island border border-line bg-paper/95 p-3 shadow-lift backdrop-blur-xl lg:!hidden" id="mobile-menu">
			<nav class="flex flex-col" aria-label="Mobile">
				<a href="{{@site.url}}/videos/" class="mobile-link">{{> "icons/play" class="h-4 w-4 text-silver"}} Videos {{> "icons/arrow-right" class="ml-auto text-silver"}}</a>
				<a href="{{@site.url}}/webseries/" class="mobile-link">{{> "icons/film" class="h-4 w-4 text-silver"}} Webseries {{> "icons/arrow-right" class="ml-auto text-silver"}}</a>
				<a href="{{@site.url}}/blog/" class="mobile-link">{{> "icons/book" class="h-4 w-4 text-silver"}} Blog {{> "icons/arrow-right" class="ml-auto text-silver"}}</a>
				<a href="{{@site.url}}/courses/" class="mobile-link">{{> "icons/graduation" class="h-4 w-4 text-silver"}} Courses {{> "icons/arrow-right" class="ml-auto text-silver"}}</a>
				<a href="{{@site.url}}/projects/" class="mobile-link">{{> "icons/terminal" class="h-4 w-4 text-silver"}} Projects {{> "icons/arrow-right" class="ml-auto text-silver"}}</a>
				<a href="{{@site.url}}/travel/" class="mobile-link">{{> "icons/map-pin" class="h-4 w-4 text-silver"}} Travel {{> "icons/arrow-right" class="ml-auto text-silver"}}</a>
				<div class="my-2 border-t border-line"></div>
				<div class="grid grid-cols-2 gap-1">
					<a href="{{@site.url}}/shop/" class="mobile-sub">Shop</a>
					<a href="{{@site.url}}/products/" class="mobile-sub">Things I use</a>
					<a href="{{@site.url}}/timeline/" class="mobile-sub">Timeline</a>
					<a href="{{@site.url}}/guestbook/" class="mobile-sub">Guestbook</a>
					<a href="{{@site.url}}/about/" class="mobile-sub">About</a>
					<a href="{{@site.url}}/contact/" class="mobile-sub">Contact</a>
				</div>
			</nav>
		</div>
	</nav>
</header>
{{!-- Spacer so content clears the fixed navbar (hidden on player-chrome pages) --}}
<div class="h-[4.5rem] sm:h-20" aria-hidden="true" id="nav-spacer"></div>
