{{!-- Navbar. Menu renders through Ghost's native {{navigation}} helper
     (template: partials/navigation.hbs — icons per slug, no bullets).
     Nesting: label "- Child" folds under the item above, "-- Grand" one deeper
     (script at the bottom). Border doubles as the reading-progress bar. --}}
<header class="fixed inset-x-0 top-0 z-50 px-4 pt-1.5 sm:pt-2" id="site-header">
	<nav class="container-site !px-0">
		<div class="nav-shell" id="nav-island">
			{{!-- Reading progress: hairline accent border, drawn bottom-left → around --}}
			<svg class="nav-progress" aria-hidden="true" preserveAspectRatio="none">
				<path id="nav-progress-path" pathLength="100" d="" />
			</svg>

			{{> "components/logo"}}

			{{!-- Desktop nav — Ghost admin navigation + the 9-dot everything panel --}}
			<div class="relative hidden items-center gap-0.5 lg:flex" role="navigation" aria-label="Primary" id="primary-nav">
				{{#if @site.navigation}}
					{{navigation}}
				{{else}}
					<a href="{{@site.url}}/videos/" class="nav-link">{{> "icons/play" class="h-3.5 w-3.5"}} Videos</a>
					<a href="{{@site.url}}/blog/" class="nav-link">{{> "icons/pen" class="h-3.5 w-3.5"}} Blog</a>
					<a href="{{@site.url}}/courses/" class="nav-link">{{> "icons/graduation" class="h-3.5 w-3.5"}} Courses</a>
					<a href="{{@site.url}}/projects/" class="nav-link">{{> "icons/code" class="h-3.5 w-3.5"}} Projects</a>
					<a href="{{@site.url}}/travel/" class="nav-link">{{> "icons/plane" class="h-3.5 w-3.5"}} Travel</a>
				{{/if}}
				<button type="button" class="icon-btn !h-8 !w-8 tooltip tooltip-bottom" data-tip="Everything" id="panel-toggle" aria-expanded="false" aria-controls="mega-panel-backdrop" aria-label="Open menu panel">
					<svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><circle cx="3" cy="3" r="1.6"/><circle cx="8" cy="3" r="1.6"/><circle cx="13" cy="3" r="1.6"/><circle cx="3" cy="8" r="1.6"/><circle cx="8" cy="8" r="1.6"/><circle cx="13" cy="8" r="1.6"/><circle cx="3" cy="13" r="1.6"/><circle cx="8" cy="13" r="1.6"/><circle cx="13" cy="13" r="1.6"/></svg>
				</button>
			</div>

			{{!-- Actions: search · theme · sign-in · github · subscribe-bell --}}
			<div class="flex items-center gap-0.5">
				<button type="button" class="icon-btn tooltip tooltip-bottom" data-tip="Search" data-ghost-search aria-label="Search">
					{{> "icons/search"}}
				</button>

				{{!-- Theme: tap toggles light/dark, long-press reveals all modes --}}
				<button type="button" id="mode-cycle" data-mode-cycle class="icon-btn" aria-label="Switch theme mode" aria-haspopup="true"></button>

				{{#if @site.members_enabled}}
					{{#if @member}}
						<a href="#/portal/account" class="mx-0.5 inline-flex items-center" aria-label="Your account" data-portal="account">
							{{#if @member.avatar_image}}
								<img src="{{@member.avatar_image}}" alt="{{@member.name}}" class="h-7 w-7 rounded-full border-2 border-line object-cover transition hover:border-ink" />
							{{else}}
								<span class="flex h-7 w-7 items-center justify-center rounded-full bg-ink text-xs font-bold text-paper" data-avatar-initial="{{@member.name}}">{{> "icons/user"}}</span>
							{{/if}}
						</a>
					{{else}}
						<a href="/signin/" class="icon-btn tooltip tooltip-bottom" data-tip="Sign in" aria-label="Sign in">{{> "icons/user"}}</a>
					{{/if}}
				{{/if}}

				<a href="https://github.com/{{@custom.github_repo}}" target="_blank" rel="noopener" class="icon-btn tooltip tooltip-bottom" data-tip="Star on GitHub" aria-label="Star on GitHub">
					{{> "icons/github"}}
				</a>

				{{!-- Subscribe bell — opens the "own your audience" pitch modal --}}
				<button type="button" class="icon-btn tooltip tooltip-left" data-tip="Subscribe" data-modal-open="#subscribe-backdrop" aria-haspopup="dialog" aria-label="Subscribe">
					{{> "icons/bell"}}
				</button>

				<button type="button" class="icon-btn lg:hidden" id="mobile-menu-toggle" aria-expanded="false" aria-controls="mobile-menu" aria-label="Open menu">
					<span class="menu-open">{{> "icons/menu"}}</span>
					<span class="menu-close hidden">{{> "icons/close"}}</span>
				</button>
			</div>
		</div>

		{{!-- Mega menu — centered modal with the full site map --}}
		<div class="fixed inset-0 z-[60] hidden items-start justify-center overflow-y-auto bg-ink/40 p-4 pt-20 backdrop-blur-sm sm:pt-28" id="mega-panel-backdrop">
			<div class="w-full max-w-3xl rounded-[2rem] border border-line bg-paper p-6 shadow-lift sm:p-8" id="mega-panel" role="dialog" aria-modal="true" aria-label="Site menu">
				<div class="mb-6 flex items-center justify-between">
					{{> "components/logo"}}
					<button type="button" class="icon-btn" id="panel-close" aria-label="Close menu">{{> "icons/close"}}</button>
				</div>
				<div class="grid grid-cols-2 gap-x-6 gap-y-6 sm:grid-cols-4">
					<div>
						<p class="kicker mb-2">Watch</p>
						<a href="/videos/" class="panel-link">{{> "icons/play" class="h-3.5 w-3.5"}} Videos</a>
						<a href="/webseries/" class="panel-link">{{> "icons/tv" class="h-3.5 w-3.5"}} Webseries</a>
						<a href="{{@custom.youtube_url}}" target="_blank" rel="noopener" class="panel-link">{{> "icons/youtube" class="h-3.5 w-3.5"}} YouTube</a>
					</div>
					<div>
						<p class="kicker mb-2">Learn</p>
						<a href="/courses/" class="panel-link">{{> "icons/graduation" class="h-3.5 w-3.5"}} Courses</a>
						<a href="/blog/" class="panel-link">{{> "icons/pen" class="h-3.5 w-3.5"}} Blog</a>
						<a href="/prompts/" class="panel-link">{{> "icons/sparkle" class="h-3.5 w-3.5"}} Prompts</a>
						<a href="/snippets/" class="panel-link">{{> "icons/code" class="h-3.5 w-3.5"}} Snippets</a>
						<a href="/newsletters/" class="panel-link">{{> "icons/mail" class="h-3.5 w-3.5"}} Newsletters</a>
						<a href="/archive/" class="panel-link">{{> "icons/search" class="h-3.5 w-3.5"}} Archive</a>
						<a href="/tags/" class="panel-link">{{> "icons/sparkle" class="h-3.5 w-3.5"}} Topics</a>
					</div>
					<div>
						<p class="kicker mb-2">Work &amp; life</p>
						<a href="/projects/" class="panel-link">{{> "icons/code" class="h-3.5 w-3.5"}} Projects</a>
						<a href="/experiences/" class="panel-link">{{> "icons/star" class="h-3.5 w-3.5"}} Experiences</a>
						<a href="/travel/" class="panel-link">{{> "icons/plane" class="h-3.5 w-3.5"}} Travel</a>
						<a href="/timeline/" class="panel-link">{{> "icons/calendar" class="h-3.5 w-3.5"}} Timeline</a>
						<a href="/bucketlist/" class="panel-link">{{> "icons/check" class="h-3.5 w-3.5"}} Bucketlist</a>
						<a href="/resume/" class="panel-link">{{> "icons/briefcase" class="h-3.5 w-3.5"}} Resume</a>
						<a href="/changelog/" class="panel-link">{{> "icons/terminal" class="h-3.5 w-3.5"}} Changelog</a>
					</div>
					<div>
						<p class="kicker mb-2">More</p>
