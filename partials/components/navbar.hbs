{{!-- Navbar: full-width flat bar at page top; morphs into a floating island
     pill as you scroll (see .nav-shell / .is-island in tailwind.css).
     Primary nav from Ghost Admin → Settings → Navigation. --}}
<header class="fixed inset-x-0 top-0 z-50 px-4 pt-3 sm:pt-4" id="site-header">
	<nav class="container-site !px-0">
		<div class="nav-shell" id="nav-island">

			{{> "components/logo"}}

			{{!-- Desktop nav (Ghost Admin → Settings → Navigation → Primary) --}}
			<div class="hidden items-center gap-0.5 lg:flex" role="navigation" aria-label="Primary">
				{{#foreach @site.navigation}}
					<a href="{{url absolute="true"}}" class="rounded-full px-3.5 py-2 text-sm font-medium text-silver transition hover:bg-mist hover:text-ink{{#if current}} bg-mist !text-ink{{/if}}">{{label}}</a>
				{{/foreach}}

				{{#if @site.secondary_navigation}}
				<div class="relative" data-dropdown>
					<button type="button" class="flex items-center gap-1 rounded-full px-3.5 py-2 text-sm font-medium text-silver transition hover:bg-mist hover:text-ink" aria-expanded="false" aria-haspopup="true" data-dropdown-toggle>
						More {{> "icons/chevron-down" class="transition-transform duration-200"}}
					</button>
					<div class="invisible absolute right-0 top-full mt-2 w-52 origin-top-right scale-95 rounded-2xl border border-line bg-paper p-1.5 opacity-0 shadow-lift transition-all duration-200 data-[open]:visible data-[open]:scale-100 data-[open]:opacity-100" data-dropdown-menu>
						{{#foreach @site.secondary_navigation}}
							<a href="{{url absolute="true"}}" class="flex items-center justify-between rounded-xl px-3.5 py-2.5 text-sm font-medium text-silver transition hover:bg-mist hover:text-ink">
								{{label}} {{> "icons/arrow-up-right" class="opacity-40"}}
							</a>
						{{/foreach}}
					</div>
				</div>
				{{/if}}
			</div>

			{{!-- Actions --}}
			<div class="flex items-center gap-1">
				<a href="https://github.com/{{@custom.github_repo}}" target="_blank" rel="noopener" class="group hidden items-center gap-1.5 rounded-full border border-line bg-mist/60 px-3 py-1.5 text-xs font-semibold transition hover:bg-mist xl:inline-flex" aria-label="Star on GitHub">
					{{> "icons/github" class=""}}
					<span class="hidden md:inline">Star</span>
					{{> "icons/star" class="text-silver transition group-hover:scale-110 group-hover:text-ink"}}
				</a>

				<button type="button" class="icon-btn tooltip tooltip-bottom" data-tip="Search" data-ghost-search aria-label="Search">
					{{> "icons/search"}}
				</button>

				{{!-- Theme mode switcher: 6 modes --}}
				<div class="relative" data-dropdown>
					<button type="button" class="icon-btn tooltip tooltip-bottom" data-tip="Theme" aria-label="Switch theme" aria-haspopup="true" aria-expanded="false" data-dropdown-toggle>
						<span class="hidden dark:inline-flex">{{> "icons/sun"}}</span>
						<span class="inline-flex dark:hidden">{{> "icons/moon"}}</span>
					</button>
					<div class="invisible absolute right-0 top-full mt-2 w-48 origin-top-right scale-95 rounded-2xl border border-line bg-paper p-1.5 opacity-0 shadow-lift transition-all duration-200 data-[open]:visible data-[open]:scale-100 data-[open]:opacity-100" data-dropdown-menu id="mode-menu">
						<button type="button" data-set-mode="light" class="mode-option"><span class="mode-dot" style="background:#fafafa;border-color:#d4d4d8"></span>Light</button>
						<button type="button" data-set-mode="dark" class="mode-option"><span class="mode-dot" style="background:#09090b"></span>Dark</button>
						<button type="button" data-set-mode="salesforce" class="mode-option"><span class="mode-dot" style="background:#0176d3"></span>Salesforce</button>
						<button type="button" data-set-mode="youtube" class="mode-option"><span class="mode-dot" style="background:#ff0033"></span>YouTube</button>
						<button type="button" data-set-mode="netflix" class="mode-option"><span class="mode-dot" style="background:#e50914"></span>Netflix</button>
						<button type="button" data-set-mode="claude" class="mode-option"><span class="mode-dot" style="background:#c15f3c"></span>Claude</button>
					</div>
				</div>

				{{!-- Everything panel shortcut --}}
				<button type="button" class="icon-btn tooltip tooltip-bottom" data-tip="Menu panel" id="panel-toggle" aria-expanded="false" aria-controls="mega-panel-backdrop" aria-label="Open menu panel">
					<svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><circle cx="3" cy="3" r="1.6"/><circle cx="8" cy="3" r="1.6"/><circle cx="13" cy="3" r="1.6"/><circle cx="3" cy="8" r="1.6"/><circle cx="8" cy="8" r="1.6"/><circle cx="13" cy="8" r="1.6"/><circle cx="3" cy="13" r="1.6"/><circle cx="8" cy="13" r="1.6"/><circle cx="13" cy="13" r="1.6"/></svg>
				</button>

				{{#if @site.members_enabled}}
					{{#if @member}}
						<a href="#/portal/account" class="ml-1 inline-flex items-center" aria-label="Your account" data-portal="account">
							{{#if @member.avatar_image}}
								<img src="{{@member.avatar_image}}" alt="{{@member.name}}" class="h-9 w-9 rounded-full border-2 border-line object-cover transition hover:border-ink" />
							{{else}}
								<span class="flex h-9 w-9 items-center justify-center rounded-full bg-ink text-sm font-bold text-paper" data-avatar-initial="{{@member.name}}">{{> "icons/user"}}</span>
							{{/if}}
						</a>
					{{else}}
						<a href="/signin/" class="btn-primary ml-1 !px-4 !py-2 !text-[13px]">Sign in</a>
					{{/if}}
				{{/if}}

				<button type="button" class="icon-btn lg:hidden" id="mobile-menu-toggle" aria-expanded="false" aria-controls="mobile-menu" aria-label="Open menu">
					<span class="menu-open">{{> "icons/menu"}}</span>
					<span class="menu-close hidden">{{> "icons/close"}}</span>
				</button>
			</div>
		</div>

		{{!-- Mega menu — centered modal with the full site map --}}
		<div class="fixed inset-0 z-[60] hidden items-start justify-center overflow-y-auto bg-ink/40 p-4 pt-20 backdrop-blur-sm sm:pt-28" id="mega-panel-backdrop">
			<div class="w-full max-w-3xl rounded-[2rem] border border-line bg-paper p-6 shadow-lift sm:p-8" id="mega-panel" role="dialog" aria-modal="true" aria-label="Site menu">
				<div class="mb-6 flex items-center justify-between">
					{{> "components/logo"}}
					<button type="button" class="icon-btn" id="panel-close" aria-label="Close menu">{{> "icons/close"}}</button>
				</div>
				<div class="grid grid-cols-2 gap-x-6 gap-y-6 sm:grid-cols-4">
					<div>
						<p class="kicker mb-2">Watch</p>
						<a href="/videos/" class="panel-link">{{> "icons/play" class="h-3.5 w-3.5"}} Videos</a>
						<a href="/webseries/" class="panel-link">{{> "icons/film" class="h-3.5 w-3.5"}} Webseries</a>
					</div>
					<div>
						<p class="kicker mb-2">Learn</p>
						<a href="/courses/" class="panel-link">{{> "icons/book" class="h-3.5 w-3.5"}} Courses</a>
						<a href="/blog/" class="panel-link">Blog</a>
						<a href="/newsletters/" class="panel-link">Newsletters</a>
						<a href="/archive/" class="panel-link">Archive</a>
					</div>
					<div>
						<p class="kicker mb-2">Work</p>
						<a href="/projects/" class="panel-link">{{> "icons/github" class="h-3.5 w-3.5"}} Projects</a>
						<a href="/timeline/" class="panel-link">Timeline</a>
						<a href="/resume/" class="panel-link">Resume</a>
						<a href="/changelog/" class="panel-link">Changelog</a>
					</div>
					<div>
						<p class="kicker mb-2">More</p>
						<a href="/products/" class="panel-link">Things I use</a>
						<a href="/shop/" class="panel-link">Shop</a>
						<a href="/guestbook/" class="panel-link">{{> "icons/heart" class="h-3.5 w-3.5"}} Guestbook</a>
						<a href="/sponsor/" class="panel-link">Sponsor</a>
						<a href="/contact/" class="panel-link">{{> "icons/mail" class="h-3.5 w-3.5"}} Contact</a>
						<a href="/sitemap-visual/" class="panel-link">Sitemap</a>
					</div>
				</div>
				<div class="mt-6 flex flex-wrap items-center justify-between gap-3 border-t border-line pt-5">
					<div class="flex items-center gap-1">
						<a href="{{@custom.youtube_url}}" target="_blank" rel="noopener" class="icon-btn" aria-label="YouTube">{{> "icons/youtube"}}</a>
						<a href="https://github.com/{{@custom.github_repo}}" target="_blank" rel="noopener" class="icon-btn" aria-label="GitHub">{{> "icons/github"}}</a>
						<a href="https://linkedin.com/in/imswarnil" target="_blank" rel="noopener" class="icon-btn" aria-label="LinkedIn">{{> "icons/linkedin"}}</a>
						<a href="{{@site.url}}/rss/" class="icon-btn" aria-label="RSS">{{> "icons/rss"}}</a>
					</div>
					{{#if @custom.topmate_url}}<a href="{{@custom.topmate_url}}" target="_blank" rel="noopener" class="btn-ghost text-xs">{{> "icons/calendar" class="h-3.5 w-3.5"}} Book a call</a>{{/if}}
				</div>
			</div>
		</div>

		{{!-- Mobile menu --}}
		<div class="mx-auto mt-2 hidden max-w-5xl overflow-hidden rounded-island border border-line bg-paper/95 p-3 shadow-lift backdrop-blur-xl lg:!hidden" id="mobile-menu">
			<nav class="flex flex-col" aria-label="Mobile">
				{{#foreach @site.navigation}}
					<a href="{{url absolute="true"}}" class="flex items-center justify-between rounded-xl px-4 py-3 text-[15px] font-medium text-ink transition hover:bg-mist{{#if current}} bg-mist{{/if}}">
						{{label}} {{> "icons/arrow-right" class="text-silver"}}
					</a>
				{{/foreach}}
				{{#if @site.secondary_navigation}}
					<div class="my-2 border-t border-line"></div>
					<div class="grid grid-cols-2 gap-1">
						{{#foreach @site.secondary_navigation}}
							<a href="{{url absolute="true"}}" class="rounded-xl px-4 py-2.5 text-sm font-medium text-silver transition hover:bg-mist hover:text-ink">{{label}}</a>
						{{/foreach}}
					</div>
				{{/if}}
			</nav>
		</div>
	</nav>
</header>
{{!-- Spacer so content clears the fixed navbar --}}
<div class="h-24 sm:h-28" aria-hidden="true"></div>
