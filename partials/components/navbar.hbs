{{!-- Spacer so content clears the fixed navbar (hidden on player-chrome pages) --}}
<div class="h-[3.5rem] sm:h-16" aria-hidden="true" id="nav-spacer"></div>

<script>
	/* Fold "- Child" / "-- Grandchild" admin-nav items into dropdowns.
	   Runs inline (before main.js) so the dropdown wiring picks it up. */
	(function () {
		document.querySelectorAll('#primary-nav .nav-list').forEach(function (list) {
			var items = [].slice.call(list.children);
			var lastTop = null, lastChild = null;
			items.forEach(function (li) {
				var label = (li.getAttribute('data-nav-label') || '').trim();
				var depth = (label.match(/^(-{1,2})\s*/) || [, ''])[1].length;
				if (!depth) { lastTop = li; lastChild = null; return; }
				var link = li.querySelector('.nav-link');
				var text = li.querySelector('.nav-label');
				if (text) text.textContent = label.replace(/^-{1,2}\s*/, '');
				if (link) { link.classList.remove('nav-link'); link.classList.add('panel-link'); }
				li.classList.add('list-none');
				var host = depth === 2 && lastChild ? lastChild : lastTop;
				if (!host) return;
				var menu;
				if (depth === 2 && lastChild) {
					/* grandchild: flyout inside the child */
					lastChild.classList.add('nav-sub', 'relative');
					menu = lastChild.querySelector('.nav-sub-menu');
					if (!menu) {
						menu = document.createElement('div');
						menu.className = 'nav-sub-menu';
						lastChild.appendChild(menu);
						var childLink = lastChild.querySelector('a');
						if (childLink) childLink.classList.add('justify-between');
					}
					menu.appendChild(li.querySelector('a'));
					li.remove();
				} else {
					/* child: dropdown under the top item */
					if (!host.hasAttribute('data-dropdown')) {
						host.setAttribute('data-dropdown', '');
						var topLink = host.querySelector('a');
						var btn = document.createElement('button');
						btn.type = 'button';
						btn.className = 'nav-link';
						btn.setAttribute('data-dropdown-toggle', '');
						btn.setAttribute('aria-expanded', 'false');
						btn.setAttribute('aria-haspopup', 'true');
						btn.innerHTML = topLink.innerHTML + '<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>';
						host.replaceChild(btn, topLink);
						menu = document.createElement('div');
						menu.className = 'invisible absolute left-0 top-full mt-2 w-52 origin-top-left scale-95 rounded-2xl border border-line bg-paper p-1.5 opacity-0 shadow-lift transition-all duration-200 data-[open]:visible data-[open]:scale-100 data-[open]:opacity-100';
						menu.setAttribute('data-dropdown-menu', '');
						host.appendChild(menu);
						/* keep the original destination reachable at the top of the menu */
						menu.appendChild(topLink);
						topLink.classList.remove('nav-link');
						topLink.classList.add('panel-link');
					}
					menu = host.querySelector('[data-dropdown-menu]');
					var moved = li.querySelector('a');
					menu.appendChild(moved);
					lastChild = document.createElement('div');
					lastChild.appendChild(moved);
					menu.appendChild(lastChild);
					li.remove();
				}
			});
		});
	})();
</script>
