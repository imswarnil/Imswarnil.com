{{!-- Reusable section header. Params:
       kicker (string) · title (string) · sub (optional string)
       actionUrl + actionLabel (optional button) --}}
<div class="flex flex-wrap items-end justify-between gap-4">
	<div class="min-w-0">
		<p class="kicker">{{kicker}}</p>
		<h2 class="section-title mt-2 text-balance">{{title}}</h2>
		{{#if sub}}<p class="mt-2 max-w-xl text-sm leading-relaxed text-silver">{{sub}}</p>{{/if}}
	</div>
	{{#if actionUrl}}
	<a href="{{actionUrl}}" class="btn-ghost shrink-0">{{actionLabel}} {{> "icons/arrow-right"}}</a>
	{{/if}}
</div>
