{{!-- Sponsor + collab CTA band. Drop anywhere:  {{> "components/collab-cta"}}
     Optional:  compact=true  for a slimmer inline version. --}}
<aside class="cta-band pub-sweep {{#if compact}}!py-3.5 !px-4{{/if}} {{class}}" aria-label="Work with me">
	<div class="min-w-0">
		<p class="kicker !text-accent">{{> "icons/cash" class="h-3.5 w-3.5"}} For brands &amp; creators</p>
		<p class="mt-1.5 text-[15px] font-semibold leading-snug tracking-tight sm:text-base">Put your brand in front of my audience.</p>
		{{#unless compact}}<p class="mt-1 max-w-md text-sm leading-relaxed text-silver">Sponsor a video, or team up on something new — collabs, features and cross-posts welcome.</p>{{/unless}}
	</div>
	<div class="flex shrink-0 flex-wrap items-center gap-2.5">
		<a href="{{@site.url}}/sponsor/" class="btn-primary btn-sm">{{> "icons/cash" class="h-3.5 w-3.5"}} Sponsor a video</a>
		<a href="{{@site.url}}/collab/" class="btn-ghost btn-sm">{{> "icons/sparkle" class="h-3.5 w-3.5"}} Let's collab</a>
	</div>
</aside>
