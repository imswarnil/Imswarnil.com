{{!-- Guide stepper — the ordered steps of a guide, as a vertical rail.
     Used by the guide landing page and by every step page.

     Params:
       tagSlug — the guide's PUBLIC tag slug (steps take it as primary tag)
       active  — slug of the current step ("" on the landing page)

     Fill is POSITIONAL, not remembered: if you're on step 5, steps 1–4 are
     ticked and 5 is current — every time, for everyone, including a first-time
     visitor on a fresh browser. It used to key off localStorage, which meant
     the rail was empty until you'd personally scrolled through each step, and
     showed a half-filled rail to nobody but you. Where you ARE in the route is
     a fact about the page, so the page decides it. --}}
{{#get "posts" filter="tag:hash-guide-content+tags:{{tagSlug}}" limit="50" order="published_at asc" as |steps|}}
	{{#if steps.length}}
	{{!-- ../active: hash params live on the partial's root context, and the
	     {{#get}} frame does not inherit them — plain {{active}} rendered empty
	     here, which left data-active off and the route stuck at 0%. --}}
	<ol class="guide-stepper" data-guide-stepper{{#if ../active}} data-active="{{../active}}"{{/if}}>
		{{#foreach steps}}
		<li class="guide-step" data-step-slug="{{slug}}">
			<a href="{{url}}" class="guide-step-link">
				<span class="guide-node" aria-hidden="true">
					<span data-node-num>{{@number}}</span>
					<span data-node-tick hidden>{{> "icons/check" class="h-3.5 w-3.5"}}</span>
				</span>
				<span class="guide-step-title">{{title}}</span>
				{{#match visibility "!=" "public"}}{{> "icons/lock" class="ml-auto mt-1.5 h-3.5 w-3.5 shrink-0 text-silver"}}{{/match}}
			</a>
		</li>
		{{/foreach}}
	</ol>
	{{else}}
	<p class="rounded-xl border border-dashed border-line p-4 text-center text-xs text-silver">
		Tag posts <code class="rounded bg-mist px-1 py-0.5 font-mono">#guide-content</code> with this guide's tag to build the route.
	</p>
	{{/if}}
{{/get}}

<script>
	(function () {
		/* Paint every stepper on the page from position alone. Runs for each
		   instance (a step page has the rail plus the mobile panel copy), and
		   never touches storage. */
		document.querySelectorAll('[data-guide-stepper]').forEach(function (ol) {
			var current = ol.getAttribute('data-active');
			var steps = [].slice.call(ol.querySelectorAll('.guide-step'));
			if (!steps.length) return;

			var idx = current
				? steps.findIndex(function (li) { return li.getAttribute('data-step-slug') === current; })
				: -1;

			steps.forEach(function (li, i) {
				var done = idx > -1 && i < idx;       /* everything before you: walked */
				var here = idx > -1 && i === idx;     /* where you are now */
				li.classList.toggle('is-done', done);
				li.classList.toggle('is-current', here);
				var num = li.querySelector('[data-node-num]');
				var tick = li.querySelector('[data-node-tick]');
				if (num && tick) { num.hidden = done; tick.hidden = !done; }
				var link = li.querySelector('.guide-step-link');
				if (link && here) link.setAttribute('aria-current', 'page');
			});

			/* the rail fills to the middle of the current node, so the line stops
			   exactly where you are rather than at the edge of the step */
			var pct = idx > -1 ? (idx + 0.5) / steps.length : 0;
			ol.style.setProperty('--progress', pct.toFixed(3));
		});
	})();
</script>
