{{!-- Dynamic JSON-LD rich snippets, per context. Every page type emits schema:
     home → WebSite+Person+SearchAction · posts → typed Article/Video/Course/…
     + breadcrumbs · pages → WebPage/AboutPage/ContactPage · tag → CollectionPage
     · author → ProfilePage. Template-specific schemas (TVSeries, TVEpisode,
     TouristTrip, Course syllabus) are emitted by their own templates. --}}
{{#is "home"}}
<script type="application/ld+json">
{
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "WebSite",
			"@id": "{{@site.url}}/#website",
			"url": "{{@site.url}}",
			"name": "{{@site.title}}",
			"description": "{{@site.description}}",
			"inLanguage": "{{@site.locale}}",
			"publisher": { "@id": "{{@site.url}}/#person" },
			"potentialAction": {
				"@type": "SearchAction",
				"target": { "@type": "EntryPoint", "urlTemplate": "{{@site.url}}/?s={search_term_string}" },
				"query-input": "required name=search_term_string"
			}
		},
		{
			"@type": "Person",
			"@id": "{{@site.url}}/#person",
			"name": "Swarnil Singhai",
			"url": "{{@site.url}}",
			"jobTitle": "{{@custom.job_title}}",
			"worksFor": { "@type": "Organization", "name": "{{@custom.workplace}}", "url": "{{@custom.workplace_url}}" },
			"sameAs": [
				"https://github.com/imswarnil",
				"https://www.linkedin.com/in/imswarnil",
				"https://www.youtube.com/@imswarnil"
			]
		},
		{
			"@type": "WebPage",
			"@id": "{{@site.url}}/#homepage",
			"url": "{{@site.url}}",
			"name": "Swarnil Singhai — personal website",
			"description": "The personal website of Swarnil Singhai, {{@custom.job_title}} at {{@custom.workplace}}: videos, blog, projects, courses, webseries, travel diaries, digital downloads and a guestbook.",
			"isPartOf": { "@id": "{{@site.url}}/#website" },
			"about": { "@id": "{{@site.url}}/#person" },
			"hasPart": [
				{ "@type": "WebPageElement", "@id": "{{@site.url}}/#home-latest", "name": "Latest videos", "url": "{{@site.url}}/videos/" },
				{ "@type": "WebPageElement", "@id": "{{@site.url}}/#home-now", "name": "What I'm doing now", "url": "{{@site.url}}/#home-now" },
				{ "@type": "WebPageElement", "@id": "{{@site.url}}/#home-webseries", "name": "Webseries", "url": "{{@site.url}}/webseries/" },
				{ "@type": "WebPageElement", "@id": "{{@site.url}}/#home-blog", "name": "From the blog", "url": "{{@site.url}}/blog/" },
				{ "@type": "WebPageElement", "@id": "{{@site.url}}/#home-portfolio", "name": "Portfolio and projects", "url": "{{@site.url}}/projects/" },
				{ "@type": "WebPageElement", "@id": "{{@site.url}}/#home-courses", "name": "Courses", "url": "{{@site.url}}/courses/" },
				{ "@type": "WebPageElement", "@id": "{{@site.url}}/#home-shop", "name": "Digital downloads and themes", "url": "{{@site.url}}/shop/" },
				{ "@type": "WebPageElement", "@id": "{{@site.url}}/#home-products", "name": "Products I use", "url": "{{@site.url}}/products/" },
				{ "@type": "WebPageElement", "@id": "{{@site.url}}/#home-timeline", "name": "Career timeline", "url": "{{@site.url}}/timeline/" },
				{ "@type": "WebPageElement", "@id": "{{@site.url}}/#home-guestbook", "name": "Guestbook", "url": "{{@site.url}}/guestbook/" },
				{ "@type": "WebPageElement", "@id": "{{@site.url}}/#home-subscribe", "name": "Subscribe", "url": "{{@site.url}}/#home-subscribe" }
			]
		}
	]
}
</script>
{{/is}}

{{#is "page"}}
{{#post}}
<script type="application/ld+json">
{
	"@context": "https://schema.org",
	"@type": "{{#match slug "about"}}AboutPage{{else match slug "contact"}}ContactPage{{else match slug "resume"}}ProfilePage{{else}}WebPage{{/match}}",
	"name": "{{title}}",
	"url": "{{url absolute="true"}}",
	"description": "{{custom_excerpt}}{{^custom_excerpt}}{{excerpt words="35"}}{{/custom_excerpt}}",
	{{#if feature_image}}"image": "{{img_url feature_image size="1600" absolute="true"}}",{{/if}}
	"dateModified": "{{date updated_at format="YYYY-MM-DDTHH:mm:ssZ"}}",
	"isPartOf": { "@type": "WebSite", "@id": "{{@site.url}}/#website" },
	"about": { "@type": "Person", "@id": "{{@site.url}}/#person", "name": "Swarnil Singhai" }
}
</script>
{{/post}}
{{/is}}

{{#is "tag"}}
{{#tag}}
<script type="application/ld+json">
{
	"@context": "https://schema.org",
	"@type": "CollectionPage",
	"name": "{{name}}",
	"url": "{{url absolute="true"}}",
	{{#if description}}"description": "{{description}}",{{/if}}
	"isPartOf": { "@type": "WebSite", "@id": "{{@site.url}}/#website" }
}
</script>
{{/tag}}
{{/is}}

{{!-- Author pages: Ghost's own ghost_head already emits Person/profile metadata,
     and gscan forbids author.* paths in partials — so no extra block here. --}}

{{#is "post"}}
{{#post}}
<script type="application/ld+json">
{
	"@context": "https://schema.org",
	"@type": "{{#has tag="#video"}}VideoObject{{else has tag="#course"}}Course{{else has tag="#project"}}CreativeWork{{else has tag="#product"}}Review{{else has tag="#episode"}}TVEpisode{{else has tag="#webseries"}}TVSeries{{else}}Article{{/has}}",
	"headline": "{{title}}",
	"name": "{{title}}",
	"description": "{{custom_excerpt}}{{^custom_excerpt}}{{excerpt words="40"}}{{/custom_excerpt}}",
	{{#if feature_image}}
	"image": "{{img_url feature_image size="1600" absolute="true"}}",
	{{#has tag="#video"}}
	"thumbnailUrl": "{{img_url feature_image size="1600" absolute="true"}}",
	"uploadDate": "{{date published_at format="YYYY-MM-DDTHH:mm:ssZ"}}",
	"contentUrl": "{{url absolute="true"}}",
	{{/has}}
	{{/if}}
	{{#has tag="#course"}}
	"provider": { "@type": "Person", "name": "{{primary_author.name}}", "url": "{{@site.url}}" },
	"offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD", "category": "Free" },
	"hasCourseInstance": { "@type": "CourseInstance", "courseMode": "online", "courseWorkload": "PT2H" },
	{{/has}}
	{{#has tag="#product"}}
	"itemReviewed": { "@type": "Product", "name": "{{title}}", "image": "{{img_url feature_image size="600" absolute="true"}}" },
	"reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
	{{/has}}
	"datePublished": "{{date published_at format="YYYY-MM-DDTHH:mm:ssZ"}}",
	"dateModified": "{{date updated_at format="YYYY-MM-DDTHH:mm:ssZ"}}",
	"author": {
		"@type": "Person",
		"name": "{{primary_author.name}}",
		"url": "{{@site.url}}/author/{{primary_author.slug}}/"
	},
	"publisher": {
		"@type": "Organization",
		"name": "{{@site.title}}",
		"url": "{{@site.url}}"
	},
	"mainEntityOfPage": { "@type": "WebPage", "@id": "{{url absolute="true"}}" },
	"url": "{{url absolute="true"}}"
}
</script>
<script type="application/ld+json">
{
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{ "@type": "ListItem", "position": 1, "name": "Home", "item": "{{@site.url}}" },
		{{#has tag="#video"}}{ "@type": "ListItem", "position": 2, "name": "Videos", "item": "{{@site.url}}/videos/" },{{/has}}
		{{#has tag="#project"}}{ "@type": "ListItem", "position": 2, "name": "Projects", "item": "{{@site.url}}/projects/" },{{/has}}
		{{#has tag="#course"}}{ "@type": "ListItem", "position": 2, "name": "Courses", "item": "{{@site.url}}/courses/" },{{/has}}
		{{#has tag="#blog"}}{ "@type": "ListItem", "position": 2, "name": "Blog", "item": "{{@site.url}}/blog/" },{{/has}}
		{ "@type": "ListItem", "position": 3, "name": "{{title}}", "item": "{{url absolute="true"}}" }
	]
}
</script>
{{/post}}
{{/is}}
