{{!-- Travel story — a single day/place inside a trip. Full-bleed photo header
     with the title and a pull-quote overlaid; prev/next walk the itinerary. --}}
<article class="{{post_class}}">
	{{!-- resolve the trip POST's real URL (tag slug ≠ post slug) --}}
	{{#foreach tags visibility="public" limit="1"}}{{#get "posts" filter="tag:hash-trip+tag:{{slug}}" limit="1" as |tt|}}{{#foreach tt}}<span id="container-post" data-url="{{url}}" hidden></span>{{/foreach}}{{/get}}{{/foreach}}
	<header class="relative -mt-16 flex min-h-[56vh] items-end overflow-hidden sm:-mt-[4.25rem]">
		<div class="absolute inset-0" aria-hidden="true">
			{{#if feature_image}}
				<img src="{{img_url feature_image size="2000"}}" alt="{{title}}" class="h-full w-full object-cover" />
			{{else}}
				<div class="bg-dots h-full w-full bg-mist"></div>
			{{/if}}
			<div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/25 to-black/25"></div>
		</div>
		<div class="container-site relative pb-12 pt-40">
			<p class="flex items-center gap-2 font-mono text-[10px] uppercase tracking-[0.3em] text-white/80">
				{{> "icons/map-pin" class="h-3.5 w-3.5"}}
				{{#primary_tag}}<a href="{{@site.url}}/travel/{{slug}}/" data-container-link class="underline underline-offset-4 hover:text-white">{{name}}</a>{{/primary_tag}}
				· {{date published_at format="DD MMM YYYY"}}
			</p>
			<h1 class="mt-3 max-w-3xl text-4xl font-black tracking-tight text-white sm:text-5xl text-balance">{{title}}</h1>
			{{#if custom_excerpt}}<p class="mt-4 max-w-xl text-lg italic leading-relaxed text-white/85">"{{custom_excerpt}}"</p>{{/if}}
		</div>
	</header>

	<div class="container-site py-12">
		<div class="mx-auto max-w-prose">
			{{> "utility/toc" class="mb-8"}}
			<section class="gh-content">
				{{content}}
			</section>

			{{!-- Prev / next stop on the itinerary --}}
			<nav class="mt-12 grid gap-4 border-t border-line pt-6 sm:grid-cols-2" aria-label="Itinerary">
				{{#prev_post in="primary_tag"}}
				<a href="{{url}}" class="card-surface group flex items-center gap-3 p-4 !transform-none">
					<span class="text-silver transition group-hover:text-ink"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="transform:scaleX(-1)" aria-hidden="true"><path d="M17.8 19.2L16 11l3.5-3.5a2.1 2.1 0 0 0-3-3L13 8 4.8 6.2a1 1 0 0 0-1 .3L3 7.3l6.3 3.6-2.6 2.6H4l-1 1 3 1 1 3 1-1v-2.7l2.6-2.6 3.6 6.3.8-.8a1 1 0 0 0 .3-1z"/></svg></span>
					<span class="min-w-0">
						<span class="block font-mono text-[10px] uppercase tracking-[0.2em] text-silver">Previous stop</span>
						<span class="block truncate text-sm font-semibold">{{title}}</span>
					</span>
				</a>
				{{/prev_post}}
				{{#next_post in="primary_tag"}}
				<a href="{{url}}" class="card-surface group flex items-center justify-end gap-3 p-4 text-right !transform-none sm:col-start-2">
					<span class="min-w-0">
						<span class="block font-mono text-[10px] uppercase tracking-[0.2em] text-silver">Next stop</span>
						<span class="block truncate text-sm font-semibold">{{title}}</span>
					</span>
					<span class="text-silver transition group-hover:text-ink"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17.8 19.2L16 11l3.5-3.5a2.1 2.1 0 0 0-3-3L13 8 4.8 6.2a1 1 0 0 0-1 .3L3 7.3l6.3 3.6-2.6 2.6H4l-1 1 3 1 1 3 1-1v-2.7l2.6-2.6 3.6 6.3.8-.8a1 1 0 0 0 .3-1z"/></svg></span>
				</a>
				{{/next_post}}
			</nav>

			{{> "utility/adsense" slot="6501428979" layout="in-article" format="fluid"}}

			<footer class="mt-6 flex items-center justify-between border-t border-line pt-6">
				{{#primary_tag}}<a href="{{@site.url}}/travel/{{slug}}/" data-container-link class="btn-ghost">{{> "icons/arrow-right" class="rotate-180"}} Back to {{name}}</a>{{/primary_tag}}
				{{> "utility/share"}}
			</footer>

			{{#if @site.comments_enabled}}
			<div class="mt-12">{{> "utility/comments" title="Postcards"}}</div>
			{{/if}}
		</div>
	</div>

	<script>
		(function () {
			var cp = document.getElementById('container-post');
			if (!cp) return;
			document.querySelectorAll('[data-container-link]').forEach(function (a) { a.href = cp.getAttribute('data-url'); });
		})();
	</script>

	<script type="application/ld+json">
	{
		"@context": "https://schema.org",
		"@type": "Article",
		"headline": "{{title}}",
		"url": "{{url absolute="true"}}",
		"datePublished": "{{date published_at format="YYYY-MM-DD"}}",
		"description": "{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{excerpt words="40"}}{{/if}}"{{#if feature_image}},
		"image": "{{img_url feature_image size="1600" absolute="true"}}"{{/if}},
		"isPartOf": { "@type": "TouristTrip", "name": "{{primary_tag.name}}", "url": "{{@site.url}}/travel/{{primary_tag.slug}}/" }
	}
	</script>
</article>
