{{!-- Trip overview — the container for travel stories (like a course, but with
     jet lag). Stories are #travel posts whose PUBLIC primary tag equals this
     trip's primary tag; they render as an itinerary. --}}
<article class="{{post_class}}">
	{{!-- Cinematic header --}}
	<header class="tv-scanlines relative -mt-16 flex min-h-[64vh] items-end overflow-hidden sm:-mt-[4.25rem]">
		<div class="absolute inset-0" aria-hidden="true">
			{{#if feature_image}}
				<img src="{{img_url feature_image size="2000"}}" alt="" class="h-full w-full object-cover" />
			{{else}}
				<video src="https://cdn.coverr.co/videos/coverr-aerial-view-of-a-beach-4241/1080p.mp4" autoplay muted loop playsinline preload="metadata" class="h-full w-full object-cover" onerror="this.style.display='none'"></video>
			{{/if}}
			<div class="absolute inset-0 bg-gradient-to-t from-black/85 via-black/25 to-black/20"></div>
		</div>
		<div class="container-site relative pb-12 pt-44">
			<p class="flex items-center gap-2 font-mono text-[10px] uppercase tracking-[0.3em] text-white/80">{{> "icons/map-pin" class="h-3.5 w-3.5"}} Trip · {{date published_at format="MMMM YYYY"}}</p>
			<h1 class="mt-3 max-w-3xl text-4xl font-black tracking-tight text-white sm:text-6xl text-balance">{{title}}</h1>
			{{#if custom_excerpt}}<p class="mt-4 max-w-xl text-lg italic leading-relaxed text-white/85">"{{custom_excerpt}}"</p>{{/if}}
			<div class="mt-6 flex flex-wrap items-center gap-2" id="trip-meta" data-trip-tags="{{#foreach tags visibility="internal"}}{{slug}} {{/foreach}}"></div>
		</div>
	</header>

	<div class="container-site py-12">
		<div class="mx-auto grid max-w-5xl gap-12 lg:grid-cols-12">
			<div class="lg:col-span-7">
				<section class="gh-content">
					{{content}}
				</section>

				{{!-- Itinerary: numbered day-by-day stories --}}
				{{#foreach tags visibility="public" limit="1"}}
				{{#get "posts" filter="tag:hash-travel+tags:{{slug}}" limit="50" order="published_at asc" as |stories|}}
				<div class="mt-12">
					<p class="kicker">{{> "icons/calendar"}} The itinerary</p>
					<h2 class="section-title mt-2">Day by day</h2>
					{{#if stories}}
					<ol class="relative mt-6 space-y-4 border-l-2 border-dashed border-line pl-8">
						{{#foreach stories}}
						<li class="relative">
							<span class="absolute -left-[2.65rem] flex h-9 w-9 items-center justify-center rounded-full border border-line bg-paper font-mono text-[11px] font-bold shadow-card">{{@number}}</span>
							<a href="{{url}}" class="card-surface group flex gap-4 overflow-hidden !transform-none p-0">
								{{#if feature_image}}
								<span class="relative hidden w-32 shrink-0 sm:block">
									<img src="{{img_url feature_image size="300"}}" width="300" height="300" alt="" loading="lazy" class="absolute inset-0 h-full w-full object-cover" />
								</span>
								{{/if}}
								<span class="min-w-0 flex-1 py-4 pr-4 {{#unless feature_image}}pl-4{{/unless}}">
									<span class="block font-mono text-[10px] uppercase tracking-[0.2em] text-silver">Day {{@number}} · {{date published_at format="DD MMM"}}</span>
									<span class="mt-1 block text-[15px] font-semibold leading-snug group-hover:underline group-hover:underline-offset-4">{{title}}</span>
									{{#if custom_excerpt}}<span class="mt-1 line-clamp-2 block text-[13px] leading-relaxed text-silver">{{custom_excerpt}}</span>{{/if}}
								</span>
								{{> "icons/arrow-right" class="my-auto mr-4 shrink-0 text-silver transition group-hover:translate-x-0.5 group-hover:text-ink"}}
							</a>
						</li>
						{{/foreach}}
					</ol>
					{{else}}
					<p class="mt-6 rounded-2xl border border-dashed border-line p-8 text-center text-sm text-silver">Stories landing soon — tag them <code class="rounded bg-mist px-1 font-mono text-xs">#travel</code> with public tag <code class="rounded bg-mist px-1 font-mono text-xs">{{slug}}</code> first.</p>
					{{/if}}
				</div>
				{{/get}}
				{{/foreach}}

				{{> "utility/adsense" slot="6501428979" layout="in-article" format="fluid"}}
			</div>

			<aside class="lg:col-span-5">
				<div class="rail-sticky">
					{{!-- Travel kit for this trip --}}
					{{#get "posts" filter="tag:hash-product+tag:hash-group-travel" limit="3" include="tags" as |kit|}}
						{{#if kit}}
						<div class="card-surface p-6 !transform-none">
							<p class="kicker">{{> "icons/zap"}} Packed for this trip</p>
							<ul class="mt-4 space-y-2">
								{{#foreach kit}}
								<li><a href="{{url}}" class="group flex items-center gap-3 rounded-xl border border-line p-2.5 transition hover:bg-mist">
									<span class="h-10 w-10 shrink-0 overflow-hidden rounded-lg border border-line bg-mist">{{#if feature_image}}<img src="{{img_url feature_image size="100"}}" width="100" height="100" alt="" loading="lazy" class="h-full w-full object-cover" />{{/if}}</span>
									<span class="min-w-0 truncate text-[13px] font-semibold">{{title}}</span>
									{{> "icons/arrow-up-right" class="ml-auto h-3.5 w-3.5 shrink-0 text-silver"}}
								</a></li>
								{{/foreach}}
							</ul>
						</div>
						{{/if}}
					{{/get}}
					{{> "utility/adsense" slot="3487917390" format="auto" class="!my-0"}}
				</div>
			</aside>
		</div>
	</div>

	{{#if @site.comments_enabled}}
	<section class="container-site pb-16">
		<div class="mx-auto max-w-3xl">{{> "utility/comments" title="Postcards"}}</div>
	</section>
	{{/if}}

	{{!-- TouristTrip JSON-LD --}}
	<script type="application/ld+json">
	{
		"@context": "https://schema.org",
		"@type": "TouristTrip",
		"name": "{{title}}",
		"url": "{{url absolute="true"}}",
		"description": "{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{excerpt words="40"}}{{/if}}"{{#if feature_image}},
		"image": "{{img_url feature_image size="1600" absolute="true"}}"{{/if}}
	}
	</script>

	<script>
		/* Country + category chips from internal tags */
		(function () {
			var el = document.getElementById('trip-meta');
			if (!el) return;
			var PIN = '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display:inline-block;vertical-align:-1px;margin-right:4px" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/></svg>';
			(el.getAttribute('data-trip-tags') || '').split(/\s+/).forEach(function (t) {
				var label = null, pin = false;
				if (t.indexOf('hash-country-') === 0) { label = t.replace('hash-country-', '').replace(/-/g, ' '); pin = true; }
				else if (t.indexOf('hash-travel-category-') === 0) label = t.replace('hash-travel-category-', '').replace(/-/g, ' ');
				if (!label) return;
				var chip = document.createElement('span');
				chip.className = 'rounded-full bg-white/15 px-3 py-1 font-mono text-[10px] uppercase tracking-[0.15em] text-white backdrop-blur';
				chip.innerHTML = (pin ? PIN : '') + label;
				el.appendChild(chip);
			});
		})();
	</script>
</article>
