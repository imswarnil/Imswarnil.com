{{!-- Post grid + pagination. Renders the current context's `posts`. --}}
<section class="mx-auto max-w-5xl px-4 py-10">
	{{#if posts}}
		<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
			{{#foreach posts}}
				{{> card}}
			{{/foreach}}
		</div>
		{{> pagination}}
	{{else}}
		<p class="text-sm text-zinc-500">Nothing published here yet.</p>
	{{/if}}
</section>
