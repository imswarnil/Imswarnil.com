<article class="card-surface group flex items-start gap-4 p-4 {{class}}">
	<a href="{{url}}" class="flex w-full items-start gap-4" aria-label="{{title}}">
		<div class="h-16 w-16 shrink-0 overflow-hidden rounded-xl border border-line bg-mist">
			{{#if feature_image}}
				<img src="{{img_url feature_image size="300"}}" alt="{{title}}" loading="lazy" class="h-full w-full object-cover" />
			{{else}}
				<div class="bg-dots flex h-full w-full items-center justify-center">{{> "icons/zap" class="text-silver"}}</div>
			{{/if}}
		</div>
		<div class="min-w-0 flex-1">
			<div class="flex items-center justify-between gap-2">
				<h3 class="truncate text-[15px] font-semibold tracking-tight">{{title}}</h3>
				{{> "icons/arrow-up-right" class="shrink-0 text-silver transition group-hover:text-ink"}}
			</div>
			<p class="mt-1 line-clamp-2 text-[13px] leading-relaxed text-silver">{{custom_excerpt}}{{^custom_excerpt}}{{excerpt words="16"}}{{/custom_excerpt}}</p>
			{{#primary_tag}}<span class="chip mt-2.5">{{name}}</span>{{/primary_tag}}
		</div>
	</a>
</article>
