<article class="card-surface group relative flex flex-col overflow-hidden {{class}}">
	<a href="{{url}}" class="flex h-full flex-col" aria-label="Start course: {{title}}">
		<div class="relative aspect-[16/9] overflow-hidden">
			{{#if feature_image}}
				<img src="{{img_url feature_image size="600"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" loading="lazy" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.04]" />
			{{else}}
				<div class="bg-cross flex h-full w-full items-center justify-center bg-mist">{{> "icons/book" class="text-silver"}}</div>
			{{/if}}
			<span class="chip absolute left-3 top-3 !border-transparent !bg-paper/90 backdrop-blur">{{> "icons/book"}} Course</span>
		</div>
		<div class="flex flex-1 flex-col p-5">
			<h3 class="text-lg font-semibold leading-snug tracking-tight">{{title}}</h3>
			<p class="mt-2 line-clamp-2 text-sm leading-relaxed text-silver">{{custom_excerpt}}{{^custom_excerpt}}{{excerpt words="22"}}{{/custom_excerpt}}</p>
			<div class="mt-auto flex items-center justify-between pt-5">
				<span class="chip !bg-ink !text-paper !border-transparent">Free</span>
				<span class="flex items-center gap-1.5 text-sm font-medium transition group-hover:gap-2.5">Start learning {{> "icons/arrow-right"}}</span>
			</div>
		</div>
	</a>
</article>
