{{!-- Shop card — cover, title, Free/Premium badge --}}
<article class="card-surface group overflow-hidden {{class}}">
	<a href="{{url}}" class="flex h-full flex-col" aria-label="{{title}}">
		<div class="relative aspect-[4/3] overflow-hidden border-b border-line bg-mist">
			{{#if feature_image}}
				<img src="{{img_url feature_image size="600"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" loading="lazy" class="h-full w-full object-cover transition duration-500 group-hover:scale-105" />
			{{else}}
				<div class="bg-cross flex h-full w-full items-center justify-center">{{> "icons/download" class="text-silver"}}</div>
			{{/if}}
			<span class="absolute right-3 top-3">
				{{#match visibility "public"}}
					<span class="chip border-line bg-paper shadow-card">Free</span>
				{{else}}
					<span class="chip border-line bg-ink text-paper shadow-card">{{> "icons/star" class="h-3 w-3"}} Premium</span>
				{{/match}}
			</span>
		</div>
		<div class="flex flex-1 flex-col p-5">
			<div class="flex items-start justify-between gap-2">
				<h3 class="text-[15px] font-semibold tracking-tight">{{title}}</h3>
				{{> "icons/arrow-up-right" class="mt-0.5 shrink-0 text-silver transition group-hover:text-ink"}}
			</div>
			<p class="mt-2 line-clamp-2 text-[13px] leading-relaxed text-silver">{{custom_excerpt}}{{^custom_excerpt}}{{excerpt words="18"}}{{/custom_excerpt}}</p>
			{{#primary_tag}}<div class="mt-auto pt-4"><span class="chip">{{name}}</span></div>{{/primary_tag}}
		</div>
	</a>
</article>
