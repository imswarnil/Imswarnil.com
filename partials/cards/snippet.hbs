{{!-- Snippet card — editor-chrome tile linking to the full snippet. --}}
<article class="snippet-card group {{class}}">
	<div class="snippet-bar">
		<span class="dot" style="background:#ff5f57"></span>
		<span class="dot" style="background:#febc2e"></span>
		<span class="dot" style="background:#28c840"></span>
		<span class="ml-1.5 min-w-0 truncate">{{slug}}</span>
		{{#primary_tag}}<span class="ml-auto shrink-0 rounded bg-white/5 px-1.5 py-0.5 text-[10px]">{{name}}</span>{{/primary_tag}}
	</div>
	<a href="{{url}}" class="block p-4">
		<h3 class="text-[13px] font-semibold text-[#e8e8e8] transition group-hover:text-white">{{title}}</h3>
		<p class="mt-1 line-clamp-2 text-[12px] leading-relaxed text-[#8b949e]">{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{excerpt words="18"}}{{/if}}</p>
		<span class="mt-3 inline-flex items-center gap-1 font-mono text-[11px] text-[#9da5b4] transition group-hover:text-white">{{> "icons/code" class="h-3.5 w-3.5"}} View snippet →</span>
	</a>
</article>
