<article class="card-surface group relative overflow-hidden {{class}}">
	<a href="{{url}}" class="block" aria-label="View project: {{title}}">
		<div class="bg-grid relative aspect-[4/3] overflow-hidden border-b border-line">
			{{#if feature_image}}
				<img src="{{img_url feature_image size="600"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" loading="lazy"
					class="absolute inset-x-6 top-6 h-full w-[calc(100%-3rem)] rounded-t-xl border border-line object-cover object-top shadow-lift transition-transform duration-500 group-hover:-translate-y-2" />
			{{else}}
				<div class="flex h-full items-center justify-center">{{> "icons/terminal" class="text-silver"}}</div>
			{{/if}}
		</div>
		<div class="p-5">
			<div class="flex items-center justify-between">
				<h3 class="text-lg font-semibold tracking-tight">{{title}}</h3>
				<span class="icon-btn !h-8 !w-8 border border-line transition group-hover:bg-ink group-hover:text-paper">{{> "icons/arrow-up-right"}}</span>
			</div>
			<p class="mt-2 line-clamp-2 text-sm leading-relaxed text-silver">{{custom_excerpt}}{{^custom_excerpt}}{{excerpt words="20"}}{{/custom_excerpt}}</p>
			<div class="mt-4 flex flex-wrap gap-1.5">
				{{#foreach tags visibility="public" limit="3"}}<span class="chip">{{name}}</span>{{/foreach}}
			</div>
		</div>
	</a>
</article>
