{{!-- Video card — YouTube-style thumbnail with duration badge.
     Hover: subtle zoom + play button. Whole card links to the video page.
     Duration badge fills in from internal #duration-* tags via site JS. --}}
<article class="video-card group relative shrink-0 {{class}}">
	<a href="{{url}}" class="block" aria-label="Watch: {{title}}">
		<div class="relative aspect-video overflow-hidden rounded-xl border border-line bg-mist shadow-card transition-all duration-300 group-hover:shadow-lift">
			{{#if feature_image}}
				<img src="{{img_url feature_image size="600"}}"
					srcset="{{img_url feature_image size="300"}} 300w, {{img_url feature_image size="600"}} 600w, {{img_url feature_image size="1000"}} 1000w"
					sizes="(max-width: 640px) 90vw, 360px"
					alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
					loading="lazy" width="600" height="338" decoding="async" data-skeleton
					class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
				<div class="skeleton absolute inset-0"></div>
			{{else}}
				{{!-- No feature image → main.js pulls this post's first YouTube id from
				     the template, paints its thumbnail and hover-previews the reel. --}}
				<div class="video-fallback" data-video-card-media>
					<template data-video-src>{{content}}</template>
					<div class="bg-dots absolute inset-0 flex items-center justify-center" data-ph>{{> "icons/film" class="text-silver"}}</div>
				</div>
			{{/if}}
			<div class="absolute inset-0 bg-gradient-to-t from-black/45 via-transparent to-transparent" aria-hidden="true"></div>
			<span class="absolute inset-0 flex items-center justify-center" aria-hidden="true">
				<span class="flex h-11 w-11 items-center justify-center rounded-full bg-white/90 text-black shadow-lg transition-transform duration-300 group-hover:scale-110">{{> "icons/play" class="ml-0.5 h-4 w-4"}}</span>
			</span>
			<span class="absolute bottom-2 right-2 rounded-md bg-black/80 px-1.5 py-0.5 font-mono text-[11px] font-semibold text-white" data-duration-tags="{{#foreach tags visibility="internal"}}{{slug}} {{/foreach}}" hidden></span>
			{{#if featured}}<span class="chip absolute left-2 top-2 !border-transparent !bg-white/90 !text-black backdrop-blur">{{> "icons/zap" class="h-3 w-3"}} Featured</span>{{/if}}
		</div>
		<div class="mt-3 px-0.5">
			<h3 class="line-clamp-2 text-[15px] font-semibold leading-snug tracking-tight transition group-hover:text-silver">{{title}}</h3>
			<p class="mt-1.5 flex flex-wrap items-center gap-x-2 gap-y-1 font-mono text-[11px] text-silver">
				<span class="flex items-center gap-1.5">{{> "icons/calendar" class="h-3 w-3"}} {{date published_at format="DD MMM YYYY"}}</span>
				{{#primary_tag}}<span class="opacity-40">·</span> {{name}}{{/primary_tag}}
			</p>
		</div>
	</a>
</article>
