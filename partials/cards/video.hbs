{{!-- Netflix-style video card. Hover = zoom + play glow. --}}
<article class="video-card group relative shrink-0 {{class}}">
	<a href="{{url}}" class="block" aria-label="Watch: {{title}}">
		<div class="relative aspect-video overflow-hidden rounded-xl border border-line bg-mist shadow-card transition-all duration-300 group-hover:shadow-lift">
			{{#if feature_image}}
				<img src="{{img_url feature_image size="600"}}"
					srcset="{{img_url feature_image size="300"}} 300w, {{img_url feature_image size="600"}} 600w, {{img_url feature_image size="1000"}} 1000w"
					sizes="(max-width: 640px) 80vw, 360px"
					alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
					loading="lazy"
					class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
			{{else}}
				<div class="bg-dots flex h-full w-full items-center justify-center">{{> "icons/film" class="text-silver"}}</div>
			{{/if}}
			<div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
			<span class="absolute bottom-3 left-3 flex translate-y-2 items-center gap-2 text-xs font-semibold text-white opacity-0 transition-all duration-300 group-hover:translate-y-0 group-hover:opacity-100">
				<span class="flex h-9 w-9 items-center justify-center rounded-full bg-white text-black shadow-lg">{{> "icons/play" class="ml-0.5"}}</span>
				Watch now
			</span>
			{{#if featured}}<span class="absolute right-3 top-3 chip !bg-white/90 !text-black !border-transparent backdrop-blur">{{> "icons/zap"}} Featured</span>{{/if}}
		</div>
		<div class="mt-3 flex items-start justify-between gap-3 px-0.5">
			<div>
				<h3 class="line-clamp-2 text-[15px] font-semibold leading-snug tracking-tight transition group-hover:text-silver">{{title}}</h3>
				<p class="mt-1.5 flex items-center gap-2 font-mono text-[11px] text-silver">
					{{> "icons/calendar"}} {{date published_at format="DD MMM YYYY"}}
					<span class="opacity-40">·</span>
					{{> "icons/clock"}} {{reading_time minute="1 min"}}
				</p>
			</div>
		</div>
	</a>
</article>
