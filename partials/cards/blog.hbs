<article class="card-surface group relative flex flex-col overflow-hidden {{class}}">
	<a href="{{url}}" class="flex h-full flex-col" aria-label="Read: {{title}}">
		{{#if feature_image}}
		<div class="relative aspect-[16/9] overflow-hidden">
			<img src="{{img_url feature_image size="600"}}"
				srcset="{{img_url feature_image size="300"}} 300w, {{img_url feature_image size="600"}} 600w, {{img_url feature_image size="1000"}} 1000w"
				sizes="(max-width: 640px) 100vw, 400px"
				alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
				loading="lazy"
				class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.04]" />
			<div class="absolute inset-0 bg-gradient-to-t from-black/10 to-transparent" aria-hidden="true"></div>
			{{#if featured}}<span class="chip absolute left-3 top-3 !border-transparent !bg-paper/90 backdrop-blur">{{> "icons/zap"}} Featured</span>{{/if}}
		</div>
		{{/if}}
		<div class="flex flex-1 flex-col p-5">
			<div class="flex items-center gap-2">
				{{#primary_tag}}<span class="kicker !text-accent">{{name}}</span>{{/primary_tag}}
			</div>
			<h3 class="mt-2 text-lg font-semibold leading-snug tracking-tight transition group-hover:text-silver">{{title}}</h3>
			<p class="mt-2 line-clamp-2 text-sm leading-relaxed text-silver">{{custom_excerpt}}{{^custom_excerpt}}{{excerpt words="24"}}{{/custom_excerpt}}</p>
			<div class="mt-auto flex items-center justify-between pt-4">
				<span class="flex items-center gap-2">
					{{#primary_author}}
						{{#if profile_image}}<img src="{{img_url profile_image size="100"}}" alt="{{name}}" class="h-6 w-6 rounded-full object-cover" loading="lazy" />{{/if}}
						<span class="text-xs font-medium text-silver">{{name}}</span>
					{{/primary_author}}
				</span>
				<span class="flex items-center gap-3 font-mono text-[11px] text-silver">
					<span>{{date published_at format="DD MMM"}}</span>
					<span class="flex items-center gap-1">{{> "icons/clock"}} {{reading_time minute="1 min"}}</span>
				</span>
			</div>
		</div>
	</a>
</article>
