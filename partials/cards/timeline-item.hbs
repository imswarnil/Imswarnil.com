<li class="relative pl-10 sm:pl-14 {{class}}">
	<span class="absolute left-0 top-1.5 flex h-7 w-7 items-center justify-center rounded-full border border-line bg-paper shadow-card sm:left-2">
		<span class="h-2 w-2 rounded-full bg-ink"></span>
	</span>
	<p class="font-mono text-xs uppercase tracking-widest text-silver">{{date published_at format="MMMM YYYY"}}</p>
	<a href="{{url}}" class="group mt-2 block rounded-2xl border border-line bg-paper p-5 shadow-card transition hover:-translate-y-0.5 hover:shadow-lift">
		<div class="flex items-start justify-between gap-4">
			<div>
				<h3 class="text-lg font-semibold tracking-tight">{{title}}</h3>
				<p class="mt-1.5 text-sm leading-relaxed text-silver">{{custom_excerpt}}{{^custom_excerpt}}{{excerpt words="28"}}{{/custom_excerpt}}</p>
			</div>
			{{#if feature_image}}
				<img src="{{img_url feature_image size="300"}}" alt="{{title}}" loading="lazy" class="hidden h-16 w-16 shrink-0 rounded-xl border border-line object-cover sm:block" />
			{{/if}}
		</div>
		{{#primary_tag}}<span class="chip mt-3">{{name}}</span>{{/primary_tag}}
	</a>
</li>
