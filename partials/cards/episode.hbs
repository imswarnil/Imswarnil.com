{{!-- Netflix-style episode row card.
     Optional param: num=@number → renders the big outlined rank number beside the thumb.
     Per-episode duration is filled in by main.js from the internal #duration-XhYm tag. --}}
<article class="group relative shrink-0 {{class}}">
	<a href="{{url}}" class="flex items-center gap-3 rounded-2xl border border-line bg-paper p-3 transition hover:bg-mist sm:gap-4" aria-label="Play episode: {{title}}">
		{{#if num}}
			<span class="rank-number relative -mr-6 hidden w-16 shrink-0 text-right sm:block sm:-mr-8 sm:w-24" style="font-size:clamp(3.5rem,6vw,6rem)" aria-hidden="true">{{num}}</span>
		{{/if}}
		<div class="relative z-10 aspect-video w-36 shrink-0 overflow-hidden rounded-xl border border-line bg-mist sm:w-48">
			{{#if feature_image}}
				<img src="{{img_url feature_image size="300"}}" alt="{{title}}" loading="lazy" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
			{{else}}
				<span class="bg-cross flex h-full w-full items-center justify-center text-silver">{{> "icons/film"}}</span>
			{{/if}}
			<span class="absolute inset-0 flex items-center justify-center bg-black/0 transition group-hover:bg-black/30">
				<span class="flex h-8 w-8 scale-75 items-center justify-center rounded-full bg-white text-black opacity-0 shadow-lg transition group-hover:scale-100 group-hover:opacity-100">{{> "icons/play" class="ml-0.5"}}</span>
			</span>
		</div>
		<div class="relative z-10 min-w-0">
			{{#if num}}<p class="kicker !text-[10px]">Episode {{num}}</p>{{else}}{{#primary_tag}}<p class="kicker !text-[10px]">{{name}}</p>{{/primary_tag}}{{/if}}
			<h3 class="mt-1 line-clamp-2 text-[15px] font-semibold leading-snug tracking-tight">{{title}}</h3>
			<p class="mt-1.5 flex flex-wrap items-center gap-x-2 font-mono text-[11px] text-silver">
				<span data-duration-tags="{{#foreach tags visibility="internal"}}{{slug}} {{/foreach}}" hidden></span>
				<span>{{date published_at format="DD MMM YYYY"}}</span>
			</p>
			{{#if num}}<p class="mt-1.5 hidden text-xs leading-relaxed text-silver md:line-clamp-2">{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{excerpt words="24"}}{{/if}}</p>{{/if}}
		</div>
	</a>
</article>
