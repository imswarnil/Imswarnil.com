<article class="group relative shrink-0 {{class}}">
	<a href="{{url}}" class="flex items-center gap-4 rounded-2xl border border-line bg-paper p-3 transition hover:bg-mist" aria-label="Play episode: {{title}}">
		<div class="relative aspect-video w-40 shrink-0 overflow-hidden rounded-xl border border-line bg-mist sm:w-48">
			{{#if feature_image}}
				<img src="{{img_url feature_image size="300"}}" alt="{{title}}" loading="lazy" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
			{{/if}}
			<span class="absolute inset-0 flex items-center justify-center bg-black/0 transition group-hover:bg-black/30">
				<span class="flex h-8 w-8 scale-75 items-center justify-center rounded-full bg-white text-black opacity-0 shadow-lg transition group-hover:scale-100 group-hover:opacity-100">{{> "icons/play" class="ml-0.5"}}</span>
			</span>
		</div>
		<div class="min-w-0">
			{{#primary_tag}}<p class="kicker !text-[10px]">{{name}}</p>{{/primary_tag}}
			<h3 class="mt-1 line-clamp-2 text-[15px] font-semibold leading-snug tracking-tight">{{title}}</h3>
			<p class="mt-1.5 font-mono text-[11px] text-silver">{{date published_at format="DD MMM YYYY"}} · {{reading_time minute="1 min"}}</p>
		</div>
	</a>
</article>
