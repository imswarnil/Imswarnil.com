{{!-- Experience detail — a "moment" story: image, when, the story. --}}
<article class="{{post_class}}">
	<header class="relative overflow-hidden border-b border-line py-12">
		<div class="bg-dots pointer-events-none absolute inset-0 fade-mask-b" aria-hidden="true"></div>
		<div class="container-site relative text-center">
			<nav class="flex items-center justify-center gap-2 font-mono text-[11px] uppercase tracking-[0.15em] text-silver" aria-label="Breadcrumb">
				<a href="{{@site.url}}/experiences/" class="transition hover:text-ink">Experiences</a>
			</nav>
			<p class="mt-4 flex items-center justify-center gap-2 font-mono text-xs text-silver">{{> "icons/calendar" class="h-3.5 w-3.5"}} {{date published_at format="DD MMMM YYYY"}}</p>
			<h1 class="mx-auto mt-3 max-w-3xl text-3xl font-semibold tracking-tight sm:text-5xl text-balance">{{title}}</h1>
			{{#if custom_excerpt}}<p class="mx-auto mt-4 max-w-xl text-lg leading-relaxed text-silver">{{custom_excerpt}}</p>{{/if}}
		</div>
	</header>

	{{#if feature_image}}
	<div class="container-site pt-10">
		<img src="{{img_url feature_image size="1600"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" width="1600" height="900" class="mx-auto w-full max-w-4xl rounded-3xl border border-line shadow-lift" />
	</div>
	{{/if}}

	<div class="container-site py-10">
		<div class="mx-auto max-w-2xl">
			<section class="gh-content">{{content}}</section>

			<footer class="mt-10 flex flex-wrap items-center justify-between gap-3 border-t border-line pt-6">
				<a href="{{@site.url}}/experiences/" class="btn-ghost btn-sm">{{> "icons/arrow-right" class="h-3.5 w-3.5 rotate-180"}} All moments</a>
				{{> "utility/share"}}
			</footer>

			{{#if @site.comments_enabled}}<section class="mt-12 border-t border-line pt-10">{{> "utility/comments" title="Were you there?"}}</section>{{/if}}
		</div>

		{{#get "posts" filter="tag:hash-experience+id:-{{id}}" limit="3" include="tags" as |more|}}
			{{#if more}}
			<section class="mx-auto mt-16 max-w-6xl border-t border-line pt-12">
				<p class="kicker mb-6">{{> "icons/star" class="h-3.5 w-3.5"}} More moments</p>
				<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">{{#foreach more}}{{> "experience/card"}}{{/foreach}}</div>
			</section>
			{{/if}}
		{{/get}}
	</div>
</article>
