{{!-- Timeline entry — a minimal calendar card: full-width image, a tear-off
     calendar leaf, title + one-line note. No clock. Rendered inside
     {{#foreach posts}} — @odd alternates sides across the spine on lg+.
     Deep-linkable via id="tl-{slug}". The image parallaxes on scroll
     (data-tl-parallax, wired in timeline.hbs). --}}
<li id="tl-{{slug}}" data-year="{{date published_at format="YYYY"}}" class="tl-item reveal relative pl-12 sm:pl-16 lg:grid lg:grid-cols-[minmax(0,1fr)_5.5rem_minmax(0,1fr)] lg:items-start lg:pl-0 {{class}}">
	{{!-- Node on the spine: icon from the entry's internal event tag --}}
	<span class="tl-dot absolute left-[1.4rem] top-7 z-10 flex h-9 w-9 -translate-x-1/2 items-center justify-center rounded-full border border-line bg-paper shadow-card transition-all duration-300 lg:static lg:col-start-2 lg:row-start-1 lg:mt-7 lg:translate-x-0 lg:justify-self-center">
		<span class="tl-dot-icon text-silver transition-colors duration-300">
			{{#has tag="#event-company-change"}}{{> "icons/briefcase" class="h-4 w-4"}}
			{{else has tag="#event-milestone"}}{{> "icons/trophy" class="h-4 w-4"}}
			{{else has tag="#event-relocation"}}{{> "icons/map-pin" class="h-4 w-4"}}
			{{else has tag="#event-education"}}{{> "icons/graduation" class="h-4 w-4"}}
			{{else has tag="#event-award"}}{{> "icons/medal" class="h-4 w-4"}}
			{{else}}{{> "icons/star" class="h-4 w-4"}}{{/has}}
		</span>
	</span>

	{{!-- Card — column 1 (left) for even entries, column 3 (right) for odd --}}
	<div class="lg:row-start-1 {{#if @odd}}lg:col-start-3{{else}}lg:col-start-1{{/if}}">
		<a href="{{url}}" class="tl-card group block overflow-hidden rounded-2xl border border-line bg-paper shadow-card transition hover:-translate-y-1 hover:shadow-lift">
			{{#if feature_image}}
				<div class="tl-media relative aspect-[16/9] overflow-hidden bg-mist">
					<img src="{{img_url feature_image size="800"}}" alt="{{title}}" loading="lazy" class="tl-media-img absolute inset-x-0 -top-[10%] h-[120%] w-full object-cover" data-tl-parallax />
				</div>
			{{/if}}
			<div class="flex items-start gap-3 p-4">
				{{!-- tear-off calendar leaf --}}
				<span class="tl-cal shrink-0 overflow-hidden rounded-lg border border-line bg-paper text-center leading-none shadow-card" aria-hidden="true">
					<span class="block bg-accent px-2.5 py-1 font-mono text-[8px] font-bold uppercase tracking-[0.18em] text-on-accent">{{date published_at format="MMM"}}</span>
					<span class="block px-2.5 pt-1.5 text-xl font-black tracking-tight">{{date published_at format="DD"}}</span>
					<span class="block px-2.5 pb-1 font-mono text-[8px] text-silver">{{date published_at format="YYYY"}}</span>
				</span>
				<div class="min-w-0">
					<time class="font-mono text-[10px] uppercase tracking-[0.15em] text-silver" datetime="{{date published_at format="YYYY-MM-DD"}}">{{date published_at format="ddd · DD MMM YYYY"}}</time>
					<h3 class="mt-1 line-clamp-2 text-base font-semibold leading-snug tracking-tight sm:text-lg">{{title}}</h3>
					<p class="mt-1 line-clamp-2 text-[13px] leading-relaxed text-silver">{{custom_excerpt}}{{^custom_excerpt}}{{excerpt words="22"}}{{/custom_excerpt}}</p>
					<div class="mt-2.5 flex flex-wrap items-center gap-2">
						{{#primary_tag}}<span class="chip !py-0.5 !text-[10px]">{{name}}</span>{{/primary_tag}}
						<span class="ml-auto inline-flex items-center gap-1 text-[11px] font-medium text-silver transition group-hover:text-ink">Read {{> "icons/arrow-right" class="h-3 w-3"}}</span>
					</div>
				</div>
			</div>
		</a>
	</div>
</li>
