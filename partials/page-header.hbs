{{!-- Collection/archive header. Params: title, description --}}
<header class="border-b border-zinc-200 dark:border-zinc-800">
	<div class="mx-auto max-w-5xl px-4 py-10">
		<h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">{{title}}</h1>
		{{#if description}}
			<p class="mt-3 max-w-2xl text-base leading-relaxed text-zinc-600 dark:text-zinc-400">{{description}}</p>
		{{/if}}
	</div>
</header>
