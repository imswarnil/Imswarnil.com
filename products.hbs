{{!< default}}

{{!-- /products — "Things I use" with a fixed filter rail. All products render once;
     the rail filters client-side by the internal #group-* tag baked into data-groups.
     New groups: add a button here — cards pick up their group chip automatically. --}}

{{> "utility/collection-header" kicker="The toolkit" title="Things I use" desc="Hardware, software and services I actually pay for — reviewed honestly, filtered neatly."}}

<section class="container-site py-12">
	<div class="grid gap-10 lg:grid-cols-[14rem_minmax(0,1fr)]">

		{{!-- Fixed filter rail --}}
		<aside class="rail-sticky">
			<p class="kicker mb-3">{{> "icons/zap"}} Filter by shelf</p>
			<nav class="no-scrollbar flex gap-1 overflow-x-auto pb-2 lg:flex-col lg:overflow-visible lg:pb-0" id="product-filters" aria-label="Product groups">
				<button type="button" class="filter-link is-active shrink-0" data-filter="all">{{> "icons/sparkle" class="h-3.5 w-3.5"}} Everything</button>
				<button type="button" class="filter-link shrink-0" data-filter="hash-group-services">{{> "icons/zap" class="h-3.5 w-3.5"}} Services</button>
				<button type="button" class="filter-link shrink-0" data-filter="hash-group-my-setup">{{> "icons/terminal" class="h-3.5 w-3.5"}} My setup</button>
				<button type="button" class="filter-link shrink-0" data-filter="hash-group-skin-care">{{> "icons/heart" class="h-3.5 w-3.5"}} Skin care</button>
				<button type="button" class="filter-link shrink-0" data-filter="hash-group-travel">{{> "icons/map-pin" class="h-3.5 w-3.5"}} Travel kit</button>
				<button type="button" class="filter-link shrink-0" data-filter="other">{{> "icons/check" class="h-3.5 w-3.5"}} Everything else</button>
			</nav>
			<p class="mt-4 hidden font-mono text-[10px] uppercase tracking-[0.2em] text-silver lg:block" id="product-count"></p>
			<div class="mt-6 hidden lg:block">{{> "utility/adsense" slot="3487917390" format="auto" class="!my-0"}}</div>
		</aside>

		{{!-- Product wall — compact cards --}}
		<div>
			{{#get "posts" filter="tag:hash-product" limit="100" include="tags" as |items|}}
				{{#if items}}
				<div class="grid grid-cols-2 gap-4 xl:grid-cols-3" id="product-grid" data-reveal-stagger="50">
					{{#foreach items}}
					<div class="product-item" data-groups="{{#foreach tags visibility="internal"}}{{slug}} {{/foreach}}">
						{{> "product/card" class="product-mini"}}
					</div>
					{{/foreach}}
				</div>
				<p class="hidden rounded-2xl border border-dashed border-line p-10 text-center text-sm text-silver" id="product-empty">Nothing on this shelf yet. It's minimalism, not laziness.</p>
				{{else}}
				<p class="rounded-2xl border border-dashed border-line p-10 text-center text-sm text-silver">Tag posts with <code class="rounded bg-mist px-1.5 py-0.5 font-mono text-xs">#product</code> to stock the shelves.</p>
				{{/if}}
			{{/get}}
			{{> "utility/adsense" slot="6808134701" format="autorelaxed"}}
		</div>
	</div>
</section>

<style>
	/* Compact product cards on this page */
	.product-mini .p-5 { padding: 0.9rem; }
	.product-mini h3 { font-size: 13px; }
	.product-mini p { font-size: 12px; }
	.product-mini .aspect-\[4\/3\] { aspect-ratio: 16/10; padding-left: 1.25rem; padding-right: 1.25rem; padding-top: 0.9rem; }
</style>

<script>
	(function () {
		var KNOWN = ['hash-group-services', 'hash-group-my-setup', 'hash-group-skin-care', 'hash-group-travel'];
		var items = [].slice.call(document.querySelectorAll('.product-item'));
		var buttons = [].slice.call(document.querySelectorAll('#product-filters .filter-link'));
		var count = document.getElementById('product-count');
		var empty = document.getElementById('product-empty');
		function apply(filter) {
			var shown = 0;
			items.forEach(function (it) {
				var groups = it.getAttribute('data-groups') || '';
				var show =
					filter === 'all' ? true :
					filter === 'other' ? !KNOWN.some(function (g) { return groups.indexOf(g) > -1; }) :
					groups.indexOf(filter) > -1;
				it.style.display = show ? '' : 'none';
				if (show) shown++;
			});
			if (count) count.textContent = shown + ' item' + (shown === 1 ? '' : 's') + ' on the shelf';
			if (empty) empty.classList.toggle('hidden', shown > 0);
			buttons.forEach(function (b) { b.classList.toggle('is-active', b.getAttribute('data-filter') === filter); });
		}
		buttons.forEach(function (b) {
			b.addEventListener('click', function () { apply(b.getAttribute('data-filter')); });
		});
		apply('all');
	})();
</script>
