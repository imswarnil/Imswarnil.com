{{!< default}}

<section class="relative flex min-h-[60vh] items-center overflow-hidden py-20">
	<div class="bg-cross pointer-events-none absolute inset-0" aria-hidden="true"></div>
	<div class="container-site relative text-center">
		<p class="kicker justify-center">Offline</p>
		<h1 class="mt-4 text-3xl font-semibold tracking-tight sm:text-4xl">No signal — literally.</h1>
		<p class="mx-auto mt-4 max-w-md text-silver">You're offline right now. Previously visited pages are still readable; everything else will load when you're back.</p>
		<button type="button" class="btn-primary mt-8" onclick="location.reload()">Try again</button>
	</div>
</section>
