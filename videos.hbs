{{!< default}}

{{!-- /videos — channel hub: subscribe CTA, topic suggestions, upload schedule,
     featured latest video, paginated grid with an in-feed ad. --}}

{{!-- Cinematic hero: full-bleed muted video, black overlay + TV scanlines,
     hero details sit on top. Glass navbar floats above (html.nav-glass). --}}
<header class="tv-scanlines relative -mt-16 flex min-h-[72vh] items-end overflow-hidden sm:-mt-[4.25rem]">
	{{!-- Poster paints instantly; main.js mounts the muted reel after load (LCP-safe) --}}
	<div class="video-hero-media" data-yt-bg="ecOkmTD7KhU" aria-hidden="true">
		<img class="video-hero-poster" src="https://i.ytimg.com/vi/ecOkmTD7KhU/maxresdefault.jpg" alt="" width="1280" height="720" fetchpriority="high" decoding="async"
			onerror="this.onerror=null;this.src='https://i.ytimg.com/vi/ecOkmTD7KhU/hqdefault.jpg'" />
		<div class="video-hero-scrim bg-black/65"></div>
	</div>

	<div class="container-site relative pb-14 pt-40">
		<div class="grid items-end gap-10 lg:grid-cols-12">
			<div class="text-white lg:col-span-7">
				<p class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-1.5 font-mono text-[11px] uppercase tracking-[0.25em] backdrop-blur animate-fade-in">{{> "icons/film" class="h-3.5 w-3.5"}} The screening room</p>
				<h1 class="mt-5 max-w-3xl text-5xl font-black tracking-tight sm:text-7xl animate-fade-up text-balance">Videos</h1>
				<p class="mt-5 max-w-xl text-lg leading-relaxed text-white/70 animate-fade-in" style="animation-delay:.2s">Tutorials, breakdowns and experiments — filmed, cut and shipped. Grab popcorn.</p>
				<div class="mt-8 flex flex-wrap items-center gap-3 animate-fade-in" style="animation-delay:.3s">
					{{#if @custom.youtube_url}}
						<a href="{{@custom.youtube_url}}?sub_confirmation=1" target="_blank" rel="noopener"
							class="btn !border-transparent shadow-card transition hover:-translate-y-0.5"
							style="background:#FF0000;color:#fff">
							{{> "icons/youtube" class="h-4 w-4"}} Subscribe on YouTube
						</a>
					{{/if}}
					<a href="{{@site.url}}/guestbook/" class="btn-glass">
						{{> "icons/sparkle" class="h-4 w-4"}} Suggest a topic
					</a>
				</div>
			</div>

			{{!-- Upload schedule — glass card on the video --}}
			<div class="lg:col-span-5">
				<div class="rounded-2xl border border-white/15 bg-black/40 p-5 text-white shadow-lift backdrop-blur-xl">
					<p class="kicker flex items-center gap-2 !text-white/60">{{> "icons/calendar" class="h-3.5 w-3.5"}} Upload schedule</p>
					<table class="mt-4 w-full text-sm">
						<tbody class="divide-y divide-white/10">
							<tr>
								<td class="w-28 py-2.5 pr-3 font-mono text-[11px] uppercase tracking-[0.15em] text-white/60">Saturday</td>
								<td class="py-2.5 font-medium">New full-length video</td>
								<td class="py-2.5 pl-3 text-right font-mono text-[11px] text-white/60">10:00 IST</td>
							</tr>
							<tr>
								<td class="py-2.5 pr-3 font-mono text-[11px] uppercase tracking-[0.15em] text-white/60">Wednesday</td>
								<td class="py-2.5 font-medium">Short / behind the scenes</td>
								<td class="py-2.5 pl-3 text-right font-mono text-[11px] text-white/60">18:00 IST</td>
							</tr>
							<tr>
								<td class="py-2.5 pr-3 font-mono text-[11px] uppercase tracking-[0.15em] text-white/60">1st Sunday</td>
								<td class="py-2.5 font-medium">Live Q&amp;A on the channel</td>
								<td class="py-2.5 pl-3 text-right font-mono text-[11px] text-white/60">11:00 IST</td>
							</tr>
						</tbody>
					</table>
					<p class="mt-4 flex items-center gap-1.5 border-t border-dashed border-white/15 pt-3 font-mono text-[11px] text-white/60">
						{{> "icons/zap" class="h-3.5 w-3.5"}} New video every Saturday — set a reminder.
					</p>
				</div>
			</div>
		</div>
	</div>
</header>

<section class="container-site py-12">
	{{!-- Featured: first video of the page, theater-sized --}}
	{{#foreach posts to="1"}}
		<article class="group reveal">
			<a href="{{url}}" class="grid items-center gap-6 overflow-hidden rounded-2xl border border-line bg-mist/40 p-4 transition hover:bg-mist sm:p-5 lg:grid-cols-2" aria-label="Watch: {{title}}">
				<div class="relative aspect-video overflow-hidden rounded-xl border border-line bg-mist shadow-card">
					{{#if feature_image}}
						<img src="{{img_url feature_image size="1000"}}"
							srcset="{{img_url feature_image size="600"}} 600w, {{img_url feature_image size="1000"}} 1000w, {{img_url feature_image size="1600"}} 1600w"
							sizes="(max-width: 1024px) 92vw, 560px"
							alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
							class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
					{{else}}
						<div class="bg-dots flex h-full w-full items-center justify-center">{{> "icons/film" class="text-silver"}}</div>
					{{/if}}
					<span class="absolute inset-0 flex items-center justify-center bg-black/0 transition duration-300 group-hover:bg-black/25">
						<span class="flex h-14 w-14 scale-75 items-center justify-center rounded-full bg-white text-black opacity-0 shadow-lg transition duration-300 group-hover:scale-100 group-hover:opacity-100">{{> "icons/play" class="ml-0.5 h-5 w-5"}}</span>
					</span>
					<span class="absolute bottom-2 right-2 rounded-md bg-black/80 px-1.5 py-0.5 font-mono text-[11px] font-semibold text-white" data-duration-tags="{{#foreach tags visibility="internal"}}{{slug}} {{/foreach}}" hidden></span>
				</div>
				<div class="px-1 pb-2 lg:px-4">
					<p class="kicker !text-accent">{{> "icons/zap" class="h-3.5 w-3.5"}} Latest upload</p>
					<h2 class="mt-3 text-2xl font-semibold leading-snug tracking-tight sm:text-3xl text-balance">{{title}}</h2>
					{{#if excerpt}}<p class="mt-3 line-clamp-3 leading-relaxed text-silver">{{excerpt words="35"}}</p>{{/if}}
					<p class="mt-4 flex flex-wrap items-center gap-x-3 gap-y-1.5 font-mono text-[11px] text-silver">
						<span class="flex items-center gap-1.5">{{> "icons/calendar" class="h-3.5 w-3.5"}} {{date published_at format="DD MMM YYYY"}}</span>
						{{#primary_tag}}<span class="chip">{{name}}</span>{{/primary_tag}}
					</p>
					<span class="btn-ghost mt-6 inline-flex">{{> "icons/play" class="h-4 w-4"}} Watch now</span>
				</div>
			</a>
		</article>
	{{/foreach}}

	{{!-- Shorts & Reels — 9:16 vertical rail (only #video posts also tagged
	     #reel/#shorts). Shown on the first page only. --}}
	{{#unless pagination.prev}}
	{{#get "posts" filter="tag:hash-video+tag:hash-shorts,tag:hash-video+tag:hash-reel" order="published_at desc" limit="12" include="tags" as |reels|}}
		{{#if reels}}
		<section class="mt-14 reveal" aria-label="Shorts and reels">
			<div class="flex items-end justify-between gap-4">
				<div>
					<p class="kicker !text-accent">{{> "icons/play" class="h-3.5 w-3.5"}} Shorts &amp; reels</p>
					<h2 class="section-title mt-2">Quick, vertical &amp; snackable</h2>
				</div>
			</div>
			<div class="reels-rail no-scrollbar mt-6 fade-mask-x" data-hscroll>
				{{#foreach reels}}{{> "cards/reel"}}{{/foreach}}
			</div>
		</section>
		{{/if}}
	{{/get}}
	{{/unless}}

	{{!-- Full library — 16:9 video cards; reels/shorts live in their own rail
	     above. An in-feed ad drops in after every third card. --}}
	<p class="kicker mb-6 mt-16">{{> "icons/film" class="h-3.5 w-3.5"}} Full library</p>
	<div class="grid gap-x-6 gap-y-10 sm:grid-cols-2 lg:grid-cols-3" data-reveal-stagger="60">
		{{#foreach posts from="2"}}
			{{#has tag="hash-reel, hash-shorts"}}{{else}}
				{{> "cards/video"}}
				{{#has number="nth:3"}}
					{{> "components/adsense" slot="9130894804" format="fluid" layoutKey="-6t+ed+2i-1n-4w" class="!my-0 self-center sm:col-span-2 lg:col-span-3"}}
				{{/has}}
			{{/has}}
		{{else}}
			<p class="col-span-full py-10 text-center text-silver">More videos are on the way — check the schedule above.</p>
		{{/foreach}}
	</div>

	{{> "components/pagination"}}

	{{!-- Work-with-me band --}}
	<div class="mt-14">{{> "components/collab-cta"}}</div>
</section>
