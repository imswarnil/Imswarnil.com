{{!< default}}

{{!-- Bucketlist — auto-used by Ghost for the page with slug "bucketlist".
     Items are posts tagged #bucketlist-to-do (left) or #bucketlist-done (right).
     Create a Page titled "Bucketlist" in Ghost Admin (like Contact / Collab). --}}
{{#post}}
<article class="{{post_class}}">
	{{!-- Quote header --}}
	<header class="relative overflow-hidden border-b border-line py-20">
		<div class="bg-grid pointer-events-none absolute inset-0 fade-mask-b" aria-hidden="true"></div>
		<div class="container-site relative text-center">
			<p class="kicker justify-center">{{> "icons/star"}} The bucketlist</p>
			<p class="mx-auto mt-6 max-w-3xl font-serif text-2xl leading-snug tracking-tight text-balance sm:text-4xl" style="font-family:Georgia,serif">
				“{{#if custom_excerpt}}{{custom_excerpt}}{{else}}Someday is not a day of the week — so here's the list I'm actually working through.{{/if}}”
			</p>
			<h1 class="mt-6 font-mono text-[11px] uppercase tracking-[0.3em] text-silver">{{title}}</h1>
		</div>
	</header>

	<div class="container-site py-14">
		{{#if content}}<div class="mx-auto mb-12 max-w-prose gh-content">{{content}}</div>{{/if}}

		<div class="mx-auto grid max-w-5xl gap-8 lg:grid-cols-2">
			{{!-- To do --}}
			<section>
				<div class="mb-5 flex items-center justify-between border-b border-line pb-3">
					<p class="kicker !mb-0">{{> "icons/clock" class="h-3.5 w-3.5"}} Still to do</p>
					{{#get "posts" filter="tag:hash-bucketlist-to-do" limit="1" as |c|}}<span class="chip !text-[10px]">{{pagination.total}}</span>{{/get}}
				</div>
				{{#get "posts" filter="tag:hash-bucketlist-to-do" order="published_at desc" limit="50" as |todo|}}
					{{#if todo}}
					<div class="bucket-col" data-reveal-stagger="50">
						{{#foreach todo}}
						<div class="bucket-item">
							<span class="bucket-check" aria-hidden="true">{{> "icons/check" class="h-3.5 w-3.5"}}</span>
							<div class="min-w-0">
								<p class="bucket-title">{{title}}</p>
								{{#if custom_excerpt}}<p class="bucket-note">{{custom_excerpt}}</p>{{/if}}
							</div>
						</div>
						{{/foreach}}
					</div>
					{{else}}<p class="text-sm text-silver">Nothing queued — tag posts <code class="rounded bg-mist px-1 font-mono text-xs">#bucketlist-to-do</code>.</p>{{/if}}
				{{/get}}
			</section>

			{{!-- Done --}}
			<section>
				<div class="mb-5 flex items-center justify-between border-b border-line pb-3">
					<p class="kicker !mb-0 !text-green-600">{{> "icons/check" class="h-3.5 w-3.5"}} Done</p>
					{{#get "posts" filter="tag:hash-bucketlist-done" limit="1" as |c|}}<span class="chip !text-[10px]">{{pagination.total}}</span>{{/get}}
				</div>
				{{#get "posts" filter="tag:hash-bucketlist-done" order="published_at desc" limit="50" as |done|}}
					{{#if done}}
					<div class="bucket-col" data-reveal-stagger="50">
						{{#foreach done}}
						<div class="bucket-item bucket-done">
							<span class="bucket-check" aria-hidden="true">{{> "icons/check" class="h-3.5 w-3.5"}}</span>
							<div class="min-w-0">
								<p class="bucket-title">{{title}}</p>
								{{#if custom_excerpt}}<p class="bucket-note">{{custom_excerpt}}</p>{{/if}}
							</div>
						</div>
						{{/foreach}}
					</div>
					{{else}}<p class="text-sm text-silver">Nothing crossed off yet — tag posts <code class="rounded bg-mist px-1 font-mono text-xs">#bucketlist-done</code>.</p>{{/if}}
				{{/get}}
			</section>
		</div>
	</div>
</article>
{{/post}}
