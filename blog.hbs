{{!< default}}

{{!-- Blog index — only #blog posts (see routes.yaml). Featured post gets a
     big editorial spread; the rest sit in a clean 3-col grid. --}}
<header class="relative overflow-hidden border-b border-line">
	<div class="bg-grid-lg pointer-events-none absolute inset-0 fade-mask-b" aria-hidden="true"></div>
	<div class="container-site relative py-14 sm:py-20">
		<p class="kicker">{{> "icons/terminal" class="h-3.5 w-3.5"}} Field notes</p>
		<h1 class="mt-3 max-w-2xl text-4xl font-semibold leading-[1.05] tracking-tight sm:text-5xl text-balance">The Blog</h1>
		<p class="mt-4 max-w-xl text-lg leading-relaxed text-silver">Marketing tech, web craft, careers and the occasional life lesson — written to be useful, edited to be short.</p>
	</div>
</header>

<div class="container-site py-12">
	{{#foreach posts}}
		{{#if @first}}
			{{!-- Featured spread --}}
			<a href="{{url}}" class="reveal group mb-14 grid gap-6 overflow-hidden rounded-3xl border border-line shadow-card transition hover:shadow-lift lg:grid-cols-2 lg:gap-0">
				{{#if feature_image}}
				<div class="relative aspect-[16/10] overflow-hidden lg:aspect-auto">
					<img src="{{img_url feature_image size="1200"}}" alt="{{title}}" loading="lazy" class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.03]" />
				</div>
				{{/if}}
				<div class="flex flex-col justify-center p-8 sm:p-10">
					<div class="flex items-center gap-2">
						<span class="chip !border-transparent !bg-ink !text-paper">Latest</span>
						{{#primary_tag}}<span class="chip">{{name}}</span>{{/primary_tag}}
					</div>
					<h2 class="mt-4 text-2xl font-semibold leading-tight tracking-tight sm:text-3xl text-balance">{{title}}</h2>
					<p class="mt-3 line-clamp-3 text-[15px] leading-relaxed text-silver">{{custom_excerpt}}{{^custom_excerpt}}{{excerpt words="34"}}{{/custom_excerpt}}</p>
					<div class="mt-6 flex items-center gap-3 text-sm text-silver">
						{{#primary_author}}
							{{#if profile_image}}<img src="{{img_url profile_image size="100"}}" alt="{{name}}" class="h-8 w-8 rounded-full object-cover" loading="lazy" />{{/if}}
							<span class="font-medium text-ink">{{name}}</span>
						{{/primary_author}}
						<span class="opacity-40">·</span>
						<span>{{date published_at format="DD MMM YYYY"}}</span>
						<span class="opacity-40">·</span>
						<span class="flex items-center gap-1">{{> "icons/clock" class="h-3.5 w-3.5"}} {{reading_time minute="1 min"}}</span>
					</div>
				</div>
			</a>
		{{/if}}
	{{/foreach}}

	<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
		{{#foreach posts from="2"}}
			{{> "cards/blog" class="reveal"}}
			{{#match @number "=" 5}}
				{{> "components/adsense" slot="9130894804" format="fluid" layoutKey="-6t+ed+2i-1n-4w" class="!my-0 sm:col-span-2"}}
			{{/match}}
		{{/foreach}}
	</div>
	{{^posts}}
		<p class="py-16 text-center text-silver">No posts yet — tag a post <code class="rounded bg-mist px-1.5 py-0.5 font-mono text-xs">#blog</code> to see it here.</p>
	{{/posts}}

	{{> "components/pagination"}}
</div>
