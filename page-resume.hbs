{{!< default}}
{{!--
	RESUME / CV — auto-applied to the Ghost page with slug "resume".
	================================================================
	All content lives in THIS TEMPLATE (it does not read from posts). Create an
	empty Ghost page with slug "resume" and edit below. Editable spots = EDIT.

	Layout: responsive two-column header (identity | contact) + a two-column
	body — main = summary + experience (stepper cards with logo badges) + side
	projects; aside (STICKY) = achievements, skills, certifications, education.
	Print button → clean Save-as-PDF (see @media print in pages/resume.css).
--}}
{{#contentFor "body-class"}} page-resume{{/contentFor}}

<article class="resume container-wide">

	{{!-- ── Header: two columns (identity | contact) ───────────────── --}}
	<header class="resume-header">
		<div class="resume-id">
			{{!-- EDIT: replace initials with a photo:
			     <div class="resume-avatar"><img src="/content/images/me.jpg" alt="Raja Swarnil Singhai"></div> --}}
			<div class="resume-avatar"><span class="resume-avatar-initials">SS</span></div>
			<div>
				<h1 class="resume-name">Raja Swarnil Singhai</h1>
				<p class="resume-role">Salesforce Engineer · CRM Analytics Developer</p>
			</div>
		</div>

		<div class="resume-contact">
			<ul class="resume-contact-list">
				<li>
					<span class="resume-contact-label">{{t "Email"}}</span>
					<a href="mailto:swarnilsinghaicse@gmail.com">swarnilsinghaicse@gmail.com</a>
				</li>
				<li>
					<span class="resume-contact-label">{{t "LinkedIn"}}</span>
					<a href="https://www.linkedin.com/in/imswarnil/" target="_blank" rel="noopener noreferrer">linkedin.com/in/imswarnil</a>
				</li>
				<li>
					<span class="resume-contact-label">{{t "Location"}}</span>
					<span>Bangalore, India</span>
				</li>
				<li>
					<span class="resume-contact-label">{{t "Nationality"}}</span>
					<span>Indian</span>
				</li>
			</ul>
			<button type="button" class="button button-sm resume-print" onclick="window.print()">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9V2h12v7"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><path d="M6 14h12v8H6z"/></svg>
				{{t "Print / Save PDF"}}
			</button>
		</div>
	</header>

	{{!-- ── Two-column body ─────────────────────────────────────────── --}}
	<div class="resume-body">

		{{!-- MAIN column ────────────────────────────────────────────── --}}
		<div class="resume-main">

			<section class="resume-section">
				<h2 class="resume-section-title">{{t "Summary"}}</h2>
				<p class="resume-summary">
					CRM Analytics Developer with 6+ years of experience across requirements,
					data preparation, and Salesforce analytics development. I specialise in
					SAQL, bindings, dashboard UX, and building secure, scalable dataflows and
					datasets. Strong in resolving data quality issues, optimising workflows,
					and aligning insights across sales and business teams. Known for delivering
					high-impact CRMA solutions that support fast, confident decision-making.
				</p>
			</section>

			{{!-- Experience — stepper cards. Each entry = a logo node on the
			     stepper line + a card. EDIT a logo: swap the .resume-logo span
			     for <img src="/content/images/company.png" alt="Company">. --}}
			<section class="resume-section">
				<h2 class="resume-section-title">{{t "Experience"}}</h2>
				<ol class="resume-timeline">

					<li class="resume-entry">
						<span class="resume-logo"><span class="resume-logo-text">T</span></span>
						<div class="resume-entry-card">
							<div class="resume-entry-top">
								<div>
									<h3 class="resume-entry-role">CRM Analytics Developer</h3>
									<p class="resume-entry-org">Twilio <span class="resume-entry-loc">· Bangalore, India</span></p>
								</div>
								<span class="resume-entry-period">07/2022 — Present</span>
							</div>
							<p class="resume-entry-desc">
								Manage CRM Analytics for the GTM Sales Operations team — dashboards that
								improve AE productivity, measure adoption, and surface insights across
								sales, service, and operational value streams. Work spans advanced CRMA
								development, Snowflake integration, performance optimisation, CPQ
								alignment, and data reliability through continuous modelling and cleanup.
							</p>
							<ul class="resume-points">
								<li>Built productivity dashboards for AEs — Account Insight Cards, Performance Trackers, Usage Metrics, Cross-Sell Views, account planning.</li>
								<li>Developed Sales &amp; Service Cloud dashboards: Case Insights, Lead Conversion, Account Plan Adoption, Product Usage.</li>
								<li>Created operational dashboards — Event Monitoring Logs, Apex Error Tracking, Lead Conversion, Credit Approval insights.</li>
								<li>Integrated Snowflake data into CRM Analytics for unified GTM reporting.</li>
								<li>Led platform cleanup and field deprecation, remapping logic and datasets during major org restructures.</li>
								<li>Advanced SAQL, bindings, and interactive dashboard logic to lift interactivity and UX.</li>
								<li>Delivered POCs, high-priority ad-hoc requests, and resolved data discrepancies across GTM workflows.</li>
							</ul>
						</div>
					</li>

					<li class="resume-entry">
						<span class="resume-logo"><span class="resume-logo-text">C</span></span>
						<div class="resume-entry-card">
							<div class="resume-entry-top">
								<div>
									<h3 class="resume-entry-role">CRM Analytics Consultant</h3>
									<p class="resume-entry-org">Cognizant <span class="resume-entry-loc">· Bangalore</span></p>
								</div>
								<span class="resume-entry-period">08/2021 — 06/2022</span>
							</div>
							<p class="resume-entry-desc">
								CRM Analytics projects for enterprise clients — improving dashboards,
								enhancing UX, and optimising performance. Handled development
								independently and supported teams with reporting and documentation.
							</p>
							<ul class="resume-points">
								<li>Redesigned and optimised CRMA dashboards for usability, performance, and interactivity using SAQL, bindings, dataflows, recipes, and clean modelling.</li>
								<li>Converted business requirements into scalable dashboard designs; supported ad-hoc reporting, issue resolution, and documentation.</li>
								<li>Independently managed enhancements and fixes, coordinating for reliable dataset performance.</li>
							</ul>
						</div>
					</li>

					<li class="resume-entry">
						<span class="resume-logo"><span class="resume-logo-text">A</span></span>
						<div class="resume-entry-card">
							<div class="resume-entry-top">
								<div>
									<h3 class="resume-entry-role">Einstein Analytics Developer</h3>
									<p class="resume-entry-org">Accenture <span class="resume-entry-loc">· Bangalore, India</span></p>
								</div>
								<span class="resume-entry-period">03/2018 — 08/2021</span>
							</div>
							<p class="resume-entry-desc">
								CRM Analytics for Consumer Goods (Trade Promotion Management) and
								Telecom — dashboards, packaged-app analytics, and Sales Cloud reporting.
								Owned modules independently and mentored junior team members.
							</p>
							<ul class="resume-points">
								<li>Built CRMA dashboards for TPM packaged apps and Sales Cloud — datasets, dataflows, SAQL, bindings, dashboard JSON.</li>
								<li>Managed data preparation, modelling, validation, and optimisation; turned requirements into scalable analytics designs.</li>
								<li>Delivered features and fixes independently, supported UAT/documentation, and guided juniors in CRMA.</li>
							</ul>
						</div>
					</li>

				</ol>
			</section>

			<section class="resume-section">
				<h2 class="resume-section-title">{{t "Side projects"}}</h2>
				<ul class="resume-list resume-sideprojects">
					<li>
						<h3 class="resume-list-title">CRM Analytics Academy</h3>
						<p class="resume-list-org"><a href="https://crmanalytics.imswarnil.com" target="_blank" rel="noopener noreferrer">crmanalytics.imswarnil.com</a></p>
						<p class="resume-entry-desc">A dedicated CRMA learning site with dashboards, lessons, and practical examples.</p>
					</li>
					<li>
						<h3 class="resume-list-title">Dev Portfolio Jekyll Theme <span class="resume-badge">{{t "Open source"}}</span></h3>
						<p class="resume-list-org"><a href="https://dev.imswarnil.com/" target="_blank" rel="noopener noreferrer">dev.imswarnil.com</a></p>
						<p class="resume-entry-desc">A customisable portfolio theme focused on clean UI and performance.</p>
					</li>
					<li>
						<h3 class="resume-list-title">Razorpay Revenue Dashboard</h3>
						<p class="resume-entry-desc">A mock analytics dashboard visualising revenue, retention, and growth metrics.</p>
					</li>
				</ul>
			</section>
		</div>

		{{!-- ASIDE column (STICKY) ───────────────────────────────────── --}}
