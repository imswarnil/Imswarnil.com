{{!< default}}
{{!-- /resume — print-friendly professional resume. Career summary comes from
     the page's own content (editable in the Ghost editor); Experience,
     Education and Awards are pulled live from #timeline posts by event tag. --}}

{{#post}}
{{!-- Document chrome: replaces the global navbar (hidden via body.page-resume CSS) --}}
<div class="player-bar no-print" id="resume-bar">
	<a href="{{@site.url}}" class="flex shrink-0 items-center gap-1.5 rounded-full px-2.5 py-1.5 text-[12.5px] font-medium text-silver transition hover:bg-mist hover:text-ink" aria-label="Back to home">
		{{> "icons/arrow-right" class="h-3.5 w-3.5 rotate-180"}} Home
	</a>
	<div class="min-w-0 flex-1 text-center">
		<p class="truncate font-mono text-[9px] uppercase tracking-[0.2em] text-silver">curriculum vitae</p>
		<p class="truncate text-sm font-semibold leading-tight">Swarnil Singhai</p>
	</div>
	<div class="flex shrink-0 items-center gap-1.5">
		<button type="button" class="btn-ghost btn-sm" onclick="window.print()">{{> "icons/download" class="h-3 w-3"}} PDF</button>
		<a href="{{@site.url}}/contact/" class="btn-primary btn-sm">{{> "icons/mail" class="h-3 w-3"}} Hire me</a>
	</div>
</div>

<article class="{{post_class}} pt-14">
	<header class="relative overflow-hidden border-b border-line py-14">
		<div class="bg-dots pointer-events-none absolute inset-0 fade-mask-b print:hidden" aria-hidden="true"></div>
		<div class="container-site relative">
			<div class="mx-auto flex max-w-4xl flex-col items-start justify-between gap-6 sm:flex-row sm:items-end">
				<div>
					<p class="kicker">Resume</p>
					<h1 class="mt-2 text-4xl font-semibold tracking-tight sm:text-5xl">Swarnil Singhai</h1>
					<p class="mt-3 text-lg text-silver">Salesforce Engineer at <span class="font-medium text-ink">EF Education First</span></p>
				</div>
				<div class="no-print flex flex-wrap gap-2">
					<button type="button" class="btn-primary tooltip" data-tip="Print / save as PDF" onclick="window.print()">{{> "icons/download"}} Download PDF</button>
					<a href="mailto:swarnilsinghaicse@gmail.com" class="btn-ghost">{{> "icons/mail"}} Email</a>
					<a href="/contact/" class="btn-ghost">{{> "icons/user"}} Contact</a>
					<a href="https://topmate.io/imswarnil" target="_blank" rel="noopener" class="btn-ghost">{{> "icons/zap"}} Book a call</a>
				</div>
			</div>
		</div>
	</header>

	<div class="container-site py-12">
		<div class="mx-auto max-w-4xl">

			{{!-- Career summary — the resume page's own content, edited in Ghost --}}
			{{#if content}}
				<section class="mb-12">
					<h2 class="section-title">Career summary</h2>
					<div class="gh-content mt-5">{{content}}</div>
				</section>
			{{/if}}

			<div class="grid gap-12 lg:grid-cols-12">

				{{!-- Main column --}}
				<div class="space-y-12 lg:col-span-8">

					{{!-- Experience: company changes logged on the timeline --}}
					<section>
						<div class="flex items-center justify-between gap-4">
							<h2 class="section-title">Experience</h2>
							<a href="/timeline/" class="no-print inline-flex items-center gap-1.5 text-sm font-medium text-silver transition hover:text-ink">Full interactive timeline {{> "icons/arrow-right"}}</a>
						</div>
						{{#get "posts" filter="tag:hash-timeline+tag:hash-event-company-change" order="published_at desc" limit="10" as |roles|}}
							{{#if roles}}
								<ol class="relative mt-6 space-y-8 border-l border-line pl-6">
									{{#foreach roles}}
									<li class="relative">
										<span class="absolute -left-[1.9rem] top-1 flex h-5 w-5 items-center justify-center rounded-full border border-line bg-paper">
											<span class="h-1.5 w-1.5 rounded-full bg-ink"></span>
										</span>
										<p class="flex items-center gap-2 font-mono text-[11px] uppercase tracking-widest text-silver">{{> "icons/calendar"}} {{date published_at format="MMM YYYY"}}</p>
										<h3 class="mt-1.5 text-lg font-semibold tracking-tight">{{title}}</h3>
										<p class="mt-1.5 text-sm leading-relaxed text-silver">{{custom_excerpt}}{{^custom_excerpt}}{{excerpt words="30"}}{{/custom_excerpt}}</p>
										<a href="/timeline/#tl-{{slug}}" class="no-print mt-2 inline-flex items-center gap-1 text-xs font-medium text-silver transition hover:text-ink">View on timeline {{> "icons/arrow-up-right"}}</a>
									</li>
									{{/foreach}}
								</ol>
							{{else}}
								<p class="mt-5 text-sm text-silver">Tag timeline posts <code>#event-company-change</code> to list roles here.</p>
							{{/if}}
						{{/get}}
					</section>

					{{!-- Selected projects — pulled live from #project posts --}}
					<section>
						<div class="flex items-center justify-between gap-4">
							<h2 class="section-title">Selected projects</h2>
							<a href="/projects/" class="no-print inline-flex items-center gap-1.5 text-sm font-medium text-silver transition hover:text-ink">All projects {{> "icons/arrow-right"}}</a>
						</div>
						{{#get "posts" filter="tag:hash-project" order="published_at desc" limit="4" as |work|}}
							{{#if work}}
							<ul class="mt-6 space-y-5">
								{{#foreach work}}
								<li class="flex gap-4">
									<span class="mt-1 flex h-9 w-9 shrink-0 items-center justify-center rounded-xl border border-line bg-mist text-silver">{{> "icons/terminal" class="h-4 w-4"}}</span>
									<div class="min-w-0">
										<h3 class="font-semibold tracking-tight"><a href="{{url}}" class="hover:underline hover:underline-offset-4">{{title}}</a></h3>
										<p class="mt-1 text-sm leading-relaxed text-silver">{{custom_excerpt}}{{^custom_excerpt}}{{excerpt words="22"}}{{/custom_excerpt}}</p>
									</div>
								</li>
								{{/foreach}}
							</ul>
							{{/if}}
						{{/get}}
					</section>

					{{!-- Talks & milestones --}}
					<section>
						<h2 class="section-title">Talks &amp; milestones</h2>
						{{#get "posts" filter="tag:hash-event-milestone" order="published_at desc" limit="6" as |wins|}}
							{{#if wins}}
							<ul class="mt-6 space-y-5">
								{{#foreach wins}}
								<li class="flex gap-4">
									<span class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-line bg-mist text-silver">{{> "icons/trophy"}}</span>
									<div>
										<p class="font-mono text-[11px] uppercase tracking-widest text-silver">{{date published_at format="MMM YYYY"}}</p>
										<h3 class="mt-0.5 font-semibold tracking-tight">{{title}}</h3>
										<p class="mt-1 text-sm leading-relaxed text-silver">{{custom_excerpt}}{{^custom_excerpt}}{{excerpt words="20"}}{{/custom_excerpt}}</p>
									</div>
								</li>
								{{/foreach}}
							</ul>
							{{else}}
							<p class="mt-5 text-sm text-silver">Tag timeline posts <code>#event-milestone</code> to list talks and wins here.</p>
							{{/if}}
						{{/get}}
					</section>

					{{!-- Education --}}
					<section>
						<h2 class="section-title">Education</h2>
						{{#get "posts" filter="tag:hash-event-education" order="published_at desc" limit="6" as |schooling|}}
							{{#if schooling}}
								<ul class="mt-6 space-y-6">
									{{#foreach schooling}}
									<li class="flex gap-4">
										<span class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-line bg-mist text-silver">{{> "icons/graduation"}}</span>
										<div>
											<p class="font-mono text-[11px] uppercase tracking-widest text-silver">{{date published_at format="YYYY"}}</p>
											<h3 class="mt-0.5 font-semibold tracking-tight">{{title}}</h3>
											<p class="mt-1 text-sm leading-relaxed text-silver">{{custom_excerpt}}{{^custom_excerpt}}{{excerpt words="20"}}{{/custom_excerpt}}</p>
										</div>
									</li>
									{{/foreach}}
								</ul>
							{{else}}
								<p class="mt-5 text-sm text-silver">Tag timeline posts <code>#event-education</code> to list education here.</p>
							{{/if}}
						{{/get}}
					</section>
				</div>

				{{!-- Side column --}}
				<aside class="space-y-8 lg:col-span-4">

					{{!-- Skills — static chip cloud; edit the spans below to update --}}
					<section class="card-surface p-6 !transform-none">
						<h2 class="kicker">Core skills</h2>
						<div class="mt-4 flex flex-wrap gap-2">
							<span class="chip">Google Ads</span>
							<span class="chip">GA4</span>
							<span class="chip">Google Tag Manager</span>
							<span class="chip">SEO</span>
							<span class="chip">Marketing Automation</span>
							<span class="chip">Looker Studio</span>
							<span class="chip">Ghost CMS</span>
							<span class="chip">HTML / CSS / JS</span>
							<span class="chip">Tailwind CSS</span>
							<span class="chip">Content &amp; Video</span>
						</div>
					</section>

					{{!-- Tools of the trade --}}
					<section class="card-surface p-6 !transform-none">
						<h2 class="kicker">Daily tools</h2>
						<div class="mt-4 grid grid-cols-2 gap-2 text-sm">
							<span class="flex items-center gap-2 text-silver">{{> "icons/zap" class="h-3.5 w-3.5"}} Google Ads</span>
							<span class="flex items-center gap-2 text-silver">{{> "icons/zap" class="h-3.5 w-3.5"}} GA4 + GTM</span>
							<span class="flex items-center gap-2 text-silver">{{> "icons/terminal" class="h-3.5 w-3.5"}} VS Code</span>
							<span class="flex items-center gap-2 text-silver">{{> "icons/terminal" class="h-3.5 w-3.5"}} Apps Script</span>
							<span class="flex items-center gap-2 text-silver">{{> "icons/film" class="h-3.5 w-3.5"}} Premiere Pro</span>
							<span class="flex items-center gap-2 text-silver">{{> "icons/film" class="h-3.5 w-3.5"}} OBS</span>
							<span class="flex items-center gap-2 text-silver">{{> "icons/book" class="h-3.5 w-3.5"}} Notion</span>
							<span class="flex items-center gap-2 text-silver">{{> "icons/book" class="h-3.5 w-3.5"}} Figma</span>
						</div>
					</section>

					{{!-- Languages --}}
					<section class="card-surface p-6 !transform-none">
						<h2 class="kicker">Languages</h2>
						<ul class="mt-4 space-y-2 text-sm text-silver">
							<li class="flex justify-between"><span>English</span><span class="font-mono text-[10px] uppercase tracking-[0.15em]">professional</span></li>
							<li class="flex justify-between"><span>Hindi</span><span class="font-mono text-[10px] uppercase tracking-[0.15em]">native</span></li>
							<li class="flex justify-between"><span>JavaScript</span><span class="font-mono text-[10px] uppercase tracking-[0.15em]">conversational</span></li>
						</ul>
					</section>

					{{!-- Awards --}}
					<section class="card-surface p-6 !transform-none">
						<h2 class="kicker">Awards</h2>
						{{#get "posts" filter="tag:hash-event-award" order="published_at desc" limit="6" as |honors|}}
							{{#if honors}}
								<ul class="mt-4 space-y-4">
									{{#foreach honors}}
									<li class="flex gap-3">
										<span class="mt-0.5 shrink-0 text-silver">{{> "icons/medal"}}</span>
										<div>
											<p class="font-mono text-[10px] uppercase tracking-widest text-silver">{{date published_at format="MMM YYYY"}}</p>
											<p class="mt-0.5 text-sm font-medium leading-snug">{{title}}</p>
										</div>
									</li>
									{{/foreach}}
								</ul>
							{{else}}
								<p class="mt-4 text-sm text-silver">Tag timeline posts <code>#event-award</code> to list honors here.</p>
							{{/if}}
						{{/get}}
					</section>

					{{!-- Elsewhere --}}
					<section class="no-print card-surface p-6 !transform-none">
						<h2 class="kicker">Elsewhere</h2>
						<ul class="mt-4 space-y-2.5 text-sm">
							<li><a href="https://github.com/imswarnil/imswarnil.com" target="_blank" rel="noopener" class="flex items-center gap-2 text-silver transition hover:text-ink">{{> "icons/github"}} GitHub</a></li>
							<li><a href="https://www.linkedin.com/in/imswarnil" target="_blank" rel="noopener" class="flex items-center gap-2 text-silver transition hover:text-ink">{{> "icons/linkedin"}} LinkedIn</a></li>
							<li><a href="https://www.youtube.com/@imswarnil" target="_blank" rel="noopener" class="flex items-center gap-2 text-silver transition hover:text-ink">{{> "icons/youtube"}} YouTube</a></li>
						</ul>
					</section>

					<a href="/timeline/" class="no-print card-surface group flex items-center justify-between gap-3 p-5 !transform-none transition hover:shadow-lift">
						<span>
							<span class="kicker">Want the full story?</span>
							<span class="mt-1 block text-sm font-semibold">View the interactive timeline</span>
						</span>
						<span class="text-silver transition group-hover:translate-x-0.5 group-hover:text-ink">{{> "icons/arrow-right"}}</span>
					</a>
				</aside>
			</div>
		</div>
	</div>
</article>
{{/post}}

<style>
	@media print {
		#site-header, footer, .ad-unit, .no-print { display: none !important; }
		article { padding-top: 0; }
		.card-surface { box-shadow: none !important; border: 1px solid #ddd; }
		a { text-decoration: none; color: inherit; }
	}
</style>
