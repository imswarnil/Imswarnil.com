				<h3 class="resume-skills-group">{{t "Technical"}}</h3>
				<ul class="resume-skills">
					<li>Salesforce CRM Analytics</li>
					<li>SAQL</li>
					<li>Bindings</li>
					<li>JSON</li>
					<li>Sales Cloud</li>
					<li>Service Cloud</li>
					<li>Conga CPQ</li>
					<li>Data Modelling</li>
					<li>Data Visualization</li>
					<li>Data Analysis</li>
					<li>ETL</li>
					<li>Snowflake</li>
					<li>Salesforce Admin</li>
