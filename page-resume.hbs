{{!< default}}
{{!-- Two-column resume. The page's own content renders in the left column,
     so extra sections can be added from the Ghost editor. --}}

{{#post}}
<article class="{{post_class}}">
	<header class="relative overflow-hidden border-b border-line py-14">
		<div class="bg-dots pointer-events-none absolute inset-0 fade-mask-b" aria-hidden="true"></div>
		<div class="container-site relative">
			<div class="mx-auto flex max-w-4xl flex-col items-start justify-between gap-6 sm:flex-row sm:items-end">
				<div>
					<p class="kicker">Resume</p>
					<h1 class="mt-2 text-4xl font-semibold tracking-tight sm:text-5xl">Swarnil Singhai</h1>
					<p class="mt-3 text-lg text-silver">{{@custom.job_title}} · <a href="{{@custom.workplace_url}}" class="font-medium text-ink underline decoration-line underline-offset-4" target="_blank" rel="noopener">{{@custom.workplace}}</a></p>
				</div>
				<div class="flex gap-2">
					<button type="button" class="btn-primary" onclick="window.print()">{{> "icons/download"}} Save PDF</button>
					<a href="mailto:{{@custom.sponsor_email}}" class="btn-ghost">{{> "icons/mail"}} Contact</a>
				</div>
			</div>
		</div>
	</header>

	<div class="container-site py-12">
		<div class="mx-auto grid max-w-4xl gap-12 lg:grid-cols-12">
			{{!-- Main column: experience etc. from the page content --}}
			<div class="lg:col-span-8">
				<section class="gh-content">
					{{content}}
				</section>
			</div>

			{{!-- Side column --}}
			<aside class="space-y-8 lg:col-span-4">
				<div class="card-surface p-6 !transform-none">
					<p class="kicker">Core skills</p>
					<div class="mt-4 flex flex-wrap gap-2">
						<span class="chip">Google Ads</span><span class="chip">GA4</span><span class="chip">GTM</span>
						<span class="chip">SEO</span><span class="chip">Marketing Automation</span><span class="chip">Ghost CMS</span>
						<span class="chip">HTML/CSS/JS</span><span class="chip">Tailwind</span><span class="chip">Data Studio</span>
					</div>
				</div>

				<div class="card-surface p-6 !transform-none">
					<p class="kicker">Toolbelt</p>
					<ul class="mt-4 space-y-2.5 text-sm text-silver">
						<li class="flex items-center gap-2">{{> "icons/check" class="text-ink"}} Performance marketing at scale</li>
						<li class="flex items-center gap-2">{{> "icons/check" class="text-ink"}} Web analytics &amp; attribution</li>
						<li class="flex items-center gap-2">{{> "icons/check" class="text-ink"}} Landing page systems</li>
						<li class="flex items-center gap-2">{{> "icons/check" class="text-ink"}} Video &amp; content production</li>
					</ul>
				</div>

				<div class="card-surface p-6 !transform-none">
					<p class="kicker">Elsewhere</p>
					<ul class="mt-4 space-y-2.5 text-sm">
						<li><a href="https://github.com/{{@custom.github_repo}}" target="_blank" rel="noopener" class="flex items-center gap-2 text-silver transition hover:text-ink">{{> "icons/github"}} GitHub</a></li>
						<li><a href="https://www.linkedin.com/in/imswarnil" target="_blank" rel="noopener" class="flex items-center gap-2 text-silver transition hover:text-ink">{{> "icons/linkedin"}} LinkedIn</a></li>
						<li><a href="https://www.youtube.com/@imswarnil" target="_blank" rel="noopener" class="flex items-center gap-2 text-silver transition hover:text-ink">{{> "icons/youtube"}} YouTube</a></li>
					</ul>
				</div>

				{{!-- Latest timeline entries double as a mini career log --}}
				<div class="card-surface p-6 !transform-none">
					<p class="kicker">Recent milestones</p>
					{{#get "posts" filter="tag:hash-timeline" limit="3" as |log|}}
					<ul class="mt-4 space-y-4">
						{{#foreach log}}
						<li>
							<p class="font-mono text-[10px] uppercase tracking-widest text-silver">{{date published_at format="MMM YYYY"}}</p>
							<a href="{{url}}" class="mt-0.5 block text-sm font-medium leading-snug transition hover:text-silver">{{title}}</a>
						</li>
						{{/foreach}}
					</ul>
					{{/get}}
				</div>
			</aside>
		</div>
	</div>
</article>
{{/post}}
