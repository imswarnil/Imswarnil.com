{{!< default}}
{{!--
	RESUME / CV — auto-applied to the Ghost page with slug "resume".
	================================================================
	Everything here is written IN THIS TEMPLATE — it does NOT read from posts.
	To use it: create an (empty) Ghost page with slug "resume", then edit the
	content below. Every editable spot is marked  EDIT .

	Layout: full-width header, then a two-column body — Experience timeline
	(main) + Education / Skills / Projects (aside). A Print button gives a
	clean Save-as-PDF (see the @media print block in assets/css/pages/resume.css).
--}}
{{#contentFor "body-class"}} page-resume{{/contentFor}}

<article class="resume container-wide">

	{{!-- ── Header (full width) ─────────────────────────────────────── --}}
	<header class="resume-header">
		{{!-- EDIT: swap the initials for a photo, e.g.
		     <div class="resume-avatar"><img src="/content/images/me.jpg" alt="Swarnil Singhai"></div> --}}
		<div class="resume-avatar">
			<span class="resume-avatar-initials">SS</span>
		</div>

		<div class="resume-headline">
			<h1 class="resume-name">Swarnil Singhai</h1> {{!-- EDIT: your name --}}
			<p class="resume-role">Software Engineer · Bengaluru, India</p> {{!-- EDIT: role · location --}}

			<div class="resume-actions">
				<button type="button" class="button button-sm resume-print" onclick="window.print()">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9V2h12v7"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><path d="M6 14h12v8H6z"/></svg>
					{{t "Print / Save PDF"}}
				</button>
				{{!-- EDIT: contact links --}}
				<a class="button button-sm button-background-200" href="mailto:hello@imswarnil.com">{{t "Email"}}</a>
				<a class="button button-sm button-background-200" href="https://www.linkedin.com/in/USERNAME" target="_blank" rel="noopener noreferrer">{{t "LinkedIn"}}</a>
			</div>
		</div>
	</header>

	{{!-- ── Two-column body ─────────────────────────────────────────── --}}
	<div class="resume-body">

		{{!-- MAIN column ────────────────────────────────────────────── --}}
		<div class="resume-main">

			{{!-- EDIT: summary --}}
			<section class="resume-section">
				<h2 class="resume-section-title">{{t "Summary"}}</h2>
				<p class="resume-summary">
					Software engineer with a focus on web platforms, developer tooling and
					content-driven products. I like shipping clean, maintainable systems and
					writing about what I learn along the way.
				</p>
			</section>

			{{!-- EDIT: experience — duplicate a <li class="resume-entry"> per role --}}
			<section class="resume-section">
				<h2 class="resume-section-title">{{t "Experience"}}</h2>
				<ol class="resume-timeline">

					<li class="resume-entry">
						<div class="resume-entry-top">
							<h3 class="resume-entry-role">Senior Software Engineer</h3>
							<span class="resume-entry-period">2022 — Present</span>
						</div>
						<p class="resume-entry-org">Acme Corp</p>
						<ul class="resume-points">
							<li>Led the rebuild of the core web app, improving load time by 40%.</li>
							<li>Mentored 3 engineers and owned the front-end architecture.</li>
							<li>Shipped a design system adopted across 5 product teams.</li>
						</ul>
					</li>

					<li class="resume-entry">
						<div class="resume-entry-top">
							<h3 class="resume-entry-role">Software Engineer</h3>
							<span class="resume-entry-period">2020 — 2022</span>
						</div>
						<p class="resume-entry-org">Globex</p>
						<ul class="resume-points">
							<li>Built and maintained REST/GraphQL APIs serving 1M+ requests/day.</li>
							<li>Introduced CI/CD pipelines, cutting release time from days to hours.</li>
						</ul>
					</li>

					<li class="resume-entry">
						<div class="resume-entry-top">
							<h3 class="resume-entry-role">Junior Developer</h3>
							<span class="resume-entry-period">2018 — 2020</span>
						</div>
						<p class="resume-entry-org">Initech</p>
						<ul class="resume-points">
							<li>Developed customer-facing features across web and mobile.</li>
						</ul>
					</li>

				</ol>
			</section>
		</div>

		{{!-- ASIDE column ───────────────────────────────────────────── --}}
		<aside class="resume-aside">

			{{!-- EDIT: education --}}
			<section class="resume-section">
				<h2 class="resume-section-title">{{t "Education"}}</h2>
				<ul class="resume-list">
					<li>
						<h3 class="resume-list-title">B.Tech, Computer Science</h3>
						<p class="resume-list-org">Your University</p>
						<span class="resume-list-year">2014 — 2018</span>
					</li>
				</ul>
			</section>

			{{!-- EDIT: skills — add/remove <li> chips --}}
			<section class="resume-section">
				<h2 class="resume-section-title">{{t "Skills"}}</h2>
				<ul class="resume-skills">
					<li>JavaScript</li>
					<li>TypeScript</li>
					<li>React</li>
					<li>Node.js</li>
					<li>Ghost</li>
					<li>PostgreSQL</li>
					<li>CSS / PostCSS</li>
					<li>CI/CD</li>
				</ul>
			</section>

			{{!-- EDIT: selected projects --}}
			<section class="resume-section">
				<h2 class="resume-section-title">{{t "Selected projects"}}</h2>
				<ul class="resume-list resume-projects">
					<li><a href="/projects/">Project One</a></li>
					<li><a href="/projects/">Project Two</a></li>
					<li><a href="/projects/">Project Three</a></li>
				</ul>
			</section>

			{{!-- EDIT: languages / interests (optional — delete if unused) --}}
			<section class="resume-section">
				<h2 class="resume-section-title">{{t "Languages"}}</h2>
				<ul class="resume-list">
					<li>
						<h3 class="resume-list-title">English</h3>
						<p class="resume-list-org">Professional</p>
					</li>
					<li>
						<h3 class="resume-list-title">Hindi</h3>
						<p class="resume-list-org">Native</p>
					</li>
				</ul>
			</section>
		</aside>
	</div>
</article>
