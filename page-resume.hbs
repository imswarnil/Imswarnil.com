					<li>Communication</li>
					<li>Documentation</li>
					<li>Requirement Gathering</li>
					<li>User Stories</li>
					<li>Reporting &amp; Dashboards</li>
				</ul>
			</section>

			<section class="resume-section">
				<h2 class="resume-section-title">{{t "Certifications"}}</h2>
				<ul class="resume-certs">
					<li>
						<span class="resume-cert-mark" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></span>
						<div>
							<h3 class="resume-list-title">Salesforce Certified Administrator</h3>
							<p class="resume-list-org">Salesforce · ADM-201</p>
						</div>
					</li>
					<li>
						<span class="resume-cert-mark" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg></span>
						<div>
							<h3 class="resume-list-title">CRM Analytics Training</h3>
							<p class="resume-list-org">Instructor-led Einstein Analytics · ANC101, ANC201, ANC301</p>
						</div>
					</li>
				</ul>
			</section>

			<section class="resume-section">
				<h2 class="resume-section-title">{{t "Education"}}</h2>
				<ul class="resume-list">
					<li>
						<h3 class="resume-list-title">B.E. Computer Science</h3>
						<p class="resume-list-org">LNCT Group of Colleges (RGPV) · Bhopal, M.P.</p>
						<span class="resume-list-year">08/2013 — 08/2017</span>
					</li>
				</ul>
			</section>
		</div>
		</aside>
	</div>
</article>
