		<div class="resume-aside-inner">

			<section class="resume-section">
				<h2 class="resume-section-title">{{t "Key achievements"}}</h2>
				<ul class="resume-list">
					<li>
						<h3 class="resume-list-title">Tableau CRM Ambassador (Ex)</h3>
						<p class="resume-list-org">Recognised for expertise in using and promoting Tableau CRM tools.</p>
