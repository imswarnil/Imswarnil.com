{{!< default}}

<section class="mx-auto max-w-5xl px-4 py-24 text-center">
	<p class="text-sm font-medium uppercase tracking-wide text-zinc-500">Error {{statusCode}}</p>
	<h1 class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">{{message}}</h1>
	<a href="{{@site.url}}" class="mt-8 inline-block rounded-md border border-zinc-300 px-4 py-2 text-sm font-medium hover:bg-zinc-100 dark:border-zinc-700 dark:hover:bg-zinc-800">Back home</a>
</section>
