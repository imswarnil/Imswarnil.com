{{!< default}}

{{> "utility/collection-header" kicker="Everything" title="The Archive" desc="Every post on this site in one stream — articles, videos, courses, projects and more."}}

{{!-- Browse-by-type is a PURE-CSS filter (no JS): each chip is a same-page
     anchor that targets itself, and `.archive-wrap:has(#at-x:target)` below
     shows only the matching rows. The list is rendered ONCE via #get. --}}
<div class="container-site py-12 archive-wrap">
	<div class="grid gap-12 lg:grid-cols-12">
		{{!-- Filter sidebar --}}
		<aside class="lg:col-span-3">
			<div class="rail-sticky">
				<div>
					<p class="kicker">Browse by type</p>
					<nav class="mt-4 flex flex-wrap gap-2 lg:flex-col lg:items-start" aria-label="Filter by collection">
						<a id="at-all"        href="#at-all"        class="atab atab-all chip transition hover:border-ink hover:text-ink">All posts</a>
						<a id="at-article"    href="#at-article"    class="atab chip transition hover:border-ink hover:text-ink">Articles</a>
						<a id="at-video"      href="#at-video"      class="atab chip transition hover:border-ink hover:text-ink">Videos</a>
						<a id="at-course"     href="#at-course"     class="atab chip transition hover:border-ink hover:text-ink">Courses</a>
						<a id="at-series"     href="#at-series"     class="atab chip transition hover:border-ink hover:text-ink">Web series</a>
						<a id="at-project"    href="#at-project"    class="atab chip transition hover:border-ink hover:text-ink">Projects</a>
						<a id="at-product"    href="#at-product"    class="atab chip transition hover:border-ink hover:text-ink">Products</a>
						<a id="at-newsletter" href="#at-newsletter" class="atab chip transition hover:border-ink hover:text-ink">Newsletters</a>
						<a id="at-timeline"   href="#at-timeline"   class="atab chip transition hover:border-ink hover:text-ink">Timeline</a>
						<a id="at-changelog"  href="#at-changelog"  class="atab chip transition hover:border-ink hover:text-ink">Changelog</a>
						<a id="at-shop"       href="#at-shop"       class="atab chip transition hover:border-ink hover:text-ink">Shop</a>
						<a id="at-travel"     href="#at-travel"     class="atab chip transition hover:border-ink hover:text-ink">Travel</a>
					</nav>
					<p class="mt-4 text-xs text-silver">
						Filtering happens in-page — no reload. Or open a full collection from the <a href="{{@site.url}}/" class="underline hover:text-ink">menu</a>.
					</p>
				</div>
				<div class="hidden lg:block">
					{{> "utility/adsense" slot="7663977887"}}
				</div>
			</div>
		</aside>

		{{!-- Post rows — Ghost collections are exclusive, so the /archive/
		     collection itself only receives unclaimed posts. We list ALL
		     posts across every collection with a #get instead. --}}
		<div class="lg:col-span-9">
			{{#get "posts" filter="slug:-hero" include="tags" order="published_at desc" limit="100" as |archive|}}
			<p class="mb-4 font-mono text-xs uppercase tracking-[0.2em] text-silver">{{plural archive.length empty="No posts yet" singular="% post" plural="% posts"}} · pick a type to filter</p>
			<ol id="archive-list" class="divide-y divide-line border-y border-line">
				{{#foreach archive}}
				{{!-- one bucket per row, matched by the CSS filter above --}}
				<li class="arow group" data-type="{{#has tag="#video"}}video{{else has tag="#course"}}course{{else has tag="#lesson"}}course{{else has tag="#webseries"}}series{{else has tag="#episode"}}series{{else has tag="#project-detail"}}project{{else has tag="#project"}}project{{else has tag="#product"}}product{{else has tag="#newsletter"}}newsletter{{else has tag="#changelog"}}changelog{{else has tag="#timeline"}}timeline{{else has tag="#shop"}}shop{{else has tag="#trip"}}travel{{else has tag="#travel"}}travel{{else}}article{{/has}}">
					<a href="{{url}}" class="flex items-center gap-4 py-4 sm:gap-6">
						{{!-- thumbnail --}}
						<span class="relative block aspect-[16/10] w-24 shrink-0 overflow-hidden rounded-xl border border-line bg-mist sm:w-32">
							{{#if feature_image}}
								<img src="{{img_url feature_image size="300"}}" width="300" height="188" alt="" loading="lazy" decoding="async" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
							{{else}}
								<span class="bg-dots flex h-full w-full items-center justify-center">{{> "icons/pen" class="h-4 w-4 text-silver"}}</span>
							{{/if}}
						</span>
						<span class="min-w-0 flex-1">
							<span class="flex flex-wrap items-center gap-x-3 gap-y-1">
								<time class="font-mono text-xs text-silver" datetime="{{date published_at format="YYYY-MM-DD"}}">{{date published_at format="DD MMM YYYY"}}</time>
								{{!-- which collection this post lives in --}}
								<span class="chip !py-0.5 !text-[10px]">
									{{#has tag="#video"}}Video{{else has tag="#course"}}Course{{else has tag="#lesson"}}Lesson{{else has tag="#webseries"}}Series{{else has tag="#episode"}}Episode{{else has tag="#project"}}Project{{else has tag="#project-detail"}}Build log{{else has tag="#product"}}Product{{else has tag="#newsletter"}}Newsletter{{else has tag="#changelog"}}Changelog{{else has tag="#timeline"}}Timeline{{else has tag="#shop"}}Shop{{else has tag="#prompt"}}Prompt{{else has tag="#snippet"}}Snippet{{else has tag="#trip"}}Trip{{else has tag="#travel"}}Travel{{else has tag="#experience"}}Experience{{else}}Article{{/has}}
								</span>
								{{#if primary_tag}}<span class="hidden font-mono text-[10px] uppercase tracking-[0.15em] text-silver sm:inline">{{primary_tag.name}}</span>{{/if}}
							</span>
							<span class="mt-1 block text-base font-semibold leading-snug tracking-tight transition group-hover:text-silver">{{title}}</span>
							<span class="mt-0.5 hidden truncate text-sm leading-relaxed text-silver sm:block">{{custom_excerpt}}{{^custom_excerpt}}{{excerpt words="20"}}{{/custom_excerpt}}</span>
						</span>
						<span class="hidden text-silver transition group-hover:translate-x-1 group-hover:text-ink sm:block">{{> "icons/arrow-right" class="h-4 w-4"}}</span>
					</a>
				</li>
				{{/foreach}}
			</ol>
			{{/get}}
		</div>
	</div>
</div>
