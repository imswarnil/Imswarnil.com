{{!< default}}

{{> "components/collection-header" kicker="Everything" title="The Archive" desc="Every post on this site in one stream — articles, videos, courses, projects and more."}}

<div class="container-site py-12">
	<div class="grid gap-12 lg:grid-cols-12">
		{{!-- Filter sidebar --}}
		<aside class="lg:col-span-3">
			<div class="sticky top-28 space-y-8">
				<div>
					<p class="kicker">Browse by type</p>
					<nav class="mt-4 flex flex-wrap gap-2 lg:flex-col lg:items-start" aria-label="Collections">
						<a href="{{@site.url}}/archive/" class="chip !border-ink !bg-ink !text-paper">All posts</a>
						<a href="{{@site.url}}/blog/" class="chip transition hover:border-ink hover:text-ink">Articles</a>
						<a href="{{@site.url}}/videos/" class="chip transition hover:border-ink hover:text-ink">Videos</a>
						<a href="{{@site.url}}/courses/" class="chip transition hover:border-ink hover:text-ink">Courses</a>
						<a href="{{@site.url}}/webseries/" class="chip transition hover:border-ink hover:text-ink">Web series</a>
						<a href="{{@site.url}}/projects/" class="chip transition hover:border-ink hover:text-ink">Projects</a>
						<a href="{{@site.url}}/products/" class="chip transition hover:border-ink hover:text-ink">Products</a>
						<a href="{{@site.url}}/newsletters/" class="chip transition hover:border-ink hover:text-ink">Newsletters</a>
						<a href="{{@site.url}}/timeline/" class="chip transition hover:border-ink hover:text-ink">Timeline</a>
						<a href="{{@site.url}}/changelog/" class="chip transition hover:border-ink hover:text-ink">Changelog</a>
						<a href="{{@site.url}}/shop/" class="chip transition hover:border-ink hover:text-ink">Shop</a>
					</nav>
				</div>
				<div class="hidden lg:block">
					{{> "components/adsense" slot="7663977887"}}
				</div>
			</div>
		</aside>

		{{!-- Post rows — Ghost collections are exclusive, so the /archive/
		     collection itself only receives unclaimed posts. We list ALL
		     posts across every collection with a #get instead. --}}
		<div class="lg:col-span-9">
			{{#get "posts" filter="slug:-hero" include="tags" order="published_at desc" limit="100" as |archive|}}
			<p class="mb-4 font-mono text-xs uppercase tracking-[0.2em] text-silver">{{plural archive.length empty="No posts yet" singular="% post" plural="% posts"}}</p>
			<ol id="archive-list" class="divide-y divide-line border-y border-line">
				{{#foreach archive}}
				<li class="group">
					<a href="{{url}}" class="grid gap-1 py-5 sm:grid-cols-[7.5rem_1fr_auto] sm:items-baseline sm:gap-6">
						<time class="font-mono text-xs text-silver" datetime="{{date published_at format="YYYY-MM-DD"}}">{{date published_at format="DD MMM YYYY"}}</time>
						<span class="min-w-0">
							<span class="block text-base font-semibold leading-snug tracking-tight transition group-hover:text-silver">{{title}}</span>
							<span class="mt-1 block truncate text-sm leading-relaxed text-silver">{{custom_excerpt}}{{^custom_excerpt}}{{excerpt words="20"}}{{/custom_excerpt}}</span>
						</span>
						<span class="chip justify-self-start sm:justify-self-end">
							{{#has tag="#video"}}Video{{else has tag="#course"}}Course{{else has tag="#lesson"}}Lesson{{else has tag="#webseries"}}Series{{else has tag="#episode"}}Episode{{else has tag="#project"}}Project{{else has tag="#product"}}Product{{else has tag="#newsletter"}}Newsletter{{else has tag="#changelog"}}Changelog{{else has tag="#timeline"}}Timeline{{else has tag="#shop"}}Shop{{else}}Article{{/has}}
						</span>
					</a>
				</li>
				{{/foreach}}
			</ol>
			{{/get}}
		</div>
	</div>
</div>
