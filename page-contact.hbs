{{!< default}}

{{!-- Contact hub — auto-used by Ghost for the page with slug "contact" --}}
{{#post}}
<article class="{{post_class}}">
	<header class="relative overflow-hidden border-b border-line py-16">
		<div class="bg-dots pointer-events-none absolute inset-0 fade-mask-b" aria-hidden="true"></div>
		<div class="container-site relative text-center">
			<p class="kicker justify-center">{{> "icons/mail"}} Say hello</p>
			<h1 class="mx-auto mt-3 max-w-3xl text-4xl font-semibold tracking-tight sm:text-5xl text-balance">{{title}}</h1>
			{{#if custom_excerpt}}<p class="mx-auto mt-5 max-w-xl text-lg leading-relaxed text-silver">{{custom_excerpt}}</p>{{/if}}
		</div>
	</header>

	<div class="container-site py-12">
		{{!-- Page body first --}}
		{{#if content}}
		<div class="mx-auto mb-14 max-w-prose">
			<section class="gh-content">
				{{content}}
			</section>
		</div>
		{{/if}}

		<div class="mx-auto max-w-4xl">
			{{!-- Topmate 1:1 CTA --}}
			<a href="https://topmate.io/imswarnil" target="_blank" rel="noopener" class="card-surface group relative mb-14 flex flex-col items-center gap-8 overflow-hidden p-8 shadow-lift transition hover:shadow-xl sm:flex-row sm:p-10">
				<div class="bg-grid pointer-events-none absolute inset-0 opacity-40" aria-hidden="true"></div>

				{{!-- CSS calendar illustration --}}
				<div class="relative shrink-0" aria-hidden="true">
					<div class="w-36 rotate-[-3deg] overflow-hidden rounded-2xl border border-line bg-paper shadow-card transition duration-500 group-hover:rotate-0">
						<div class="flex items-center justify-between bg-ink px-4 py-2.5">
							<span class="font-mono text-[10px] uppercase tracking-[0.25em] text-paper">1:1 call</span>
							<span class="h-2 w-2 rounded-full bg-paper/70"></span>
						</div>
						<div class="grid grid-cols-4 gap-1.5 p-4">
							<span class="h-4 rounded bg-mist"></span><span class="h-4 rounded bg-mist"></span><span class="h-4 rounded bg-mist"></span><span class="h-4 rounded bg-mist"></span>
							<span class="h-4 rounded bg-mist"></span><span class="flex h-4 items-center justify-center rounded bg-ink font-mono text-[9px] text-paper">30m</span><span class="h-4 rounded bg-mist"></span><span class="h-4 rounded bg-mist"></span>
							<span class="h-4 rounded bg-mist"></span><span class="h-4 rounded bg-mist"></span><span class="h-4 rounded bg-mist"></span><span class="h-4 rounded bg-mist"></span>
						</div>
					</div>
					<span class="absolute -right-2 -top-2 flex h-8 w-8 items-center justify-center rounded-full border border-line bg-paper shadow-card">{{> "icons/zap" class="h-4 w-4"}}</span>
				</div>

				<div class="relative min-w-0 flex-1 text-center sm:text-left">
					<p class="kicker justify-center sm:justify-start">{{> "icons/calendar"}} Topmate</p>
					<h2 class="mt-2 text-2xl font-semibold tracking-tight sm:text-3xl">Schedule a 1:1 with me</h2>
					<p class="mt-3 max-w-md text-sm leading-relaxed text-silver">Career advice, code reviews, mock interviews or just a chat — book a slot that works for you.</p>
					<span class="btn btn-primary mt-5 inline-flex">Book a slot {{> "icons/arrow-up-right"}}</span>
				</div>
			</a>

			{{!-- Social handles grid --}}
			<h2 class="section-title mb-6">Find me everywhere</h2>
			<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">

				<a href="https://www.youtube.com/@imswarnil" target="_blank" rel="noopener" class="card-surface group flex items-center gap-4 p-5">
					<span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl border border-line bg-mist transition group-hover:bg-ink group-hover:text-paper">{{> "icons/youtube"}}</span>
					<span class="min-w-0 flex-1">
						<span class="block text-sm font-semibold tracking-tight">YouTube</span>
						<span class="block truncate font-mono text-[11px] text-silver">@imswarnil</span>
					</span>
					<span class="btn-ghost shrink-0 text-xs">Subscribe {{> "icons/arrow-up-right" class="h-3.5 w-3.5"}}</span>
				</a>

				<a href="https://github.com/imswarnil" target="_blank" rel="noopener" class="card-surface group flex items-center gap-4 p-5">
					<span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl border border-line bg-mist transition group-hover:bg-ink group-hover:text-paper">{{> "icons/github"}}</span>
					<span class="min-w-0 flex-1">
						<span class="block text-sm font-semibold tracking-tight">GitHub</span>
						<span class="block truncate font-mono text-[11px] text-silver">@imswarnil</span>
					</span>
					<span class="btn-ghost shrink-0 text-xs">Follow {{> "icons/arrow-up-right" class="h-3.5 w-3.5"}}</span>
				</a>

				<a href="https://linkedin.com/in/imswarnil" target="_blank" rel="noopener" class="card-surface group flex items-center gap-4 p-5">
					<span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl border border-line bg-mist transition group-hover:bg-ink group-hover:text-paper">{{> "icons/linkedin"}}</span>
					<span class="min-w-0 flex-1">
						<span class="block text-sm font-semibold tracking-tight">LinkedIn</span>
						<span class="block truncate font-mono text-[11px] text-silver">in/imswarnil</span>
					</span>
					<span class="btn-ghost shrink-0 text-xs">Connect {{> "icons/arrow-up-right" class="h-3.5 w-3.5"}}</span>
				</a>

				<a href="https://x.com/imswarnil" target="_blank" rel="noopener" class="card-surface group flex items-center gap-4 p-5">
					<span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl border border-line bg-mist transition group-hover:bg-ink group-hover:text-paper">{{> "icons/x-twitter"}}</span>
					<span class="min-w-0 flex-1">
						<span class="block text-sm font-semibold tracking-tight">X (Twitter)</span>
						<span class="block truncate font-mono text-[11px] text-silver">@imswarnil</span>
					</span>
					<span class="btn-ghost shrink-0 text-xs">Follow {{> "icons/arrow-up-right" class="h-3.5 w-3.5"}}</span>
				</a>

				<a href="https://instagram.com/imswarnil" target="_blank" rel="noopener" class="card-surface group flex items-center gap-4 p-5">
					<span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl border border-line bg-mist transition group-hover:bg-ink group-hover:text-paper">{{> "icons/instagram"}}</span>
					<span class="min-w-0 flex-1">
						<span class="block text-sm font-semibold tracking-tight">Instagram</span>
						<span class="block truncate font-mono text-[11px] text-silver">@imswarnil</span>
					</span>
					<span class="btn-ghost shrink-0 text-xs">Follow {{> "icons/arrow-up-right" class="h-3.5 w-3.5"}}</span>
				</a>

				<a href="mailto:swarnilsinghaicse@gmail.com" class="card-surface group flex items-center gap-4 p-5">
					<span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl border border-line bg-mist transition group-hover:bg-ink group-hover:text-paper">{{> "icons/mail"}}</span>
					<span class="min-w-0 flex-1">
						<span class="block text-sm font-semibold tracking-tight">Email</span>
						<span class="block truncate font-mono text-[11px] text-silver">swarnilsinghaicse@gmail.com</span>
					</span>
					<span class="btn-ghost shrink-0 text-xs">Write {{> "icons/arrow-up-right" class="h-3.5 w-3.5"}}</span>
				</a>

			</div>

			{{!-- Contact form — posts via formsubmit.co to the sponsor email, zero backend.
			     First-ever submission sends a one-time activation email to that address. --}}
			<div class="reveal mx-auto mt-16 max-w-2xl">
				<div class="card-surface !transform-none p-8 sm:p-10">
					<p class="kicker">{{> "icons/mail"}} Or use the form</p>
					<h2 class="section-title mt-2">Write to me here</h2>
					<p class="mt-2 text-sm leading-relaxed text-silver">Goes straight to my inbox. Replies within 48 hours unless I'm rendering video, in which case… 72.</p>
					<form action="https://formsubmit.co/swarnilsinghaicse@gmail.com" method="POST" class="mt-6 grid gap-4 sm:grid-cols-2">
						<input type="hidden" name="_subject" value="New message via imswarnil.com" />
						<input type="hidden" name="_captcha" value="true" />
						<input type="text" name="_honey" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />
						<label class="block">
							<span class="mb-1.5 block font-mono text-[10px] uppercase tracking-[0.2em] text-silver">Your name</span>
							<input type="text" name="name" required placeholder="Nice Human" class="w-full rounded-xl border border-line bg-paper px-4 py-3 text-sm outline-none transition placeholder:text-silver/60 focus:border-ink" />
						</label>
						<label class="block">
							<span class="mb-1.5 block font-mono text-[10px] uppercase tracking-[0.2em] text-silver">Your email</span>
							<input type="email" name="email" required placeholder="you@email.com" class="w-full rounded-xl border border-line bg-paper px-4 py-3 text-sm outline-none transition placeholder:text-silver/60 focus:border-ink" />
						</label>
						<label class="block sm:col-span-2">
							<span class="mb-1.5 block font-mono text-[10px] uppercase tracking-[0.2em] text-silver">What's on your mind</span>
							<textarea name="message" rows="5" required placeholder="Job offer, collab, typo report, existential question — all welcome." class="w-full rounded-xl border border-line bg-paper px-4 py-3 text-sm outline-none transition placeholder:text-silver/60 focus:border-ink"></textarea>
						</label>
						<div class="flex items-center justify-between sm:col-span-2">
							<p class="font-mono text-[10px] uppercase tracking-[0.15em] text-silver">no spam · no newsletters you didn't ask for</p>
							<button type="submit" class="btn-primary">{{> "icons/mail"}} Send it</button>
						</div>
					</form>
				</div>
			</div>
		</div>
	</div>
</article>
{{/post}}
