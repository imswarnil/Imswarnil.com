{{!< default}}

{{> "components/collection-header" kicker="The classroom" title="Courses" desc="Structured, self-paced series of lessons. Start anywhere, finish everywhere."}}

<section class="container-site py-12">

	{{!-- Featured course spotlight --}}
	{{#foreach posts}}
		{{#if featured}}
		<div class="course-spotlight mb-10 rounded-[1.65rem] bg-gradient-to-r from-accent via-silver/50 to-accent p-[1.5px]" data-visibility="{{visibility}}">
			<article class="card-surface group grid overflow-hidden !rounded-[1.55rem] !transform-none md:grid-cols-2">
				<a href="{{url}}" class="relative block min-h-[220px] overflow-hidden" aria-label="Start course: {{title}}">
					{{#if feature_image}}
						<img src="{{img_url feature_image size="1000"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" loading="lazy" class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]" />
					{{else}}
						<div class="bg-cross absolute inset-0 flex items-center justify-center bg-mist">{{> "icons/book" class="text-silver"}}</div>
					{{/if}}
					<span class="chip absolute left-4 top-4 !border-transparent !bg-paper/90 backdrop-blur">{{> "icons/sparkle"}} Featured course</span>
				</a>
				<div class="flex flex-col justify-center p-7 sm:p-9">
					<div class="flex flex-wrap items-center gap-2">
						{{#match visibility "public"}}<span class="tooltip chip" data-tip="Free — no account needed">{{> "icons/check"}} Free</span>{{/match}}
						{{#match visibility "members"}}<span class="tooltip chip" data-tip="Sign up free to unlock">{{> "icons/star"}} Members</span>{{/match}}
						{{#match visibility "paid"}}<span class="tooltip chip !border-transparent !bg-ink !text-paper" data-tip="Requires a paid plan">{{> "icons/lock"}} Paid</span>{{/match}}
						<span class="chip" data-duration-tags="{{#foreach tags visibility="internal"}}{{slug}} {{/foreach}}" hidden></span>
					</div>
					<h2 class="mt-4 text-2xl font-semibold tracking-tight sm:text-3xl text-balance"><a href="{{url}}" class="hover:underline hover:underline-offset-4">{{title}}</a></h2>
					<p class="mt-3 line-clamp-3 leading-relaxed text-silver">{{custom_excerpt}}{{^custom_excerpt}}{{excerpt words="35"}}{{/custom_excerpt}}</p>
					<div class="mt-6 flex flex-wrap items-center gap-4">
						<a href="{{url}}" class="btn-primary !px-6 !py-3">{{> "icons/play"}} Start course</a>
						<span class="flex items-center gap-2 text-sm text-silver">
							{{#foreach authors limit="3"}}
								{{#if profile_image}}<img src="{{img_url profile_image size="100"}}" alt="{{name}}" loading="lazy" class="h-7 w-7 rounded-full border border-line object-cover" />{{/if}}
							{{/foreach}}
							{{primary_author.name}}
						</span>
					</div>
				</div>
			</article>
		</div>
		{{/if}}
	{{/foreach}}

	{{!-- Access filter --}}
	<div id="course-filters" class="mb-8 flex flex-wrap items-center gap-2" role="group" aria-label="Filter courses by access">
		<span class="mr-1 font-mono text-[10px] uppercase tracking-[0.25em] text-silver">Filter</span>
		<button type="button" class="chip transition" data-filter="all" aria-pressed="true">All</button>
		<button type="button" class="chip transition" data-filter="public" aria-pressed="false">{{> "icons/check"}} Free</button>
		<button type="button" class="chip transition" data-filter="members" aria-pressed="false">{{> "icons/star"}} Members</button>
		<button type="button" class="chip transition" data-filter="paid" aria-pressed="false">{{> "icons/lock"}} Paid</button>
	</div>

	<div id="course-grid" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
		{{#foreach posts}}
			{{#unless featured}}
				{{> "cards/course"}}
			{{/unless}}
		{{/foreach}}
	</div>
	<p id="course-filter-empty" class="hidden py-10 text-center text-sm text-silver">No courses match this filter yet.</p>

	{{> "components/adsense" slot="9130894804" format="fluid" layoutKey="-6t+ed+2i-1n-4w"}}

	{{> "components/pagination"}}
</section>

{{!-- Gear shelf --}}
{{#get "posts" filter="tag:hash-product+tag:hash-course-gear" limit="4" as |gear|}}
	{{#if gear}}
	<section class="border-t border-line bg-mist/40 py-14">
		<div class="container-site">
			<p class="kicker">{{> "icons/zap"}} Behind the scenes</p>
			<h2 class="section-title mt-2">Products I use to make courses</h2>
			<div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
				{{#foreach gear}}
					{{> "cards/product"}}
				{{/foreach}}
			</div>
		</div>
	</section>
	{{else}}
	{{#get "posts" filter="tag:hash-product" limit="4" as |gearfallback|}}
		{{#if gearfallback}}
		<section class="border-t border-line bg-mist/40 py-14">
			<div class="container-site">
				<p class="kicker">{{> "icons/zap"}} Behind the scenes</p>
				<h2 class="section-title mt-2">Products I use to make courses</h2>
				<div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
					{{#foreach gearfallback}}
						{{> "cards/product"}}
					{{/foreach}}
				</div>
			</div>
		</section>
		{{/if}}
	{{/get}}
	{{/if}}
{{/get}}

<script>
	(function () {
		var wrap = document.getElementById('course-filters');
		if (!wrap) return;
		var buttons = [].slice.call(wrap.querySelectorAll('[data-filter]'));
		var cards = [].slice.call(document.querySelectorAll('#course-grid [data-visibility], .course-spotlight[data-visibility]'));
		var empty = document.getElementById('course-filter-empty');
		var ACTIVE = ['!bg-ink', '!text-paper', '!border-transparent'];

		function apply(filter) {
			var shown = 0;
			cards.forEach(function (card) {
				var show = filter === 'all' || card.getAttribute('data-visibility') === filter;
				card.classList.toggle('hidden', !show);
				if (show) shown++;
			});
			if (empty) empty.classList.toggle('hidden', shown > 0);
			buttons.forEach(function (b) {
				var on = b.getAttribute('data-filter') === filter;
				b.setAttribute('aria-pressed', on ? 'true' : 'false');
				ACTIVE.forEach(function (c) { b.classList.toggle(c, on); });
			});
		}

		buttons.forEach(function (b) {
			b.addEventListener('click', function () { apply(b.getAttribute('data-filter')); });
		});
		apply('all');
	})();
</script>
