{
	"name": "swarnil",
	"version": "1.1.0",
	"description": "Swarnil — a monochrome, pattern-rich personal OS for Ghost. Videos, blog, projects, courses, webseries, timeline, changelog, resume & more. Built with Tailwind CSS, PWA-ready, JSON-LD everywhere.",
	"keywords": [
		"ghost",
		"theme",
		"ghost-theme",
		"tailwindcss",
		"pwa"
	],
	"author": {
		"name": "Swarnil Singhai",
		"email": "swarnilsinghaicse@gmail.com",
		"url": "https://imswarnil.com"
	},
	"license": "MIT",
	"scripts": {
		"dev": "concurrently -n css,js,sync -c cyan,yellow,magenta \"npm:dev:css\" \"npm:dev:js\" \"npm:dev:sync\"",
		"dev:css": "tailwindcss -i ./assets/css/tailwind.css -o ./assets/built/screen.css --watch",
		"dev:js": "esbuild ./assets/js/main.js --bundle --sourcemap --target=es2018 --outfile=./assets/built/main.js --watch",
		"dev:sync": "browser-sync start --proxy localhost:2368 --port 3000 --ui-port 3001 --no-notify --files \"assets/built/screen.css\" \"assets/built/main.js\" \"**/*.hbs\"",
		"build": "npm run build:css && npm run build:js",
		"build:css": "tailwindcss -i ./assets/css/tailwind.css -o ./assets/built/screen.css --minify",
		"build:js": "esbuild ./assets/js/main.js --bundle --minify --target=es2018 --legal-comments=none --outfile=./assets/built/main.js",
		"build:prod": "npm run build",
		"test": "gscan .",
		"test:fatal": "gscan . --fatal",
		"test:verbose": "gscan . --verbose",
		"clean": "rm -rf dist",
		"zip": "npm run build && npm run test:fatal && mkdir -p dist && zip -r -X dist/swarnil.zip . -x 'node_modules/*' 'dist/*' '.git/*' '.github/*' '.claude/*' 'dummy-content/*' 'theme-customize.txt' 'instruction.md' 'documentation.md' 'redirects.yaml' '*.map' '.DS_Store' '.gitignore'",
		"release": "npm run zip && echo '→ dist/swarnil.zip ready to upload (Ghost Admin → Design → Change theme → Upload)'"
	},
	"config": {
		"card_assets": true,
		"posts_per_page": 12,
		"image_sizes": {
			"100": {
				"width": 100
			},
			"300": {
				"width": 300
			},
			"600": {
				"width": 600
			},
			"1000": {
				"width": 1000
			},
			"1600": {
				"width": 1600
			},
			"2000": {
				"width": 2000
			}
		},
		"custom": {
			"color_scheme": {
				"type": "select",
				"options": [
					"Light",
					"Dark",
					"System",
					"Salesforce",
					"YouTube",
					"Netflix",
					"Claude",
					"Twilio",
					"Neubrutal"
				],
				"default": "Light",
				"description": "Default theme mode. Visitors can still switch."
			}
		}
	},
	"devDependencies": {
		"browser-sync": "^3.0.4",
		"concurrently": "^10.0.3",
		"esbuild": "^0.28.1",
		"gscan": "^5.0.0",
		"tailwindcss": "^3.4.17"
	},
	"engines": {
		"ghost": ">=5.0.0"
	},
	"screenshots": {
		"desktop": "assets/screenshot-desktop.jpg"
	}
}
