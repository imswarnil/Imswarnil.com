{{!< default}}
{{!-- /timeline — animated career timeline. Center spine with alternating
     cards on lg+, single column on mobile, huge outlined year markers,
     scroll-driven active node, deep-link entrance (#tl-{slug} or
     #tl-year-{YYYY}), and an xl right rail with year nav + vertical ad. --}}

{{> "components/collection-header" kicker="The long game" title="Life, in commits" desc="A chronological log of milestones, launches and plot twists. Tag a post #timeline and it lands here."}}

<section class="container-site py-14 sm:py-20">
	<div class="grid gap-12 xl:grid-cols-[minmax(0,1fr)_15rem]">

		{{!-- Timeline column --}}
		<div class="min-w-0">
			<ol id="tl-list" class="relative space-y-12 pb-4 before:absolute before:bottom-0 before:left-[1.4rem] before:top-0 before:w-px before:bg-line lg:space-y-16 lg:before:left-1/2 lg:before:-translate-x-1/2">
				{{!-- Spine fill: grows as you scroll through the timeline --}}
				<span id="tl-fill" class="pointer-events-none absolute left-[1.4rem] top-0 w-px bg-accent transition-[height] duration-200 ease-linear lg:left-1/2 lg:-translate-x-1/2" style="height:0" aria-hidden="true"></span>
				{{#foreach posts}}
					{{!-- Year marker before every entry; a script below removes
					     consecutive duplicates so only the first of each year stays --}}
					<li class="tl-year relative scroll-mt-32 pl-12 sm:pl-16 lg:pl-0 lg:text-center" data-year="{{date published_at format="YYYY"}}">
						<span class="tl-year-text relative z-[1] bg-paper px-3 lg:px-6">{{date published_at format="YYYY"}}</span>
					</li>
					{{> "cards/timeline-item"}}
				{{/foreach}}

				{{!-- Origin: where the whole story began --}}
				<li class="tl-year relative scroll-mt-32 pl-12 sm:pl-16 lg:pl-0 lg:text-center" data-year="1996">
					<span class="tl-year-text relative z-[1] bg-paper px-3 lg:px-6">1996</span>
				</li>
				<li class="tl-item relative pl-12 sm:pl-16 lg:grid lg:grid-cols-[minmax(0,1fr)_5.5rem_minmax(0,1fr)] lg:items-start lg:pl-0" data-year="1996">
					<span class="tl-dot absolute left-[1.4rem] top-7 z-10 flex h-9 w-9 -translate-x-1/2 items-center justify-center rounded-full border border-line bg-accent text-on-accent shadow-card lg:static lg:col-start-2 lg:row-start-1 lg:mt-7 lg:translate-x-0 lg:justify-self-center">
						{{> "icons/heart" class="h-4 w-4"}}
					</span>
					<div class="lg:row-start-1 lg:col-start-1">
						<div class="tl-card rounded-2xl border border-line bg-mist/40 p-6 text-center lg:text-left">
							<span class="tl-cal inline-flex flex-col overflow-hidden rounded-lg border border-line bg-paper text-center leading-none shadow-card" aria-hidden="true">
								<span class="bg-accent px-3 py-1 font-mono text-[9px] font-bold uppercase tracking-[0.18em] text-on-accent">Jul</span>
								<span class="px-3 pt-1.5 text-2xl font-black tracking-tight">15</span>
								<span class="px-3 pb-1 font-mono text-[9px] text-silver">1996</span>
							</span>
							<h3 class="mt-4 text-xl font-bold tracking-tight sm:text-2xl">My journey started</h3>
							<p class="mt-2 text-sm leading-relaxed text-silver">15 July 1996 — I was born. Everything after this is just commits on top. 🎬</p>
						</div>
					</div>
				</li>
			</ol>
			<div class="mx-auto max-w-2xl">{{> "components/pagination"}}</div>
		</div>

		{{!-- Right rail (xl+): mini year nav + vertical ad --}}
		<aside class="hidden xl:block" aria-label="Timeline navigation">
			<div class="rail-sticky">
				<div class="card-surface p-5 !transform-none">
					<p class="kicker">Jump to year</p>
					<nav id="tl-yearnav" class="mt-3 flex flex-col gap-0.5" aria-label="Timeline years"></nav>
				</div>
				{{> "components/adsense" slot="3487917390" format="auto" class="!my-0"}}
			</div>
		</aside>
	</div>
</section>

<style>
	/* Big outlined year — rank-number treatment, scaled down */
	.tl-year-text {
		display: inline-block;
		font-weight: 900;
		line-height: 1;
		letter-spacing: -0.05em;
		font-size: clamp(3.25rem, 7vw, 5.5rem);
		color: transparent;
		-webkit-text-stroke: 1.5px rgb(var(--silver) / 0.5);
		user-select: none;
	}
	/* Active node: nearest to viewport center gets an accent ring + scale */
	.tl-item .tl-dot { scale: 1; }
	.tl-item.is-active .tl-dot {
		scale: 1.18;
		border-color: rgb(var(--accent) / 0.7);
		box-shadow: 0 0 0 5px rgb(var(--accent) / 0.12);
	}
	.tl-item.is-active .tl-dot-icon { color: rgb(var(--accent)); }
	/* Deep-link pulse */
	@keyframes tl-ping {
		0% { box-shadow: 0 0 0 0 rgb(var(--accent) / 0.4); }
		100% { box-shadow: 0 0 0 26px rgb(var(--accent) / 0); }
	}
	.tl-pulse .tl-dot { animation: tl-ping 1.1s ease-out 2; }
	.tl-pulse .tl-card { border-color: rgb(var(--accent) / 0.55); }
	.tl-yearnav-link.is-active { background-color: rgb(var(--mist)); color: rgb(var(--ink)); }

	/* Calendar leaf tilts a touch with the card on hover */
	.tl-cal { transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1); }
	.tl-card:hover .tl-cal { transform: rotate(-4deg) scale(1.05); }
	/* Parallax image inside the card frame */
	.tl-media-img { transition: transform 0.1s linear; will-change: transform; }
	@media (prefers-reduced-motion: reduce) {
		.tl-media-img { transform: none !important; }
	}
</style>

<script>
	(function () {
		var list = document.getElementById('tl-list');
		if (!list) return;

		/* --- Year markers: keep only the first of each year, build the rail nav --- */
		var nav = document.getElementById('tl-yearnav');
		var seen = null;
		var navLinks = {};
		Array.prototype.slice.call(list.querySelectorAll('.tl-year')).forEach(function (el) {
			var y = el.getAttribute('data-year');
			if (y === seen) { el.remove(); return; }
			seen = y;
			el.id = 'tl-year-' + y;
			if (nav) {
				var a = document.createElement('a');
				a.href = '#tl-year-' + y;
				a.textContent = y;
				a.className = 'panel-link tl-yearnav-link font-mono';
				a.addEventListener('click', function (e) {
					e.preventDefault();
					el.scrollIntoView({ behavior: 'smooth', block: 'center' });
					history.replaceState(null, '', '#tl-year-' + y);
				});
				nav.appendChild(a);
				navLinks[y] = a;
			}
		});

		/* --- Parallax: card images drift within their frame as they scroll --- */
		var reduceMo = matchMedia('(prefers-reduced-motion: reduce)').matches;
		var imgs = reduceMo ? [] : Array.prototype.slice.call(list.querySelectorAll('[data-tl-parallax]'));
		function parallax() {
			var vh = window.innerHeight;
			imgs.forEach(function (img) {
				var frame = img.parentElement;
				var r = frame.getBoundingClientRect();
				if (r.bottom < 0 || r.top > vh) return; /* off-screen */
				/* -1 (entering) .. 1 (leaving); image drifts opposite, ±9% */
				var p = (r.top + r.height / 2 - vh / 2) / vh;
				img.style.transform = 'translateY(' + (-p * 9).toFixed(2) + '%)';
			});
		}

		/* --- Scroll-driven active node: item nearest viewport center --- */
		var items = Array.prototype.slice.call(list.querySelectorAll('.tl-item'));
		var ticking = false;
		function setActive() {
			ticking = false;
			var mid = window.innerHeight / 2, best = null, bestD = Infinity;
			items.forEach(function (it) {
				var r = it.getBoundingClientRect();
				var d = Math.abs(r.top + r.height / 2 - mid);
				if (d < bestD) { bestD = d; best = it; }
			});
			items.forEach(function (it) { it.classList.toggle('is-active', it === best); });
			if (best && nav) {
				var year = best.getAttribute('data-year');
				for (var y in navLinks) navLinks[y].classList.toggle('is-active', y === year);
			}
		}
		/* --- Spine fill: line "draws itself" down to the viewport middle --- */
		var fill = document.getElementById('tl-fill');
		function setFill() {
			if (!fill) return;
			var r = list.getBoundingClientRect();
			var mid = window.innerHeight / 2;
			fill.style.height = Math.max(0, Math.min(mid - r.top, r.height)) + 'px';
		}
		var origSetActive = setActive;
		setActive = function () { origSetActive(); setFill(); parallax(); };

		function queue() { if (!ticking) { ticking = true; requestAnimationFrame(setActive); } }
		window.addEventListener('scroll', queue, { passive: true });
		window.addEventListener('resize', queue);
		setActive();

		/* --- Deep-link entrance: #tl-{slug} → smooth-scroll + pulse --- */
		if (location.hash && /^#[\w-]+$/.test(location.hash)) {
			var target = document.getElementById(location.hash.slice(1));
			if (target) {
				setTimeout(function () {
					target.scrollIntoView({ behavior: 'smooth', block: 'center' });
					if (target.classList.contains('tl-item')) {
						target.classList.add('tl-pulse');
						setTimeout(function () { target.classList.remove('tl-pulse'); }, 2600);
					}
				}, 300);
			}
		}
	})();
</script>
