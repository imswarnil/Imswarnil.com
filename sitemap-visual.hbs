{{!< default}}

{{> "components/collection-header" kicker="Every corner of the site" title="Visual sitemap" desc="The whole site as one tree — every collection, all of its posts with thumbnails, plus pages and topics."}}

<style>
	/* Self-contained tree — no daisyUI. Theme-aware via CSS vars. */
	.sm-wrap { position: relative; }

	.sm-root {
		display: inline-flex; align-items: center; gap: 0.85rem;
		padding: 0.85rem 1.25rem;
		border: 1px solid rgb(var(--line)); border-radius: 1rem;
		background: rgb(var(--mist) / 0.45);
		box-shadow: 0 1px 2px rgb(0 0 0 / 0.04), 0 10px 30px -18px rgb(0 0 0 / 0.25);
	}

	.sm-tree { list-style: none; margin: 0.4rem 0 0; padding: 0; position: relative; margin-left: 1.6rem; }
	/* the trunk */
	.sm-tree::before {
		content: ""; position: absolute; left: 0; top: 0; bottom: 2.1rem;
		width: 2px; background: rgb(var(--line));
	}
	.sm-branch { position: relative; padding-left: 2.1rem; }
	/* elbow connector from trunk → node */
	.sm-branch::before {
		content: ""; position: absolute; left: 0; top: 2rem;
		width: 1.6rem; height: 2px; background: rgb(var(--line));
	}

	.sm-details {
		margin: 0.55rem 0; overflow: hidden;
		border: 1px solid rgb(var(--line)); border-radius: 1rem;
		background: rgb(var(--paper));
		transition: box-shadow 0.2s ease;
	}
	.sm-details[open] { box-shadow: 0 1px 2px rgb(0 0 0 / 0.04), 0 12px 34px -20px rgb(0 0 0 / 0.22); }

	.sm-node {
		display: flex; align-items: center; gap: 0.6rem; cursor: pointer;
		padding: 0.8rem 1rem; list-style: none;
		font-size: 0.92rem; font-weight: 650; letter-spacing: -0.01em;
	}
	.sm-node::-webkit-details-marker { display: none; }
	.sm-dot {
		width: 0.62rem; height: 0.62rem; border-radius: 9999px; flex: none;
		background: rgb(var(--accent));
		box-shadow: 0 0 0 4px rgb(var(--accent) / 0.14);
	}
	.sm-node-name { color: rgb(var(--ink)); }
	.sm-route {
		font-family: 'Geist Mono', ui-monospace, monospace;
		font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase;
		color: rgb(var(--silver));
	}
	.sm-count {
		font-family: 'Geist Mono', ui-monospace, monospace; font-size: 10px;
		padding: 0.08rem 0.45rem; border-radius: 9999px;
		background: rgb(var(--mist)); color: rgb(var(--silver));
	}
	.sm-chev { margin-left: auto; color: rgb(var(--silver)); transition: transform 0.25s ease; display: inline-flex; }
	.sm-details[open] .sm-chev { transform: rotate(180deg); }

	.sm-children {
		display: grid; grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
		gap: 0.5rem; padding: 0.85rem 1rem 1rem;
		border-top: 1px solid rgb(var(--line));
	}
	.sm-leaf {
		display: flex; align-items: center; gap: 0.6rem; min-width: 0;
		padding: 0.4rem; border: 1px solid transparent; border-radius: 0.65rem;
		transition: background 0.15s ease, border-color 0.15s ease;
	}
	.sm-leaf:hover { background: rgb(var(--mist) / 0.7); border-color: rgb(var(--line)); }
	.sm-thumb {
		width: 2.85rem; height: 2.85rem; flex: none; overflow: hidden;
		border-radius: 0.55rem; border: 1px solid rgb(var(--line)); background: rgb(var(--mist));
	}
	.sm-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
	.sm-thumb-ph { display: block; width: 100%; height: 100%; }
	.sm-leaf-t {
		font-size: 13px; font-weight: 500; line-height: 1.25; color: rgb(var(--ink));
		display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
	}
	.sm-all {
		grid-column: 1 / -1; display: inline-flex; align-items: center; gap: 0.35rem;
		margin-top: 0.15rem; font-size: 12.5px; font-weight: 650; color: rgb(var(--accent));
	}
	.sm-all:hover { text-decoration: underline; text-underline-offset: 3px; }
	.sm-empty { grid-column: 1 / -1; font-size: 13px; color: rgb(var(--silver)); }

	@media (max-width: 639px) {
		.sm-branch { padding-left: 1.4rem; }
		.sm-branch::before { width: 0.9rem; }
		.sm-children { grid-template-columns: 1fr; }
	}
</style>

<section class="container-site py-12">
	<div class="sm-wrap mx-auto max-w-4xl">
		{{!-- Root node --}}
		<div class="sm-root">
			{{> "components/logo"}}
		</div>

		<ul class="sm-tree">
			{{> "components/sitemap-branch" name="Blog"        route="/blog/"        filter="tag:hash-blog"}}
			{{> "components/sitemap-branch" name="Videos"      route="/videos/"      filter="tag:hash-video"}}
			{{> "components/sitemap-branch" name="Courses"     route="/courses/"     filter="tag:hash-course"}}
			{{> "components/sitemap-branch" name="Webseries"   route="/webseries/"   filter="tag:hash-webseries"}}
			{{> "components/sitemap-branch" name="Projects"    route="/projects/"    filter="tag:hash-project"}}
			{{> "components/sitemap-branch" name="Products"    route="/products/"    filter="tag:hash-product"}}
			{{> "components/sitemap-branch" name="Timeline"    route="/timeline/"    filter="tag:hash-timeline"}}
			{{> "components/sitemap-branch" name="Changelog"   route="/changelog/"   filter="tag:hash-changelog"}}
			{{> "components/sitemap-branch" name="Newsletters" route="/newsletters/" filter="tag:hash-newsletter"}}
			{{> "components/sitemap-branch" name="Shop"        route="/shop/"        filter="tag:hash-shop"}}
			{{> "components/sitemap-branch" name="Travel"      route="/travel/"      filter="tag:hash-trip"}}
			{{> "components/sitemap-branch" name="Prompts"     route="/prompts/"     filter="tag:hash-prompt"}}
			{{> "components/sitemap-branch" name="Snippets"    route="/snippets/"    filter="tag:hash-snippet"}}
			{{> "components/sitemap-branch" name="Experiences" route="/experiences/" filter="tag:hash-experience"}}

			{{!-- Topics (tags) --}}
			<li class="sm-branch">
				<details class="sm-details" open>
					<summary class="sm-node">
						<span class="sm-dot" aria-hidden="true"></span>
						<span class="sm-node-name">Topics</span>
						<span class="sm-route">/tags/</span>
						{{#get "tags" limit="1" filter="visibility:public" as |t|}}<span class="sm-count">{{pagination.total}}</span>{{/get}}
						<span class="sm-chev" aria-hidden="true">{{> "icons/chevron-down"}}</span>
					</summary>
					<div class="sm-children">
						{{#get "tags" limit="100" include="count.posts" filter="visibility:public" order="count.posts desc" as |tags|}}
							{{#foreach tags}}
							<a href="{{url}}" class="sm-leaf" title="#{{name}}">
								<span class="sm-thumb">{{#if feature_image}}<img src="{{img_url feature_image size="300"}}" width="300" height="169" alt="" loading="lazy" />{{else}}<span class="sm-thumb-ph bg-pat-grid"></span>{{/if}}</span>
								<span class="sm-leaf-t">#{{name}} <span class="sm-route">({{count.posts}})</span></span>
							</a>
							{{else}}
							<span class="sm-empty">No public tags yet</span>
							{{/foreach}}
							<a href="{{@site.url}}/tags/" class="sm-all">All topics {{> "icons/arrow-right" class="h-3.5 w-3.5"}}</a>
						{{/get}}
					</div>
				</details>
			</li>

			{{!-- Pages --}}
			<li class="sm-branch">
				<details class="sm-details" open>
					<summary class="sm-node">
						<span class="sm-dot" aria-hidden="true"></span>
						<span class="sm-node-name">Pages</span>
						<span class="sm-route">/</span>
						{{#get "pages" limit="1" as |p|}}<span class="sm-count">{{pagination.total}}</span>{{/get}}
						<span class="sm-chev" aria-hidden="true">{{> "icons/chevron-down"}}</span>
					</summary>
					<div class="sm-children">
						{{#get "pages" limit="50" order="title asc" as |pages|}}
							{{#foreach pages}}
							<a href="{{url}}" class="sm-leaf" title="{{title}}">
								<span class="sm-thumb">{{#if feature_image}}<img src="{{img_url feature_image size="300"}}" width="300" height="169" alt="" loading="lazy" />{{else}}<span class="sm-thumb-ph bg-pat-graph-paper"></span>{{/if}}</span>
								<span class="sm-leaf-t">{{title}}</span>
							</a>
							{{else}}
							<span class="sm-empty">No pages yet</span>
							{{/foreach}}
							<a href="{{@site.url}}/archive/" class="sm-all">Archive — everything {{> "icons/arrow-right" class="h-3.5 w-3.5"}}</a>
						{{/get}}
					</div>
				</details>
			</li>
		</ul>
	</div>
</section>

<script type="application/ld+json">
