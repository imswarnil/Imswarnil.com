	"@type": "ItemList",
	"name": "Site navigation",
	"itemListElement": [
		{ "@type": "SiteNavigationElement", "position": 1, "name": "Blog", "url": "{{@site.url}}/blog/" },
		{ "@type": "SiteNavigationElement", "position": 2, "name": "Videos", "url": "{{@site.url}}/videos/" },
		{ "@type": "SiteNavigationElement", "position": 3, "name": "Courses", "url": "{{@site.url}}/courses/" },
		{ "@type": "SiteNavigationElement", "position": 4, "name": "Webseries", "url": "{{@site.url}}/webseries/" },
		{ "@type": "SiteNavigationElement", "position": 5, "name": "Projects", "url": "{{@site.url}}/projects/" },
		{ "@type": "SiteNavigationElement", "position": 6, "name": "Products", "url": "{{@site.url}}/products/" },
		{ "@type": "SiteNavigationElement", "position": 7, "name": "Timeline", "url": "{{@site.url}}/timeline/" },
		{ "@type": "SiteNavigationElement", "position": 8, "name": "Changelog", "url": "{{@site.url}}/changelog/" },
		{ "@type": "SiteNavigationElement", "position": 9, "name": "Newsletters", "url": "{{@site.url}}/newsletters/" },
		{ "@type": "SiteNavigationElement", "position": 10, "name": "Shop", "url": "{{@site.url}}/shop/" },
		{ "@type": "SiteNavigationElement", "position": 11, "name": "Travel", "url": "{{@site.url}}/travel/" },
		{ "@type": "SiteNavigationElement", "position": 12, "name": "Prompts", "url": "{{@site.url}}/prompts/" },
		{ "@type": "SiteNavigationElement", "position": 13, "name": "Snippets", "url": "{{@site.url}}/snippets/" },
		{ "@type": "SiteNavigationElement", "position": 14, "name": "Experiences", "url": "{{@site.url}}/experiences/" },
		{ "@type": "SiteNavigationElement", "position": 15, "name": "Topics", "url": "{{@site.url}}/tags/" }
