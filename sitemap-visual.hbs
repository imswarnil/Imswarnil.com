						<div class="collapse-content">
							<ul class="tree-leaves">
								{{#get "posts" filter="tag:hash-blog" limit="5" as |items|}}
									{{#foreach items}}<li><a href="{{url}}" class="text-[13px] text-silver transition hover:text-ink">{{title}}</a></li>{{/foreach}}
								{{else}}
									<li><span class="text-[13px] text-silver/60">Nothing here yet</span></li>
								{{/get}}
								<li><a href="{{@site.url}}/blog/" class="inline-flex items-center gap-1 text-[13px] font-medium">View all {{> "icons/arrow-right" class="h-3.5 w-3.5"}}</a></li>
							</ul>
						</div>
					</details>
				</li>

