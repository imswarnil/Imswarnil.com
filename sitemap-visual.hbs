{{!< default}}

{{> "components/collection-header" kicker="Every corner of the site" title="Visual sitemap" desc="The whole site as one tree — every collection, its latest posts, and where to go for more."}}

<style>
	.tree-root, .tree-leaves { list-style: none; margin: 0; padding: 0; }
	.tree-trunk { position: relative; margin-left: 1.25rem; padding-left: 1.75rem; }
	.tree-root > li { position: relative; padding: .5rem 0; }
	.tree-root > li::before { content: ""; position: absolute; left: -1.75rem; top: 0; bottom: 0; width: 1px; background: rgb(var(--line)); }
	.tree-root > li:last-child::before { bottom: auto; height: 2rem; }
	.tree-root > li::after { content: ""; position: absolute; left: -1.75rem; top: 2rem; width: 1.4rem; height: 1px; background: rgb(var(--line)); }
	.tree-leaves { position: relative; margin-left: .35rem; padding-left: 1.35rem; }
	.tree-leaves > li { position: relative; padding: .3rem 0; }
	.tree-leaves > li::before { content: ""; position: absolute; left: -1.35rem; top: 0; bottom: 0; width: 1px; background: rgb(var(--line)); }
	.tree-leaves > li:last-child::before { bottom: auto; height: 1.05rem; }
	.tree-leaves > li::after { content: ""; position: absolute; left: -1.35rem; top: 1.05rem; width: 1rem; height: 1px; background: rgb(var(--line)); }
	.tree-branch .collapse-title { min-height: 0; }
</style>

<section class="container-site py-12">
	<div class="mx-auto max-w-3xl">
		{{!-- Root node --}}
		<div class="card-surface inline-flex items-center gap-3 p-4 shadow-card">
			{{> "components/logo"}}
		</div>

		<div class="tree-trunk mt-2">
			{{!-- One branch per collection --}}
			<ul class="tree-root">

				<li class="tree-branch">
					<details class="collapse collapse-arrow rounded-2xl border border-line bg-paper" open>
