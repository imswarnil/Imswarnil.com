{{!< default}}

{{#tag}}
{{!-- Tag hero — feature image + description + post count --}}
<section class="relative overflow-hidden border-b border-line">
	<div class="bg-cross pointer-events-none absolute inset-0" aria-hidden="true"></div>
	<div class="container-site relative py-12 sm:py-16">
		<div class="grid items-center gap-8 {{#if feature_image}}lg:grid-cols-12{{/if}}">
			<div class="{{#if feature_image}}lg:col-span-7{{/if}}">
				<p class="kicker">{{> "icons/sparkle"}} Topic</p>
				<h1 class="mt-3 text-3xl font-semibold tracking-tight sm:text-4xl text-balance">{{name}}</h1>
				{{#if description}}
					<p class="mt-4 max-w-xl leading-relaxed text-silver">{{description}}</p>
				{{else}}
					<p class="mt-4 max-w-xl leading-relaxed text-silver">Everything on this site filed under “{{name}}”.</p>
				{{/if}}
				<div class="mt-5 flex flex-wrap items-center gap-3">
					<span class="chip">{{> "icons/pen" class="h-3 w-3"}} {{plural ../pagination.total empty="No posts yet" singular="% post" plural="% posts"}}</span>
					<a href="{{@site.url}}/tags/" class="chip transition hover:border-ink hover:text-ink">All topics</a>
				</div>
			</div>
			{{#if feature_image}}
			<div class="lg:col-span-5">
				<div class="relative overflow-hidden rounded-3xl border border-line shadow-card">
					<img src="{{img_url feature_image size="1000"}}" width="1000" height="563" alt="{{name}}" class="aspect-[16/9] h-auto w-full object-cover" fetchpriority="high" />
					<span class="chip absolute left-3 top-3 !border-transparent !bg-paper/90 backdrop-blur">{{name}}</span>
				</div>
			</div>
			{{/if}}
		</div>
	</div>
</section>
{{/tag}}

{{!-- Rail ads flank the grid on very wide screens; harmless elsewhere --}}
<section class="container-site py-12">
	<div class="flex gap-8">
		<aside class="rail-ad" aria-hidden="true">
			{{> "utility/adsense" slot="2712169578" format="auto" class="!my-0"}}
		</aside>

		<div class="min-w-0 flex-1">
			<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3" data-reveal-stagger="70">
				{{#foreach posts}}
					{{> "blog/card"}}
					{{#match @number 6}}
						{{> "utility/adsense" slot="9130894804" format="fluid" layoutKey="-6t+ed+2i-1n-4w" class="!my-0 sm:col-span-2 lg:col-span-3"}}
					{{/match}}
				{{/foreach}}
			</div>
			{{> "utility/pagination"}}
			{{> "utility/adsense" slot="8939839370" format="auto"}}
		</div>

		<aside class="rail-ad" aria-hidden="true">
			{{> "utility/adsense" slot="3487917390" format="auto" class="!my-0"}}
		</aside>
	</div>
	<p class="mt-4 text-center"><a href="{{@site.url}}/tags/" class="btn-ghost">{{> "icons/sparkle" class="h-3.5 w-3.5"}} All topics</a></p>
</section>
