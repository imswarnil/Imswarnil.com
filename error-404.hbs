{{!< default}}

<section class="relative flex min-h-[60vh] items-center overflow-hidden py-20">
	<div class="bg-dots pointer-events-none absolute inset-0" aria-hidden="true"></div>
	<div class="container-site relative text-center">
		<p class="rank-number mx-auto !text-transparent" style="-webkit-text-stroke: 2px rgb(var(--silver) / .5)">404</p>
		<h1 class="mt-4 text-3xl font-semibold tracking-tight sm:text-4xl">Cropped out of existence.</h1>
		<p class="mx-auto mt-4 max-w-md text-silver">This page is noise now — it was framed out of the final cut. Let's get you back to the good stuff.</p>
		<div class="mt-8 flex justify-center gap-3">
			<a href="{{@site.url}}" class="btn-primary">Back home</a>
			<button type="button" class="btn-ghost" data-ghost-search>{{> "icons/search"}} Search instead</button>
		</div>
	</div>
</section>
