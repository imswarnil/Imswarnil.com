{{!< default}}

<section class="relative flex min-h-[70vh] items-center overflow-hidden py-20">
	<div class="bg-dots pointer-events-none absolute inset-0" aria-hidden="true"></div>
	<div class="container-site relative text-center">

		{{!-- Illustration: a lost frame on a tripod, wandering --}}
		<div class="relative mx-auto mb-4 h-28 w-full max-w-md text-silver" aria-hidden="true">
			<span class="err-art absolute left-[12%] top-2" style="animation-delay:.3s">
				<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="9" width="18" height="12" rx="2"/><path d="M3 9l2-5 16 2-1 3M8.5 4.7L7 9M14 5.4L12.4 9"/></svg>
			</span>
			<span class="err-art absolute right-[14%] top-6" style="animation-delay:.9s">
				<svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="2"/><path d="M7 2v20M17 2v20M2 7h5M2 17h5M17 7h5M17 17h5"/></svg>
			</span>
			<span class="err-art absolute left-1/2 top-0 -translate-x-1/2 text-ink">
				<svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.35-4.35"/><path d="M8.5 10.5h.01M13.5 10.5h.01M9 13.5c.8.7 3.2.7 4 0"/></svg>
			</span>
			<span class="absolute bottom-0 left-1/2 h-px w-40 -translate-x-1/2 bg-line" aria-hidden="true"></span>
		</div>

		<p class="err-glitch rank-number mx-auto !text-transparent" data-text="404" style="-webkit-text-stroke: 2px rgb(var(--silver) / .5)">404</p>
		<h1 class="mt-4 text-3xl font-semibold tracking-tight sm:text-4xl">Cropped out of existence.</h1>
		<p class="mx-auto mt-4 max-w-md leading-relaxed text-silver">This page was noise, so it got the director's-cut treatment: cut. Or you typed the URL from memory — bold move, respect.</p>
		<p class="mx-auto mt-2 max-w-md font-mono text-[11px] uppercase tracking-[0.2em] text-silver/70" id="err-excuse">rolling excuse reel…</p>
		<div class="mt-8 flex flex-wrap justify-center gap-3">
			<a href="{{@site.url}}" class="btn-primary">{{> "icons/arrow-right" class="rotate-180"}} Back home</a>
			<button type="button" class="btn-ghost" data-ghost-search>{{> "icons/search"}} Search instead</button>
			<a href="{{@site.url}}/archive/" class="btn-ghost">Browse everything</a>
		</div>
		<p class="mt-10 font-mono text-[10px] uppercase tracking-[0.25em] text-silver/60">error 404 · content not found · confidence unaffected</p>
	</div>
</section>

<script>
	(function () {
		var excuses = [
			'the intern deleted it. we don\'t have an intern.',
			'this page is on a silent retreat.',
			'404: page went to get milk, never came back.',
			'it exists in the director\'s cut only.',
			'the URL is real, the page is cinema.',
			'lost in a git rebase, presumed happy.',
			'this page failed the vibe check at review.'
		];
		var el = document.getElementById('err-excuse');
		if (!el) return;
		var i = Math.floor(Math.random() * excuses.length);
		function next() {
			el.textContent = '“' + excuses[i % excuses.length] + '”';
			i++;
		}
		next();
		setInterval(next, 3200);
	})();
</script>
