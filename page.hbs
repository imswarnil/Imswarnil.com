{{!< default}}

{{#post}}
<article class="{{post_class}}">
	<header class="relative overflow-hidden border-b border-line py-16">
		<div class="bg-grid pointer-events-none absolute inset-0 fade-mask-b" aria-hidden="true"></div>
		<div class="container-site relative text-center">
			<h1 class="mx-auto max-w-3xl text-4xl font-semibold tracking-tight sm:text-5xl text-balance">{{title}}</h1>
			{{#if custom_excerpt}}<p class="mx-auto mt-5 max-w-xl text-lg text-silver">{{custom_excerpt}}</p>{{/if}}
		</div>
	</header>

	<div class="container-site py-12">
		<div class="mx-auto max-w-prose">
			{{#if feature_image}}
				<img src="{{img_url feature_image size="1600"}}" alt="{{title}}" class="mb-10 w-full rounded-3xl border border-line shadow-card" />
			{{/if}}
			<section class="gh-content">
				{{content}}
			</section>
		</div>
	</div>
</article>
{{/post}}
