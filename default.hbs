<!DOCTYPE html>
<html lang="{{@site.locale}}">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<title>{{meta_title}}</title>

	<link rel="preload" href="{{asset "vendors/Geist-Variable.woff2"}}" as="font" type="font/woff2" crossorigin />
	<link rel="preload" href="{{asset "built/screen.css"}}" as="style" />
	<link rel="stylesheet" href="{{asset "built/screen.css"}}" />
	{{#if @custom.enable_adsense}}
	<link rel="preconnect" href="https://pagead2.googlesyndication.com" crossorigin />
	{{/if}}
	<link rel="preconnect" href="https://www.youtube-nocookie.com" />
	<link rel="preconnect" href="https://i.ytimg.com" crossorigin />
	<link rel="preconnect" href="https://cdn.coverr.co" />

	<link rel="icon" href="{{asset "favicon.svg"}}" type="image/svg+xml" />

	{{!-- PWA --}}
	<link rel="manifest" href="{{@site.url}}/manifest/" />
	<meta name="theme-color" content="#fafafa" media="(prefers-color-scheme: light)" />
	<meta name="theme-color" content="#09090b" media="(prefers-color-scheme: dark)" />
	<meta name="apple-mobile-web-app-capable" content="yes" />
	<meta name="apple-mobile-web-app-title" content="{{@site.title}}" />

	{{!-- Flash-free theme mode boot: light | dark | salesforce | youtube | netflix | claude --}}
	<script>
		(function () {
			var MODES = ['light', 'dark', 'salesforce', 'youtube', 'netflix', 'claude', 'twilio', 'neubrutal'];
			var DARK_MODES = { dark: 1, netflix: 1 };
			var pref = localStorage.getItem('swarnil-mode');
			var fallback = '{{@custom.color_scheme}}'.toLowerCase();
			var mode =
				MODES.indexOf(pref) > -1 ? pref
				: MODES.indexOf(fallback) > -1 ? fallback
				: matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
			var root = document.documentElement;
			root.setAttribute('data-theme', mode);
			root.classList.toggle('dark', !!DARK_MODES[mode]);
			// Video-hero index pages get the glass navbar (flash-free)
			if (/^\/(videos|webseries|travel)\/(page\/\d+\/)?$/.test(location.pathname)) root.classList.add('nav-glass');
		})();
	</script>

	{{#if @custom.enable_adsense}}
	<script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1291242080282540" crossorigin="anonymous"></script>
	{{/if}}

	{{> "components/json-ld"}}
	{{ghost_head}}
</head>

<body class="{{body_class}} min-h-screen bg-paper text-ink">
	<div class="bg-grid-lg pointer-events-none fixed inset-0 -z-10 fade-mask-b" aria-hidden="true"></div>

	{{> "components/navbar"}}

	<main id="site-main" class="relative">
		{{{body}}}
	</main>

	{{> "components/footer"}}

	<script src="{{asset "built/main.js"}}" defer></script>
	<script>
		// Ghost rejects dot-routes, so the old /sw.js/ worker 404s and can never
		// update — it serves stale CSS/JS forever. Unregister any existing worker
		// and clear its caches so every visitor self-heals. A root-scoped worker
		// at /sw/ needs a Service-Worker-Allowed header; re-enable only with that.
		if ('serviceWorker' in navigator) {
			window.addEventListener('load', function () {
				navigator.serviceWorker.getRegistrations().then(function (regs) {
					if (!regs.length) return;
					regs.forEach(function (r) { r.unregister(); });
					if (window.caches && caches.keys) {
						caches.keys().then(function (keys) {
							keys.forEach(function (k) { caches.delete(k); });
						});
					}
				}).catch(function () {});
			});
		}
	</script>

	{{ghost_foot}}
</body>
</html>
