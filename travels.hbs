{{!< default}}

{{!-- /travel-index — every travel story, grouped by trip. Mostly a fallback
     index; the real entrance is /travel/. --}}
{{> "components/collection-header" kicker="Field diaries" title="Travel stories" desc="Every story, grouped by trip. Chronological, like a good itinerary."}}

<section class="container-site py-12">
	<div class="mx-auto max-w-3xl space-y-10">
		{{#get "posts" filter="tag:hash-trip" limit="50" order="published_at desc" include="tags" as |trips|}}
			{{#if trips}}
			{{#foreach trips}}
			<div class="card-surface p-6 !transform-none">
				<p class="kicker">{{> "icons/map-pin"}} Trip</p>
				<h2 class="mt-2 text-xl font-semibold tracking-tight"><a href="{{url}}" class="hover:underline hover:underline-offset-4">{{title}}</a></h2>
				{{#foreach tags visibility="public" limit="1"}}{{#get "posts" filter="tag:hash-travel+tags:{{slug}}" limit="50" order="published_at asc" as |stories|}}
					{{#if stories}}
					<ol class="mt-4 space-y-1">
						{{#foreach stories}}
						<li>
							<a href="{{url}}" class="group flex items-center gap-3 rounded-xl px-3 py-2 transition hover:bg-mist">
								<span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-line font-mono text-[10px] font-semibold text-silver group-hover:border-ink group-hover:text-ink">{{@number}}</span>
								<span class="text-sm font-medium leading-snug">{{title}}</span>
								<span class="ml-auto shrink-0 font-mono text-[10px] text-silver">{{date published_at format="DD MMM"}}</span>
							</a>
						</li>
						{{/foreach}}
					</ol>
					{{else}}
					<p class="mt-3 text-sm text-silver">Stories still in the camera roll.</p>
					{{/if}}
				{{/get}}{{/foreach}}
				<a href="{{url}}" class="btn-ghost mt-4">{{> "icons/map-pin"}} Trip overview {{> "icons/arrow-right"}}</a>
			</div>
			{{/foreach}}
			{{else}}
			<p class="text-center text-silver">No trips published yet.</p>
			{{/if}}
		{{/get}}
	</div>
</section>
