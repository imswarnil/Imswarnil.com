{{!< default}}

{{!-- /guide — the guides collection index (#guide container posts).
     Each card shows the guide plus the first few steps of its route, so the
     shape of the thing is visible before you commit to it. --}}

{{> "utility/collection-header" kicker="Field guides" title="Guides" desc="Long, opinionated walkthroughs of things I've actually done — laid out as a route you can walk one step at a time."}}

<section class="container-site py-12">
	{{#if posts}}
	<div class="mx-auto max-w-4xl space-y-8">
		{{#foreach posts}}
		<article class="card-surface guide-shell overflow-hidden !transform-none">
			<div class="grid md:grid-cols-12">
				{{!-- cover --}}
				<a href="{{url}}" class="relative block md:col-span-5" aria-label="Open guide: {{title}}">
					<div class="relative h-full min-h-[200px] overflow-hidden bg-mist">
						{{#if feature_image}}
							<img src="{{img_url feature_image size="1000"}}" width="1000" height="563"
								alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
								loading="lazy" class="absolute inset-0 h-full w-full object-cover" />
						{{else}}
							<span class="bg-pat-grid absolute inset-0 flex items-center justify-center">{{> "icons/compass" class="h-8 w-8 text-silver"}}</span>
						{{/if}}
						<span class="guide-kicker absolute left-4 top-4 !bg-paper/90 backdrop-blur">{{> "icons/compass" class="h-3 w-3"}} Field guide</span>
					</div>
				</a>

				{{!-- body + route preview --}}
				<div class="p-6 sm:p-8 md:col-span-7">
					<h2 class="text-2xl font-semibold tracking-tight text-balance"><a href="{{url}}" class="hover:underline hover:underline-offset-4">{{title}}</a></h2>
					<p class="mt-2.5 line-clamp-3 text-sm leading-relaxed text-silver">{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{excerpt words="34"}}{{/if}}</p>

					{{#primary_tag}}
					<div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-1.5 font-mono text-[10px] uppercase tracking-[0.14em] text-silver">
						{{#get "posts" filter="tag:hash-guide-content+tags:{{slug}}" limit="1" as |s|}}
							<span class="flex items-center gap-1.5">{{> "icons/route" class="h-3 w-3"}} {{plural pagination.total empty="no steps yet" singular="% step" plural="% steps"}}</span>
						{{/get}}
						<span class="flex items-center gap-1.5">{{> "icons/calendar" class="h-3 w-3"}} {{date ../updated_at format="MMM YYYY"}}</span>
					</div>

					{{!-- first steps of the route --}}
					<div class="mt-5 border-t border-line pt-5">
						{{> "guide/stepper" tagSlug=slug active=""}}
					</div>
					{{/primary_tag}}

					<div class="mt-6 flex flex-wrap items-center gap-2">
						<a href="{{url}}" class="btn-primary btn-sm">{{> "icons/compass" class="h-3 w-3"}} Open guide</a>
						{{#primary_tag}}{{#get "posts" filter="tag:hash-guide-content+tags:{{slug}}" limit="1" order="published_at asc" as |first|}}
							{{#foreach first}}<a href="{{url}}" class="btn-ghost btn-sm">{{> "icons/play" class="h-3 w-3"}} Start at step 1</a>{{/foreach}}
						{{/get}}{{/primary_tag}}
					</div>
				</div>
			</div>
		</article>
		{{/foreach}}
	</div>

	<div class="mx-auto mt-12 max-w-4xl">
		{{> "utility/adsense" slot="8939839370" format="auto"}}
	</div>

	{{> "utility/pagination"}}
	{{else}}
	<p class="rounded-2xl border border-dashed border-line p-12 text-center text-sm text-silver">
		Tag a post <code class="rounded bg-mist px-1.5 py-0.5 font-mono text-xs">#guide</code> to open the first field guide.
	</p>
	{{/if}}
</section>
