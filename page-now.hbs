{{!< default}}
{{!--
	NOW / timeline page — auto-applied to the Ghost page with slug "now".
	Shows the page body ("what I'm doing now") then a reverse-chronological
	timeline built from posts tagged #timeline.
--}}
{{#page}}
{{#contentFor "body-class"}} page-now{{/contentFor}}

<header class="container ptype-now-header">
	<span class="ptype-eyebrow">{{t "Now"}}</span>
	<h1 class="post-title">{{title}}</h1>
	<p class="ptype-now-note">
		{{t "What I'm focused on right now."}}
		<span class="ptype-updated">{{t "Updated"}} <time datetime="{{date updated_at format="YYYY-MM-DD"}}">{{date updated_at format=(t "MMMM D, YYYY")}}</time></span>
	</p>
</header>

{{#if html}}
<div class="container post-content ptype-now-intro">{{{html}}}</div>
{{/if}}

<section class="container ptype-timeline">
	<h2 class="ptype-section-title">{{t "Timeline"}}</h2>
	{{#get "posts" include="tags" filter="tag:hash-timeline" order="published_at desc" limit="50" as |entries|}}
		{{#if entries}}
			<ol class="ptype-timeline-list">
				{{#foreach entries}}
				<li class="ptype-timeline-item">
					<time class="ptype-timeline-date" datetime="{{date format="YYYY-MM-DD"}}">{{date format=(t "MMM D, YYYY")}}</time>
					<div class="ptype-timeline-card">
						<h3 class="ptype-timeline-title"><a href="{{url}}">{{title}}</a></h3>
						{{#if excerpt}}<p class="ptype-timeline-excerpt">{{excerpt words="28"}}</p>{{/if}}
					</div>
				</li>
				{{/foreach}}
			</ol>
		{{else}}
			<p class="ptype-empty">{{t "No timeline entries yet — tag a post #timeline to add one."}}</p>
		{{/if}}
	{{/get}}
</section>
{{/page}}
