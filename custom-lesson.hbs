{{!-- 
    PARTIAL: course/lessons-aside
    REUSING: Native Aspect Theme CSS + Inline Timeline Logic
--}}

{{#if primary_tag}}
    {{#get "posts" filter="tag:hash-lesson+tag:{{primary_tag.slug}}" include="tags" limit="all" order="published_at asc" as |lessons|}}
        {{#if lessons}}
            <nav class="navigation-sidebar" aria-label="{{t "Course lessons"}}" style="padding: var(--spacing-4); background: var(--color-background-100); border: 1px solid var(--color-border); border-radius: var(--radius-4);">
                
                <div class="nav-section" style="margin-bottom: var(--spacing-6); border-bottom: 1px solid var(--color-border); padding-bottom: var(--spacing-4);">
                    <span class="nav-section-link" style="cursor: default; opacity: 1; font-weight: 800; color: var(--color-contrast);">
                        {{t "Step-by-Step Guide"}}
                    </span>
                </div>

                {{!-- The Timeline Wrapper --}}
                <ul style="list-style: none; padding: 0; margin: 0; position: relative; display: flex; flex-direction: column; gap: var(--spacing-2);">
                    
                    {{!-- The Vertical Spine (Line) --}}
                    <div style="position: absolute; left: 19px; top: 10px; bottom: 10px; width: 2px; background: var(--color-border); z-index: 0;"></div>

                    {{#foreach lessons}}
                        <li style="position: relative; z-index: 1;">
                            {{#match slug "=" ../../slug}}
                                {{!-- ACTIVE STEP --}}
                                <div class="nav-link nav-link-current" style="display: grid; grid-template-columns: 40px 1fr; gap: var(--spacing-4); align-items: center; padding: var(--spacing-3); border-radius: var(--radius-3); background: var(--color-background);">
                                    
                                    {{!-- Active Node --}}
                                    <div style="width: 40px; height: 40px; border-radius: 50%; background: var(--ghost-accent-color); border: 4px solid var(--color-background); box-shadow: 0 0 0 1px var(--ghost-accent-color); color: var(--color-background); display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 0.8rem; z-index: 2;">
                                        {{@number}}
                                    </div>

                                    <div style="min-width: 0;">
                                        <div style="font-family: var(--font-family-headings); font-weight: 700; font-size: 0.9rem; color: var(--ghost-accent-color);">
                                            {{title}}
                                        </div>
                                        <div style="font-size: 0.75rem; opacity: 0.8;">{{t "Current Lesson"}}</div>
                                    </div>
                                </div>
                            {{else}}
                                {{#if access}}
                                    {{!-- COMPLETED/UNLOCKED STEP --}}
                                    <a href="{{url}}" class="nav-link" style="display: grid; grid-template-columns: 40px 1fr; gap: var(--spacing-4); align-items: center; padding: var(--spacing-3); border-radius: var(--radius-3); text-decoration: none;">
                                        
                                        {{!-- Static Node --}}
                                        <div style="width: 40px; height: 40px; border-radius: 50%; background: var(--color-background-200); border: 2px solid var(--color-background); color: var(--color-secondary); display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 0.8rem; z-index: 2; transition: all 0.2s ease;">
                                            {{@number}}
                                        </div>

                                        <div style="min-width: 0;">
                                            <div style="font-family: var(--font-family-headings); font-weight: 600; font-size: 0.9rem; color: var(--color-contrast);">
                                                {{title}}
                                            </div>
                                            {{#if reading_time}}
                                                <div style="font-size: 0.7rem; color: var(--color-mute);">{{reading_time}}</div>
                                            {{/if}}
                                        </div>
                                    </a>
                                {{else}}
                                    {{!-- LOCKED STEP --}}
                                    <div class="nav-link" style="display: grid; grid-template-columns: 40px 1fr; gap: var(--spacing-4); align-items: center; padding: var(--spacing-3); border-radius: var(--radius-3); opacity: 0.5; cursor: not-allowed;">
                                        
                                        <div style="width: 40px; height: 40px; border-radius: 50%; background: var(--color-background-100); border: 2px solid var(--color-background); display: flex; align-items: center; justify-content: center; z-index: 2;">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                                        </div>

                                        <div style="min-width: 0;">
                                            <div style="font-family: var(--font-family-headings); font-size: 0.9rem; color: var(--color-mute);">{{title}}</div>
                                        </div>
                                    </div>
                                {{/if}}
                            {{/match}}
                        </li>
                    {{/foreach}}
                </ul>
            </nav>
        {{/if}}
    {{/get}}
{{/if}}