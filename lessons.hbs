{{!< default}}

{{> "components/collection-header" kicker="The classroom" title="Lessons" desc="Every lesson, grouped by course. Lessons are best taken in order — jump into a course below."}}

<section class="container-site py-12">
	<div class="mx-auto max-w-3xl space-y-10">
		{{#get "posts" filter="tag:hash-course" limit="50" order="published_at desc" as |courses|}}
			{{#if courses}}
			{{#foreach courses}}
			<div class="card-surface p-6 !transform-none">
				<p class="kicker">{{> "icons/book"}} Course</p>
				<h2 class="mt-2 text-xl font-semibold tracking-tight"><a href="{{url}}" class="hover:underline hover:underline-offset-4">{{title}}</a></h2>
				{{#get "posts" filter="tag:hash-lesson+tags:{primary_tag.slug}" limit="50" order="published_at asc" as |lessons|}}
					{{#if lessons}}
					<ol class="mt-4 space-y-1">
						{{#foreach lessons}}
						<li>
							<a href="{{url}}" class="group flex items-center gap-3 rounded-xl px-3 py-2 transition hover:bg-mist">
								<span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full border border-line font-mono text-[10px] font-semibold text-silver group-hover:border-ink group-hover:text-ink">{{@number}}</span>
								<span class="text-sm font-medium leading-snug">{{title}}</span>
								{{#match visibility "!=" "public"}}{{> "icons/lock" class="ml-auto shrink-0 text-silver"}}{{/match}}
							</a>
						</li>
						{{/foreach}}
					</ol>
					{{else}}
					<p class="mt-3 text-sm text-silver">Lessons coming soon.</p>
					{{/if}}
				{{/get}}
				<a href="{{url}}" class="btn-ghost mt-4">{{> "icons/play"}} Course overview {{> "icons/arrow-right"}}</a>
			</div>
			{{/foreach}}
			{{else}}
			<p class="text-center text-silver">No courses published yet.</p>
			{{/if}}
		{{/get}}
	</div>
</section>
