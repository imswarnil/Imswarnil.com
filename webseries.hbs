{{!< default}}

{{!-- Cinematic hero: muted looping ambient video with the newest series' poster underneath --}}
<section class="tv-scanlines relative -mt-16 flex min-h-[72vh] items-end overflow-hidden sm:-mt-[4.25rem]">
	{{!-- Poster (newest series' image, else the reel thumbnail) paints first;
	     main.js mounts the muted reel after load. --}}
	<div class="video-hero-media" data-yt-bg="ecOkmTD7KhU" aria-hidden="true">
		{{#foreach posts limit="1"}}{{#if feature_image}}
			<img class="video-hero-poster opacity-70" src="{{img_url feature_image size="1600"}}" alt="" width="1600" height="900" fetchpriority="high" decoding="async" />
		{{else}}
			<img class="video-hero-poster" src="https://i.ytimg.com/vi/ecOkmTD7KhU/maxresdefault.jpg" alt="" width="1280" height="720" decoding="async" onerror="this.onerror=null;this.src='https://i.ytimg.com/vi/ecOkmTD7KhU/hqdefault.jpg'" />
		{{/if}}{{else}}
			<img class="video-hero-poster" src="https://i.ytimg.com/vi/ecOkmTD7KhU/maxresdefault.jpg" alt="" width="1280" height="720" decoding="async" onerror="this.onerror=null;this.src='https://i.ytimg.com/vi/ecOkmTD7KhU/hqdefault.jpg'" />
		{{/foreach}}
		<div class="video-hero-scrim video-hero-scrim-b"></div>
	</div>

	<div class="container-site relative pb-14 pt-40 text-white">
		<p class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-1.5 font-mono text-[11px] uppercase tracking-[0.25em] backdrop-blur">{{> "icons/film"}} Now streaming</p>
		<h1 class="mt-6 max-w-3xl text-5xl font-black tracking-tight sm:text-7xl text-balance">Webseries</h1>
		<p class="mt-5 max-w-xl text-lg leading-relaxed text-white/70">Multi-episode stories, shot and shipped season by season. Pick a series, press play.</p>
		{{#foreach posts limit="1"}}
			<a href="{{url}}" class="btn-invert mt-8">{{> "icons/play"}} Latest: {{title}}</a>
		{{/foreach}}
	</div>
</section>

{{!-- Ranked Netflix row --}}
<section class="border-b border-line py-12">
	<div class="container-site">
		<h2 class="section-title">Top series</h2>
	</div>
	<div class="mt-6 flex snap-x gap-2 overflow-x-auto px-4 pb-4 sm:px-8">
		{{#foreach posts limit="6"}}
			<a href="{{url}}" class="group relative flex shrink-0 snap-start items-end pl-10 sm:pl-16" aria-label="Watch series: {{title}}">
				<span class="rank-number absolute bottom-0 left-0 z-0" aria-hidden="true">{{@number}}</span>
				<span class="relative z-10 block aspect-[2/3] w-40 overflow-hidden rounded-2xl border border-line bg-mist shadow-lift transition-transform duration-300 group-hover:-translate-y-1 sm:w-48">
					{{#if feature_image}}
						<img src="{{img_url feature_image size="600"}}" alt="{{title}}" loading="lazy" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
					{{else}}
						<span class="bg-cross flex h-full w-full items-center justify-center text-silver">{{> "icons/film"}}</span>
					{{/if}}
				</span>
			</a>
		{{/foreach}}
	</div>
</section>

{{!-- All series, poster grid --}}
<section class="container-site py-12">
	<h2 class="section-title">All series</h2>
	<div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
		{{#foreach posts}}
			<article class="card-surface group relative flex flex-col overflow-hidden reveal">
				<a href="{{url}}" class="flex h-full flex-col" aria-label="Watch series: {{title}}">
					<div class="relative aspect-video overflow-hidden">
						{{#if feature_image}}
							<img src="{{img_url feature_image size="600"}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" loading="lazy" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.04]" />
						{{else}}
							<div class="bg-cross flex h-full w-full items-center justify-center bg-mist">{{> "icons/film" class="text-silver"}}</div>
						{{/if}}
						<span class="chip absolute left-3 top-3 !border-transparent !bg-paper/90 backdrop-blur">{{> "icons/film"}} Series</span>
						<span class="absolute inset-0 flex items-center justify-center bg-black/0 transition group-hover:bg-black/25">
							<span class="flex h-12 w-12 scale-75 items-center justify-center rounded-full bg-white text-black opacity-0 shadow-lg transition group-hover:scale-100 group-hover:opacity-100">{{> "icons/play" class="ml-0.5"}}</span>
						</span>
					</div>
					<div class="flex flex-1 flex-col p-5">
						<h3 class="text-lg font-semibold leading-snug tracking-tight">{{title}}</h3>
						<p class="mt-2 line-clamp-2 text-sm leading-relaxed text-silver">{{#if custom_excerpt}}{{custom_excerpt}}{{else}}{{excerpt words="22"}}{{/if}}</p>
						<div class="mt-auto flex items-center justify-between pt-5">
							<span class="font-mono text-[11px] text-silver">{{date published_at format="YYYY"}}</span>
							<span class="flex items-center gap-1.5 text-sm font-medium transition group-hover:gap-2.5">Start watching {{> "icons/arrow-right"}}</span>
						</div>
					</div>
				</a>
			</article>
		{{/foreach}}
	</div>
	{{> "utility/pagination"}}

	{{> "utility/adsense" slot="6808134701" format="autorelaxed"}}
</section>
