{{!< default}}
{{!-- The tag above means: insert everything in this file into the body of the default.hbs template --}}

{{#post}}
{{!-- Everything inside the #post block pulls data from the page --}}

{{#contentFor "body-class"}} post-template-default{{#> "with-sidebar"}} post-has-sidebar{{/"with-sidebar"}}{{#unless access}} post-locked{{/unless}}{{/contentFor}}

<header class="post-header container-wide">
	<div class="post-header-info">
		<h1 class="post-title">{{title}}</h1>
		<ul class="post-meta">
			{{#if authors}}
				{{> "post/meta-author"}}

				<li class="separator">&bull;</li>
			{{/if}}
			<li>
				<time class="post-meta-date" datetime="{{date format="YYYY-MM-DD"}}">{{date format=(t "MMMM D, YYYY")}}</time>
			</li>
			{{#if reading_time}}
			<li class="separator">&bull;</li>
			<li>
				<span class="post-meta-time">{{reading_time minute=(t "1 min read") minutes=(t "% min read")}}</span>
			</li>
			{{/if}}
		</ul>
	</div>

	<div class="post-header-buttons">
		{{> "post/button-comments"}}
		{{> "post/button-share"}}
	</div>
</header>

{{!-- Media (featured image and video). --}}
{{> "post/media"}}

{{!-- Ad: top of article (Horizontal responsive). --}}
{{> "monetization/adsense" slot="8939839370" class="ad-post-top container" cta=true}}

{{!-- Content. --}}
{{> "post/content"}}

{{!-- Ad: below article body (In-article fluid). --}}
{{> "monetization/adsense" slot="6501428979" format="fluid" layout="in-article" class="ad-post-bottom container"}}

{{!-- Read next. --}}
{{> "post/read-next"}}

{{!-- Ad: related/multiplex after read-next. --}}
{{> "monetization/adsense" slot="3375031396" format="autorelaxed" class="ad-post-multiplex container"}}

{{!-- Subscription (show on --breakpoint-max-lg) --}}
{{> "sections/subscription"}}

{{!-- Ad: just before comments (Square responsive). --}}
{{> "monetization/adsense" slot="7663977887" class="ad-post-comments container"}}

{{!-- Comments. --}}
{{> "post/comments"}}

{{/post}}
